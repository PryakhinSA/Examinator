Функция ПолучитьБлокируемыеРеквизитыОбъекта() Экспорт

  Результат = Новый Массив;

  Результат.Добавить("ПрограммаОбучения");

  Возврат Результат;

КонецФункции

#КонецОбласти


#Область ОбработчикиСобытий

// ОБРАБОТЧИКИ СОБЫТИЙ

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Поля.Добавить("ПрограммаОбучения");
	Поля.Добавить("БезСценария");
	Поля.Добавить("Наименование");
	
КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	УстановитьПривилегированныйРежим(Истина);
	
	СтандартнаяОбработка = Ложь;
	
	НаименованиеСценария = "";
	
	Если Данные.БезСценария Тогда
		НаименованиеСценария = Данные.Наименование;
	Иначе
		НаименованиеСценария = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Данные.ПрограммаОбучения, "Наименование");
	КонецЕсли;
	
	Представление = НаименованиеСценария;
	
КонецПроцедуры

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		
		Если Параметры.Свойство("Ключ") Тогда
			Возврат;
		КонецЕсли;
		
		Если Параметры.Свойство("ЗначениеКопирования") Тогда
			Возврат;
		КонецЕсли;			
		
		Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьКаталогОбученийСУО") Тогда
			// Нельзя создавать программу по сценарию без расширенного режима
			Если НЕ Параметры.Свойство("ЗначенияЗаполнения") Тогда
				Параметры.Вставить("ЗначенияЗаполнения", Новый Структура);				
			КонецЕсли;
			Параметры.ЗначенияЗаполнения.Вставить("БезСценария", Истина);
			Параметры.ЗначенияЗаполнения.Вставить("ПрограммаОбучения", Неопределено);
			ПоказатьФормуСоздания = Ложь;
		КонецЕсли;		
		
		ПоказатьФормуСоздания = Истина;
		
		Если Параметры.Свойство("ЗначенияЗаполнения")
			И (Параметры.ЗначенияЗаполнения.Свойство("БезСценария")
			ИЛИ Параметры.ЗначенияЗаполнения.Свойство("ПрограммаОбучения")) Тогда
			
			ПоказатьФормуСоздания = Ложь;
			
		КонецЕсли;
		
		Если Параметры.Свойство("Основание") Тогда
			ПоказатьФормуСоздания = Ложь;
		КонецЕсли;
		
		
		Если ПоказатьФормуСоздания Тогда			
			СтандартнаяОбработка = Ложь;			
			ВыбраннаяФорма = "ФормаСоздания";			
		КонецЕсли;		
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#КонецЕсли

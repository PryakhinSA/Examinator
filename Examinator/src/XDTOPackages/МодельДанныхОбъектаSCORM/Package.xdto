	<objectType name="comments_from_learner">
		<property name="comment" type="xs:string" lowerBound="0"/>
		<property name="location" type="xs:string" lowerBound="0"/>
		<property name="timestamp" type="xs:string" lowerBound="0"/>
		<property name="_children" type="xs:string"/>
	</objectType>
	<objectType name="comments_from_lms">
		<property name="_children" type="xs:string"/>
		<property name="comment" type="xs:string" lowerBound="0"/>
		<property name="location" type="xs:string" lowerBound="0"/>
		<property name="timestamp" type="xs:string" lowerBound="0"/>
	</objectType>
	<objectType name="interactions">
		<property name="_children" type="xs:string"/>
		<property name="id" type="xs:string" lowerBound="0"/>
		<property name="type" type="xs:string" lowerBound="0"/>
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/SCORM/DataModel" name="objectives" type="d3p1:objectives" lowerBound="0" upperBound="-1"/>

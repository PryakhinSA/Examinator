////////////////////////////////////////////////////////////////////////////////
// Процедуры и функции специфичные для ресурсов SCORM

////////////////////////////////////////////////////////////////////////////////
// Общие

// Выполняет поиск попытки прохождения объекта SCORM.
//
Функция ПолучитьНезавершеннуюПопыткуВыполненияОбъектаSCORM(Пользователь, ЭлектронныйРесурс, ЭлементСодержания, Ресурс, ПрохождениеОбучения, Задание) Экспорт
	   
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПопыткаВыполненияАктивногоРесурсаSCORM.Ссылка
		|ИЗ
		|	Документ.ПопыткаВыполненияАктивногоРесурсаSCORM КАК ПопыткаВыполненияАктивногоРесурсаSCORM
		|ГДЕ
		|	ПопыткаВыполненияАктивногоРесурсаSCORM.Проведен = ИСТИНА
		|	И ПопыткаВыполненияАктивногоРесурсаSCORM.Ресурс = &Ресурс
		|	И ПопыткаВыполненияАктивногоРесурсаSCORM.Пользователь = &Пользователь
		|	И ПопыткаВыполненияАктивногоРесурсаSCORM.СводЗнаний = &ЭлектронныйРесурс
		|	И ПопыткаВыполненияАктивногоРесурсаSCORM.ПрохождениеОбучения = &ПрохождениеОбучения
		|	И ПопыткаВыполненияАктивногоРесурсаSCORM.Задание = &Задание
		|	И ПопыткаВыполненияАктивногоРесурсаSCORM.ЭлементСодержанияСводаЗнаний = &ЭлементСодержания
		|	И ПопыткаВыполненияАктивногоРесурсаSCORM.Отменено = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПопыткаВыполненияАктивногоРесурсаSCORM.Дата УБЫВ";

	Запрос.УстановитьПараметр("Задание", Задание);
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("ПрохождениеОбучения", ПрохождениеОбучения);
	Запрос.УстановитьПараметр("Ресурс", Ресурс);
	Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);
	Запрос.УстановитьПараметр("ЭлементСодержания", ЭлементСодержания);

	Результат = Запрос.Выполнить();

	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	ВыборкаДетальныеЗаписи.Следующий();

	Возврат ВыборкаДетальныеЗаписи.Ссылка;
	
КонецФункции

// Получает объект XDTO попытки выполнения SCORM-объекта
//
Функция ПолучитьМодельДанныхПопыткиОбъектаSCORM(ДокументПопыткиОбъект, КонтекстВыполнения, НоваяПопытка=Ложь) Экспорт
	
	cmiXDTOТип  = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/SCORM/DataModel", "cmi"); 
	cmiXDTO     = ФабрикаXDTO.Создать(cmiXDTOТип);
	
	// _version
	
	cmiXDTO._version = "1.0";
	
	// comments_from_learner
	
	comments_from_learnerXDTOТип  = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/SCORM/DataModel", "comments_from_learner");
	
	ДокументПопыткиОбъект.КомментарииПользователей.Сортировать("Номер Возр");
	
	Для каждого Строка Из ДокументПопыткиОбъект.КомментарииПользователей Цикл
	
		comments_from_learnerXDTO  = ФабрикаXDTO.Создать(comments_from_learnerXDTOТип);
		comments_from_learnerXDTO.comment = Строка.Текст;
		comments_from_learnerXDTO.location = Строка.ТекущееПоложение;
		comments_from_learnerXDTO.timestamp = Строка.ДатаИзменения;
		comments_from_learnerXDTO._children = "comment,location,timestamp";
		
		cmiXDTO.comments_from_learner.Добавить(comments_from_learnerXDTO);
		
	КонецЦикла;
	
	// interactions
	
	interactionsXDTOТип  = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/SCORM/DataModel", "interactions");
	
	ДокументПопыткиОбъект.Интерактивности.Сортировать("Номер Возр");
	
	Для каждого Строка Из ДокументПопыткиОбъект.Интерактивности Цикл
		
		interactionsXDTO  = ФабрикаXDTO.Создать(interactionsXDTOТип);
		
		interactionsXDTO._children = "id,type,objectives,timestamp,correct_responses,weighting,learner_response,result,latency,description";
		
		interactionsXDTO.id = Строка.Идентификатор;
				
		interactionsXDTO.type = Строка.Тип;
		
		objectivesXDTOТип  = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/SCORM/DataModel", "objectives");
		МассивЦелей = Строка.Цели.Получить();
		Если ТипЗнч(МассивЦелей) = Тип("Массив") Тогда
			Для каждого Цель Из МассивЦелей Цикл
				Если Цель = Неопределено Тогда
					Цель = "";
				КонецЕсли;
				objectiveXDTO = ФабрикаXDTO.Создать(objectivesXDTOТип);
				objectiveXDTO.id = Цель;
				interactionsXDTO.objectives.Добавить(objectiveXDTO);
			КонецЦикла;
		КонецЕсли;
		
		interactionsXDTO.timestamp = Строка.ДатаИзменения;
		
		correct_responsesXDTOТип  = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/SCORM/DataModel", "correct_responses");
		МассивВерныхОтветов = Строка.ВерныеОтветы.Получить();
		Если ТипЗнч(МассивВерныхОтветов) = Тип("Массив") Тогда
			Для каждого ВерныйОтвет Из МассивВерныхОтветов Цикл
				Если ВерныйОтвет = Неопределено Тогда
					ВерныйОтвет = "";
				КонецЕсли;
				correct_responseXDTO = ФабрикаXDTO.Создать(correct_responsesXDTOТип);
				correct_responseXDTO.pattern = ВерныйОтвет;
				interactionsXDTO.correct_responses.Добавить(correct_responseXDTO);
			КонецЦикла;
		КонецЕсли;
		
		interactionsXDTO.weighting = Формат(Строка.ВесОценки, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
		
		interactionsXDTO.learner_response = Строка.ОтветПользователя;
		
		Если ТипЗнч(Строка.Результат) = Тип("Число") Тогда
			interactionsXDTO.result = Формат(Строка.Результат, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
		Иначе
			Если ЗначениеЗаполнено(Строка.Результат) Тогда
				interactionsXDTO.result = Строка.Результат;
			Иначе
				interactionsXDTO.result = "";
			КонецЕсли;
		КонецЕсли;
		
		interactionsXDTO.latency = Строка.Продолжительность;
		
		interactionsXDTO.description = Строка.Описание;
		
		cmiXDTO.interactions.Добавить(interactionsXDTO);
		
	КонецЦикла;	
	
	// objectives
	
	objectivesXDTOТип  = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/SCORM/DataModel", "objectives");
	scoreXDTOТип       = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/SCORM/DataModel", "score");
	
	ДокументПопыткиОбъект.Цели.Сортировать("Номер Возр");
	
	Для каждого Строка Из ДокументПопыткиОбъект.Цели Цикл
		
		objectivesXDTO  = ФабрикаXDTO.Создать(objectivesXDTOТип);
		
		objectivesXDTO._children = "id,score,success_status,completion_status,progress_measure,description";
		
		objectivesXDTO.id = Строка.Идентификатор;
		
		scoreXDTO  = ФабрикаXDTO.Создать(scoreXDTOТип);
		scoreXDTO.max = Формат(Строка.МаксимальноВозможныйРезультат, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
		scoreXDTO.min = Формат(Строка.МинимальноВозможныйРезультат, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
		scoreXDTO.raw = Формат(Строка.Результат, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
		scoreXDTO.scaled = Формат(Строка.РезультатВПроцентах, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
		scoreXDTO._children = "scaled,min,max,raw";
		objectivesXDTO.score = scoreXDTO;
		
		objectivesXDTO.success_status = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(Строка.СостояниеПрохождения);
		
		objectivesXDTO.completion_status = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(Строка.СостояниеВыполнения);
		
		objectivesXDTO.progress_measure = Формат(Строка.Прогресс, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
		
		objectivesXDTO.description = Строка.Описание;
		
		cmiXDTO.objectives.Добавить(objectivesXDTO);
		
	КонецЦикла;	
	
	// completion_status
	
	cmiXDTO.completion_status = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ДокументПопыткиОбъект.СостояниеВыполнения);
	
	// learner_id, learner_name
	
	cmiXDTO.learner_id   = Строка(ОбъектыСУЗ.ТекущийПользователь(КонтекстВыполнения).УникальныйИдентификатор());
	cmiXDTO.learner_name = ОбъектыСУЗ.ТекущийПользователь(КонтекстВыполнения).Наименование;
	
	// entry
	
	Если НоваяПопытка Тогда
		cmiXDTO.entry = "";		
	Иначе
		cmiXDTO.entry = "resume";
	КонецЕсли;

	// location
	
	cmiXDTO.location = ДокументПопыткиОбъект.ТекущееПоложение;
	
	// suspend_data
	
	cmiXDTO.suspend_data = ДокументПопыткиОбъект.ДанныеПопытки;
		
	// score
	
	scoreXDTOТип  = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/SCORM/DataModel", "score");
	scoreXDTO  = ФабрикаXDTO.Создать(scoreXDTOТип);
	
	scoreXDTO.max = Формат(ДокументПопыткиОбъект.МаксимальноВозможныйРезультат, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
	scoreXDTO.min = Формат(ДокументПопыткиОбъект.МинимальноВозможныйРезультат, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
	scoreXDTO.raw = Формат(ДокументПопыткиОбъект.Результат, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
	scoreXDTO.scaled = Формат(ДокументПопыткиОбъект.РезультатВПроцентах, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
	scoreXDTO._children = "scaled,min,max,raw";
	
	cmiXDTO.score = scoreXDTO;
	
	// session_time
	
	cmiXDTO.session_time = ДокументПопыткиОбъект.ПродолжительностьПоследнейСессии;
	
	// success_status
	
	cmiXDTO.success_status = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ДокументПопыткиОбъект.СостояниеПрохождения);
	
	// total_time
	
	cmiXDTO.total_time = ДокументПопыткиОбъект.ОбщаяПродолжительностьСессий;
	
	// exit
	
	cmiXDTO.exit = ДокументПопыткиОбъект.ПричинаВыхода;
	
	// launch_data
	
	ЭлементСодержанияСводаЗнаний = ДокументПопыткиОбъект.ЭлементСодержанияСводаЗнаний;	
	
	cmiXDTO.launch_data = ЭлементСодержанияСводаЗнаний.ДанныеИнициализации;
	
	// time_limit_action
	
	cmiXDTO.time_limit_action = Перечисления.ДействияПослеИстеченияВремениВыполненияОбъектаSCORM.ЗначениеSCORM(ЭлементСодержанияСводаЗнаний.ДействиеПослеИстеченияВремени);
	
	// max_time_allowed
	
	Если ЗначениеЗаполнено(ЭлементСодержанияСводаЗнаний.ПродолжительностьПопытки) Тогда
		cmiXDTO.max_time_allowed = ЭлементСодержанияСводаЗнаний.ПродолжительностьПопытки; 	
	Иначе
		cmiXDTO.max_time_allowed = "";
	КонецЕсли;
	
	// completion_threshold
	
	Если ЗначениеЗаполнено(ЭлементСодержанияСводаЗнаний.ПорогВыполнения) Тогда
		cmiXDTO.completion_threshold = Формат(ЭлементСодержанияСводаЗнаний.ПорогВыполнения, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
	Иначе
		cmiXDTO.completion_threshold = "";
	КонецЕсли;
	
	// progress_measure
	
	Если ЗначениеЗаполнено(ДокументПопыткиОбъект.ПроцентВыполнения) Тогда
		cmiXDTO.progress_measure = Формат(ДокументПопыткиОбъект.ПроцентВыполнения, "ЧРД=.; ЧРГ=0; ЧН=0; ЧО=1");
	Иначе
		cmiXDTO.progress_measure = "";
	КонецЕсли;
	
	// scaled_passing_score
	
	cmiXDTO.scaled_passing_score = "1.0"; // (default value) !!!
	
	// credit
	
	cmiXDTO.credit = "credit";	
	
	// mode
	
	cmiXDTO.mode = "normal";	
	
	Возврат cmiXDTO;
	
КонецФункции


// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

Функция НовыйУникальныйКод(Длина, Вид, МассивКодов, КоличествоИтераций=Неопределено, Генератор)
	
	Если КоличествоИтераций = Неопределено Тогда		
		КоличествоИтераций = 0;		
	Иначе		
		КоличествоИтераций = КоличествоИтераций + 1;		
	КонецЕсли;
	
	Если КоличествоИтераций > 10 Тогда
		ВызватьИсключение НСтр("ru = 'Генератор не может сгенерировать новый уникальный код в данной серии. Создайте новую серию пин-кодов'");
	КонецЕсли;
	
	Код = НовыйКод(Длина, Вид, Генератор);
	
	Если МассивКодов.Найти(Код) = Неопределено Тогда
		Возврат Код;		
	Иначе
		Возврат НовыйУникальныйКод(Длина, Вид, МассивКодов, КоличествоИтераций, Генератор); // Рекурсия
	КонецЕсли;
	
КонецФункции

Функция НовыйКод(Длина, Вид, Генератор)
	
	ЗаглавныеБуквы = "QWERTYUOPASDFGHJKLZXCVBNM"; // Без буквы I
	КоличествоЗаглавныхБукв = СтрДлина(ЗаглавныеБуквы);
	
	Цифры = "1234567890";
	КоличествоЦифр = СтрДлина(Цифры);
	
	НовыйКод = "";
	
	Пока СтрДлина(НовыйКод) < Длина Цикл
		
		Число = Генератор.СлучайноеЧисло(1, 3);
		
		Если (Число = 1 Или Число = 2) И Вид = Перечисления.ВидыПинКодовСУО.ЦифрыИАнглийскиеБуквы Тогда
			
			Индекс = Генератор.СлучайноеЧисло(1, КоличествоЗаглавныхБукв);
			НовыйКод = НовыйКод + Сред(ЗаглавныеБуквы, Индекс, 1);
			
		Иначе
			
			Индекс = Генератор.СлучайноеЧисло(1, КоличествоЦифр);
			НовыйКод = НовыйКод + Сред(Цифры, Индекс, 1);
			
		КонецЕсли;
		
	КонецЦикла;

	Возврат НовыйКод;
	
КонецФункции

#КонецОбласти

#КонецЕсли

		Исключение
			Возврат ОтветКлиентуJSON("errorData");
		КонецПопытки;		
		
		ЗапросДанных.Текст = 
			"ВЫБРАТЬ
			|	ОтложенныеЗаданияНаПроверкуСУО.ДатаИзменения КАК postponeDate,
			|	ДанныеВебКабинетаСУО.Объект КАК Объект,
			|	ДанныеВебКабинетаСУО.Пользователь КАК Пользователь,
			|	ДанныеВебКабинетаСУО.Тип КАК Тип
			|ПОМЕСТИТЬ ДанныеКабинета
			|ИЗ
			|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборыДанныхВебКабинетаСУО_О
			|		ПО ДанныеВебКабинетаСУО.Объект = ОтборыДанныхВебКабинетаСУО_О.Объект
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОтложенныеЗаданияНаПроверкуСУО КАК ОтложенныеЗаданияНаПроверкуСУО
			|		ПО ДанныеВебКабинетаСУО.Пользователь = ОтложенныеЗаданияНаПроверкуСУО.Преподаватель
			|			И ДанныеВебКабинетаСУО.Объект = ОтложенныеЗаданияНаПроверкуСУО.ПопыткаВыполнения
			|ГДЕ
			|	ДанныеВебКабинетаСУО.Пользователь = &Пользователь
			|	И ДанныеВебКабинетаСУО.Тип = &Тип
			|	И ОтборыДанныхВебКабинетаСУО_О.Отбор = &ПроведениеОбученияИдентификатор
			|
			|ОБЪЕДИНИТЬ
			|
			|ВЫБРАТЬ
			|	ОтложенныеЗаданияНаПроверкуСУО.ДатаИзменения,
			|	ДанныеВебКабинетаСУО.Объект,
			|	ДанныеВебКабинетаСУО.Пользователь,
			|	ДанныеВебКабинетаСУО.Тип
			|ИЗ
			|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтложенныеЗаданияНаПроверкуСУО КАК ОтложенныеЗаданияНаПроверкуСУО
			|		ПО ДанныеВебКабинетаСУО.Пользователь = ОтложенныеЗаданияНаПроверкуСУО.Преподаватель
			|			И ДанныеВебКабинетаСУО.Объект = ОтложенныеЗаданияНаПроверкуСУО.ПопыткаВыполнения
			|ГДЕ
			|	ДанныеВебКабинетаСУО.Пользователь = &Пользователь
			|	И ДанныеВебКабинетаСУО.Тип = &Тип
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ДанныеКабинета.postponeDate КАК postponeDate,
			|	ДанныеВебКабинетаСУО_ПН.Данные КАК data
			|ИЗ
			|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО_ПН
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеКабинета КАК ДанныеКабинета
			|		ПО ДанныеВебКабинетаСУО_ПН.Пользователь = ДанныеКабинета.Пользователь
			|			И ДанныеВебКабинетаСУО_ПН.Тип = ДанныеКабинета.Тип
			|			И ДанныеВебКабинетаСУО_ПН.Объект = ДанныеКабинета.Объект";
					
		ЗапросДанных.УстановитьПараметр("ПроведениеОбученияИдентификатор", ПроведениеОбученияИдентификатор);
		
	ИначеЕсли НастройкиОтбора.Свойство("count") Тогда
		
		ЗапросДанных.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 10
			|	ДанныеВебКабинетаСУО.Данные КАК data,
			|	NULL КАК postponeDate
			|ИЗ
			|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО
			|ГДЕ
			|	ДанныеВебКабинетаСУО.Пользователь = &Пользователь
			|	И ДанныеВебКабинетаСУО.Тип = &Тип
			|
			|УПОРЯДОЧИТЬ ПО
			|	ДанныеВебКабинетаСУО.ДатаИзменения";	
		
		ЗапросДанных.Текст = СтрЗаменить(ЗапросДанных.Текст, "10", ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(НастройкиОтбора.count)); 
		
	Иначе		
		
		ЗапросДанных.Текст = 
			"ВЫБРАТЬ
			|	ДанныеВебКабинетаСУО.Данные КАК data,
			|	ОтложенныеЗаданияНаПроверкуСУО.ДатаИзменения КАК postponeDate
			|ИЗ
			|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОтложенныеЗаданияНаПроверкуСУО КАК ОтложенныеЗаданияНаПроверкуСУО
			|		ПО ДанныеВебКабинетаСУО.Пользователь = ОтложенныеЗаданияНаПроверкуСУО.Преподаватель
			|			И ДанныеВебКабинетаСУО.Объект = ОтложенныеЗаданияНаПроверкуСУО.ПопыткаВыполнения
			|ГДЕ
			|	ДанныеВебКабинетаСУО.Пользователь = &Пользователь
			|	И ДанныеВебКабинетаСУО.Тип = &Тип";
		
	КонецЕсли;
		
	ЗапросДанных.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	ЗапросДанных.УстановитьПараметр("Тип", Перечисления.ТипыДанныхВебКабинетаСУО.ПроверкаЗаданияОписание);
	
	РезультатЗапросаТаблица = ЗапросДанных.Выполнить().Выгрузить();
	
	// Возвращаем результат
	//
	
	Возврат ОтветКлиентуJSON(,РезультатЗапросаТаблица);
	
КонецФункции

Функция НачатьПрохождениеОбученияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
		
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Обучение");
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные
	//	
	
	Попытка
		ИдентификаторПрохожденияОбучения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ПрохождениеОбучения"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторПрохожденияОбучения) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	ПрохождениеОбучения = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(ИдентификаторПрохожденияОбучения);
	
	// Начинаем обучение
	//
	
	ОбновитьДанныеПрохожденияОбученияВебКабинета(ПрохождениеОбучения, Перечисления.СтатусыПрохожденияОбъектовСУО.Проходит);
	
	// Возвращаем новое описание обучения
	//

	ЗапросДанных = Новый Запрос;
	ЗапросДанных.Текст = 
		"ВЫБРАТЬ
		|	ДанныеВебКабинетаСУО.Данные КАК data
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО
		|ГДЕ
		|	ДанныеВебКабинетаСУО.Пользователь = &Пользователь
		|	И ДанныеВебКабинетаСУО.Тип = &Тип
		|	И ДанныеВебКабинетаСУО.Объект = &Объект";
	
	ЗапросДанных.УстановитьПараметр("Объект", ПрохождениеОбучения);
	ЗапросДанных.УстановитьПараметр("Тип", Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивностьОписание);
	ЗапросДанных.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
		
	РезультатЗапроса = ЗапросДанных.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда		
		Возврат ОтветКлиентуJSON("errorData");		
	Иначе	
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();		
		ВыборкаДетальныеЗаписи.Следующий();		
		Возврат ОтветКлиентуXML(ВыборкаДетальныеЗаписи.data.Получить());		
	КонецЕсли;
	
КонецФункции

Функция ЗавершитьПрохождениеОбученияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
		
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Обучение");
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные
	//	
	
	Попытка
		ИдентификаторПрохожденияОбучения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ИдентификаторАктивности"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторПрохожденияОбучения) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	ПрохождениеОбучения = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(ИдентификаторПрохожденияОбучения);
	
	ПрохождениеЗадания = Неопределено;
	Задание = Неопределено;
	ПрохождениеЗадания = Неопределено;
	
	Задания = Документы.ПрохождениеОбученияСУО.ЗаданияПрохождения(ПрохождениеОбучения);
	
	Если Задания.Количество() = 1 Тогда
		Задание = Задания[0].Задание;
		ПрохождениеЗадания = Задания[0].ПопыткаВыполнения;
	КонецЕсли;	
		
	// Завершаем обучение
	//
	
	Если ЗначениеЗаполнено(ПрохождениеЗадания) И ЗначениеЗаполнено(Задание) Тогда
		ДанныеПрохожденияЗадания = ОбучениеСУО.ПриПрохожденииЗадания(ПрохождениеОбучения,Задание,,,Ложь,,,Истина,,,,ПрохождениеЗадания);
		ВебКабинетСУ.ОбновитьДанныеОбъекта(Документы.ПопыткаВыполненияЗаданияСУО, ДанныеПрохожденияЗадания.ПопыткаВыполненияЗадания);
	КонецЕсли;			
	
	ОписаниеПрохождения = ОбучениеСУО.ПриПрохожденииМероприятия(ПрохождениеОбучения, "Завершил",,,,,Истина,Истина);
	
	Если ЗначениеЗаполнено(ПрохождениеЗадания) И ЗначениеЗаполнено(Задание) Тогда
		ОписаниеПрохождения.ЗавершеноВПроцентах = ДанныеПрохожденияЗадания.ЗавершеноВПроцентах;
	КонецЕсли;
	
	ВебКабинетСУО.ОбновитьДанныеПрохожденияОбученияВебКабинета(ПрохождениеОбучения, ОписаниеПрохождения);
		
	Возврат ОтветКлиентуJSON(,ОписаниеПрохождения)	
	
КонецФункции


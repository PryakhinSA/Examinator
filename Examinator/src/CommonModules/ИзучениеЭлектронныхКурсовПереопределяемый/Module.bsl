// Вызывается при начале изучения электронного курса.
// Может быть использована для регистрации события.
// Отказаться от изучения нельзя.
// Для одного изучения может вызываться несколько раз.
//
// Параметры:
//   ЭлектронныйКурс - СправочникСсылка.ЭлектронныеКурсы - Ссылка на электронный курс.
//   Контекст - ОпределяемыйТип.КонтекстЭлектронногоОбучения - 
//              Задает ссылку на событие, в рамках которого проходит изучение курса.
//   Учащийся - ОпределяемыйТип.УчащийсяЭлектронногоОбучения - 
//              Задает ссылку на тестируемого.
//
Процедура ПриСозданииФормыИзученияЭлектронногоКурса(ЭлектронныйКурс, Контекст, Учащийся) Экспорт
	
КонецПроцедуры

// Вызывается при закрытии формы электронного курса в режиме изучения.
// Отказаться от закрытия нельзя.
//
// Параметры:
//   ЭлектронныйКурс - СправочникСсылка.ЭлектронныеКурсы - Ссылка на электронный курс.
//   Контекст - ОпределяемыйТип.КонтекстЭлектронногоОбучения - 
//              Задает ссылку на событие, в рамках которого пользователь изучает курс.
//   Учащийся - ОпределяемыйТип.УчащийсяЭлектронногоОбучения - 
//              Задает ссылку на учащегося.
//   Данные - Структура - Значения структуры:
//             - ЗавершеноВПроцентах - Число - прогресс изучения.
//             
//
Процедура ПриЗакрытииФормыИзученияЭлектронногоКурса(ЭлектронныйКурс, Контекст, Учащийся, Данные) Экспорт	
	
	Если НЕ ЗначениеЗаполнено(Контекст) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Контекст) <> Тип("ДокументСсылка.ПроведениеОбученияСУО") Тогда
		ВызватьИсключение НСтр("ru = 'Неизвестный тип контекста изучения электронного курса'");
	КонецЕсли;
	
	Если ТипЗнч(Учащийся) <> Тип("СправочникСсылка.Пользователи") Тогда
		ВызватьИсключение НСтр("ru = 'Неизвестный тип участника электронного курса'");
	КонецЕсли;	
	
	ПрохождениеОбучения = Документы.ПроведениеОбученияСУО.ПрохождениеОбучения(Контекст,,Учащийся);
	
	Если НЕ ЗначениеЗаполнено(ПрохождениеОбучения) Тогда
		ВызватьИсключение НСтр("ru = 'Данные прохождения обучения участником не найдены'");
	КонецЕсли;	
	
	ОбучениеСУО.ПриПрохожденииЗадания(ПрохождениеОбучения, ЭлектронныйКурс); 
	
КонецПроцедуры


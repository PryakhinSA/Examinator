<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>ЭлектронныеРесурсы</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЭлектронныйРесурс</dataPath>
			<field>ЭлектронныйРесурс</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Электронный ресурс</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СводыЗнанийСУЗ.Ссылка КАК ЭлектронныйРесурс
ИЗ
	Справочник.СводыЗнанийСУЗ КАК СводыЗнанийСУЗ
ГДЕ
	СводыЗнанийСУЗ.ПометкаУдаления = ЛОЖЬ</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>ГруппыПользователей</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Пользователь</dataPath>
			<field>Пользователь</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ГруппаПользователей</dataPath>
			<field>ГруппаПользователей</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Группа пользователей</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ГруппыПользователейСостав.Ссылка КАК ГруппаПользователей,
	ГруппыПользователейСостав.Пользователь
ИЗ
	Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейСостав</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>СтатистикаИспользования</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Период</dataPath>
			<field>Период</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Пользователь</dataPath>
			<field>Пользователь</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВремяПрохожденияВСекундах</dataPath>
			<field>ВремяПрохожденияВСекундах</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЭтоТест</dataPath>
			<field>ЭтоТест</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЭлементПросмотра</dataPath>
			<field>СсылкаНаОбъектСУЗ</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Элемент просмотра</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЭлементСодержания</dataPath>
			<field>ЭлементСодержания</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
			<presentationExpression>Выбор Когда ЭлементСодержания = ЗНАЧЕНИЕ(Справочник.СодержаниеСУЗ.ПустаяСсылка) ИЛИ ЭлементСодержания ЕСТЬ NULL ТОГДА "Стартовая страница" ИНАЧЕ ЭлементСодержания КОНЕЦ</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЭлектронныйРесурс</dataPath>
			<field>ЭлектронныйРесурс</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПросмотрЭлемента</dataPath>
			<field>ПросмотрЭлемента</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Просмотр элемента</v8:content>
				</v8:item>
			</title>
			<presentationExpression>ДатаНачалаПросмотраЭлемента</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Месяц</dataPath>
			<field>Месяц</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Месяц</v8:content>
				</v8:item>
			</title>
			<presentationExpression>Выбор 
    Когда Месяц(Месяц) = 1 Тогда "Январь"
    Когда Месяц(Месяц) = 2 Тогда "Февраль"
    Когда Месяц(Месяц) = 3 Тогда "Март"
    Когда Месяц(Месяц) = 4 Тогда "Апрель"
    Когда Месяц(Месяц) = 5 Тогда "Май"
    Когда Месяц(Месяц) = 6 Тогда "Июнь"
    Когда Месяц(Месяц) = 7 Тогда "Июль"
    Когда Месяц(Месяц) = 8 Тогда "Август"
    Когда Месяц(Месяц) = 9 Тогда "Сентябрь"
    Когда Месяц(Месяц) = 10 Тогда "Октябрь"
    Когда Месяц(Месяц) = 11 Тогда "Ноябрь"
    Когда Месяц(Месяц) = 12 Тогда "Декабрь"
Конец</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Год</dataPath>
			<field>Год</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Год</v8:content>
				</v8:item>
			</title>
			<presentationExpression>Формат(Год, "ДФ=yyyy") + " год"</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>МесяцГода</dataPath>
			<field>МесяцГода</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Месяц года</v8:content>
				</v8:item>
			</title>
			<presentationExpression>Выбор 
    Когда Месяц(МесяцГода) = 1 Тогда "Январь " + Формат(Год, "ДФ=yyyy")
    Когда Месяц(МесяцГода) = 2 Тогда "Февраль " + Формат(Год, "ДФ=yyyy")
    Когда Месяц(МесяцГода) = 3 Тогда "Март " + Формат(Год, "ДФ=yyyy")
    Когда Месяц(МесяцГода) = 4 Тогда "Апрель " + Формат(Год, "ДФ=yyyy")
    Когда Месяц(МесяцГода) = 5 Тогда "Май " + Формат(Год, "ДФ=yyyy")
    Когда Месяц(МесяцГода) = 6 Тогда "Июнь " + Формат(Год, "ДФ=yyyy")
    Когда Месяц(МесяцГода) = 7 Тогда "Июль " + Формат(Год, "ДФ=yyyy")
    Когда Месяц(МесяцГода) = 8 Тогда "Август " + Формат(Год, "ДФ=yyyy")
    Когда Месяц(МесяцГода) = 9 Тогда "Сентябрь " + Формат(Год, "ДФ=yyyy")
    Когда Месяц(МесяцГода) = 10 Тогда "Октябрь " + Формат(Год, "ДФ=yyyy")
    Когда Месяц(МесяцГода) = 11 Тогда "Ноябрь " + Формат(Год, "ДФ=yyyy")
    Когда Месяц(МесяцГода) = 12 Тогда "Декабрь " + Формат(Год, "ДФ=yyyy")
Конец</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаНачалаПросмотраЭлемента</dataPath>
			<field>ДатаНачалаПрохождения</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата начала просмотра элемента</v8:content>
				</v8:item>
			</title>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаОкончанияПросмотраЭлемента</dataPath>
			<field>ДатаОкончанияПрохождения</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата окончания просмотра элемента</v8:content>
				</v8:item>
			</title>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПрохождениеОбучения</dataPath>
			<field>ПрохождениеОбучения</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Задание</dataPath>
			<field>Задание</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПроведениеОбучения</dataPath>
			<field>ПроведениеОбучения</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Результат</dataPath>
			<field>Результат</field>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>ЧДЦ=0</v8:content>
						</v8:item>
					</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Регистратор КАК ПросмотрЭлемента,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Период,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Пользователь,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ЭлементСодержания,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ВремяПрохожденияВСекундах,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ЭлектронныйРесурс,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.СсылкаНаОбъектСУЗ,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ЭтоТест,
	НАЧАЛОПЕРИОДА(ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Период, ГОД) КАК Год,
	НАЧАЛОПЕРИОДА(ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Период, МЕСЯЦ) КАК Месяц,
	НАЧАЛОПЕРИОДА(ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Период, МЕСЯЦ) КАК МесяцГода,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ДатаНачалаПрохождения,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ДатаОкончанияПрохождения,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ПрохождениеОбучения,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Задание,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ПроведениеОбучения,
	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Результат
ИЗ
	РегистрСведений.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ КАК ПопыткиПрохожденияЭлектронныхРесурсовСУЗ
{ГДЕ
	(ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Период МЕЖДУ &amp;Начало И &amp;Конец)}</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Содержание</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЭлектронныйРесурс</dataPath>
			<field>ЭлектронныйРесурс</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Электронный ресурс</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЭлементСодержания</dataPath>
			<field>ЭлементСодержания</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Элемент содержания</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СодержаниеСУЗ.Ссылка КАК ЭлементСодержания,
	СодержаниеСУЗ.Владелец КАК ЭлектронныйРесурс
ИЗ
	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
ГДЕ
	СодержаниеСУЗ.ПометкаУдаления = ЛОЖЬ</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Студенты</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Студент.Статус</dataPath>
			<field>Статус</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Статус</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Пользователь</dataPath>
			<field>Пользователь</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Студент.Специализация</dataPath>
			<field>Специализация</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Специализация</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Студент.Курс</dataPath>
			<field>Курс</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Курс</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Студент.УчебнаяГруппа</dataPath>
			<field>УчебнаяГруппа</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Учебная группа</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Студент.ФормаОбучения</dataPath>
			<field>ФормаОбучения</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Форма обучения</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Студент.Специальность</dataPath>
			<field>Специальность</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Специальность</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Студент.Отделение</dataPath>
			<field>Отделение</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Отделение</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	СтудентыООСрезПоследних.Пользователь,
	СтудентыООСрезПоследних.Курс,
	СтудентыООСрезПоследних.УчебнаяГруппа,
	СтудентыООСрезПоследних.Статус,
	СтудентыООСрезПоследних.Специализация,
	СтудентыООСрезПоследних.Специальность,
	СтудентыООСрезПоследних.ФормаОбучения,
	СтудентыООСрезПоследних.Отделение
ИЗ
	РегистрСведений.СтудентыОО.СрезПоследних({(&amp;НачалоПериода)}, ) КАК СтудентыООСрезПоследних</query>
	</dataSet>

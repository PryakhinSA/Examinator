
#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем необходимые реквизиты
	
	ЭтоОбразовательнаяОрганизация = ПолучитьФункциональнуюОпцию("ОбразовательнаяОрганизацияОО");	
	ЭтоПолныйИнтерфейс = ПолучитьФункциональнуюОпцию("ПолныйИнтерфейсСУО");
	ЭтоЭкзаменатор = ПолучитьФункциональнуюОпцию("ЭкзаменаторЭР");
	ИспользуютсяСлушатели = ПолучитьФункциональнуюОпцию("ИспользоватьСлушателейСУО");
	ИспользоватьСотрудников = ПолучитьФункциональнуюОпцию("ИспользоватьСотрудниковСУО");
	ИспользоватьСтудентов = ПолучитьФункциональнуюОпцию("ИспользоватьСтудентовСУО");
	
	ГруппаПользователейВсеПользователи = Справочники.ГруппыПользователей.ВсеПользователи;
	
	Если ЗначениеЗаполнено(Параметры.ВариантПодбора) Тогда
		
		ВариантПодбора = Параметры.ВариантПодбора;		
		Элементы.ВариантыПодбора.Видимость = Ложь;	
		
	Иначе
		
		ДанныеНастроек = ХранилищеСистемныхНастроек.Загрузить(ЭтотОбъект.ИмяФормы+"/ТекущиеДанные");		
		Если ДанныеНастроек = Неопределено Тогда
			ВариантПодбора = "ОбщийСписок";
		Иначе
			ВариантПодбора = ДанныеНастроек.Получить("ВариантПодбора");
		КонецЕсли;
		
	КонецЕсли;
	
	ХранимыеПараметры = Новый Структура;	
	ХранимыеПараметры.Вставить("ИспользоватьГруппы", ПолучитьФункциональнуюОпцию("ИспользоватьГруппыПользователей"));
	
	// Заполняем таблицу ВыбранныеПользователи
	
	Если Параметры.РасширенныйПодбор И ЗначениеЗаполнено(Параметры.ПараметрыРасширеннойФормыПодбора) Тогда
		
		ХранимыеПараметры.Вставить("РасширенныйПодбор", Истина);
		
		ПараметрыРасширеннойФормыПодбора = ПолучитьИзВременногоХранилища(Параметры.ПараметрыРасширеннойФормыПодбора);
		
		ХранимыеПараметры.Вставить("ЗаголовокФормыПодбора", ПараметрыРасширеннойФормыПодбора.ЗаголовокФормыПодбора);
		
		Если ТипЗнч(ПараметрыРасширеннойФормыПодбора.ВыбранныеПользователи) = Тип("ТаблицаЗначений") Тогда
			ВыбранныеПользователи.Загрузить(ПараметрыРасширеннойФормыПодбора.ВыбранныеПользователи);
		Иначе
			Для Каждого ВыбранныйПользователь Из ПараметрыРасширеннойФормыПодбора.ВыбранныеПользователи Цикл
				ВыбранныеПользователи.Добавить().Пользователь = ВыбранныйПользователь;
			КонецЦикла;
		КонецЕсли;		
		
		// Находим недействительных пользователей
		
		МассивПодобранныхПользователей = ВыбранныеПользователи.Выгрузить(,"Пользователь");
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	Пользователи.Ссылка КАК Пользователь
			|ИЗ
			|	Справочник.Пользователи КАК Пользователи
			|ГДЕ
			|	Пользователи.Ссылка В(&МассивПодобранныхПользователей)
			|	И Пользователи.Недействителен = ИСТИНА";
		
		Запрос.УстановитьПараметр("МассивПодобранныхПользователей", МассивПодобранныхПользователей);
		
		МассивНедействительныхПользователей = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Пользователь");

		// Заполняем недостающие реквизиты
		
		Для каждого Строка Из ВыбранныеПользователи Цикл
			Строка.ВыбранРаньше = Истина;	
			Строка.НомерКартинки = 7;
			Строка.Недействителен = ?(МассивНедействительныхПользователей.Найти(Строка.Пользователь) <> Неопределено, Истина, Ложь);
		КонецЦикла;
		
	Иначе
		
		ХранимыеПараметры.Вставить("РасширенныйПодбор", Ложь);
		ХранимыеПараметры.Вставить("ЗаголовокФормыПодбора", НСтр("ru = 'Подбор пользователей'"));
		
	КонецЕсли;
	
	ВыбранныеПользователи.Сортировать("Пользователь");
	
	// Формируем варианты подбора
	
	ЗначениеДляУдаления = Элементы.ВариантыПодбора.СписокВыбора.НайтиПоЗначению("Подчиненные");
	Элементы.ВариантыПодбора.СписокВыбора.Удалить(ЗначениеДляУдаления);	
	
	Если ЭтоОбразовательнаяОрганизация ИЛИ ЭтоЭкзаменатор ИЛИ ИспользуютсяСлушатели Тогда
		
		ЗначениеДляУдаления = Элементы.ВариантыПодбора.СписокВыбора.НайтиПоЗначению("Мероприятия");
		Элементы.ВариантыПодбора.СписокВыбора.Удалить(ЗначениеДляУдаления);
		
		ЗначениеДляУдаления = Элементы.ВариантыПодбора.СписокВыбора.НайтиПоЗначению("ПрограммыОбучения");
		Элементы.ВариантыПодбора.СписокВыбора.Удалить(ЗначениеДляУдаления);
		
	КонецЕсли;
	
	Если НЕ ИспользоватьСотрудников Тогда
	
		ЗначениеДляУдаления = Элементы.ВариантыПодбора.СписокВыбора.НайтиПоЗначению("СтруктураОрганизации");
		Элементы.ВариантыПодбора.СписокВыбора.Удалить(ЗначениеДляУдаления);		
		
		ЗначениеДляУдаления = Элементы.ВариантыПодбора.СписокВыбора.НайтиПоЗначению("УчебныеГруппы");
		Элементы.ВариантыПодбора.СписокВыбора.Удалить(ЗначениеДляУдаления);		
		
	КонецЕсли;
	
	Если НЕ ИспользоватьСтудентов Тогда
		
		ЗначениеДляУдаления = Элементы.ВариантыПодбора.СписокВыбора.НайтиПоЗначению("Студенты");
		Элементы.ВариантыПодбора.СписокВыбора.Удалить(ЗначениеДляУдаления);
		
		ЗначениеДляУдаления = Элементы.ВариантыПодбора.СписокВыбора.НайтиПоЗначению("УчебныеГруппыОО");
		Элементы.ВариантыПодбора.СписокВыбора.Удалить(ЗначениеДляУдаления);
		
	КонецЕсли;
	
	// Устанавливаем начальные параметры динамических список
	
	ПользователиОбщийСписок.Параметры.УстановитьЗначениеПараметра("ГруппаПользователей", Справочники.ГруппыПользователей.ВсеПользователи);
	
	ПользователиОбщийСписок.Параметры.УстановитьЗначениеПараметра("ВыбиратьИерархически", Истина);
	ПользователиОбщийСписок.Параметры.УстановитьЗначениеПараметра("ПустойУникальныйИдентификатор", Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000"));
	
	ПользователиУчебныхГрупп.Параметры.УстановитьЗначениеПараметра("УчебнаяГруппа", Справочники.УчебныеГруппыСУО.ПустаяСсылка());
	
	ПользователиМероприятий.Параметры.УстановитьЗначениеПараметра("ПроведениеОбучения", Документы.ПроведениеОбученияСУО.ПустаяСсылка());
	ПользователиМероприятий.Параметры.УстановитьЗначениеПараметра("Сценарий", Справочники.КаталогМероприятийСУО.ПустаяСсылка());
	
	ПользователиПрограммОбучения.Параметры.УстановитьЗначениеПараметра("ПроведениеПрограммыОбучения", Документы.ПроведениеПрограммыОбученияСУО.ПустаяСсылка());
	
	Подчиненные.Параметры.УстановитьЗначениеПараметра("Пользователь", Пользователи.ТекущийПользователь());
	Подчиненные.Параметры.УстановитьЗначениеПараметра("ПустойУникальныйИдентификатор", Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000"));
	
	ПользователиУчебныхГруппОО.Параметры.УстановитьЗначениеПараметра("УчебнаяГруппа", Справочники.УчебныеГруппыОО.ПустаяСсылка());
	
	ЗаполнитьТаблицуНастроекДоступа();
	УстановитьПараметрыНастроекДоступаПоУмолчанию();

	
	// Управляем интерфейсом формы
	
	УстановитьДоступностьЭлементовФормы();	
	
	Заголовок = ХранимыеПараметры.ЗаголовокФормыПодбора;
	
	Если ХранимыеПараметры.РасширенныйПодбор Тогда
		ЗакрыватьПриВыборе = Истина; // Всегда, для корректной отработки ОповеститьОВыборе
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ВариантПодбора = "ОбщийСписок" Тогда
		ОбновитьСодержимоеФормыПриИзмененииГруппы();
	КонецЕсли;
	
	Если ВариантПодбора = "УчебныеГруппы" Тогда
		ОбновитьСодержимоеФормыПриИзмененииУчебнойГруппы();
	КонецЕсли;
	
	Если ВариантПодбора = "СтруктураОрганизации" Тогда
		ОбновитьСодержимоеФормыПриИзмененииПараметровСтруктурыОрганизации();
	КонецЕсли;
	
	Если ВариантПодбора = "Мероприятия" Тогда
		ОбновитьСодержимоеФормыПриИзмененииМероприятия();
	КонецЕсли;
	
	Если ВариантПодбора = "ПрограммыОбучения" Тогда
		ОбновитьСодержимоеФормыПриИзмененииПрограммыОбучения();
	КонецЕсли;

	Если ВариантПодбора = "УчебныеГруппыОО" Тогда
		ОбновитьСодержимоеФормыПриИзмененииУчебнойГруппыОО();		
	КонецЕсли;
	
	Если ВариантПодбора = "Студенты" Тогда
		ОбновитьСодержимоеФормыПриИзмененииОтбораСтудентов();
	КонецЕсли;
	
	ФормированиеПоляВводаТаблицыНастроекДоступа(Элементы.ТаблицаНастроекДоступа);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "Запись_Пользователи" Тогда
		СброситьТаблицуПользователейИБ();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаЗаписиНового(НовыйОбъект, Источник, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(НовыйОбъект)
		И ТипЗнч(НовыйОбъект) = Тип("СправочникСсылка.Пользователи") Тогда
		
		ВыбратьПользователя(НовыйОбъект);
		
	КонецЕсли;
	
КонецПроцедуры


#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура ВариантыПодбораПриИзменении(Элемент)
	УстановитьДоступностьЭлементовФормы();
КонецПроцедуры

// Структура организации

&НаКлиенте
Процедура ОбновитьСодержимоеФормыПриИзмененииПараметровСтруктурыОрганизации()
	
	Если ЗначениеЗаполнено(Организация) Тогда
		
		МассивПараметровВыбора = Новый Массив();
		МассивПараметровВыбора.Добавить(Новый ПараметрВыбора("Отбор.Владелец", Организация));
		Элементы.ПодразделениеОрганизации.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметровВыбора);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Должность) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ПользователиОрганизаций.Отбор, "Должность", Должность);
	Иначе
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(ПользователиОрганизаций.Отбор, "Должность");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Организация) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ПользователиОрганизаций.Отбор, "Организация", Организация);
	Иначе
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(ПользователиОрганизаций.Отбор, "Организация");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПодразделениеОрганизации) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ПользователиОрганизаций.Отбор, "ПодразделениеОрганизации", ПодразделениеОрганизации);
	Иначе
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(ПользователиОрганизаций.Отбор, "ПодразделениеОрганизации");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПодразделениеПредприятия) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ПользователиОрганизаций.Отбор, "ПодразделениеПредприятия", ПодразделениеПредприятия);
	Иначе
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(ПользователиОрганизаций.Отбор, "ПодразделениеПредприятия");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	ОбновитьСодержимоеФормыПриИзмененииПараметровСтруктурыОрганизации();
КонецПроцедуры

&НаКлиенте
Процедура ПодразделениеОрганизацииПриИзменении(Элемент)
	ОбновитьСодержимоеФормыПриИзмененииПараметровСтруктурыОрганизации();
КонецПроцедуры

&НаКлиенте
Процедура ПодразделениеПредприятияПриИзменении(Элемент)
	ОбновитьСодержимоеФормыПриИзмененииПараметровСтруктурыОрганизации();
КонецПроцедуры

&НаКлиенте
Процедура ДолжностьПриИзменении(Элемент)
	ОбновитьСодержимоеФормыПриИзмененииПараметровСтруктурыОрганизации();
КонецПроцедуры

&НаКлиенте
Процедура ПользователиОрганизацийВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыбратьПользователя(Элемент.ТекущиеДанные.Пользователь);
	
	ВыбранныеПользователи.Сортировать("Пользователь");
	
КонецПроцедуры

// Общий список

&НаКлиенте
Процедура ОбновитьСодержимоеФормыПриИзмененииГруппы()
	
	ТекущиеДанные = Элементы.СписокГруппПользователей.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Элементы.СписокГруппПользователей.ТекущаяСтрока = ГруппаПользователейВсеПользователи Тогда
		Элементы.ГруппаПоказыватьПользователейДочернихГрупп.ТекущаяСтраница = Элементы.ГруппаНельзяУстановитьСвойство;
		ОбновитьЗначениеПараметраКомпоновкиДанных(ПользователиОбщийСписок, "ВыбиратьИерархически", Истина);
	Иначе
		Элементы.ГруппаПоказыватьПользователейДочернихГрупп.ТекущаяСтраница = Элементы.ГруппаУстановитьСвойство;
		ОбновитьЗначениеПараметраКомпоновкиДанных(ПользователиОбщийСписок, "ВыбиратьИерархически", ВыбиратьИерархически);
	КонецЕсли;
	
	ОбновитьЗначениеПараметраКомпоновкиДанных(ПользователиОбщийСписок, "ГруппаПользователей", Элементы.СписокГруппПользователей.ТекущаяСтрока);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбиратьИерархическиПриИзменении(Элемент)
	ОбновитьСодержимоеФормыПриИзмененииГруппы();
КонецПроцедуры

&НаКлиенте
Процедура СписокГруппПользователейПриАктивизацииСтроки(Элемент)
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьСодержимоеФормыПриИзмененииГруппы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПользователиОбщийСписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыбратьПользователя(Элемент.ТекущиеДанные.Пользователь);
	
	ВыбранныеПользователи.Сортировать("Пользователь");
	
КонецПроцедуры

&НаКлиенте
Процедура ПользователиДоступВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыбратьПользователя(Элемент.ТекущиеДанные.Пользователь);
	
	ВыбранныеПользователи.Сортировать("Пользователь");
	
КонецПроцедуры

// Учебные группы

&НаКлиенте
Процедура ОбновитьСодержимоеФормыПриИзмененииУчебнойГруппы()
	
	ТекущиеДанные = Элементы.УчебныеГруппы.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьЗначениеПараметраКомпоновкиДанных(ПользователиУчебныхГрупп, "УчебнаяГруппа", Элементы.УчебныеГруппы.ТекущаяСтрока);	
	
КонецПроцедуры


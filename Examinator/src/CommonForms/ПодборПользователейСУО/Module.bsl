// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Процедура УстановитьДоступностьЭлементовФормы()
	
	Если ВариантПодбора = "ОбщийСписок" Тогда		
		Элементы.ГруппыПользователей.Видимость     = Истина;
		Элементы.ПользователиОбщийСписок.Видимость = Истина;		
	Иначе		
		Элементы.ГруппыПользователей.Видимость     = Ложь;
		Элементы.ПользователиОбщийСписок.Видимость = Ложь;		
	КонецЕсли;
	
	Если ВариантПодбора = "СтруктураОрганизации" Тогда
		Элементы.СтруктураОрганизации.Видимость    = Истина;
		Элементы.ПользователиОрганизаций.Видимость = Истина;		
	Иначе		
		Элементы.СтруктураОрганизации.Видимость    = Ложь;
		Элементы.ПользователиОрганизаций.Видимость = Ложь;		
	КонецЕсли;
	
	Если ВариантПодбора = "УчебныеГруппы" Тогда		
		Элементы.ГруппаУчебныеГруппы.Видимость      = Истина;
		Элементы.ПользователиУчебныхГрупп.Видимость = Истина;		
	Иначе		
		Элементы.ГруппаУчебныеГруппы.Видимость      = Ложь;
		Элементы.ПользователиУчебныхГрупп.Видимость = Ложь;		
	КонецЕсли;
	
	Если ВариантПодбора = "Мероприятия" Тогда		
		Элементы.ПользователиМероприятий.Видимость = Истина;
		Элементы.ПроведенияМероприятий.Видимость   = Истина;		
	Иначе		
		Элементы.ПользователиМероприятий.Видимость = Ложь;
		Элементы.ПроведенияМероприятий.Видимость   = Ложь;		
	КонецЕсли;	
	
	Если ВариантПодбора = "ПрограммыОбучения" Тогда		
		Элементы.ПользователиПрограммОбучения.Видимость = Истина;
		Элементы.ПроведенияПрограммОбучения.Видимость   = Истина;		
	Иначе		
		Элементы.ПользователиПрограммОбучения.Видимость = Ложь;
		Элементы.ПроведенияПрограммОбучения.Видимость   = Ложь;		
	КонецЕсли;
	
	Если ВариантПодбора = "Подчиненные" Тогда		
		Элементы.Подчиненные.Видимость = Истина;		
	Иначе		
		Элементы.Подчиненные.Видимость = Ложь;		
	КонецЕсли;
	
	Если ВариантПодбора = "Студенты" Тогда		
		Элементы.Студенты.Видимость = Истина;
		Элементы.ГруппаОтборСтудентов.Видимость = Истина;		
	Иначе		
		Элементы.Студенты.Видимость = Ложь;
		Элементы.ГруппаОтборСтудентов.Видимость = Ложь;
	КонецЕсли;
	
	Если ВариантПодбора = "УчебныеГруппыОО" Тогда		
		Элементы.ГруппаУчебныеГруппыОО.Видимость = Истина;
		Элементы.ПользователиУчебныхГруппОО.Видимость = Истина;		
	Иначе		
		Элементы.ГруппаУчебныеГруппыОО.Видимость = Ложь;
		Элементы.ПользователиУчебныхГруппОО.Видимость = Ложь;		
	КонецЕсли;
	
	Если ВариантПодбора = "Доступ" Тогда		
		Элементы.ГруппаНастройкиДоступа.Видимость = Истина;
		Элементы.ПользователиДоступ.Видимость = Истина;		
	Иначе		
		Элементы.ГруппаНастройкиДоступа.Видимость = Ложь;
		Элементы.ПользователиДоступ.Видимость = Ложь;
	КонецЕсли;
	
	// Убираем неиспользуемые элементы
	
	Если НЕ ХранимыеПараметры.РасширенныйПодбор Тогда
		Элементы.ГруппаКомандыВыбора.Видимость = Ложь;
		Элементы.ГруппаВыбранныеПользователи.Видимость = Ложь;
		Элементы.ФормаОК.Видимость = Ложь;
	Иначе
		Элементы.ФормаВыбратьПользователя.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗначениеПараметраКомпоновкиДанных(Знач ВладелецПараметров, Знач ИмяПараметра, Знач ЗначениеПараметра)
	
	Для каждого Параметр Из ВладелецПараметров.Параметры.Элементы Цикл
		Если Строка(Параметр.Параметр) = ИмяПараметра Тогда
			Если Параметр.Использование И Параметр.Значение = ЗначениеПараметра Тогда
				Возврат;
			КонецЕсли;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ВладелецПараметров.Параметры.УстановитьЗначениеПараметра(ИмяПараметра, ЗначениеПараметра);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьПользователя(Пользователь, Исключить = Ложь)
	
	Если ХранимыеПараметры.РасширенныйПодбор Тогда
	
		ПользовательУжеДобавлен = Ложь;
		
		НайденныеСтроки = ВыбранныеПользователи.НайтиСтроки(Новый Структура("Пользователь", Пользователь));
		
		Если НайденныеСтроки.Количество() <> 0 Тогда
			ПользовательУжеДобавлен = Истина;
		КонецЕсли;
		
		Если НЕ ПользовательУжеДобавлен Тогда
			
			НоваяСтрока = ВыбранныеПользователи.Добавить();				
			
			НоваяСтрока.Пользователь  = Пользователь;
			НоваяСтрока.НомерКартинки = 11;
			НоваяСтрока.Исключен      = Исключить;
			
		КонецЕсли;
		
	Иначе
		
		ОповеститьОВыборе(Пользователь);
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Функция ПолучитьИмяТекущейТаблицыПользователей()
	
	ИмяТаблицы = "";
	
	Если ВариантПодбора = "ОбщийСписок" Тогда
		ИмяТаблицы = "ПользователиОбщийСписок";
	КонецЕсли;
	
	Если ВариантПодбора = "СтруктураОрганизации" Тогда
		ИмяТаблицы = "ПользователиОрганизаций";
	КонецЕсли;
	
	Если ВариантПодбора = "УчебныеГруппы" Тогда
		ИмяТаблицы = "ПользователиУчебныхГрупп";
	КонецЕсли;
	
	Если ВариантПодбора = "Мероприятия" Тогда
		ИмяТаблицы = "ПользователиМероприятий";
	КонецЕсли;
	
	Если ВариантПодбора = "ПрограммыОбучения" Тогда
		ИмяТаблицы = "ПользователиПрограммОбучения";
	КонецЕсли;
	
	Если ВариантПодбора = "Подчиненные" Тогда
		ИмяТаблицы = "Подчиненные";
	КонецЕсли;
	
	Если ВариантПодбора = "Студенты" Тогда
		ИмяТаблицы = "Студенты";
	КонецЕсли;
	
	Если ВариантПодбора = "УчебныеГруппыОО" Тогда
		ИмяТаблицы = "ПользователиУчебныхГруппОО";
	КонецЕсли;
	
	Если ВариантПодбора = "Доступ" Тогда
		ИмяТаблицы = "ПользователиДоступ";
	КонецЕсли;
	
	Возврат ИмяТаблицы;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПреобразоватьВыделенныхПользователей(Знач МассивВыделенныхСтрок)
	
	МассивПользователей = Новый Массив();
	
	Если МассивВыделенныхСтрок.Количество() < 1 Тогда
		Возврат МассивПользователей;
	КонецЕсли;
	
	Если ТипЗнч(МассивВыделенныхСтрок[0]) = Тип("СправочникСсылка.Пользователи") Тогда
		Возврат МассивВыделенныхСтрок;
	КонецЕсли;
	
	Если ТипЗнч(МассивВыделенныхСтрок[0]) = Тип("РегистрСведенийКлючЗаписи.СотрудникиСУО")
		ИЛИ ТипЗнч(МассивВыделенныхСтрок[0]) = Тип("РегистрСведенийКлючЗаписи.СтудентыОО") Тогда
	
		Для каждого Элемент Из МассивВыделенныхСтрок Цикл
			МассивПользователей.Добавить(Элемент.Пользователь);
		КонецЦикла;
		
	КонецЕсли;
	
	Если ТипЗнч(МассивВыделенныхСтрок[0]) = Тип("ДокументСсылка.ПрохождениеОбученияСУО")
		ИЛИ ТипЗнч(МассивВыделенныхСтрок[0]) = Тип("ДокументСсылка.ПрохождениеПрограммыОбученияСУО") Тогда
		
		МассивТипов = Новый Массив;
		МассивТипов.Добавить(ТипЗнч(МассивВыделенныхСтрок[0]));
		
		ОписаниеТипов = Новый ОписаниеТипов(МассивТипов); 
		
		ТаблицаПрохождений = Новый ТаблицаЗначений;
		ТаблицаПрохождений.Колонки.Добавить("Прохождение", ОписаниеТипов);
		
		Для каждого Элемент Из МассивВыделенныхСтрок Цикл
			НоваяСтрока = ТаблицаПрохождений.Добавить();
			НоваяСтрока.Прохождение = Элемент;
		КонецЦикла;
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
		
		Запрос.УстановитьПараметр("ВнешнийИсточник", ТаблицаПрохождений);
		Запрос.Текст =
		"ВЫБРАТЬ *
		|ПОМЕСТИТЬ Прохождения
		|ИЗ &ВнешнийИсточник КАК ВнешнийИсточник";
		Запрос.Выполнить();
		
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	Прохождения.Прохождение.Пользователь КАК Пользователь
			|ИЗ
			|	Прохождения КАК Прохождения";

		Результат = Запрос.Выполнить();

		ВыборкаДетальныеЗаписи = Результат.Выбрать();

		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			МассивПользователей.Добавить(ВыборкаДетальныеЗаписи.Пользователь);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат МассивПользователей;
	
КонецФункции

&НаКлиенте
Процедура ВыбратьПользователей(Исключить = Ложь)
	
	ИмяТаблицы = ПолучитьИмяТекущейТаблицыПользователей();
	Таблица    = Элементы[ИмяТаблицы];

	Если Таблица.ТекущиеДанные = Неопределено ИЛИ Таблица.ВыделенныеСтроки.Количество() > 1 Тогда
		
		Если Таблица.ВыделенныеСтроки.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
		
		Если ТипЗнч(Таблица.ВыделенныеСтроки[0]) = Тип("СправочникСсылка.Пользователи") Тогда
			МассивПользователей = Таблица.ВыделенныеСтроки;
		Иначе
			МассивПользователей = ПреобразоватьВыделенныхПользователей(Таблица.ВыделенныеСтроки); // Вызов сервера
		КонецЕсли;
		
		Для каждого Строка Из МассивПользователей Цикл
			ВыбратьПользователя(Строка, Исключить);
		КонецЦикла;
		
	Иначе
		
		Пользователь = Элементы[ИмяТаблицы].ТекущиеДанные.Пользователь;
		
		ВыбратьПользователя(Пользователь, Исключить);
		
	КонецЕсли;
	
	ВыбранныеПользователи.Сортировать("Пользователь");
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПользователейУчебнойГруппы(УчебнаяГруппа)
	
	ТаблицаПользователей = Справочники.УчебныеГруппыСУО.Участники(УчебнаяГруппа);
	
	МассивПользователей = ТаблицаПользователей.ВыгрузитьКолонку("Пользователь");
	
	Возврат Новый ФиксированныйМассив(МассивПользователей);
	
КонецФункции

&НаСервере
Функция ПолучитьПользователейУчебнойГруппыОО(УчебнаяГруппаОО)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СтудентыООСрезПоследних.Пользователь
		|ИЗ
		|	РегистрСведений.СтудентыОО.СрезПоследних(, ) КАК СтудентыООСрезПоследних
		|ГДЕ
		|	СтудентыООСрезПоследних.УчебнаяГруппа = &УчебнаяГруппа
		|	И (СтудентыООСрезПоследних.Статус = &СтатусСтудента
		|			ИЛИ &ПустойСтатус)";

	// Такой же запрос есть в списке ПользователиУчебныхГруппОО
	
	Запрос.УстановитьПараметр("УчебнаяГруппа", УчебнаяГруппаОО);
	
	Если ЗначениеЗаполнено(СтатусСтудента) Тогда
		Запрос.УстановитьПараметр("СтатусСтудента", СтатусСтудента);
		Запрос.УстановитьПараметр("ПустойСтатус", Ложь);
	Иначе
		Запрос.УстановитьПараметр("СтатусСтудента", ПредопределенноеЗначение("Справочник.СтатусыСтудентовОО.ПустаяСсылка"));
		Запрос.УстановитьПараметр("ПустойСтатус", Истина);
	КонецЕсли;

	Результат = Запрос.Выполнить();
	ТаблицаПользователей = Результат.Выгрузить();
	МассивПользователей = ТаблицаПользователей.ВыгрузитьКолонку("Пользователь");

	Возврат Новый ФиксированныйМассив(МассивПользователей);	
	
КонецФункции

&НаКлиенте
Процедура НачатьВставкуИзБуфераОбмена()
	
	ПараметрыПоиска = Новый Структура;
	ПараметрыПоиска.Вставить("ОписаниеТипов", Новый ОписаниеТипов("СправочникСсылка.Пользователи"));
	ПараметрыПоиска.Вставить("ПредставлениеПоля", НСтр("ru = 'Пользователи'"));
	ПараметрыПоиска.Вставить("Сценарий", "ВставкаИзБуфераОбмена");
	
	ПараметрыВыполнения = Новый Структура;
	Обработчик = Новый ОписаниеОповещения("Подключаемый_ВставитьИзБуфераЗавершение", ЭтотОбъект, ПараметрыВыполнения);
	
	ЗагрузкаДанныхИзФайлаКлиент.ПоказатьФормуЗагрузки(ПараметрыПоиска, Обработчик);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ВставитьИзБуфераЗавершение(МассивПользователей, ПараметрыВыполнения) Экспорт
	
	Если ТипЗнч(МассивПользователей) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого ТекущийПользователь Из МассивПользователей Цикл
		ВыбратьПользователя(ТекущийПользователь, Ложь);
	КонецЦикла;	
	
	ВыбранныеПользователи.Сортировать("Пользователь");
	
КонецПроцедуры


	//	
	
	Попытка
		ИдентификаторПроведенияПреподавателемОбучения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ПроведениеПреподавателемОбучения"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторПроведенияПреподавателемОбучения) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	
	
	Попытка
		Проведено = ОбщегоНазначенияСУКлиентСервер.СтрокаВБулево(Запрос.ПараметрыURL.Получить("Проведено"));
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;	
	
	// Записываем данные
	//
	
	ПроведениеПреподавателемОбучения = Документы.ПроведениеПреподавателемОбученияСУО.ПолучитьСсылку(ИдентификаторПроведенияПреподавателемОбучения);
	РезультатОтмены = Документы.ПроведениеПреподавателемОбученияСУО.УстановитьОтметкуПроведено(ПроведениеПреподавателемОбучения, Проведено); // Плюс обновится ВК 	
	

Функция СоздатьСессиюПользователя(ТипАутентификации, СтруктураДанных)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем основные проверки
	
	Если СтруктураДанных = Неопределено
		ИЛИ ТипАутентификации = Неопределено 
		ИЛИ НЕ СтруктураДанных.Свойство("version")
		ИЛИ НЕ СтруктураДанных.Свойство("clientID")
		ИЛИ НЕ ЗначениеЗаполнено(СтруктураДанных.clientID) Тогда
		
		Возврат ОтветКлиентуJSON("errorAuthorization");
		
	КонецЕсли;

	ВерсияКабинета = ВебКабинетСУ.ВерсияAPI();
	
	Если СтруктураДанных.version <> ВерсияКабинета Тогда
		Возврат ОтветКлиентуJSON("differentVersions");
	КонецЕсли;		
	
	НачатьТранзакцию();
	
	// Выполняем действия в зависимости от типа аутентификации
	
	Если ТипАутентификации = "standard" Тогда
		
		// Делаем проверки
		
		Если НЕ СтруктураДанных.Свойство("login")
			ИЛИ НЕ ЗначениеЗаполнено(СтруктураДанных.login) Тогда
			
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("errorData");
			
		КонецЕсли;	
		
		// Ищем данные пользователя
		
		ДанныеПользователя = РегистрыСведений.ПользователиВебКабинетаСУ.ДанныеПользователя(СтруктураДанных.login);
		
		Если ДанныеПользователя = Неопределено Тогда
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("noUser");
		КонецЕсли;		
		
		ДанныеПользователя.Права = ДанныеПользователя.Права.Получить();
		
		// Определяем корректность ключа
		
		Хеширование = Новый ХешированиеДанных(ХешФункция.SHA1);
		Хеширование.Добавить(СтруктураДанных.version + ДанныеПользователя.СохраняемоеЗначениеПароля + СтруктураДанных.clientID);
		
		КлючАвторизации = Base64Строка(Хеширование.ХешСумма);
		
		Если КлючАвторизации <> СтруктураДанных.key Тогда
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("errorAuthorization");
		КонецЕсли;		
		
		// Активируем пин-код
		
		Если СтруктураДанных.Свойство("pinCode") И ЗначениеЗаполнено(СтруктураДанных.pinCode) Тогда
		
			//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
			
			ДанныеПинКода = РегистрыСведений.ВыданныеПинКодыСУО.КодДоступенДляАктивации(
				СтруктураДанных.pinCode,
				?(СтруктураДанных.Свойство("pinCodeOption"), СтруктураДанных.pinCodeOption, Неопределено)
			);
			
			Если ДанныеПинКода.ТребуетсяОпция Тогда
				
				// Наборы свойств соответствуют дополнительным свойствам настроек пользователя, например.				
				
				ДополнительныеСведения = Новый Массив();
				ДополнительныеСведения.Добавить(Справочники.СерииПинКодовСУО.СтруктураОпцийДляВебКабинета(ДанныеПинКода.Серия));
				
				Возврат ОтветКлиентуJSON(, Новый Структура("additionalInformation", ДополнительныеСведения));
				
			КонецЕсли;
			
			Если НЕ ДанныеПинКода.ДоступенДляАктивации Тогда
				Возврат ОтветКлиентуJSON(ДанныеПинКода.КодОшибки);
			КонецЕсли;
			
			РегистрыСведений.ВыданныеПинКодыСУО.АктивироватьКод(ДанныеПинКода.Серия, ДанныеПинКода.Код, ДанныеПользователя.Пользователь,, ДанныеПинКода.Опция, Истина);
			
			//----------------------------------//
			
			//--# КОНСТРУКТОР КУРСОВ ДОБАВИТЬ #--//

			// Возврат ОтветКлиентуJSON("noFunctionality");
			
			//----------------------------------//				
			
		КонецЕсли;

		
	КонецЕсли;
	
	Если ТипАутентификации = "cas" Тогда
		
		// Делаем проверки
		
		Если НЕ СтруктураДанных.Свойство("publication")
			ИЛИ НЕ ЗначениеЗаполнено(СтруктураДанных.publication) Тогда
			
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("errorData");
			
		КонецЕсли;		
		
		// Получаем настройки публикации
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПубликацииВебКабинетаСУ.АдресСервераCAS,
			|	ПубликацииВебКабинетаСУ.ИмяСервисаCAS
			|ИЗ
			|	Справочник.ПубликацииВебКабинетаСУ КАК ПубликацииВебКабинетаСУ
			|ГДЕ
			|	ПубликацииВебКабинетаСУ.Код = &Публикация";
		
		Запрос.УстановитьПараметр("Публикация", СтруктураДанных.publication);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() Тогда
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;
		
		НастройкиПубликации = РезультатЗапроса.Выбрать();		
		НастройкиПубликации.Следующий();
		
		// Получаем данные о пользователе с CAS сервера
		
		СтруктураURI = ОбщегоНазначенияКлиентСервер.СтруктураURI(
			НастройкиПубликации.АдресСервераCAS + "/serviceValidate?" +
			"service=" + НастройкиПубликации.ИмяСервисаCAS + "&" +
			"ticket=" + СтруктураДанных.clientID
		);		
		
		Если НРег(СтруктураURI.Схема) = "https" Тогда
			HTTPСоединение = Новый HTTPСоединение(СтруктураURI.Хост, СтруктураURI.Порт,,,, 10, Новый ЗащищенноеСоединениеOpenSSL()); 
		Иначе
			HTTPСоединение = Новый HTTPСоединение(СтруктураURI.Хост, СтруктураURI.Порт,,,, 10);
		КонецЕсли;
			
		HTTPЗапрос = Новый HTTPЗапрос(СтруктураURI.ПутьНаСервере);
		
		Попытка
			ОтветСервера = HTTPСоединение.Получить(HTTPЗапрос);
		Исключение
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("errorHTTPConnect");  // Запрос не дошел до HTTP-Сервера
		КонецПопытки;
		
		Если ОтветСервера.КодСостояния = 200 Тогда
			
			ОтветСервераСтрока = ОтветСервера.ПолучитьТелоКакСтроку();
			
			ЧтениеXML = Новый ЧтениеXML;
			ЧтениеXML.УстановитьСтроку(ОтветСервераСтрока);
			
			СообщениеXDTOТип = ФабрикаXDTO.Тип("http://www.yale.edu/tp/cas", "serviceResponse");
			
			СообщениеXDTO = ФабрикаXDTO.Создать(СообщениеXDTOТип);
			
			СообщениеXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML); // Получаем модель XDTO сообщения
			
			СвойстваСообщенияXDTO = СообщениеXDTO.Свойства();
			
			Если ЕстьСвойствоXDTO(СвойстваСообщенияXDTO, "authenticationFailure")
				ИЛИ НЕ ЕстьСвойствоXDTO(СвойстваСообщенияXDTO, "authenticationSuccess") Тогда
				
				ОтменитьТранзакцию();
				Возврат ОтветКлиентуJSON("errorAuthorization");
				
			КонецЕсли;
			
		Иначе
			
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("errorHTTPConnect");
			
		КонецЕсли;
		
		// Создаем нового пользователя или обновляем данные существующего
		
		АтрибутыПользователя = СообщениеXDTO.authenticationSuccess.attributes;
		СписокАтрибутовПользователя = СообщениеXDTO.authenticationSuccess.attributes.Свойства();
		
		Если НЕ ЗначениеЗаполнено(АтрибутыПользователя.uin) Тогда
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;
		
		ИмяПользователя = АтрибутыПользователя.uin;
		ПолноеИмяПользователя = "";
		
		Если ЕстьСвойствоXDTO(СписокАтрибутовПользователя, "last_name") Тогда
			ПолноеИмяПользователя = ПолноеИмяПользователя + АтрибутыПользователя.last_name + " ";
		КонецЕсли;
		
		Если ЕстьСвойствоXDTO(СписокАтрибутовПользователя, "first_name") Тогда
			ПолноеИмяПользователя = ПолноеИмяПользователя + АтрибутыПользователя.first_name + " ";
		КонецЕсли;
		
		Если ЕстьСвойствоXDTO(СписокАтрибутовПользователя, "middle_name") Тогда
			ПолноеИмяПользователя = ПолноеИмяПользователя + АтрибутыПользователя.middle_name + " ";
		КонецЕсли;
		
		ПолноеИмяПользователя = СокрЛП(ПолноеИмяПользователя);
		
		Если НЕ ЗначениеЗаполнено(ПолноеИмяПользователя) Тогда
			ПолноеИмяПользователя = ИмяПользователя;
		КонецЕсли;
		
		ЭлектроннаяПочтаПользователя = "";
		
		Если ЕстьСвойствоXDTO(СписокАтрибутовПользователя, "email") Тогда
			ЭлектроннаяПочтаПользователя = АтрибутыПользователя.email;
		КонецЕсли;
		
		Пользователь = Пользователи.НайтиПоИмени(ИмяПользователя);
		
		Если Пользователь = Справочники.Пользователи.ПустаяСсылка() Тогда
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("errorRegisterUser"); // Есть пользователь ИБ, но его нет в справочнике Пользователи
		КонецЕсли;		
		
		Если Пользователь = Неопределено Тогда
			Пользователь = ЗаписатьНовогоПользователя(Пользователь, ИмяПользователя, "", ПолноеИмяПользователя, ЭлектроннаяПочтаПользователя);
		КонецЕсли;
		
		// Формируем структуру с данными пользователя
		
		ПраваПользователя = ВебКабинетСУ.ПраваПользователя(Пользователь);
		
		ДанныеПользователя = Новый Структура("Пользователь, СохраняемоеЗначениеПароля, Права, Имя", Пользователь, "", ПраваПользователя, ИмяПользователя);

	КонецЕсли;		
	
	Если ТипАутентификации = "openid" Тогда		
		
		ОшибкаЗапросаOpenID = ПроверитьЗапросOpenID(СтруктураДанных);
		
		Если ОшибкаЗапросаOpenID <> Неопределено Тогда
			ОтменитьТранзакцию();
			Возврат ОшибкаЗапросаOpenID; 
		КонецЕсли;
		
		Пользователь = Пользователи.НайтиПоИмени(СтруктураДанных.login);
		
		Если Пользователь = Справочники.Пользователи.ПустаяСсылка() Тогда
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("errorRegisterUser"); // Есть пользователь ИБ, но его нет в справочнике Пользователи			
		КонецЕсли;		
		
		Если Пользователь = Неопределено Тогда
			Пользователь = ЗаписатьНовогоПользователя(Пользователь, СтруктураДанных.login, "", СтруктураДанных.login, "");
		КонецЕсли;
		
		// Формируем структуру с данными пользователя
		
		ПраваПользователя = ВебКабинетСУ.ПраваПользователя(Пользователь);
		
		ДанныеПользователя = Новый Структура("Пользователь, СохраняемоеЗначениеПароля, Права, Имя", Пользователь, "", ПраваПользователя, СтруктураДанных.login);
		
	КонецЕсли;
	
	// Ищем старую сессию с такими же параметрами
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СессииВебКабинетаСУ.Идентификатор
		|ИЗ
		|	РегистрСведений.СессииВебКабинетаСУ КАК СессииВебКабинетаСУ
		|ГДЕ
		|	СессииВебКабинетаСУ.ИдентификаторКлиента = &ИдентификаторКлиента
		|	И СессииВебКабинетаСУ.Пользователь = &Пользователь";

	Запрос.УстановитьПараметр("ИдентификаторКлиента", СтруктураДанных.clientID);
	Запрос.УстановитьПараметр("Пользователь", ДанныеПользователя.Пользователь);

	РезультатЗапроса = Запрос.Выполнить();

	Если НЕ РезультатЗапроса.Пустой() Тогда
		ОтменитьТранзакцию();
		Возврат ОтветКлиентуJSON("errorDoubleAuthorization");
	КонецЕсли;
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	// Проверяем возможность входа
	
	Если НЕ ОбучениеСУО.ПользователюРазрешенВход(ДанныеПользователя.Пользователь) Тогда
		ОтменитьТранзакцию();
		Возврат ОтветКлиентуJSON("errorDateAuthorization", РегистрыСведений.ВремяДоступаПользователейСУО.ДатыДоступа(ДанныеПользователя.Пользователь));
	КонецЕсли;
	
	//----------------------------------//
	
	// Создаем новую сессию
	
	ДанныеНовойСессии = РегистрыСведений.СессииВебКабинетаСУ.СоздатьСессию(ДанныеПользователя.Пользователь, СтруктураДанных.clientID, ДанныеПользователя.СохраняемоеЗначениеПароля, ДанныеПользователя.Права, ТипАутентификации);	
	Уведомление = "";
	ЭтоОбразовательнаяОрганизация = Ложь;
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	ЭтоОбразовательнаяОрганизация = ПолучитьФункциональнуюОпцию("ОбразовательнаяОрганизацияОО");
	
	// Получаем уведомление
	
	Если СтруктураДанных.Свойство("usePinCode")
		И СтруктураДанных.usePinCode Тогда
		
		Уведомление = РегистрыСведений.ВыданныеПинКодыСУО.ПолучитьТекстУведомленияИЗапомнить(ДанныеПользователя.Пользователь);
		
	КонецЕсли;
	
	//----------------------------------//
	
	// Возвращаем идентификатор новой сессии
	
	ЗафиксироватьТранзакцию();
	
	ИмяСобытия = "";
	СтруктураДанных.Свойство("event", ИмяСобытия);
	
	Возврат ОтветКлиентуJSON(,
		Новый Структура("
		|session,
		|user,
		|date,
		|permissions,
		|login,
		|typeSession,
		|notification,
		|eduOrganization,
		|clientID,
		|event",
		ДанныеНовойСессии.ИдентификаторНовойСессии,
		Строка(ДанныеПользователя.Пользователь.УникальныйИдентификатор()),
		ДанныеНовойСессии.ДатаНачалаСессии,
		ДанныеПользователя.Права,
		ДанныеПользователя.Имя,
		ТипАутентификации,
		Уведомление,
		ЭтоОбразовательнаяОрганизация,
		СтруктураДанных.clientID,
		ИмяСобытия)
	);
	
	
КонецФункции

Функция ПроверитьЗапросOpenID(СтруктураДанных)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки
	
	Если НЕ СтруктураДанных.Свойство("publication")
		ИЛИ НЕ ЗначениеЗаполнено(СтруктураДанных.publication) Тогда
		
		Возврат ОтветКлиентуJSON("errorData");
		
	КонецЕсли;			
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПубликацииВебКабинета.АдресПровайдераOpenID КАК АдресПровайдера
		|ИЗ
		|	Справочник.ПубликацииВебКабинетаСУ КАК ПубликацииВебКабинета
		|ГДЕ
		|	ПубликацииВебКабинета.Код = &КодПубликации
		|	И ПубликацииВебКабинета.ДоступнаАутентификацияOpenID = ИСТИНА";
	
	Запрос.УстановитьПараметр("КодПубликации", СтруктураДанных.publication);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	НастройкиПубликации = РезультатЗапроса.Выбрать();		
	НастройкиПубликации.Следующий();	
	
	СтруктураURI = ОбщегоНазначенияКлиентСервер.СтруктураURI(
		НастройкиПубликации.АдресПровайдера + "?cmd=check"
	);			
	
	Если НРег(СтруктураURI.Схема) = "https" Тогда
		HTTPСоединение = Новый HTTPСоединение(СтруктураURI.Хост, СтруктураURI.Порт,,,, 10, Новый ЗащищенноеСоединениеOpenSSL()); 
	Иначе
		Возврат ОтветКлиентуJSON("errorHTTPConnect"); // Для OpenID только SSL
	КонецЕсли;
		
	HTTPЗапрос = Новый HTTPЗапрос(СтруктураURI.ПутьНаСервере);
	
	ТелоЗапроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("openid.auth.user=%1&openid.auth.uid=%2", СтруктураДанных.login, СтруктураДанных.clientID);
	
	HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);	
	
	Попытка
		ОтветСервера = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	Исключение
		Возврат ОтветКлиентуJSON("errorHTTPConnect");  // Запрос не дошел до HTTP-Сервера
	КонецПопытки;
	
	Если ОтветСервера.КодСостояния <> 200 Тогда
		Возврат ОтветКлиентуJSON("errorAuthorization");
	КонецЕсли;
		
	ОтветСервераСтрока = СокрЛП(ОтветСервера.ПолучитьТелоКакСтроку());
	
	Если ОтветСервераСтрока <> "is_valid:true" Тогда			
		Возврат ОтветКлиентуJSON("errorAuthorization");			
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ЗаписатьНовогоПользователя(Пользователь = Неопределено, Логин, Пароль, ПолноеИмя, ЭлектроннаяПочта, АутентификацияВебКабинета = Неопределено, Знач Комментарий = "", КонтактнаяИнформация = Неопределено, ДополнительныеРеквизиты = Неопределено)
	
	УстановитьПривилегированныйРежим(Истина);
	
	НачатьТранзакцию();
	
	Попытка
		
		// Необходимость транзакции обусловлена тем,
		// что пользователь записывается перед сохранением
		// некоторых данных. Если при сохранении доп. данных
		// произойдет ошибка, то откатится вся транзакция
		// и пользователь не запишется.
		
		Если Пользователь = Неопределено Тогда
			ПользовательОбъект = Справочники.Пользователи.СоздатьЭлемент();
		Иначе
			ПользовательОбъект = Пользователь.ПолучитьОбъект();
		КонецЕсли;	
			
		ПользовательОбъект.Наименование = ПолноеИмя;
		ПользовательОбъект.Комментарий  = Комментарий;
		
		ОписаниеПользователяИБ = Новый Структура;
		ОписаниеПользователяИБ.Вставить("Действие", "Записать");
		ОписаниеПользователяИБ.Вставить("ВходВПрограммуРазрешен", Ложь);
		ОписаниеПользователяИБ.Вставить("Пароль", Пароль);
		ОписаниеПользователяИБ.Вставить("Имя", Логин);
		ОписаниеПользователяИБ.Вставить("ПолноеИмя", ПолноеИмя);
		
		//--# КОНСТРУКТОР КУРСОВ ДОБАВИТЬ #--//
		
		//МассивРолей = Новый Массив;
		//МассивРолей.Добавить("УченикКК"); 
		//
		//ОписаниеПользователяИБ.Вставить("Роли", МассивРолей);
		
		//----------------------------------//	
		
		ПользовательОбъект.ДополнительныеСвойства.Вставить(
			"ОписаниеПользователяИБ", ОписаниеПользователяИБ);
			
		Если АутентификацияВебКабинета <> Неопределено Тогда
			ПользовательОбъект.ДополнительныеСвойства.Вставить("АутентификацияВебКабинета", АутентификацияВебКабинета);
		КонецЕсли;
		
		ДанныеЗаполненияКИ = УправлениеКонтактнойИнформацией.НоваяКонтактнаяИнформация(Ложь);	
		
		Если КонтактнаяИнформация <> Неопределено Тогда
				
			Для каждого Строка Из КонтактнаяИнформация Цикл				
				СтрокаЗаполнения = ДанныеЗаполненияКИ.Добавить();
				СтрокаЗаполнения.Вид = Строка.ВидКонтактнойИнформации;
				СтрокаЗаполнения.Представление = СокрЛП(Строка.Значение);							
			КонецЦикла;									
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ЭлектроннаяПочта)
			И ДанныеЗаполненияКИ.Найти(Справочники.ВидыКонтактнойИнформации.EmailПользователя, "Вид") = Неопределено Тогда
			
			СтрокаЗаполнения = ДанныеЗаполненияКИ.Добавить();
			СтрокаЗаполнения.Вид = Справочники.ВидыКонтактнойИнформации.EmailПользователя;
			СтрокаЗаполнения.Представление = СокрЛП(ЭлектроннаяПочта);

		КонецЕсли;
		
		Если ДанныеЗаполненияКИ.Количество() > 0 Тогда
			УправлениеКонтактнойИнформацией.УстановитьКонтактнуюИнформациюОбъекта(ПользовательОбъект, ДанныеЗаполненияКИ, Истина);	
		КонецЕсли;
		
		ПользовательОбъект.Записать();
		
		//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//

		Если ДополнительныеРеквизиты <> Неопределено Тогда
			
			ДанныеДополнительныхРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(ДополнительныеРеквизиты.ВыгрузитьКолонку("Реквизит"), "ЭтоДополнительноеСведение, ТипЗначения");
			
			Для каждого ЭлементСоответствия Из ДанныеДополнительныхРеквизитов Цикл
				
				ЗначениеРеквизита = ДополнительныеРеквизиты.Найти(ЭлементСоответствия.Ключ, "Реквизит").Значение;
				
				ОписаниеТиповЗначенияРеквизита = ЭлементСоответствия.Значение.ТипЗначения;
				
				Если ОписаниеТиповЗначенияРеквизита.СодержитТип(Тип("СправочникСсылка.ЗначенияСвойствОбъектов")) Тогда
					
					Попытка
						ЗначениеРеквизита = Справочники.ЗначенияСвойствОбъектов.ПолучитьСсылку(Новый УникальныйИдентификатор(ЗначениеРеквизита));
					Исключение
						ЗначениеРеквизита = Неопределено;
					КонецПопытки;				
					
				ИначеЕсли ОписаниеТиповЗначенияРеквизита.СодержитТип(Тип("СправочникСсылка.ЗначенияСвойствОбъектовИерархия")) Тогда
					
					Попытка
						ЗначениеРеквизита = Справочники.ЗначенияСвойствОбъектовИерархия.ПолучитьСсылку(Новый УникальныйИдентификатор(ЗначениеРеквизита));
					Исключение
						ЗначениеРеквизита = Неопределено;
					КонецПопытки;				
					
				ИначеЕсли ОписаниеТиповЗначенияРеквизита.СодержитТип(Тип("Булево")) Тогда
					
					ЗначениеРеквизита = ОбщегоНазначенияСУКлиентСервер.СтрокаВБулево(ЗначениеРеквизита);
					
				ИначеЕсли ОписаниеТиповЗначенияРеквизита.СодержитТип(Тип("Дата")) Тогда
					
					ЗначениеРеквизита = ОбщегоНазначенияСУКлиентСервер.СтрокаISO8601ВДату(ЗначениеРеквизита);				
					
				Иначе
					
					ЗначениеРеквизита = ОписаниеТиповЗначенияРеквизита.ПривестиЗначение(ЗначениеРеквизита);
					
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ЗначениеРеквизита) Тогда
				
					Если ЭлементСоответствия.Значение.ЭтоДополнительноеСведение Тогда
						
						МенеджерЗаписи = РегистрыСведений.ДополнительныеСведения.СоздатьМенеджерЗаписи();
						
						МенеджерЗаписи.Объект = ПользовательОбъект.Ссылка;
						МенеджерЗаписи.Свойство = ЭлементСоответствия.Ключ;
						МенеджерЗаписи.Значение = ЗначениеРеквизита;
						
						МенеджерЗаписи.Записать(Истина);				
						
					Иначе
						
						НоваяСтрокаДР = ПользовательОбъект.ДополнительныеРеквизиты.Добавить();
						
						НоваяСтрокаДР.Свойство = ЭлементСоответствия.Ключ;
						НоваяСтрокаДР.Значение = ЗначениеРеквизита;
						
					КонецЕсли;			
					
				КонецЕсли;
					
			КонецЦикла;
			
			ПользовательОбъект.Записать();
			
		КонецЕсли;
		
			
		//----------------------------------//	
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//

	МассивПараметровФЗ = Новый Массив;
	МассивПараметровФЗ.Добавить(ПользовательОбъект.Ссылка);
	МассивПараметровФЗ.Добавить(Истина);
	
	ФоновыеЗадания.Выполнить("ВебКабинетСУО.ОбновитьДанныеПользователяВебКабинета", МассивПараметровФЗ);	
		
	//----------------------------------//	
	
	Возврат ПользовательОбъект.Ссылка;	
	
КонецФункции

Процедура ИзменитьПарольПользователя(Пользователь, Пароль)	
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПользовательОбъект = Пользователь.ПолучитьОбъект();	
	
	ОписаниеПользователяИБ = Новый Структура;
	ОписаниеПользователяИБ.Вставить("Пароль", Пароль);
	ОписаниеПользователяИБ.Вставить("Действие", "Записать");
	
	ПользовательОбъект.ДополнительныеСвойства.Вставить(
		"ОписаниеПользователяИБ", ОписаниеПользователяИБ);	
	
	ПользовательОбъект.ДополнительныеСвойства.Вставить("АутентификацияВебКабинета", Истина);
	
	ПользовательОбъект.Записать();	
	
КонецПроцедуры

Функция ЕстьСвойствоXDTO(СписокСвойствXDTO, ИмяСвойства)
	Возврат ?(СписокСвойствXDTO.Получить(ИмяСвойства) = Неопределено, Ложь, Истина)	
КонецФункции

Функция РазрешитьМежсайтовыеЗапросыOPTIONS(Запрос)
	
	Ответ = Новый HTTPСервисОтвет(200);
	ДобавитьЗаголовкиМежсайтовогоЗапроса(Ответ, Истина);
	Возврат Ответ;
	
КонецФункции

Процедура ДобавитьЗаголовкиМежсайтовогоЗапроса(Ответ, ПроверитьРазрешение = Ложь)
	Если НЕ ПроверитьРазрешение ИЛИ Константы.РазрешитьЗапросыКСервисамСДругихДоменовСУ.Получить() = Истина Тогда
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	    Ответ.Заголовки.Вставить("Access-Control-Allow-Methods", "GET, PUT, POST, DELETE, HEAD, OPTIONS");
	    Ответ.Заголовки.Вставить("Access-Control-Allow-Credentials", "true");
	    Ответ.Заголовки.Вставить("Access-Control-Allow-Headers", "X-Requested-With, origin, content-type, accept");
	КонецЕсли;
КонецПроцедуры









// ОБМЕН ДАННЫМИ И ПУБЛИКАЦИИ

Функция ПолучитьЗначенияПеременнойИзФайлаExcel(ДанныеФайла, Колонки, Переменная, ОдноЗначение = Истина, АльтернативноеЗначение = Неопределено, Тип = Неопределено, Владелец = Неопределено) Экспорт
	
	МассивКолонок = Колонки.НайтиСтроки(Новый Структура("Значение", Переменная));
	
	МассивЗначений = Новый Массив();
	
	Для каждого Колонка Из МассивКолонок Цикл
	
		Значение = ДанныеФайла[Колонка.Номер - 1];
		
		Если ЗначениеЗаполнено(Тип) Тогда
		
			Если Тип = "Булево" Тогда
				
				Если Значение = "1"
					ИЛИ НРег(Значение) = "да"
					ИЛИ НРег(Значение) = "истина"
					ИЛИ НРег(Значение) = "true" Тогда
					
					Значение = Истина;
					
				КонецЕсли;	
				
				Если Значение = "0"
					ИЛИ НРег(Значение) = "нет"
					ИЛИ НРег(Значение) = "ложь"
					ИЛИ НРег(Значение) = "false" Тогда
					
					Значение = Ложь;
					
				КонецЕсли;
				
			ИначеЕсли Тип = "Число" Тогда
				
				Попытка
					Значение = Число(Значение);
				Исключение
					Значение = 0;
				КонецПопытки;
				
			Иначе // Ссылка
				
				Тип              = Тип(Тип);
				ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
				ПолноеИмя        = ОбъектМетаданных.ПолноеИмя(); // Например: Справочник.РубрикаторыСУЗ
				ПолноеИмяМассив  = ОбщегоНазначенияСУКлиентСервер.РасщепитьСтроку(ПолноеИмя, "."); // Первые элемент - тип объекта метаданных. Второй - его имя.
				
				Если ПолноеИмяМассив[0] = "Справочник" Тогда
					Значение = ОбщегоНазначенияСУ.НайтиЭлементСправочника(ПолноеИмяМассив[1], "Наименование", Значение, Владелец);
				КонецЕсли;
				
				Если ПолноеИмяМассив[0] = "Перечисление" Тогда
					
					Попытка
						Значение = Перечисления[ПолноеИмяМассив[1]][Значение];
					Исключение
						Значение = Перечисления[ПолноеИмяМассив[1]].ПустаяСсылка();
					КонецПопытки;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
			
		Если ЗначениеЗаполнено(Значение) Тогда
			МассивЗначений.Добавить(Значение);
		ИначеЕсли АльтернативноеЗначение <> Неопределено Тогда
			МассивЗначений.Добавить(АльтернативноеЗначение);
		КонецЕсли;
	
	КонецЦикла;
	
	Если ОдноЗначение Тогда
		
		Если МассивЗначений.Количество() > 0 Тогда
			Возврат МассивЗначений[0];
		Иначе
			Возврат ?(АльтернативноеЗначение <> Неопределено, АльтернативноеЗначение, Неопределено); 
		КонецЕсли;
		
	Иначе
		
		Возврат МассивЗначений;
		
	КонецЕсли;

КонецФункции

Процедура НачатьЧтениеПакетаДанных(ЧтениеXML, Секция = "ЭлементыДляЗагрузки") Экспорт
	
	Пока ЧтениеXML.Прочитать() Цикл

		Если ЧтениеXML.Имя = Секция 
			И ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда 
			
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ЧтениеXML.Прочитать();
	
КонецПроцедуры

Процедура ОпубликоватьПакетДанных(ПараметрыПубликации, АдресХранилища, АдресХранилищаДополнительный) Экспорт

	ОбработкаОбъект = Обработки.ПубликацияЭлектронныхРесурсовСУЗ.Создать();
	ОбработкаОбъект.ТипПубликации = ПараметрыПубликации.ТипПубликации;
	ОбработкаОбъект.Описание = ПараметрыПубликации.Описание;
	
	ОбработкаОбъект.УдалитьСтарыеПубликации = ПараметрыПубликации.УдалитьСтарыеПубликации;
	ОбработкаОбъект.ДляТестирования = ПараметрыПубликации.ДляТестирования;
	ОбработкаОбъект.СохранятьАктивность = ПараметрыПубликации.СохранятьАктивность;
	ОбработкаОбъект.ВключитьБраузер = ПараметрыПубликации.ВключитьБраузер;
	ОбработкаОбъект.ПредпочитатьФорматВидеоWEBM = ПараметрыПубликации.ПредпочитатьФорматВидеоWEBM;
	ОбработкаОбъект.КаталогДляСохранения = ПараметрыПубликации.КаталогДляСохранения;
	ОбработкаОбъект.ВключитьИнтерфейсПреподавателя = ПараметрыПубликации.ВключитьИнтерфейсПреподавателя;	
	ОбработкаОбъект.ПарольПользователя = ПараметрыПубликации.ПарольПользователя;
	ОбработкаОбъект.ПарольПреподавателя = ПараметрыПубликации.ПарольПреподавателя;
	
	ОбработкаОбъект.ПользовательскиеСтили = ПараметрыПубликации.ПользовательскиеСтили;
	ОбработкаОбъект.ЯзыкИнтерфейса = ПараметрыПубликации.ЯзыкИнтерфейса;	
	ОбработкаОбъект.ПоискРазрешен = ПараметрыПубликации.ПоискРазрешен;	
	
	НомерСтроки = 0;
	Для каждого ЭлектронныйРесурс Из ПараметрыПубликации.ЭлектронныеРесурсы Цикл	
		НоваяСтрока = ОбработкаОбъект.ЭлектронныеРесурсы.Добавить();
		НоваяСтрока.ЭлектронныйРесурс = ЭлектронныйРесурс;
		НоваяСтрока.РазмещениеКнопкиВыхода = ПараметрыПубликации.РазмещениеКнопкиВыхода[НомерСтроки];
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;	
	
	Если ПараметрыПубликации.ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS Тогда		
		Результат = ОбработкаОбъект.ВыполнитьПубликацию(ПараметрыПубликации.УникальныйИдентификатор);		
	Иначе		
		Результат = ОбработкаОбъект.ВыполнитьПубликацию(АдресХранилищаДополнительный);		
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
	
КонецПроцедуры


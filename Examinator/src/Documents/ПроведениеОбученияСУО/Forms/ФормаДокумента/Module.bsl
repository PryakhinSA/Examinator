	Отказ = Ложь;
	
	ОбщегоНазначенияСУКлиент.ПередДобавлениемЭлементаПодчиненногоСправочника(ЭтотОбъект, Отказ);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;	
	
	ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьНовыйФайлПродолжение", ЭтотОбъект);		
	РаботаСФайламиКлиент.ДобавитьФайл(ОписаниеОповещения, ПредопределенноеЗначение("Справочник.ПапкиФайлов.ПроведенияМероприятий"), ЭтотОбъект, 2, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНовыйФайлПродолжение(Результат, Дополнительно) Экспорт
	
	НовыйФайлСсылка = Неопределено;
	
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("ФайлСсылка") И ЗначениеЗаполнено(Результат.ФайлСсылка) Тогда
		НовыйФайлСсылка = Результат.ФайлСсылка;
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("СправочникСсылка.Файлы") И ЗначениеЗаполнено(Результат) Тогда
		НовыйФайлСсылка = Результат;
	КонецЕсли;
	
	Если НовыйФайлСсылка <> Неопределено Тогда
		НоваяСтрока = Объект.Файлы.Добавить();
		НоваяСтрока.Файл = НовыйФайлСсылка;
		НоваяСтрока.ПоказатьПриСтатусеЗапланировано = Ложь;
		НоваяСтрока.ПоказатьПриСтатусеАктивно = Истина;
		НоваяСтрока.ПоказатьПриСтатусеЗавершено = Истина;
		Модифицированность = Истина;
	КонецЕсли;
		
КонецПроцедуры


Функция ПроведенияОбученияСоВстроеннымПлеером(Знач ЭлектронныйРесурс) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПроведениеОбученияСУО.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО
		|ГДЕ
		|	ПроведениеОбученияСУО.Проведен = ИСТИНА
		|	И ПроведениеОбученияСУО.Статус = &Статус
		|	И ПроведениеОбученияСУО.ПлеерВебКабинета = &ПлеерВебКабинета
		|	И ПроведениеОбученияСУО.ЭлектронныйРесурс = &ЭлектронныйРесурс
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПроведениеОбученияСУОЭлектронныеЗадания.Ссылка
		|ИЗ
		|	Документ.ПроведениеОбученияСУО.ЭлектронныеЗадания КАК ПроведениеОбученияСУОЭлектронныеЗадания
		|ГДЕ
		|	ПроведениеОбученияСУОЭлектронныеЗадания.Задание = &ЭлектронныйРесурс
		|	И ПроведениеОбученияСУОЭлектронныеЗадания.ПлеерВебКабинета = &ПлеерВебКабинета
		|	И ПроведениеОбученияСУОЭлектронныеЗадания.Ссылка.Проведен = ИСТИНА
		|	И ПроведениеОбученияСУОЭлектронныеЗадания.Ссылка.Статус = &Статус
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПроведениеОбученияСУОЭлектронныеРесурсы.Ссылка
		|ИЗ
		|	Документ.ПроведениеОбученияСУО.ЭлектронныеРесурсы КАК ПроведениеОбученияСУОЭлектронныеРесурсы
		|ГДЕ
		|	ПроведениеОбученияСУОЭлектронныеРесурсы.ЭлектронныйРесурс = &ЭлектронныйРесурс
		|	И ПроведениеОбученияСУОЭлектронныеРесурсы.Ссылка.Проведен = ИСТИНА
		|	И ПроведениеОбученияСУОЭлектронныеРесурсы.Ссылка.Статус = &Статус
		|	И ПроведениеОбученияСУОЭлектронныеРесурсы.ПлеерВебКабинета = &ПлеерВебКабинета";
	
	Запрос.УстановитьПараметр("ПлеерВебКабинета", Перечисления.ПлеерыКурсовВебКабинетаСУЗ.Встроенный);
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыПроведенияОбъектовСУО.Активно);
	Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);
	
	МассивПроведенийОбучений = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	МассивПроведенийОбучений = ОбщегоНазначенияКлиентСервер.СвернутьМассив(МассивПроведенийОбучений);
	Возврат МассивПроведенийОбучений;
	
КонецФункции


Функция ВыставляетсяОценка(Знач ВидОбучения, Знач ЭлектронныйРесурс, Знач Задания) Экспорт
	
	ВыставляетсяОценка = ВидОбучения.ВыставляетсяОценка;
	
	Если НЕ ВидОбучения.Электронное Тогда
		Возврат ВыставляетсяОценка;
	КонецЕсли;
	
	Если ВыставляетсяОценка Тогда
		
		Если ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
			
			Возврат Справочники.СводыЗнанийСУЗ.ВыставляетсяОценка(ЭлектронныйРесурс);
						
		ИначеЕсли ВидОбучения.Общее Тогда
			
			Возврат ВыставляетсяОценка; // Не реализовано
			
		ИначеЕсли Задания <> Неопределено Тогда			
			
			Если Задания.Количество() = 0 Тогда
				Возврат ВыставляетсяОценка;
			КонецЕсли;
			
			Если Задания.Найти(Истина, "ВыставляетсяОценка") <> Неопределено Тогда
				Возврат Истина;
			Иначе
				Возврат Ложь;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;	
	
	Возврат ВыставляетсяОценка;
	
КонецФункции

// ДОПОЛНИТЕЛЬНО

Процедура УстановитьВидСценария(Объект, Отказ) Экспорт
	
	КоличествоУстановленныхСценариев = 0;
	
	Если Объект.БезСценария Тогда
		КоличествоУстановленныхСценариев = КоличествоУстановленныхСценариев + 1;
	КонецЕсли;
	
	Если Объект.НаОсновеМероприятия Тогда
		КоличествоУстановленныхСценариев = КоличествоУстановленныхСценариев + 1;
	КонецЕсли;
	
	Если Объект.НаОсновеЭлектронногоРесурса Тогда
		КоличествоУстановленныхСценариев = КоличествоУстановленныхСценариев + 1;
	КонецЕсли;
	
	Если КоличествоУстановленныхСценариев = 0 Тогда
		
		Если ЗначениеЗаполнено(Объект.Мероприятие) И ЗначениеЗаполнено(Объект.ЭлектронныйРесурс) Тогда
			Текст = НСтр("ru = 'Произошла ошибка при установке вида сценария: неопределенная ситуация'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст,,,,Отказ);
			Возврат;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.Мероприятие) Тогда
			Объект.НаОсновеМероприятия = Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.ЭлектронныйРесурс) Тогда
			Объект.НаОсновеЭлектронногоРесурса = Истина;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Объект.Мероприятие) И НЕ ЗначениеЗаполнено(Объект.ЭлектронныйРесурс) Тогда
			Объект.БезСценария = Истина;
		КонецЕсли;
		
	КонецЕсли;		
	
	Если КоличествоУстановленныхСценариев > 1 Тогда
		Текст = НСтр("ru = 'Произошла ошибка при установке вида сценария. Противоречивая ситуация'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст,,,,Отказ);
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

Функция ЕстьЭлементыВГруппеПораСделатьАктивным() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ПроведениеОбученияСУО.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО
		|ГДЕ
		|	ПроведениеОбученияСУО.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПроведенияОбъектовСУО.Запланировано)
		|	И ПроведениеОбученияСУО.ПометкаУдаления = ЛОЖЬ
		|	И НАЧАЛОПЕРИОДА(ПроведениеОбученияСУО.ДатаНачалаПроведения, ДЕНЬ) <= НАЧАЛОПЕРИОДА(&ЭтотДень, ДЕНЬ)
		|	И ПроведениеОбученияСУО.ДатаНачалаПроведения <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|	И ПроведениеОбученияСУО.Проведен = ИСТИНА
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПроведениеОбученияСУО.Ссылка
		|ИЗ
		|	Документ.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО
		|ГДЕ
		|	ПроведениеОбученияСУО.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПроведенияОбъектовСУО.Запланировано)
		|	И ПроведениеОбученияСУО.ПометкаУдаления = ЛОЖЬ
		|	И НАЧАЛОПЕРИОДА(ПроведениеОбученияСУО.ДатаНачалаДоступа, ДЕНЬ) <= НАЧАЛОПЕРИОДА(&ЭтотДень, ДЕНЬ)
		|	И ПроведениеОбученияСУО.ДатаНачалаДоступа <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|	И ПроведениеОбученияСУО.Проведен = ИСТИНА";
	
	Запрос.Параметры.Вставить("ЭтотДень", ТекущаяДатаСеанса());
	
	Возврат НЕ Запрос.Выполнить().Пустой();
	
КонецФункции

Функция ЕстьЭлементыВГруппеПораЗавершить() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ПроведениеОбученияСУО.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО
		|ГДЕ
		|	ПроведениеОбученияСУО.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПроведенияОбъектовСУО.Активно)
		|	И ГОД(ПроведениеОбученияСУО.ДатаОкончанияПроведения) > 1
		|	И НЕ ПроведениеОбученияСУО.ДатаОкончанияПроведения ЕСТЬ NULL
		|	И НАЧАЛОПЕРИОДА(ПроведениеОбученияСУО.ДатаОкончанияПроведения, ДЕНЬ) < НАЧАЛОПЕРИОДА(&ЭтотДень, ДЕНЬ)
		|	И ПроведениеОбученияСУО.Проведен = ИСТИНА
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПроведениеОбученияСУО.Ссылка
		|ИЗ
		|	Документ.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО
		|ГДЕ
		|	ПроведениеОбученияСУО.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПроведенияОбъектовСУО.Активно)
		|	И ГОД(ПроведениеОбученияСУО.ДатаКонтроля) > 1
		|	И НЕ ПроведениеОбученияСУО.ДатаКонтроля ЕСТЬ NULL
		|	И НАЧАЛОПЕРИОДА(ПроведениеОбученияСУО.ДатаКонтроля, ДЕНЬ) < НАЧАЛОПЕРИОДА(&ЭтотДень, ДЕНЬ)
		|	И ПроведениеОбученияСУО.Проведен = ИСТИНА";
	
	Запрос.Параметры.Вставить("ЭтотДень", ТекущаяДатаСеанса());
	
	Возврат НЕ Запрос.Выполнить().Пустой();	
	
КонецФункции

// ВЕБ-КАБИНЕТ

Процедура ОбновитьДанныеВебКабинета(ПроведениеОбучения, ДополнительныеДанные = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем переменные
	
	ТаблицаФайловВебКабинета = Новый ТаблицаЗначений;
	ТаблицаФайловВебКабинета.Колонки.Добавить("ИмяРеквизита");
	ТаблицаФайловВебКабинета.Колонки.Добавить("ИдентификаторКаталога");
	ТаблицаФайловВебКабинета.Колонки.Добавить("ДвоичныеДанные");
	
	НоваяСтрока = ТаблицаФайловВебКабинета.Добавить();
	НоваяСтрока.ИмяРеквизита = "КомментарийОткрытогоМероприятияДляУчастника";	
	
	НоваяСтрока = ТаблицаФайловВебКабинета.Добавить();
	НоваяСтрока.ИмяРеквизита = "КомментарийЗапланированногоМероприятияДляУчастника";
	
	НоваяСтрока = ТаблицаФайловВебКабинета.Добавить();
	НоваяСтрока.ИмяРеквизита = "КомментарийАктивногоМероприятияДляУчастника";
	
	НоваяСтрока = ТаблицаФайловВебКабинета.Добавить();
	НоваяСтрока.ИмяРеквизита = "КомментарийЗавершенногоМероприятияДляУчастника";
	
	НоваяСтрока = ТаблицаФайловВебКабинета.Добавить();
	НоваяСтрока.ИмяРеквизита = "КомментарийОтмененногоМероприятияДляУчастника";
	
	НоваяСтрока = ТаблицаФайловВебКабинета.Добавить();
	НоваяСтрока.ИмяРеквизита = "КомментарийЗапланированногоМероприятияДляПреподавателя";
	
	НоваяСтрока = ТаблицаФайловВебКабинета.Добавить();
	НоваяСтрока.ИмяРеквизита = "КомментарийАктивногоМероприятияДляПреподавателя";
	
	НоваяСтрока = ТаблицаФайловВебКабинета.Добавить();
	НоваяСтрока.ИмяРеквизита = "КомментарийЗавершенногоМероприятияДляПреподавателя";
	
	НоваяСтрока = ТаблицаФайловВебКабинета.Добавить();
	НоваяСтрока.ИмяРеквизита = "КомментарийОтмененногоМероприятияДляПреподавателя";
		
	
	РеквизитыДляПолучения = Новый Структура;
	РеквизитыДляПолучения.Вставить("Проведен", "Проведен");	
	РеквизитыДляПолучения.Вставить("Открытое", "ОткрытоеМероприятие");	
	РеквизитыДляПолучения.Вставить("ДатаОткрытияЗаписи", "ДатаОткрытияЗаписи");	
	РеквизитыДляПолучения.Вставить("ДатаЗакрытияЗаписи", "ДатаЗакрытияЗаписи");	
	РеквизитыДляПолучения.Вставить("ФайлКартинки", "ФайлКартинки");
	РеквизитыДляПолучения.Вставить("КачествоОбученияОцениваетсяУчастниками", "КачествоОбученияОцениваетсяУчастниками");
	РеквизитыДляПолучения.Вставить("ПоказыватьОценкиИКомментарииВсемУчастникам", "ПоказыватьОценкиИКомментарииВсемУчастникам");
	РеквизитыДляПолучения.Вставить("ВариантПродолжительности", "ВариантПродолжительности");
	РеквизитыДляПолучения.Вставить("ПродолжительностьВСекундах", "ПродолжительностьВСекундах");	
	
	Для каждого Строка Из ТаблицаФайловВебКабинета Цикл
		РеквизитыДляПолучения.Вставить(Строка.ИмяРеквизита, Строка.ИмяРеквизита);
	КонецЦикла;
	
	ДанныеПроведенияОбучения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПроведениеОбучения, РеквизитыДляПолучения);	
	
	Сценарий = Документы.ПроведениеОбученияСУО.СценарийОбучения(ПроведениеОбучения);
	
	// Выгружаем файлы форматированных документов
	
	Если ДанныеПроведенияОбучения.Проведен Тогда
	
		Для каждого Строка Из ТаблицаФайловВебКабинета Цикл
			
			КонтекстныйКомментарийСтруктура = ОбщегоНазначенияСУ.ПредставлениеФорматированногоДокументаДляВыгрузкиHTML(ДанныеПроведенияОбучения[Строка.ИмяРеквизита].Получить(), Строка(ПроведениеОбучения.УникальныйИдентификатор()), Строка.ИмяРеквизита, Истина, Ложь);
			
			Если КонтекстныйКомментарийСтруктура.ЕстьВложения Тогда					
				ВебКабинетСУО.ВыгрузитьФайлыФорматированногоДокументаВКаталогВебКабинета(КонтекстныйКомментарийСтруктура.ДвоичныеДанные, КонтекстныйКомментарийСтруктура.ИдентификаторКаталога);					
			КонецЕсли;
				
		КонецЦикла;		
		
	КонецЕсли;
	
	// Выгружаем файл картинки
	
	Если ЗначениеЗаполнено(ДанныеПроведенияОбучения.ФайлКартинки) Тогда
		
		ПутьККаталогуПроведенияОбучения = ПутьККаталогуФайловПроведенияОбучения(
			ВебКабинетСУ.ПутьККаталогуКартинок(ОбъектыСУЗПовтИсп.ПутьКОбщемуКаталогу()), ПроведениеОбучения);
			
		СоздатьКаталог(ПутьККаталогуПроведенияОбучения);			
			
		ОписаниеФайлаКартинки = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаИДвоичныеДанные(ДанныеПроведенияОбучения.ФайлКартинки);
		ОписаниеФайлаКартинки.ДвоичныеДанные.Записать(ПутьККаталогуПроведенияОбучения 
			+ ИмяФайлаКартинки(ОписаниеФайлаКартинки.ДанныеФайла.Расширение));
		
	КонецЕсли;
	
	// Обновляем список авто-разделов форума у пользователей
		
	РегистрыСведений.ДанныеВебКабинетаСУО_ПН.УдалитьДанные(ПроведениеОбучения, Перечисления.ТипыДанныхВебКабинетаСУО.РазделФорума);
	
	Если ДанныеПроведенияОбучения.Проведен Тогда
		
		ТаблицаПользовательскихРазделов = РегистрыСведений.АвтоРазделыФорумаСУО.РазделыПользователя(,ПроведениеОбучения); // Пользователи, которым доступен авто-раздел

		ОписаниеРазделаJSON = Справочники.РазделыФорумаСУО.РазделJSON(ПроведениеОбучения);

		Для каждого Строка Из ТаблицаПользовательскихРазделов Цикл
			РегистрыСведений.ДанныеВебКабинетаСУО_ПН.ДобавитьДанные(Строка.Пользователь, Перечисления.ТипыДанныхВебКабинетаСУО.РазделФорума, ПроведениеОбучения, ОписаниеРазделаJSON, Перечисления.ФорматыВебДанныхСУ.json);
		КонецЦикла;
			
	КонецЕсли;	
	
	// Обновляем преподавателей участников
	
	ПрохожденияОбучения = Документы.ПроведениеОбученияСУО.ПрохожденияОбучения(ПроведениеОбучения, Истина);
	
	Для каждого Строка Из ПрохожденияОбучения Цикл
		РегистрыСведений.ПреподавателиОбученияСУО.ОбновитьДанныеВебКабинета(Строка.Пользователь);		
	КонецЦикла;
	
	// Отборы
	
	РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.УдалитьОтбор(ПроведениеОбучения);
		
	// Обновляем открытое обучение
	
	РегистрыСведений.ДанныеВебКабинетаСУО_ПП.УдалитьДанные(ПроведениеОбучения, Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивность);
	РегистрыСведений.ДанныеВебКабинетаСУО_ПН.УдалитьДанные(ПроведениеОбучения, Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивность);
	
	Если ДанныеПроведенияОбучения.Проведен Тогда
	
		ОткрытоеОбучениеВыборка = РегистрыСведений.ОткрытоеОбучениеСУО.ВыбратьЭлементыРасписания(ПроведениеОбучения);
		
		Если ОткрытоеОбучениеВыборка.Количество() > 0 Тогда
			
			// Устанавливаем отбор именно для проведения обучения, как открытое,
			// чтобы оно нашлось при запросе открытого обучения пользователя.
			// Отбор не пользовательский, а общий.
			
			РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(ПроведениеОбучения, Перечисления.ОтборыДанныхВебКабинетаСУО.Открытые);
			
			// Устанавливаем данные для каждого потенциального участника открытого обучения.
			
			ЭлектронноДистанционное = Документы.ПроведениеОбученияСУО.ЭлектронноДистанционноеОбучение(ПроведениеОбучения);
			ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(ПроведениеОбучения); 
			
			Пока ОткрытоеОбучениеВыборка.Следующий() Цикл			
				
				ОписаниеОткрытогоОбучения = Документы.ПрохождениеОбученияСУО.УчебнаяАктивностьПустаяСтруктура();		
				
				ОписаниеОткрытогоОбучения.Тип = ?(ОткрытоеОбучениеВыборка.ТребуетсяЗаявка, "ЗаявкаНаОбучение", "ЗаписьНаОбучение");
				ОписаниеОткрытогоОбучения.Идентификатор = Строка(ПроведениеОбучения.УникальныйИдентификатор());
				ОписаниеОткрытогоОбучения.Наименование = ОткрытоеОбучениеВыборка.Наименование;			
				ОписаниеОткрытогоОбучения.ДатаНачала = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ОткрытоеОбучениеВыборка.ДатаНачалаПроведения);				
				ОписаниеОткрытогоОбучения.ДатаОкончания = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ОткрытоеОбучениеВыборка.ДатаОкончанияПроведения);		
				ОписаниеОткрытогоОбучения.ЭлектронноДистанционное = ЭлектронноДистанционное;
				ОписаниеОткрытогоОбучения.СкрытьВремяПроведения = ОткрытоеОбучениеВыборка.СкрытьВремяПроведения;		
				ОписаниеОткрытогоОбучения.ПрохождениеОбучения = ОткрытоеОбучениеВыборка.ПрохождениеОбучения;
				ОписаниеОткрытогоОбучения.ДатаОткрытияЗаписи = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ОткрытоеОбучениеВыборка.ДатаОткрытияЗаписи);				
				ОписаниеОткрытогоОбучения.ДатаЗакрытияЗаписи = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ОткрытоеОбучениеВыборка.ДатаЗакрытияЗаписи);			
				ОписаниеОткрытогоОбучения.ПроведениеОбучения = ПроведениеОбучения;				
				ОписаниеОткрытогоОбучения.РодительскаяАктивность = Справочники.ВидыМероприятийСУО.ПустаяСсылка();
				
				ОписаниеОткрытогоОбучения.ПродолжительностьВСекундах = ДанныеПроведенияОбучения.ПродолжительностьВСекундах;
	
				ОписаниеОткрытогоОбучения.ВариантПродолжительности = Перечисления.ПродолжительностьОбученияСУО.ЗначениеВЧисло(
					ДанныеПроведенияОбучения.ВариантПродолжительности);

				// Качество обучения
	
				ОписаниеОткрытогоОбучения.СредняяОценкаКачестваОбучения = 0;
				ОписаниеОткрытогоОбучения.КоличествоОценокКачестваОбучения = 0;
								
				Если ДанныеПроведенияОбучения.КачествоОбученияОцениваетсяУчастниками
					И ДанныеПроведенияОбучения.ПоказыватьОценкиИКомментарииВсемУчастникам Тогда
					
					ОписаниеОценокКачества = УправлениеОбучениемСУОПовтИсп.ОценкаКачестваПроведенияОбучения(ПроведениеОбучения);						
					ОписаниеОткрытогоОбучения.СредняяОценкаКачестваОбучения = ОписаниеОценокКачества.СредняяОценка;
					ОписаниеОткрытогоОбучения.КоличествоОценокКачестваОбучения = ОписаниеОценокКачества.КоличествоОценок;
						
				КонецЕсли;

				// Картинка обучения
				
				ОписаниеОткрытогоОбучения.Картинка = "";
				Если ЗначениеЗаполнено(ОткрытоеОбучениеВыборка.ФайлКартинки) Тогда
					ОписаниеОткрытогоОбучения.Картинка = Документы.ПроведениеОбученияСУО.АдресФайлаКартинки(
						ОткрытоеОбучениеВыборка.ПроведениеОбучения, ОткрытоеОбучениеВыборка.РасширениеКартинки); 
				КонецЕсли;
				
				ДанныеУчебнойАктивности = ОбщегоНазначенияСУ.ДанныеВJSON(ОписаниеОткрытогоОбучения);		
				
				Если НЕ ЗначениеЗаполнено(ОткрытоеОбучениеВыборка.ДатаНачалаПроведения) Тогда
					РегистрыСведений.ДанныеВебКабинетаСУО_ПН.ДобавитьДанные(ОткрытоеОбучениеВыборка.Пользователь, Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивность, ПроведениеОбучения, ДанныеУчебнойАктивности, Перечисления.ФорматыВебДанныхСУ.json);				
				Иначе				
					РегистрыСведений.ДанныеВебКабинетаСУО_ПП.ДобавитьДанные(ОткрытоеОбучениеВыборка.ДатаНачалаПроведения, ОткрытоеОбучениеВыборка.Пользователь, Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивность, ПроведениеОбучения, ДанныеУчебнойАктивности, Перечисления.ФорматыВебДанныхСУ.json);				
				КонецЕсли;
				
			КонецЦикла;
		
		КонецЕсли;
		
	КонецЕсли;
		
	// Обновляем описание проведения обучения
	
	РегистрыСведений.ДанныеВебКабинетаСУО_ОН.УдалитьДанные(ПроведениеОбучения, Перечисления.ТипыДанныхВебКабинетаСУО.ОписаниеОбучения);
	
	Если ДанныеПроведенияОбучения.Проведен Тогда
	
		ОписаниеОбученияСтруктура = Новый Структура(
		"Идентификатор,
		|Наименование,
		|Открытое,
		|ОписаниеОткрытогоОбучения");
		
		ОписаниеОбученияСтруктура.Идентификатор      = Строка(ПроведениеОбучения.УникальныйИдентификатор());
		ОписаниеОбученияСтруктура.Наименование       = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сценарий, "Наименование");
		ОписаниеОбученияСтруктура.Открытое           = ДанныеПроведенияОбучения.Открытое;
		
		Если ДанныеПроведенияОбучения.Открытое Тогда
		
			ОписаниеОбученияСтруктура.ОписаниеОткрытогоОбучения = Новый Структура("ДатаОткрытияЗаписи, ДатаЗакрытияЗаписи, Описание, ДополнительныеСведения");
			
			ОписаниеОбученияСтруктура.ОписаниеОткрытогоОбучения.ДатаОткрытияЗаписи = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ДанныеПроведенияОбучения.ДатаОткрытияЗаписи);
			ОписаниеОбученияСтруктура.ОписаниеОткрытогоОбучения.ДатаЗакрытияЗаписи = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ДанныеПроведенияОбучения.ДатаЗакрытияЗаписи);
			
			Если ТипЗнч(ДанныеПроведенияОбучения.КомментарийОткрытогоМероприятияДляУчастника) = Тип("ХранилищеЗначения") Тогда
				
			    ОписаниеОткрытогоОбученияДляУчастникаФорматированныйДокумент = ДанныеПроведенияОбучения.КомментарийОткрытогоМероприятияДляУчастника.Получить();
		
				ОписаниеОткрытогоОбученияДляУчастникаСтруктура = ОбщегоНазначенияСУ.ПредставлениеФорматированногоДокументаДляВыгрузкиHTML(ОписаниеОткрытогоОбученияДляУчастникаФорматированныйДокумент, Строка(ПроведениеОбучения.УникальныйИдентификатор()), "КомментарийОткрытогоМероприятияДляУчастника", Истина);
					
				ОписаниеОткрытогоОбученияДляУчастникаHTML = СокрЛП(ОписаниеОткрытогоОбученияДляУчастникаСтруктура.ПредставлениеHTML);
				
				Если ЗначениеЗаполнено(ОписаниеОткрытогоОбученияДляУчастникаHTML) Тогда
					ОписаниеОбученияСтруктура.ОписаниеОткрытогоОбучения.Описание = ОписаниеОткрытогоОбученияДляУчастникаHTML;
				КонецЕсли;	
				
			КонецЕсли;
			
			ОписаниеОбученияСтруктура.ОписаниеОткрытогоОбучения.ДополнительныеСведения = ВебКабинетСУО.ТаблицаДополнительныхРеквизитовОбъекта(Документы.ЗаявкаНаОбучениеСУО.ПустаяСсылка());
			
		КонецЕсли;
			
		ОписаниеОбученияJSON = ОбщегоНазначенияСУ.ДанныеВJSON(ОписаниеОбученияСтруктура);
		
		РегистрыСведений.ДанныеВебКабинетаСУО_ОН.ДобавитьДанные(Перечисления.ТипыДанныхВебКабинетаСУО.ОписаниеОбучения, ПроведениеОбучения, ОписаниеОбученияJSON, Перечисления.ФорматыВебДанныхСУ.json); 
		
	КонецЕсли;
	
	// Обновляем оценки качества обучения
	
	РегистрыСведений.ДанныеВебКабинетаСУО_ОН.УдалитьДанные(ПроведениеОбучения, Перечисления.ТипыДанныхВебКабинетаСУО.ОценкиКачестваОбучения);
	
	Если ДанныеПроведенияОбучения.Проведен Тогда
		
		ОписаниеОценокJSON = ОбщегоНазначенияСУ.ДанныеВJSON(
			РегистрыСведений.ОценкиКачестваОбученияСУО.ОписаниеОценокПроведенияОбучения(ПроведениеОбучения));
		
		РегистрыСведений.ДанныеВебКабинетаСУО_ОН.ДобавитьДанные(Перечисления.ТипыДанныхВебКабинетаСУО.ОценкиКачестваОбучения, ПроведениеОбучения, ОписаниеОценокJSON, Перечисления.ФорматыВебДанныхСУ.json);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

// ОБРАБОТЧИКИ СОБЫТИЙ

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Поля.Добавить("ЭлектронныйРесурс");
	Поля.Добавить("Мероприятие");
	Поля.Добавить("НаОсновеЭлектронногоРесурса");
	Поля.Добавить("НаОсновеМероприятия");
	Поля.Добавить("БезСценария");
	Поля.Добавить("Наименование");
	
КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	УстановитьПривилегированныйРежим(Истина);
	
	СтандартнаяОбработка = Ложь;
	
	НаименованиеСценария = "";
	
	Если ЗначениеЗаполнено(Данные.Наименование) Тогда
		
		НаименованиеСценария = Данные.Наименование;
		
	Иначе
		
		Если Данные.НаОсновеЭлектронногоРесурса Тогда
			НаименованиеСценария = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Данные.ЭлектронныйРесурс, "Наименование");
		ИначеЕсли Данные.НаОсновеМероприятия Тогда
			НаименованиеСценария = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Данные.Мероприятие, "Наименование");
		Иначе
			НаименованиеСценария = НСтр("ru = 'Обучение'");
		КонецЕсли;		
		
	КонецЕсли;
	
	Представление = Строка(НаименованиеСценария);
	
КонецПроцедуры

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		
		Если Параметры.Свойство("Ключ") Тогда
			Возврат;
		КонецЕсли;
		
		Если Параметры.Свойство("ЗначениеКопирования") Тогда
			Возврат;
		КонецЕсли;			
		
		ПоказатьФормуСоздания = Истина;
		
		Если Параметры.Свойство("ЗначенияЗаполнения")
			И (Параметры.ЗначенияЗаполнения.Свойство("БезСценария")
			ИЛИ Параметры.ЗначенияЗаполнения.Свойство("НаОсновеМероприятия")
			ИЛИ Параметры.ЗначенияЗаполнения.Свойство("НаОсновеЭлектронногоРесурса"))
			ИЛИ ПолучитьФункциональнуюОпцию("ОбразовательнаяОрганизацияОО")
			ИЛИ ПолучитьФункциональнуюОпцию("ЭкзаменаторЭР") Тогда
			
			ПоказатьФормуСоздания = Ложь;
			
		КонецЕсли;
		
		Если Параметры.Свойство("Основание") Тогда
			ПоказатьФормуСоздания = Ложь;
		КонецЕсли;
			
		Если ПоказатьФормуСоздания Тогда
			
			СтандартнаяОбработка = Ложь;
			
			ВыбраннаяФорма = "ФормаСоздания";
			
		КонецЕсли;
		
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
	
#КонецЕсли


#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
			
	СформироватьТаблицуАвтоматическихРассылок();
	
	СформироватьКомандыСоздания();

	Если ЗначениеЗаполнено(Параметры.ПроведениеОбучения) Тогда
		Сообщения.Параметры.УстановитьЗначениеПараметра("ПроведениеОбучения", Параметры.ПроведениеОбучения);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ПроведениеПрограммыОбучения) Тогда
		Сообщения.Параметры.УстановитьЗначениеПараметра("ПроведениеПрограммыОбучения", Параметры.ПроведениеПрограммыОбучения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановитьДоступностьКомандСоздания();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыАвтоматическиеПравила

// ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЦЫ ФОРМЫ АвтоматическиеПравила

&НаКлиенте
Процедура АвтоматическиеПравилаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗакрытияПодчиненногоОкна", ЭтотОбъект);
	Если Поле.Имя = Элементы.АвтоматическиеПравилаШаблон.Имя Тогда
		ПоказатьЗначение(ОписаниеОповещения, Элемент.ТекущиеДанные.Шаблон);
	Иначе
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Ключ", Элемент.ТекущиеДанные.КлючЗаписи);
		ПараметрыФормы.Вставить("ТолькоПросмотр", Элемент.ТекущиеДанные.ТолькоПросмотр);
		ПараметрыФормы.Вставить("ТолькоПросмотрУсловийПрименения", Истина);
		ОткрытьФорму("РегистрСведений.АвтоматическиеРассылкиСУО.ФормаЗаписи", ПараметрыФормы, ЭтотОбъект,,,,ОписаниеОповещения);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияПодчиненногоОкна(ЗначениеЗакрытия, ДополнительныеПараметры) Экспорт
	СформироватьТаблицуАвтоматическихРассылок();
	УстановитьДоступностьКомандСоздания();
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Процедура СформироватьТаблицуАвтоматическихРассылок()
	
	АвтоматическиеПравила.Очистить();
	
	// Формируем массив организаторов
	
	Организаторы = Новый Массив;
		
	Справочники.ОрганизаторыСУО.ОрганизаторыЭлемента(Параметры.ПроведениеОбучения, Организаторы);
	Справочники.ОрганизаторыСУО.ОрганизаторыЭлемента(Параметры.ПроведениеПрограммыОбучения, Организаторы);
	
	Если Организаторы.Найти(Справочники.ОрганизаторыСУО.ПустаяСсылка()) = Неопределено Тогда		
		Организаторы.Добавить(Справочники.ОрганизаторыСУО.ПустаяСсылка()); // Чтобы искать правила без организатора
	КонецЕсли;	
	
	// Формируем массив отборов
	
	ОтборыПользователей = Справочники.ОтборыПользователейСУО.ВсеОтборы();
	Если ОтборыПользователей.Найти(Справочники.ОтборыПользователейСУО.ПустаяСсылка()) = Неопределено Тогда
		ОтборыПользователей.Добавить(Справочники.ОтборыПользователейСУО.ПустаяСсылка()); // Для поиска без отбора
	КонецЕсли;	
	
	// Рассылки проведений обучения
	
	Если ЗначениеЗаполнено(Параметры.ПроведениеОбучения) Тогда
		
		МассивТипов = Новый Массив;
		Перечисления.ТипыАвтоматическихРассылокСУО.ДобавитьТипыПроведенийОбучения(МассивТипов);
		
		СценарийОбучения = Документы.ПроведениеОбученияСУО.СценарийОбучения(Параметры.ПроведениеОбучения);
		ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(Параметры.ПроведениеОбучения, СценарийОбучения);
		Мероприятие = ?(ТипЗнч(СценарийОбучения) = Тип("СправочникСсылка.КаталогМероприятийСУО"), СценарийОбучения, Неопределено);
		
		Для каждого ТипРассылки Из МассивТипов Цикл
			
			ДанныеРассылки = РегистрыСведений.АвтоматическиеРассылкиСУО.АвтоматическаяРассылка(
				ТипРассылки, ВидОбучения, Мероприятие,, Параметры.ПроведениеОбучения, Организаторы, ОтборыПользователей);  	
			
			Если ДанныеРассылки = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока = АвтоматическиеПравила.Добавить();
			НоваяСтрока.Тип = ТипРассылки;
			НоваяСтрока.Шаблон = ДанныеРассылки.Шаблон;
			НоваяСтрока.ТолькоЭлектроннаяПочта = ДанныеРассылки.ТолькоЭлектроннаяПочта;
			НоваяСтрока.КлючЗаписи = ДанныеРассылки.КлючЗаписи;
			НоваяСтрока.ИмяТипа = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ТипРассылки); 
			
			Если ЗначениеЗаполнено(ДанныеРассылки.КлючЗаписи.ПроведениеОбучения) Тогда
				НоваяСтрока.Действует = НСтр("ru = 'Только на это обучение'");
				НоваяСтрока.ТолькоПросмотр = Ложь;				
				НоваяСтрока.ДоступноСоздание = Ложь;
			ИначеЕсли ЗначениеЗаполнено(ДанныеРассылки.КлючЗаписи.Мероприятие) Тогда
				НоваяСтрока.Действует = НСтр("ru = 'На все обучения этого шаблона'");
				НоваяСтрока.ТолькоПросмотр = Истина;
				НоваяСтрока.ДоступноСоздание = Истина;
			ИначеЕсли ЗначениеЗаполнено(ДанныеРассылки.КлючЗаписи.ВидМероприятия) Тогда
				НоваяСтрока.Действует = НСтр("ru = 'На все обучения данного вида'");
				НоваяСтрока.ТолькоПросмотр = Истина;
				НоваяСтрока.ДоступноСоздание = Истина;
			Иначе
				НоваяСтрока.Действует = НСтр("ru = 'На все обучения'");				
				НоваяСтрока.ТолькоПросмотр = Истина;
				НоваяСтрока.ДоступноСоздание = Истина;
			КонецЕсли;			
						
		КонецЦикла;
		
	КонецЕсли;
	
	// Рассылки программ обучения
	
	Если ЗначениеЗаполнено(Параметры.ПроведениеПрограммыОбучения) Тогда
		
		МассивТипов = Новый Массив;
		Перечисления.ТипыАвтоматическихРассылокСУО.ДобавитьТипыПрограммОбучения(МассивТипов);
		
		ПрограммаОбучения = Документы.ПроведениеПрограммыОбученияСУО.ПрограммаОбучения(Параметры.ПроведениеПрограммыОбучения);
		
		Для каждого ТипРассылки Из МассивТипов Цикл
			
			ДанныеРассылки = РегистрыСведений.АвтоматическиеРассылкиСУО.АвтоматическаяРассылка(
				ТипРассылки,,,ПрограммаОбучения, Параметры.ПроведениеПрограммыОбучения, Организаторы, ОтборыПользователей,,Параметры.ПроведениеПрограммыОбучения);
								
			Если ДанныеРассылки = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока = АвтоматическиеПравила.Добавить();
			НоваяСтрока.Тип = ТипРассылки;
			НоваяСтрока.Шаблон = ДанныеРассылки.Шаблон;
			НоваяСтрока.ТолькоЭлектроннаяПочта = ДанныеРассылки.ТолькоЭлектроннаяПочта;
			НоваяСтрока.КлючЗаписи = ДанныеРассылки.КлючЗаписи;
			НоваяСтрока.ИмяТипа = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ТипРассылки); 

			Если ЗначениеЗаполнено(ДанныеРассылки.КлючЗаписи.ПроведениеПрограммыОбучения) Тогда
				НоваяСтрока.Действует = НСтр("ru = 'Только на эту программу обучения'");
				НоваяСтрока.ТолькоПросмотр = Ложь;
				НоваяСтрока.ДоступноСоздание = Ложь;
			ИначеЕсли ЗначениеЗаполнено(ДанныеРассылки.КлючЗаписи.ПрограммаОбучения) Тогда
				НоваяСтрока.Действует = НСтр("ru = 'На все программы обучения этого шаблона'");
				НоваяСтрока.ТолькоПросмотр = Истина;
				НоваяСтрока.ДоступноСоздание = Истина;
			Иначе
				НоваяСтрока.Действует = НСтр("ru = 'На все программы обучения'");
				НоваяСтрока.ТолькоПросмотр = Истина;
				НоваяСтрока.ДоступноСоздание = Истина;
			КонецЕсли;			
			
		КонецЦикла;		
		
	КонецЕсли;	
	
	// Получаем рассылки отборов
	
КонецПроцедуры

&НаСервере
Процедура СформироватьКомандыСоздания()	
	
	МассивТипов = Новый Массив;
	
	Если ЗначениеЗаполнено(Параметры.ПроведениеОбучения) Тогда
		Перечисления.ТипыАвтоматическихРассылокСУО.ДобавитьТипыПроведенийОбучения(МассивТипов);
	КонецЕсли;
	Если ЗначениеЗаполнено(Параметры.ПроведениеПрограммыОбучения) Тогда
		Перечисления.ТипыАвтоматическихРассылокСУО.ДобавитьТипыПрограммОбучения(МассивТипов);
	КонецЕсли;
	
	СписокВыбора = Перечисления.ТипыАвтоматическихРассылокСУО.СписокВыбора();
	Если СписокВыбора <> Неопределено Тогда
		МассивВычитания = Новый Массив;
		Для каждого ТипРассылки Из МассивТипов Цикл
			Если СписокВыбора.НайтиПоЗначению(ТипРассылки) = Неопределено Тогда
				МассивВычитания.Добавить(ТипРассылки);
			КонецЕсли;
		КонецЦикла;
		МассивТипов = ОбщегоНазначенияКлиентСервер.СократитьМассив(МассивТипов, МассивВычитания);
	КонецЕсли;
	
	// Формируем команды создания
	
	Для каждого ТипРассылки Из МассивТипов Цикл
		
		ИмяПеречисления = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ТипРассылки);
		ИмяЭлемента = "Создать_" + ИмяПеречисления;
		
		Команда = Команды.Добавить(ИмяЭлемента);
		Команда.Действие  = "Подключаемый_СоздатьАвтоматическуюРассылкуПоТипу";
		Команда.Заголовок = Строка(ТипРассылки);

		ЭлементФормы = Элементы.Добавить(ИмяЭлемента, Тип("КнопкаФормы"), Элементы.АвтоматическиеПравилаКомандыСоздания); 	
		ЭлементФормы.ИмяКоманды = ИмяЭлемента;			
	
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступностьКомандСоздания()
	
	Для каждого Строка Из АвтоматическиеПравила Цикл
		ИмяЭлемента = "Создать_" + Строка.ИмяТипа;
		Если Элементы.Найти(ИмяЭлемента) <> Неопределено Тогда
			Элементы[ИмяЭлемента].Доступность = Строка.ДоступноСоздание;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_СоздатьАвтоматическуюРассылкуПоТипу(Команда)
	
	Если Команда = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяТипа = СтрЗаменить(Команда.Имя, "Создать_", "");
	ТипРассылки = ПредопределенноеЗначение("Перечисление.ТипыАвтоматическихРассылокСУО." + ИмяТипа);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗакрытияПодчиненногоОкна", ЭтотОбъект);
	
	ЗначенияЗаполнения = Новый Структура;
	ЗначенияЗаполнения.Вставить("Тип", ТипРассылки);
	Если ЗначениеЗаполнено(Параметры.ПроведениеОбучения) Тогда
		ЗначенияЗаполнения.Вставить("ПроведениеОбучения", Параметры.ПроведениеОбучения);
	КонецЕсли;
	Если ЗначениеЗаполнено(Параметры.ПроведениеПрограммыОбучения) Тогда
		ЗначенияЗаполнения.Вставить("ПроведениеПрограммыОбучения", Параметры.ПроведениеПрограммыОбучения);
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	ПараметрыФормы.Вставить("ТолькоПросмотрУсловийПрименения", Истина);
	ОткрытьФорму("РегистрСведений.АвтоматическиеРассылкиСУО.ФормаЗаписи", ПараметрыФормы, ЭтотОбъект,,,,ОписаниеОповещения);	
	
КонецПроцедуры


#КонецОбласти


&НаСервереБезКонтекста
Функция УдалитьДополнительныйМатериал(Знач Период, Знач ЭлементСодержания)
	
	РегистрыСведений.ДополнительныеМатериалыПользователейСУЗ.УдалитьМатериал(Период, ЭлементСодержания);
	
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьНастройкиДополнительногоМатериала(Знач Период, Знач ЭлементСодержания, Знач Общий=Неопределено)
	
	НаборЗаписей = РегистрыСведений.ДополнительныеМатериалыПользователейСУЗ.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Период.Установить(Период);
	НаборЗаписей.Отбор.ЭлементСодержания.Установить(ЭлементСодержания);

	НаборЗаписей.Прочитать();
	
	Запись = НаборЗаписей[0]; // Всегда есть одна запись
	
	Если Общий <> Неопределено Тогда
		Запись.Общий = Общий;
	КонецЕсли;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Определяем недостающие параметры или переопределяем их при необходимости
	//
	
	Если НЕ ЗначениеЗаполнено(Параметры.СводЗнаний)
		И ТипЗнч(Параметры.АдресОбъекта) = Тип("СправочникСсылка.СодержаниеСУЗ") Тогда
		
		Параметры.СводЗнаний = Параметры.АдресОбъекта.Владелец;
		
	КонецЕсли;
	
	Если Параметры.ПрохождениеОбучения = Неопределено Тогда
		Параметры.ПрохождениеОбучения = Метаданные.ОпределяемыеТипы.ПрохождениеЭлектронногоОбучения.Тип.ПривестиЗначение(Параметры.ПрохождениеОбучения);
	КонецЕсли;		
	
	Если Параметры.Задание = Неопределено Тогда
		Параметры.Задание = Метаданные.ОпределяемыеТипы.ЗаданиеЭлектронногоОбучения.Тип.ПривестиЗначение(Параметры.Задание);
	КонецЕсли;
	
	Если Параметры.Вариант = Неопределено Тогда
		Параметры.Вариант = Метаданные.ОпределяемыеТипы.ВариантЗаданияЭлектронногоОбучения.Тип.ПривестиЗначение(Параметры.Вариант);
	КонецЕсли;	        	
	
	// Проверяем корректность параметров формы.
	//
	
	Если НЕ ЗначениеЗаполнено(Параметры.Задание)
		И ЗначениеЗаполнено(Параметры.ПрохождениеОбучения) Тогда
		
		ВызватьИсключение НСтр("ru = 'Задание прохождения обучения не задано'");
		
	КонецЕсли;			
	
	Если (ЗначениеЗаполнено(Параметры.СводЗнаний)
		И Параметры.СводЗнаний.ЭтоГруппа)
		ИЛИ (
		ЗначениеЗаполнено(Параметры.АдресОбъекта)
		И ТипЗнч(Параметры.АдресОбъекта) <> Тип("Строка")
		И Параметры.АдресОбъекта.ЭтоГруппа
		) Тогда
		
		Отказ = Истина;
		Текст = НСтр("ru = 'Выберите элемент справочника для просмотра'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
		Возврат;
		
	КонецЕсли;
	
	Если Параметры.РежимПросмотра И НЕ ЗначениеЗаполнено(Параметры.ПрохождениеОбучения) Тогда
		
		Отказ = Истина;
		Текст = НСтр("ru = 'Электронный курс/тест не может быть открыт в режиме просмотра без привязки к проведению обучения'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
		Возврат;
		
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Параметры.СводЗнаний) И НЕ ЗначениеЗаполнено(Параметры.АдресОбъекта) Тогда
		
		Отказ = Истина;
		Текст = НСтр("ru = 'Не задан объект для открытия'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
		Возврат;
		
	КонецЕсли;
		
	// Проверяем тип электронного ресурса.
	//
	
	Если ЗначениеЗаполнено(Параметры.СводЗнаний) Тогда
		
		Если НЕ СтандартныеПодсистемыСервер.ЭтоБазоваяВерсияКонфигурации()
			И Параметры.СводЗнаний.Базовый Тогда
			
			Отказ = Истина;
			Текст = НСтр("ru = 'Электронный курс/тест не может быть просмотрен в этой конфигурации'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Получаем необходимые реквизиты формы и устанавливаем нужные параметры.
	//
	
	ТекущийПользовательСеанса = Пользователи.ТекущийПользователь(); 
	
	Если ЗначениеЗаполнено(Параметры.ТекущийПользователь) Тогда
		ТекущийПользователь = Параметры.ТекущийПользователь;
	Иначе
		ТекущийПользователь = ТекущийПользовательСеанса;
	КонецЕсли;
	
	
	Если ЗначениеЗаполнено(Параметры.ПрохождениеОбучения) Тогда
		
		ПользовательПрохожденияОбучения = ТекущийПользователь;
		ЭлектронныеРесурсыПереопределяемый.ПользовательОбучения(ПользовательПрохожденияОбучения, Параметры.ПрохождениеОбучения);
		
		Если ТекущийПользователь <> ПользовательПрохожденияОбучения Тогда		
			Параметры.РежимПросмотра = Истина;			
		КонецЕсли;
		
		// Проверяем противоречия между личным кабинетом и веб-кабинетом
		
		ЕстьПопыткиПрохожденияИзЛичногоКабинета = РегистрыСведений.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ЕстьПопыткиПрохожденияИзЛичногоКабинета(ПользовательПрохожденияОбучения, Параметры.ПрохождениеОбучения, Параметры.Задание);
		ЕстьПопыткиПрохожденияИзВебКабинета = ЗначениеЗаполнено(Документы.СессияЭлектронногоРесурсаСУЗ.КорневаяСессияПрохожденияЭлектронногоКурса(ПользовательПрохожденияОбучения, Параметры.ПрохождениеОбучения, Параметры.СводЗнаний, Параметры.Задание));

		Если ЕстьПопыткиПрохожденияИзЛичногоКабинета
			И ЕстьПопыткиПрохожденияИзВебКабинета Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Данный электронный курс/тест ранее изучался через веб-кабинет. Результаты этого изучения показать здесь нельзя, их просмотр доступен только через веб-кабинет'"));
			
		КонецЕсли;
		
		Если НЕ ЕстьПопыткиПрохожденияИзЛичногоКабинета
			И ЕстьПопыткиПрохожденияИзВебКабинета Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Используйте веб-кабинет для открытия электронного курса или теста'"),,,,Отказ);
			
		КонецЕсли;				
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.СводЗнаний) Тогда
		СправочнаяИнформация = Параметры.СводЗнаний.СправочнаяИнформация;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.СводЗнаний) Тогда
		Глоссарий = Параметры.СводЗнаний.Глоссарий;
	КонецЕсли;
	
	ЕстьПравоИзмененияОбщихДополнительныхМатериалов = ПравоДоступа("Редактирование", Метаданные.РегистрыСведений.ДополнительныеМатериалыПользователейСУЗ);
	НастройкиПредыдущегоПрохождения                 = ПолучитьНастройкиПредыдущегоПрохождения(ТекущийПользователь);
	
	ЗаполнитьТаблицуНастроекЭР(НастройкиПредыдущегоПрохождения.ЗначенияНастроекЭР, ТекущийПользователь);
	
	ЗавершеноВПроцентах = -1;
	
	ОбластьПросмотраЗагружена = Ложь;
	
	ИдентификаторВладельца = Справочники.СводыЗнанийСУЗ.ИдентификаторКаталога(Параметры.СводЗнаний);
	
	Если ЗначениеЗаполнено(Параметры.СводЗнаний) Тогда
		
		Если Параметры.СводЗнаний.ПоказыватьПоследнююВерсию Тогда
			ПредпочитаемыйПоставщик = Параметры.СводЗнаний.ПредпочитатьПоставщика;
		Иначе
			ПредпочитаемыйПоставщик = Неопределено;
		КонецЕсли;
		
	Иначе
		
		ПредпочитаемыйПоставщик = Неопределено; // Именно Неопределено, а не пустая ссылка.
		
	КонецЕсли;
	
	ИмяКаталогаРесурсов      = "res_" + ИдентификаторВладельца;
	ИспользуетсяКэшНаКлиенте = ПараметрыСеанса.ИспользуетсяЛокальныйКэшНаКлиентеСУЗ;
	
	АдресОбщегоКаталога      = ОбъектыСУзПовтИсп.АдресКаталогаОбъектов();
	ПутьКОбщемуКаталогу      = ОбъектыСУЗПовтИсп.ПутьКаталогуОбъектов();
	
	Если НЕ ЗначениеЗаполнено(АдресОбщегоКаталога)
		ИЛИ НЕ ЗначениеЗаполнено(ПутьКОбщемуКаталогу) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОбщегоНазначенияСУПовтИсп.ТекстОНеобходимостиНастроитьОбщийКаталог(),,,,Отказ);
		Возврат;		
		
	КонецЕсли;	
	
	АдресКаталогаРесурсов    = ОбщегоНазначенияСУКлиентСервер.ПривестиСлэши(АдресОбщегоКаталога + ИмяКаталогаРесурсов);
	АдресКаталогаРесурсов    = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(АдресКаталогаРесурсов);	
	
	ПутьККаталогуРесурсов    = ОбъектыСУЗПовтИсп.ПутьКаталогуОбъектов() + ИмяКаталогаРесурсов;
	ПутьККаталогуРесурсов    = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьККаталогуРесурсов);
	
	Если ЗначениеЗаполнено(Параметры.СводЗнаний) Тогда
		ПоследовательнаяНавигация = Параметры.СводЗнаний.ПоследовательнаяНавигация;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ЭлементСодержания) Тогда
		ТекущийЭлементСодержания = Параметры.ЭлементСодержания;
	Иначе
		ТекущийЭлементСодержания = НастройкиПредыдущегоПрохождения.ПоследнийЭлементСодержания;
	КонецЕсли;
	
	Комментарий                  = НастройкиПредыдущегоПрохождения.Комментарий;
	ГруппаОбщиеРесурсы           = Справочники.РесурсыСУЗ.Общие;
	ГруппаОбщиеСтраницы          = Справочники.СтраницыСУЗ.Общие;
	ПрохождениеОбучения          = Параметры.ПрохождениеОбучения;
		
	// Формируем таблицу зависимых ресурсов
	
    Если ЗначениеЗаполнено(Параметры.СводЗнаний) Тогда
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СкрытыеРесурсы.Ресурс,
			|	СкрытыеРесурсы.Размер
			|ИЗ
			|	Справочник.СводыЗнанийСУЗ.СкрытыеРесурсы КАК СкрытыеРесурсы
			|ГДЕ
			|	СкрытыеРесурсы.Ссылка = &ЭлектронныйРесурс
			|	И СкрытыеРесурсы.ВыгружатьПриОткрытии = ИСТИНА";

		Запрос.УстановитьПараметр("ЭлектронныйРесурс", Параметры.СводЗнаний);

		Результат = Запрос.Выполнить();

		ЗначениеВРеквизитФормы(Результат.Выгрузить(), "ЗависимыеРесурсы");

	КонецЕсли;
	
	// Заполняем навигационное дерево
	//
	
	// Получаем выгрузку элементов содержания
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СодержаниеСУЗ.Ссылка КАК Ссылка,
		|	СодержаниеСУЗ.СсылкаНаЭлемент КАК СсылкаНаЭлемент,
		|	СодержаниеСУЗ.Наименование КАК Наименование,
		|	СодержаниеСУЗ.ЭтоГруппа,
		|	СодержаниеСУЗ.Родитель КАК Группа
		|ИЗ
		|	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
		|ГДЕ
		|	СодержаниеСУЗ.Владелец = &ЭлектронныйРесурс
		|	И СодержаниеСУЗ.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	СодержаниеСУЗ.Код ИЕРАРХИЯ,
		|	Наименование ИЕРАРХИЯ";

	Запрос.УстановитьПараметр("ЭлектронныйРесурс", Параметры.СводЗнаний);

	Результат = Запрос.Выполнить();

	ДеревоСодержанияВыгрузка = Результат.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	// Получаем избранное пользователя

	ТаблицаИзбранное = РегистрыСведений.ИзбранноеПользователейСУЗ.ТаблицаИзбранного(ТекущийПользователь);
	
	// Получаем дополнительные материалы пользователя

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ДополнительныеМатериалыПользователейСУЗСрезПоследних.ЭлементСодержания
		|ИЗ
		|	РегистрСведений.ДополнительныеМатериалыПользователейСУЗ.СрезПоследних(
		|			,
		|			Общий = ИСТИНА
		|					И НЕ &ПоказыватьПослеПроверки
		|				ИЛИ Общий = ИСТИНА
		|					И Проверено = ИСТИНА
		|					И &ПоказыватьПослеПроверки
		|				ИЛИ Автор = &ТекущийПользователь) КАК ДополнительныеМатериалыПользователейСУЗСрезПоследних";

	Запрос.УстановитьПараметр("ПоказыватьПослеПроверки", Константы.ПоказыватьОбщиеДополнительныеМатериалыПослеПроверкиСУЗ.Получить());
	Запрос.УстановитьПараметр("ТекущийПользователь", ТекущийПользователь);

	Результат = Запрос.Выполнить();

	ТаблицаДопМатериалы = Результат.Выгрузить();

	// Получаем данные о прохождении
	
	ПользовательПрохождения = ТекущийПользовательПрохождения(Параметры.РежимПросмотра, Параметры.ПрохождениеОбучения, ТекущийПользователь);
	
	ТаблицаПрохождений = РегистрыСведений.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ПопыткиПрохождения(
		ПользовательПрохождения, Параметры.ПрохождениеОбучения, Параметры.Задание, Параметры.СводЗнаний);  
	
	// Формируем итоговое дерево содержания и выводим его в форму	
	
	ДеревоСодержания = Новый ДеревоЗначений();
	
	ДеревоСодержания.Колонки.Добавить("Ссылка");
	ДеревоСодержания.Колонки.Добавить("СсылкаНаЭлемент");
	ДеревоСодержания.Колонки.Добавить("Наименование");
	ДеревоСодержания.Колонки.Добавить("ЭтоГруппа");
	ДеревоСодержания.Колонки.Добавить("КартинкаДополнительногоМатериала");
	ДеревоСодержания.Колонки.Добавить("Картинка");
	ДеревоСодержания.Колонки.Добавить("Пройдено");
    ДеревоСодержания.Колонки.Добавить("Отмечено");
	ДеревоСодержания.Колонки.Добавить("ЭтоКорень");
	
	КореньДереваСодержания = ДеревоСодержания.Строки.Добавить();
	КореньДереваСодержания.Ссылка = Параметры.СводЗнаний;
	КореньДереваСодержания.СсылкаНаЭлемент = Параметры.СводЗнаний;
	КореньДереваСодержания.Наименование = НСтр("ru = 'Начало'");
	КореньДереваСодержания.КартинкаДополнительногоМатериала = 1;
	КореньДереваСодержания.ЭтоКорень = Истина;
	КореньДереваСодержания.Отмечено = Ложь;
	КореньДереваСодержания.Пройдено = Истина;
	
	ИндексСтрокиДС = 0;
	
	НоваяСтрокаАЭС = АдресаЭлементовСодержания.Добавить();
	НоваяСтрокаАЭС.Адрес = ОбъектыСУЗПовтИсп.СсылкаНаОбъектСУЗ(Параметры.СводЗнаний);
    НоваяСтрокаАЭС.ЭлементСодержания = Справочники.СодержаниеСУЗ.ПустаяСсылка();
	НоваяСтрокаАЭС.Индекс = ИндексСтрокиДС;
	
	ПовторныеПрохождения = РегистрыСведений.ПовторноеПрохождениеЭлектронныхРесурсовСУЗ.ПовторныеПрохождения(ПользовательПрохождения, Параметры.ПрохождениеОбучения, Параметры.Задание); 
	
	ДобавитьЭлементыСодержанияВДерево(КореньДереваСодержания.Строки, ДеревоСодержанияВыгрузка.Строки, ТаблицаИзбранное, ТаблицаДопМатериалы, ТаблицаПрохождений,, ИндексСтрокиДС, ПовторныеПрохождения);
	
	Для каждого Строка Из КореньДереваСодержания.Строки Цикл
	
		Если НЕ Строка.Пройдено Тогда
			КореньДереваСодержания.Пройдено = Ложь;
			Прервать;
		КонецЕсли;
	
	КонецЦикла;
	
	КореньДереваСодержания.Картинка = ПолучитьКартинкуЭлементаСодержания(КореньДереваСодержания, Параметры.ПрохождениеОбучения); // Книга
	
	ЗначениеВРеквизитФормы(ДеревоСодержания, "НавигационноеДерево");
	
	// Ищем попытку выполнения статичного объекта, которая могла остаться при аварийном завершении программы
    //
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПопыткаВыполненияСтатичногоОбъектаСУЗ.Ссылка
		|ИЗ
		|	Документ.ПопыткаВыполненияСтатичногоОбъектаСУЗ КАК ПопыткаВыполненияСтатичногоОбъектаСУЗ
		|ГДЕ
		|	ПопыткаВыполненияСтатичногоОбъектаСУЗ.ПрохождениеОбучения = &ПрохождениеОбучения
		|	И ПопыткаВыполненияСтатичногоОбъектаСУЗ.Задание = &Задание
		|	И ПопыткаВыполненияСтатичногоОбъектаСУЗ.СводЗнаний = &СводЗнаний
		|	И ПопыткаВыполненияСтатичногоОбъектаСУЗ.Пользователь = &Пользователь
		|	И ПопыткаВыполненияСтатичногоОбъектаСУЗ.ПопыткаЗавершена = ЛОЖЬ
		|	И ПопыткаВыполненияСтатичногоОбъектаСУЗ.ПометкаУдаления = ЛОЖЬ
		|	И ПопыткаВыполненияСтатичногоОбъектаСУЗ.Отменено = ЛОЖЬ";

	Запрос.УстановитьПараметр("Задание", Параметры.Задание);
	Запрос.УстановитьПараметр("Пользователь", ТекущийПользовательПрохождения(Параметры.РежимПросмотра, Параметры.ПрохождениеОбучения, ТекущийПользователь));
	Запрос.УстановитьПараметр("ПрохождениеОбучения", Параметры.ПрохождениеОбучения);
	Запрос.УстановитьПараметр("СводЗнаний", Параметры.СводЗнаний);
	
	Результат = Запрос.Выполнить();

	Если НЕ Результат.Пустой() Тогда
		
		ВыборкаДетальныеЗаписи = Результат.Выбрать();

		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ОбъектыСУЗ.ЗавершитьПопыткуВыполненияСтатичногоОбъекта(ВыборкаДетальныеЗаписи.Ссылка);
		КонецЦикла;
		
	КонецЕсли;
	
	// Выгружаем общий ресурс в каталог ресурсов свода знаний на сервере.
	//
	
	Если НЕ ИспользуетсяКэшНаКлиенте Тогда
		
		ОбщегоНазначенияСУКлиентСервер.ВыгрузитьОбщийРесурсВКэш(ПутьКОбщемуКаталогу, ИмяКаталогаРесурсов, ПредпочитаемыйПоставщик);
		
		Если ЗависимыеРесурсы.Количество() > 0 Тогда
			
			МассивРесурсовДляВыгрузки = Новый Массив();
			
			Для каждого Строка Из ЗависимыеРесурсы Цикл
				МассивРесурсовДляВыгрузки.Добавить(ОбъектыСУЗ.ПолучитьСтруктуруРесурса(Строка.Ресурс));
			КонецЦикла;
			
			ОбщегоНазначенияСУКлиентСервер.ВыгрузитьРесурсыВКэш(МассивРесурсовДляВыгрузки, ПутьККаталогуРесурсов, ПредпочитаемыйПоставщик, Параметры.СводЗнаний);
			
		КонецЕсли;
			
	КонецЕсли;
	
	// Устанавливаем заголовок по умолчанию для формы.
	//
	
	Если ЗначениеЗаполнено(Параметры.Заголовок) Тогда
		
		ЗаголовокПоУмолчанию = Параметры.Заголовок;
		
	Иначе
	
		Если ЗначениеЗаполнено(Параметры.СводЗнаний) Тогда
			
			Если ЗначениеЗаполнено(Параметры.АдресОбъекта)
				И ТипЗнч(Параметры.АдресОбъекта) <> Тип("Строка") Тогда
				ЗаголовокПоУмолчанию = Параметры.СводЗнаний.Наименование + " (" + Параметры.АдресОбъекта.Наименование + ")";
			Иначе
				ЗаголовокПоУмолчанию = Параметры.СводЗнаний.Наименование;
			КонецЕсли;
			
		Иначе
			
			Если ЗначениеЗаполнено(Параметры.АдресОбъекта)
				И ТипЗнч(Параметры.АдресОбъекта) <> Тип("Строка") Тогда
				
				ЗаголовокПоУмолчанию = "Просмотр " + """" + Параметры.АдресОбъекта.Наименование + """";
				
			Иначе
				
				ЗаголовокПоУмолчанию = "Просмотр элемента";
				
			КонецЕсли;		
				
		КонецЕсли;
		
	КонецЕсли;
		
	// Загружаем из настроек сохраняемые реквизиты.
	//
	
	ДанныеНастроек = ХранилищеСистемныхНастроек.Загрузить(ЭтотОбъект.ИмяФормы+"/ТекущиеДанные");
	
	Если ДанныеНастроек <> Неопределено Тогда
		ДополнительныеМатериалыВидны = ДанныеНастроек.Получить("ДополнительныеМатериалыВидны");
	КонецЕсли;
	
	// Устанавливаем начальное состояние элементов формы.
	//
	
	НавигацияДоступна = Истина;
	
	УстановитьДоступностьЭлементовФормыНаСервере(НастройкиПредыдущегоПрохождения);
	
	ДатаОткрытияФормы = ТекущаяДата();	
	
	ЭлектронныеРесурсыПереопределяемый.ПриПросмотреЭлектронногоРесурса(Параметры.СводЗнаний, Параметры.ПрохождениеОбучения, Параметры.Задание);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	#Если ВебКлиент Тогда
	Если НРег(Лев(АдресКаталогаРесурсов, СтрДлина("http"))) = "http" Тогда
		АдресКаталогаРесурсовСтруктура = ОбщегоНазначенияКлиентСервер.СтруктураURI(АдресКаталогаРесурсов);
		АдресКаталогаРесурсов = "/" + АдресКаталогаРесурсовСтруктура.ПутьНаСервере;
	КонецЕсли;
	#КонецЕсли
	
	УстановитьЗаголовокФормы();
	
	// Выгружаем общий ресурс в каталог ресурсов свода знаний на клиенте.
	
	Если ИспользуетсяКэшНаКлиенте Тогда
		
		ОбщегоНазначенияСУКлиентСервер.ВыгрузитьОбщийРесурсВКэш(ПутьКОбщемуКаталогу, ИмяКаталогаРесурсов, ПредпочитаемыйПоставщик);
		
		Если ЗависимыеРесурсы.Количество() > 0 Тогда
			
			МассивРесурсовДляВыгрузки = Новый Массив();
			
			Для каждого Строка Из ЗависимыеРесурсы Цикл
				МассивРесурсовДляВыгрузки.Добавить(Новый Структура("Ресурс, Размер", Строка.Ресурс, Строка.Размер));	
			КонецЦикла;
			
			МассивРесурсовДляВыгрузки = Новый ФиксированныйМассив(МассивРесурсовДляВыгрузки);
			
			ОписаниеРесурсовДляВыгрузки = ПолучитьОписаниеРесурсовДляВыгрузки(МассивРесурсовДляВыгрузки);
			
			ОбщегоНазначенияСУКлиентСервер.ВыгрузитьРесурсыВКэш(ОписаниеРесурсовДляВыгрузки, ПутьККаталогуРесурсов, ПредпочитаемыйПоставщик, Параметры.СводЗнаний, Отказ);
			
		КонецЕсли;
		
		ПодключитьОбработчикОжидания("Подключаемый_ВыполнитьПроверкуОбщегоКаталога", 0.1, Истина);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.АдресОбъекта) Тогда
		
		Если ТипЗнч(Параметры.АдресОбъекта) = Тип("Строка") Тогда
			Адрес = Параметры.АдресОбъекта;
		Иначе
			Адрес = ОбъектыСУЗПовтИсп.СсылкаНаОбъектСУЗ(Параметры.АдресОбъекта);
		КонецЕсли;
		
		Адрес = ?(Лев(Адрес, 1) = "?", "", "?") + Адрес;
		
	ИначеЕсли ЗначениеЗаполнено(ТекущийЭлементСодержания) Тогда
		
		Адрес = ОбъектыСУЗПовтИсп.СсылкаНаОбъектСУЗ(ТекущийЭлементСодержания);
		
	Иначе
		
		Адрес = "";
		
	КонецЕсли;
	
	ПропуститьАктивациюЭлементаСодержания = Истина;
	
	УстановитьТекущийОбъект(Адрес);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы = Неопределено Тогда
		ЗавершениеРаботы = Ложь;
	КонецЕсли;
	
	Если ЗавершениеРаботы Тогда			
		Отказ = Истина;			
		ТекстПредупреждения = НСтр("ru = 'Изучение электронного курса будет прервано без сохранения последних результатов.
		|Перед выходом из программы закройте все открытые электронные курсы для сохранения данных об изучении.'");			
		Возврат;
	КонецЕсли;
	
	Если ВыполняетсяТестирование И ЗначениеЗаполнено(СессияТестирования) Тогда
		Отказ = Истина;
		СпроситьОЗакрытииСессииТестирования("Закрыть");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)

	Если ЗавершениеРаботы = Неопределено Тогда
		ЗавершениеРаботы = Ложь;
	КонецЕсли;
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	ВыполнитьДействияПриЗакрытии(ПопыткаВыполненияСтатичногоОбъекта,
	                             Параметры,
								 Комментарий,
								 ТекущийЭлементСодержания,
								 Элементы.НавигационноеДерево.Видимость,
								 ЗначенияНастроекЭР,
								 Параметры.РежимПросмотра,
								 ТекущийПользователь,
								 Параметры.ПрохождениеОбучения);
	
	Если ЗначениеЗаполнено(Параметры.ПрохождениеОбучения) Тогда
		Оповестить("ОбновитьПрохождениеОбучения", Параметры.ПрохождениеОбучения, ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаЗаписиНового(НовыйОбъект, Источник, СтандартнаяОбработка)
	
	Если НЕ ЗначениеЗаполнено(НовыйОбъект)
		ИЛИ ТипЗнч(НовыйОбъект) = Тип("РегистрСведенийКлючЗаписи.УчебныеБазыСУЗ") Тогда
		Возврат;
	КонецЕсли;
	
	НовыйЭлементИнформация = ЗаписатьДополнительныйМатериал(,,?(ЗначениеЗаполнено(ТекущийЭлементСодержания), ТекущийЭлементСодержания, Параметры.СводЗнаний), НовыйОбъект, ТекущийПользователь);
	
	НоваяСтрока = ДополнительныеМатериалы.Добавить();
	
	Для каждого Колонка Из КолонкиТаблицыДополнительныеМатериалы Цикл
//		Если НовыйЭлементИнформация.Свойство(Колонка) Тогда
			НоваяСтрока[Колонка] = НовыйЭлементИнформация[Колонка];
//		КонецЕсли;
	КонецЦикла;
	
	Элементы.НавигационноеДерево.ТекущиеДанные.КартинкаДополнительногоМатериала = 0;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОбъектСУЗЗаписан"
		И Источник <> ЭтотОбъект
		И ЗначениеЗаполнено(Параметр) Тогда
		
		// Оповещение срабатывает, когда был отредактирован
		// ОбъектСУЗ дополнительного материала и требуется обновить
		// Его наименование.
		
		ДополнительныйМатериалНайден = Ложь;
		
		Для каждого Строка Из ДополнительныеМатериалы Цикл
		
			Если Строка.СсылкаНаОбъектСУЗ = Параметр Тогда
				ДополнительныйМатериалНайден = Истина;
				Прервать;
			КонецЕсли;
		
		КонецЦикла;
		
		Если ДополнительныйМатериалНайден Тогда
			
			ДополнительныйМатериалИнформация = ЗаписатьДополнительныйМатериал(Строка.Дата, Строка.Автор, ?(ЗначениеЗаполнено(ТекущийЭлементСодержания), ТекущийЭлементСодержания, Параметры.СводЗнаний), Строка.СсылкаНаОбъектСУЗ, ТекущийПользователь);
			
			Если ДополнительныйМатериалИнформация <> Неопределено Тогда
				Строка.Наименование = ДополнительныйМатериалИнформация.Наименование;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ИмяСобытия = Строка("goToLink_" + Строка(УникальныйИдентификатор)) Тогда
		УстановитьТекущийОбъект(Параметр);
		Активизировать();
	КонецЕсли;
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ДЕЙСТВИЯ КОМАНД

// Навигация

&НаКлиенте
Процедура Назад(Команда)
	Элементы.ОбластьПросмотра.Назад();
КонецПроцедуры

&НаКлиенте
Процедура Вперед(Команда)
	Элементы.ОбластьПросмотра.Вперед();
КонецПроцедуры

&НаКлиенте
Процедура НавигацияВперед(Команда)
	ТекущийЭлементСодержания = СледующийЭлементСодержания;  // Сохраняем в реквизите
	ПропуститьАктивациюЭлементаСодержания = Истина;
	Если Элементы.НавигационноеДерево.Видимость Тогда
		Элементы.НавигационноеДерево.ТекущаяСтрока = ПолучитьИндексЭлементаСодержания(ТекущийЭлементСодержания);
	КонецЕсли;
	УстановитьТекущийОбъект(ТекущийЭлементСодержания);
КонецПроцедуры

&НаКлиенте
Процедура НавигацияНазад(Команда)
	ТекущийЭлементСодержания = ПредыдущийЭлементСодержания; // Сохраняем в реквизите
	ПропуститьАктивациюЭлементаСодержания = Истина;
	Если Элементы.НавигационноеДерево.Видимость Тогда
		Элементы.НавигационноеДерево.ТекущаяСтрока = ПолучитьИндексЭлементаСодержания(ТекущийЭлементСодержания);
	КонецЕсли;
	УстановитьТекущийОбъект(ТекущийЭлементСодержания);
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьСкрытьНавигационноеДерево(Команда)
	
	Если НЕ ВозможноОтобразитьСодержание Тогда
		Возврат;
	КонецЕсли;
	
	ПропуститьАктивациюЭлементаСодержания = Истина;
	АдресЗагруженногоОбъекта = "";
	
	Кнопка = Элементы.ПоказатьСкрытьНавигационноеДерево;
	
	Кнопка.Пометка = ?(Кнопка.Пометка, Ложь, Истина);
	Кнопка.ЦветФона = ?(Кнопка.Пометка, Новый Цвет(235, 231, 205), Новый Цвет(245, 242, 221));
	Элементы.НавигационноеДерево.Видимость = ?(Кнопка.Пометка, Истина, Ложь);
	Элементы.ДобавитьВИзбранное.Видимость = ?(Кнопка.Пометка, Истина, Ложь);

	Если Элементы.НавигационноеДерево.Видимость Тогда
		Элементы.НавигационноеДерево.ТекущаяСтрока = ПолучитьИндексЭлементаСодержания(ТекущийЭлементСодержания);
		ПропуститьФормированиеКорневогоДокумента = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВИзбранное(Команда)
	
	ДобавитьИлиУдалитьЭлементСодержанияВИзбранном(ТекущийЭлементСодержания, ТекущийПользователь);
	
	ТекущиеДанные          = Элементы.НавигационноеДерево.ТекущиеДанные; 
	ТекущиеДанные.Отмечено = НЕ ТекущиеДанные.Отмечено;
	ТекущиеДанные.Картинка = ПолучитьКартинкуЭлементаСодержания(ТекущиеДанные, Параметры.ПрохождениеОбучения)
	
КонецПроцедуры

&НаКлиенте
Процедура Комментарий(Команда)
	
	ПропуститьАктивациюЭлементаСодержания = Истина;
	ПропуститьФормированиеКорневогоДокумента = Истина;
	
	АдресЗагруженногоОбъекта = "";
	
	Кнопка = Элементы.КомандаКомментарий;
	Кнопка.Пометка  = ?(Кнопка.Пометка, Ложь, Истина);
	Кнопка.ЦветФона = ?(Кнопка.Пометка, Новый Цвет(235, 231, 205), Новый Цвет(245, 242, 221));
	
	Элементы.Комментарий.Видимость = ?(Кнопка.Пометка, Истина, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура СправочнаяИнформация(Команда)
	ОбъектыСУЗКлиент.ОткрытьОбозреватель(,СправочнаяИнформация,,,,,,Истина,,Параметры.ТекущийПользователь,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура Глоссарий(Команда)
	ОбъектыСУЗКлиент.ОткрытьОбозреватель(,Глоссарий,,,,,,Истина,,Параметры.ТекущийПользователь,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура Настройки(Команда)
	
	ПропуститьАктивациюЭлементаСодержания = Истина;
	ПропуститьФормированиеКорневогоДокумента = Истина;
	
	АдресЗагруженногоОбъекта = "";
	
	Кнопка = Элементы.КомандаНастройки;
	Кнопка.Пометка  = ?(Кнопка.Пометка, Ложь, Истина);
	Кнопка.ЦветФона = ?(Кнопка.Пометка, Новый Цвет(235, 231, 205), Новый Цвет(245, 242, 221));
	
	Элементы.ЗначенияНастроекЭР.Видимость = ?(Кнопка.Пометка, Истина, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолнотекстовыйПоиск(Команда)
	
	ПараметрыФормы = Новый Структура("ЭлектронныйРесурс_СУ, ФормаДляОповещения_СУ", Параметры.СводЗнаний, Строка(УникальныйИдентификатор));
	 
	РезультатПоиска = ОткрытьФорму("Обработка.ПолнотекстовыйПоискВДанных.Форма", ПараметрыФормы, ЭтотОбъект,,,,,РежимОткрытияОкнаФормы.Независимый);
	 
КонецПроцедуры

// Дополнительные материалы

&НаКлиенте
Процедура ДополнительныеМатериалы(Команда=Неопределено)
	
	ПропуститьАктивациюЭлементаСодержания = Истина;
	ПропуститьФормированиеКорневогоДокумента = Истина;
	
	АдресЗагруженногоОбъекта = "";
	
	Кнопка = Элементы.КомандаДополнительныеМатериалы;
	Кнопка.Пометка  = ?(Кнопка.Пометка, Ложь, Истина);
	Кнопка.ЦветФона = ?(Кнопка.Пометка, Новый Цвет(235, 231, 205), Новый Цвет(245, 242, 221));
	
	Элементы.ГруппаДополнительныеМатериалы.Видимость = ?(Кнопка.Пометка, Истина, Ложь);

	ДополнительныеМатериалыВидны = Элементы.ГруппаДополнительныеМатериалы.Видимость;
	
	ОтобразитьТекущийОбъект();
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСтраницуВДополнительныеМатериалы(Команда)
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", Новый Структура("Родитель", ГруппаОбщиеСтраницы));
	
	ОткрытьФорму("Справочник.СтраницыСУЗ.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьФайлВДополнительныеМатериалы(Команда)
	
	ПараметрыФормы = Новый Структура("РодительРесурса", ГруппаОбщиеРесурсы);
	ОткрытьФорму("Справочник.ФайлыСУЗ.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьЭлементДополнительныхМатериалов(Команда)
	
	ТекущиеДанные = Элементы.ДополнительныеМатериалы.ТекущиеДанные;
	
	Если НЕ ОбщегоНазначенияСУКлиент.ТекущиеДанныеТаблицыДоступны(ТекущиеДанные) Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.СсылкаНаОбъектСУЗ) Тогда
		ПоказатьЗначение(, ТекущиеДанные.СсылкаНаОбъектСУЗ);
	Иначе
		Оповещение = Новый ОписаниеОповещения("РедактироватьЭлементДополнительныхМатериаловПродолжение", ЭтотОбъект, Новый Структура("Дата, Автор", ТекущиеДанные.Дата, ТекущиеДанные.Автор));
		ПоказатьВводСтроки(Оповещение, ТекущиеДанные.Текст, НСтр("ru = 'Текст дополнительного материала'"), 0, Истина);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьЭлементДополнительныхМатериаловПродолжение(Текст, ДопПараметры) Экспорт
	
	Если Текст = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ДопПараметры.Автор <> ТекущийПользователь Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Запрещено редактировать общий материал другого автора'"));
	КонецЕсли;
	
	ДополнительныйМатериалНайден = Ложь;
		
	Для каждого Строка Из ДополнительныеМатериалы Цикл
	
		Если Строка.Дата = ДопПараметры.Дата Тогда
			ДополнительныйМатериалНайден = Истина;
			Прервать;
		КонецЕсли;
	
	КонецЦикла;
	
	Если ДополнительныйМатериалНайден Тогда	
	
		ДополнительныйМатериалИнформация = ЗаписатьДополнительныйМатериал(ДопПараметры.Дата, ДопПараметры.Автор, ?(ЗначениеЗаполнено(ТекущийЭлементСодержания), ТекущийЭлементСодержания, Параметры.СводЗнаний),,ТекущийПользователь, Текст);
		
		Если ДополнительныйМатериалИнформация <> Неопределено Тогда
			Строка.Наименование = ДополнительныйМатериалИнформация.Текст;
			Строка.Текст        = ДополнительныйМатериалИнформация.Текст;
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьЭлементИзДополнительныхМатериалов(Команда)

	ОписаниеОповещения = Новый ОписаниеОповещения("УдалитьДополнительныйМатериалПродолжение", ЭтотОбъект);		
	
	ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'Удалить дополнительный материал?'"), РежимДиалогаВопрос.ДаНет, 0);
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьДополнительныйМатериалПродолжение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
	    Возврат;
	КонецЕсли;
		
	ТекущиеДанные = Элементы.ДополнительныеМатериалы.ТекущиеДанные;
	
	Если НЕ ОбщегоНазначенияСУКлиент.ТекущиеДанныеТаблицыДоступны(ТекущиеДанные) Тогда
		Возврат;
	КонецЕсли;
	
	УдалитьДополнительныйМатериал(ТекущиеДанные.Дата, ?(ЗначениеЗаполнено(ТекущийЭлементСодержания), ТекущийЭлементСодержания, Параметры.СводЗнаний));
	
	СтрокаДляУдаления = ДополнительныеМатериалы.НайтиПоИдентификатору(Элементы.ДополнительныеМатериалы.ТекущаяСтрока);
	ДополнительныеМатериалы.Удалить(СтрокаДляУдаления);	
	
	Элементы.НавигационноеДерево.ТекущиеДанные.КартинкаДополнительногоМатериала = ?(ДополнительныеМатериалы.Количество() = 0, 1, 0);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДополнительныйМатериалКакОбщий(Команда)
	
	ТекущиеДанные = Элементы.ДополнительныеМатериалы.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписатьНастройкиДополнительногоМатериала(ТекущиеДанные.Дата,
											  ?(ЗначениеЗаполнено(ТекущийЭлементСодержания), ТекущийЭлементСодержания, Параметры.СводЗнаний),
											  ?(ТекущиеДанные.Общий, Ложь, Истина));
											  
	ТекущиеДанные.Общий    = ?(ТекущиеДанные.Общий, Ложь, Истина);
	ТекущиеДанные.Картинка = ?(ТекущиеДанные.Общий, 0, 1);
											  
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура ОбластьПросмотраДокументСформирован(Элемент)
	
	ОбщегоНазначенияСУКлиент.ОпределитьБраузер(ЭтотОбъект, Элемент.Документ);
	
	Если НЕ ЗначениеЗаполнено(Браузер) Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаПоиска = ПолучитьСтрокуПоискаДокумента();
	
	Если ПропуститьФормированиеКорневогоДокумента Тогда
		
		ПропуститьФормированиеКорневогоДокумента = Ложь;
		
		Если СтрокаПоиска = ОбъектыСУЗПовтИсп.СсылкаНаОбъектСУЗ(Параметры.СводЗнаний) Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ОбластьПросмотраЗагружена = Истина;
	
	ДобавитьОбработчик Элемент.Документ.onkeypress, ДокументПриНажатииКлавиши;
	
	Если АдресЗагруженногоОбъекта <> СтрокаПоиска Тогда
		ОтобразитьТекущийОбъект();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументПриНажатииКлавиши(ДанныеСобытия) Экспорт	
	ОбработатьСобытиеОбластиПросмотра();
КонецПроцедуры

&НаКлиенте
Процедура ОбластьПросмотраПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)	
	ОбработатьСобытиеОбластиПросмотра();	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСобытиеОбластиПросмотра()
	
	// Делаем необходимые проверки и получаем URL объекта.
	
	Если НЕ ОбластьПросмотраЗагружена Тогда
		Возврат;
	КонецЕсли;
	
	Если ДанныеКоманды <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеКоманды = ОбщегоНазначенияСУКлиент.ПолучитьДанныеКоманды(Элементы.ОбластьПросмотра.Документ, Браузер); // Реквизит
	
	Если ДанныеКоманды = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Найти(ДанныеКоманды.Параметры, "action=SCORequest") > 0 
		ИЛИ ОбщегоНазначенияСУКлиент.ЭтоВстроенныйWeKit(Браузер) Тогда
		ВыполнитьДействие();
	Иначе
		ПодключитьОбработчикОжидания("ВыполнитьДействие", 0.01, Истина); //Web-client 404 bug
	КонецЕсли;
	
КонецПроцедуры


////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЧНОГО ПОЛЯ "НавигационноеДерево"

&НаКлиенте
Процедура НавигационноеДеревоПриАктивизацииСтроки(Элемент)
	
	Если ПропуститьАктивациюЭлементаСодержания Тогда
		ПропуститьАктивациюЭлементаСодержания = Ложь;
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено Тогда
		АктивированныйЭлементСодержания = Элемент.ТекущиеДанные.Ссылка;
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("АктивироватьЭлементСодержания", 0.01, Истина); //V8 bug

КонецПроцедуры

&НаКлиенте
Процедура АктивироватьЭлементСодержания()
	
	Если ВыполняетсяТестирование И ЗначениеЗаполнено(СессияТестирования) Тогда
		СпроситьОЗакрытииСессииТестирования("АктивироватьЭлементСодержанияПродолжение");
	Иначе
		АктивироватьЭлементСодержанияПродолжение();	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АктивироватьЭлементСодержанияПродолжение()
	
	УстановитьТекущийОбъект(АктивированныйЭлементСодержания);
	АктивированныйЭлементСодержания = Неопределено;
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЧНОГО ПОЛЯ "ДополнительныеМатериалы"

&НаКлиенте
Процедура ДополнительныеМатериалыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.СсылкаНаОбъектСУЗ) Тогда
		ОбъектыСУЗКлиент.ОткрытьОбозреватель(, ТекущиеДанные.СсылкаНаОбъектСУЗ, Истина,,,,, Истина, Параметры.ТекущийПользователь,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	Иначе
		Оповещение = Новый ОписаниеОповещения("РедактироватьЭлементДополнительныхМатериаловПродолжение", ЭтотОбъект, Новый Структура("Дата, Автор", ТекущиеДанные.Дата, ТекущиеДанные.Автор));
		ПоказатьВводСтроки(Оповещение, ТекущиеДанные.Текст, НСтр("ru = 'Текст дополнительного материала'"), 0, Истина);				
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ДополнительныеМатериалыПриАктивизацииСтроки(Элемент)
	
	Если ЕстьПравоИзмененияОбщихДополнительныхМатериалов Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.Автор <> ТекущийПользовательСеанса Тогда
		Элементы.УстановитьДополнительныйМатериалКакОбщий.Доступность     = Ложь;
		Элементы.РедактироватьЭлементДополнительныхМатериалов.Доступность = Ложь;
		Элементы.УдалитьЭлементИзДополнительныхМатериалов.Доступность     = Ложь;
	Иначе
		Элементы.УстановитьДополнительныйМатериалКакОбщий.Доступность     = Истина;
		Элементы.РедактироватьЭлементДополнительныхМатериалов.Доступность = Истина;
		Элементы.УдалитьЭлементИзДополнительныхМатериалов.Доступность     = Истина;
	КонецЕсли;
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ОПЕРАТОРЫ ОСНОВНОЙ ПРОГРАММЫ

ПропуститьАктивациюЭлементаСодержания    = Ложь;
ПропуститьФормированиеКорневогоДокумента = Ложь;

КолонкиТаблицыДополнительныеМатериалы = Новый Массив();
КолонкиТаблицыДополнительныеМатериалы.Добавить("Наименование");
КолонкиТаблицыДополнительныеМатериалы.Добавить("Автор");
КолонкиТаблицыДополнительныеМатериалы.Добавить("Дата");
КолонкиТаблицыДополнительныеМатериалы.Добавить("СсылкаНаОбъектСУЗ");
КолонкиТаблицыДополнительныеМатериалы.Добавить("НаименованиеАвтора");
КолонкиТаблицыДополнительныеМатериалы.Добавить("Картинка");
КолонкиТаблицыДополнительныеМатериалы.Добавить("Общий");
КолонкиТаблицыДополнительныеМатериалы.Добавить("Текст");
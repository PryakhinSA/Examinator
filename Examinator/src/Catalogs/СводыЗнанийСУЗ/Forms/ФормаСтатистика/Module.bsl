

////////////////////////////////////////////////////////////////////////////////
// ЭКСПОРТНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

&НаСервере
Процедура СформироватьДиаграмму()	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РегистрСведенийПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Период КАК Дата,
		|	РегистрСведенийПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ВремяПрохожденияВСекундах
		|ИЗ
		|	РегистрСведений.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ КАК РегистрСведенийПопыткиПрохожденияЭлектронныхРесурсовСУЗ
		|%1%2%3%4%5%6";

		
	Подстановка1 = "";
	Подстановка2 = "";
	Подстановка3 = "";
	Подстановка4 = "";
	Подстановка5 = "";
	Подстановка6 = "";
		
	Если ЗначениеЗаполнено(Параметры.Пользователь) Тогда
		Подстановка1 = " ГДЕ ";
		Подстановка2 = " РегистрСведенийПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Пользователь = &Пользователь И";
		Запрос.УстановитьПараметр("Пользователь", Параметры.Пользователь);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.Задание) Тогда
		Подстановка1 = " ГДЕ ";
		Подстановка3 = " РегистрСведенийПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Задание = &Задание И";
		Запрос.УстановитьПараметр("Задание", Параметры.Задание);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ПрохождениеОбучения) Тогда
		Подстановка1 = " ГДЕ ";
		Подстановка4 = " РегистрСведенийПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ПрохождениеОбучения = &ПрохождениеОбучения И";
		Запрос.УстановитьПараметр("ПрохождениеОбучения", Параметры.ПрохождениеОбучения);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ЭлектронныйРесурс) Тогда
		Подстановка1 = " ГДЕ ";
		Подстановка5 = " РегистрСведенийПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ЭлектронныйРесурс = &ЭлектронныйРесурс И";
		Запрос.УстановитьПараметр("ЭлектронныйРесурс", Параметры.ЭлектронныйРесурс);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПериодДиаграммы) Тогда
		Подстановка1 = " ГДЕ ";
		Подстановка6 = " РегистрСведенийПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Период МЕЖДУ &НачалоПериода И &КонецПериода И";
		Запрос.УстановитьПараметр("НачалоПериода", ПериодДиаграммы.ДатаНачала);
		Запрос.УстановитьПараметр("КонецПериода", ПериодДиаграммы.ДатаОкончания);
	КонецЕсли;
	
	Запрос.Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Запрос.Текст, Подстановка1, Подстановка2, Подстановка3, Подстановка4, Подстановка5, Подстановка6);
	
	Если ЗначениеЗаполнено(Подстановка1) Тогда
		Запрос.Текст = Сред(Запрос.Текст, 1, СтрДлина(Запрос.Текст) - 1); // Убираем последнюю "И"
	КонецЕсли;
	
	Результат = Запрос.Выполнить();

	ТаблицаДанныхАктивности = Результат.Выгрузить();

	ТаблицаДанныхАктивности.Колонки.Добавить("КоличествоПопыток");
	
	Для каждого Строка Из ТаблицаДанныхАктивности Цикл
	
		Строка.КоличествоПопыток = 1;
		
		Если ШагДиаграммы = "Неделя" Тогда
			Строка.Дата = НачалоНедели(Строка.Дата);	
		ИначеЕсли ШагДиаграммы = "Месяц" Тогда
			Строка.Дата = НачалоМесяца(Строка.Дата);	
		ИначеЕсли ШагДиаграммы = "Год" Тогда
			Строка.Дата = НачалоГода(Строка.Дата);	
		ИначеЕсли ШагДиаграммы = "Квартал" Тогда
			Строка.Дата = НачалоКвартала(Строка.Дата);	
		Иначе
			Строка.Дата = НачалоДня(Строка.Дата);
		КонецЕсли;
	
	КонецЦикла;
	
	ТаблицаДанныхАктивности.Свернуть("Дата", "КоличествоПопыток, ВремяПрохожденияВСекундах");
	
	ДиаграммаАктивности.Обновление = Ложь;
	ДиаграммаАктивности.Очистить();

	СерияДиаграммы = ДиаграммаАктивности.УстановитьСерию("Количество попыток");

	Если ЗначениеЗаполнено(ПериодДиаграммы.ДатаНачала) Тогда
		
		ТекущаяДата = ПериодДиаграммы.ДатаНачала;
		
	Иначе	
		
		Если ТаблицаДанныхАктивности.Количество() > 0 Тогда
			ТекущаяДата = ТаблицаДанныхАктивности[0].Дата;
		Иначе
			ТекущаяДата = Дата("00010101");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПериодДиаграммы.ДатаОкончания) Тогда
		ПоследняяДата = ПериодДиаграммы.ДатаОкончания;
	Иначе	
		Если ТаблицаДанныхАктивности.Количество() > 0 Тогда
			ПоследняяДата = ТаблицаДанныхАктивности[ТаблицаДанныхАктивности.Количество()-1].Дата;
		Иначе
			ПоследняяДата = Дата("00010101");
		КонецЕсли;
		
	КонецЕсли;
	
	Пока ТекущаяДата <= ПоследняяДата Цикл
		
		Если ШагДиаграммы = "Неделя" ИЛИ ШагДиаграммы = "Квартал" Тогда
			ТочкаДиаграммы = ДиаграммаАктивности.УстановитьТочку(Формат(ТекущаяДата, "ДЛФ=D") + " - " + Формат(КонецНедели(ТекущаяДата), "ДЛФ=D"));
		ИначеЕсли ШагДиаграммы = "Месяц" Тогда
			ТочкаДиаграммы = ДиаграммаАктивности.УстановитьТочку(Формат(ТекущаяДата, "ДФ=MM.yyyy"));
		ИначеЕсли ШагДиаграммы = "Год" Тогда
			ТочкаДиаграммы = ДиаграммаАктивности.УстановитьТочку(Формат(ТекущаяДата, "ДФ=yyyy"));
		Иначе
			ТочкаДиаграммы = ДиаграммаАктивности.УстановитьТочку(Формат(ТекущаяДата, "ДЛФ=D"));
		КонецЕсли;			
		
		Строка = ТаблицаДанныхАктивности.Найти(ТекущаяДата, "Дата");
		
		Если Строка = Неопределено Тогда
			
			ДиаграммаАктивности.УстановитьЗначение(ТочкаДиаграммы, СерияДиаграммы, 0);
			
		Иначе				
			
			Если ЗначениеДиаграммы = "ВремяВСекундах" Тогда
				ДиаграммаАктивности.УстановитьЗначение(ТочкаДиаграммы, СерияДиаграммы, Строка.ВремяПрохожденияВСекундах);	
			ИначеЕсли ЗначениеДиаграммы = "ВремяВМинутах" Тогда
				ДиаграммаАктивности.УстановитьЗначение(ТочкаДиаграммы, СерияДиаграммы, Окр(Строка.ВремяПрохожденияВСекундах / 60, 2));	
			ИначеЕсли ЗначениеДиаграммы = "ВремяВЧасах" Тогда
				ДиаграммаАктивности.УстановитьЗначение(ТочкаДиаграммы, СерияДиаграммы, Окр(Строка.ВремяПрохожденияВСекундах / 60 / 60, 2));	
			Иначе
				ДиаграммаАктивности.УстановитьЗначение(ТочкаДиаграммы, СерияДиаграммы, Строка.КоличествоПопыток);	
			КонецЕсли;				
			
		КонецЕсли;
		
		// Переходим к следующей дате
			
		Если ШагДиаграммы = "Неделя" Тогда
			ТекущаяДата = НачалоНедели(ТекущаяДата + (60*60*24*7));
		ИначеЕсли ШагДиаграммы = "Месяц" Тогда
			ТекущаяДата = ДобавитьМесяц(ТекущаяДата, 1);
		ИначеЕсли ШагДиаграммы = "Год" Тогда
			ТекущаяДата = НачалоГода(ТекущаяДата + (60*60*24*365));
		ИначеЕсли ШагДиаграммы = "Квартал" Тогда
			ТекущаяДата = ДобавитьМесяц(ТекущаяДата, 3);
		Иначе
			ТекущаяДата = НачалоДня(ТекущаяДата + (60*60*24));
		КонецЕсли;			
		
	КонецЦикла;		
		
	ДиаграммаАктивности.ОтображатьЛегенду = Ложь;
	
	Если ЗначениеЗаполнено(ПредставлениеДиаграммы) Тогда
		ДиаграммаАктивности.ТипДиаграммы = ТипДиаграммы[ПредставлениеДиаграммы];
	Иначе
		ДиаграммаАктивности.ТипДиаграммы = ТипДиаграммы.Гистограмма;
	КонецЕсли;
	
	ДиаграммаАктивности.Обновление = Истина;
	
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Параметры
	
	Если НЕ ЗначениеЗаполнено(Параметры.ЭлектронныйРесурс) ИЛИ ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.ЭлектронныйРесурс, "ЭтоГруппа") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Электронный ресурс не выбран. Действие отменено'"),,,,Отказ);
	КонецЕсли;
	
	// Переменные
	
	ДанныеНастроек = ХранилищеСистемныхНастроек.Загрузить(ЭтотОбъект.ИмяФормы+"/ТекущиеДанные");
	
	Если ДанныеНастроек = Неопределено Тогда
		
		ЗначениеДиаграммы = "Попытки";
		ПредставлениеДиаграммы = "Гистограмма";
		ШагДиаграммы = "Месяц";
		
	Иначе
		
		Для каждого ЗначениеНастройки Из ДанныеНастроек Цикл
			ЭтотОбъект[ЗначениеНастройки.Ключ] = ЗначениеНастройки.Значение; 
		КонецЦикла;
		
	КонецЕсли;
		
	ЕстьПравоПросмотраСессий = Ложь;
	ЭлектронныеРесурсыПереопределяемый.ПриОпределенииПраваПросмотраПрохожденийДругихПользователей(ЕстьПравоПросмотраСессий);
	
	// Отборы
	
	Если ЗначениеЗаполнено(Параметры.Пользователь) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Активность.Отбор, "Пользователь", Параметры.Пользователь);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.Задание) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Активность.Отбор, "Задание", Параметры.Задание);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ПрохождениеОбучения) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Активность.Отбор, "ПрохождениеОбучения", Параметры.ПрохождениеОбучения);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ЭлектронныйРесурс) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Активность.Отбор, "ЭлектронныйРесурс", Параметры.ЭлектронныйРесурс);
	КонецЕсли;
	
	// Заголовок
	
	Заголовок = НСтр("ru = 'Статистика: '");
	
	Если ЗначениеЗаполнено(Параметры.Пользователь) Тогда
		Заголовок = Заголовок + Параметры.Пользователь + ", ";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.Задание) Тогда
		Заголовок = Заголовок + Параметры.Задание + ", ";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ЭлектронныйРесурс) Тогда
		Заголовок = Заголовок + Параметры.ЭлектронныйРесурс + ", ";
	КонецЕсли;
	
	Заголовок = Сред(Заголовок, 1, СтрДлина(Заголовок) - 2);
	
	// Видимость элементов
	
	Элементы.АктивностьПользователь.Видимость        = НЕ ЗначениеЗаполнено(Параметры.Пользователь);
	Элементы.АктивностьЭлектронныйРесурс.Видимость   = НЕ ЗначениеЗаполнено(Параметры.ЭлектронныйРесурс);
	
	Если Элементы.Найти("АктивностьПрохождениеОбучения") <> Неопределено Тогда 
		Элементы.АктивностьПрохождениеОбучения.Видимость = НЕ ЗначениеЗаполнено(Параметры.ПрохождениеОбучения);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.Задание)
		ИЛИ Параметры.МероприятиеСОднимЗаданием Тогда
		
		Элементы.АктивностьЗадание.Видимость = Ложь;
		
	КонецЕсли;
	
	// Формируем статистику
	
	СформироватьДиаграмму();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОбновитьПрохождениеОбучения" Тогда
		Элементы.Активность.Обновить();
		СформироватьДиаграмму();
	КонецЕсли;

КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ДЕЙСТВИЯ КОМАНД

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура ПериодДиаграммыПриИзменении(Элемент)
	СформироватьДиаграмму();
КонецПроцедуры

&НаКлиенте
Процедура ШагДиаграммыПриИзменении(Элемент)
	СформироватьДиаграмму();
КонецПроцедуры

&НаКлиенте
Процедура ЗначениеДиаграммыПриИзменении(Элемент)
	СформироватьДиаграмму();
КонецПроцедуры

&НаКлиенте
Процедура ТипДиаграммыПриИзменении(Элемент)
	СформироватьДиаграмму();
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЧНОГО ПОЛЯ Активность

&НаКлиенте
Процедура АктивностьВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные = Неопределено
		ИЛИ НЕ ЕстьПравоПросмотраСессий Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ОбъектыСУЗКлиент.ОткрытьОбозреватель(Элемент.ТекущиеДанные.ЭлектронныйРесурс,
										 Элемент.ТекущиеДанные.СсылкаНаОбъектСУЗ,
										 Истина,
										 Элемент.ТекущиеДанные.ЭлементСодержанияСсылка,
										 Элемент.ТекущиеДанные.ПрохождениеОбучения,
										 Элемент.ТекущиеДанные.Задание);
		
	
КонецПроцедуры



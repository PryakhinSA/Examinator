&НаКлиенте
Процедура СохранитьДокумент(Синхронно)

	// Сохраняем документ
	
	ПропуститьЗаписьДокумента = Истина;
	
	Приложение.Документ.Save();
	
	ПропуститьЗаписьДокумента = Ложь;
	
	// Делаем копию документа	
	
	Объект.ИмяФайла = Приложение.Документ.Name;
	
	РабочийКаталог.ФайлДляСохранения = РабочийКаталог.Копия + Объект.ИмяФайла;
	
	КопироватьФайл(Приложение.Документ.FullName, РабочийКаталог.ФайлДляСохранения);
	
	// Сохраняем копию в HTML
	
	Если Синхронно Тогда
		СохранитьДокументПродолжение();
	Иначе
		ПодключитьОбработчикОжидания("СохранитьДокументПродолжение", 0.01, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДокументПродолжение()
	
	Если НЕ ЗначениеЗаполнено(РабочийКаталог.ФайлДляСохранения) Тогда
		Возврат;
	КонецЕсли;		
	
	ПропуститьСохранениеДокумента = Истина;
	
	ПараметрыЗагрузки = Новый Структура();	
	
	// Свойства загрузки
	
	ПараметрыЗагрузки.Вставить("ПутьКДокументу", РабочийКаталог.ФайлДляСохранения);
	ПараметрыЗагрузки.Вставить("Приложение", Приложение.Скрытое);
	ПараметрыЗагрузки.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
	ПараметрыЗагрузки.Вставить("КонтекстФайла", "");
	
	// Параметры для заполнения в процессе загрузки
	
	ПараметрыЗагрузки.Вставить("ЗависимыеРесурсы", Новый Массив);	
	ПараметрыЗагрузки.Вставить("ЗависимыеРесурсыДополняющиеAPI", Новый Массив);		
	ПараметрыЗагрузки.Вставить("ПереданныеФайлы", Новый Массив);	
	ПараметрыЗагрузки.Вставить("НастройкиКартинок", РазработкаСУЗКлиент.НовоеОписаниеКартинокДокумента());	
	ПараметрыЗагрузки.Вставить("ПередаваемыеФайлы", Новый Массив);
	ПараметрыЗагрузки.Вставить("СтруктураФайлов", Новый Массив);
	ПараметрыЗагрузки.Вставить("ТекстовыеДанныеДляИндексирования", "");
	
	РазработкаСУЗКлиент.СформироватьДокументДляСохраненияВБазе(ПараметрыЗагрузки);
	
	Описание = РазработкаСУЗ.ОписаниеДокумента(ПараметрыЗагрузки.НастройкиКартинок);		
	ФайлыДляСохранения    = Новый Фиксированныймассив(ПараметрыЗагрузки.ПереданныеФайлы); // Сохраняем в реквизит
	ТекстовыеДанныеДляИндексирования = ПараметрыЗагрузки.ТекстовыеДанныеДляИндексирования;
	
	РабочийКаталог.ФайлДляСохранения = Неопределено;
	
	МассивПараметровФЗ = Новый Массив;
	МассивПараметровФЗ.Добавить(Объект.Владелец);
	МассивПараметровФЗ.Добавить(Новый ФиксированныйМассив(ПараметрыЗагрузки.ЗависимыеРесурсы));
	МассивПараметровФЗ.Добавить(Новый ФиксированныйМассив(ПараметрыЗагрузки.ЗависимыеРесурсыДополняющиеAPI));
	
	ЗависимыеРесурсыДляСохранения = Новый ФиксированныйМассив(МассивПараметровФЗ); // Сохраняем в реквизит и будем использовать после сохранения	
	
	Записать();
	
КонецПроцедуры


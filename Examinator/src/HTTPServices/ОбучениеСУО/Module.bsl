Функция СоздатьРассылкуPOST(ЗапросHTTP)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Сообщения");
	ПраваДляПроверки.Добавить("Форум");	
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(ЗапросHTTP, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;

	// Получаем параметры запроса
	//
	
	ДанныеЗапросаJSON = СокрЛП(ЗапросHTTP.ПолучитьТелоКакСтроку());
	
	Если НЕ ЗначениеЗаполнено(ДанныеЗапросаJSON) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Попытка
		ДанныеЗапросаСтруктура = ОбщегоНазначенияСУ.JSONВДанные(ДанныеЗапросаJSON);
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;
	
	Попытка
		ПроведениеОбучения = Документы.ПроведениеОбученияСУО.ПолучитьСсылку(
			Новый УникальныйИдентификатор(ДанныеЗапросаСтруктура.providingEducation));
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;
	
	ВсеАдресаты = Новый Массив;	
	
	ВсеУчастники = Документы.ПроведениеОбученияСУО.УчастникиОбучения(ПроведениеОбучения).ВыгрузитьКолонку("Пользователь");
	ВсеПреподаватели = Документы.ПроведениеОбученияСУО.Преподаватели(ПроведениеОбучения).ВыгрузитьКолонку("Пользователь");
	
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ВсеАдресаты, ВсеУчастники, Истина); 
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ВсеАдресаты, ВсеПреподаватели, Истина); 
	
	// Формируем рассылку
	//
	
	НоваяРассылка = Документы.РассылкаСообщенийСУО.СоздатьДокумент();
				
	НоваяРассылка.Дата = ТекущаяДатаСеанса();				
	НоваяРассылка.Автор = ДанныеСессии.Пользователь;
	НоваяРассылка.Заголовок = ДанныеЗапросаСтруктура.textNewTopic;
	ТекстРассылки = Новый ФорматированныйДокумент();
	Вложения = Новый Структура;	
	ТекстРассылки.УстановитьHTML(ДанныеЗапросаСтруктура.textNewMessage, Вложения);
	НоваяРассылка.ФорматированныйДокумент = Новый ХранилищеЗначения(ТекстРассылки);	
	НоваяРассылка.Описание = НСтр("ru = 'Ручная рассылка преподавателя из веб-кабинета'");
	НоваяРассылка.Основание = ПроведениеОбучения;
	НоваяРассылка.ТолькоЭлектроннаяПочта = Ложь;
	НоваяРассылка.БезШаблона = Истина;
	НоваяРассылка.АвтоматическаяРассылка = Ложь;
			
	Для каждого ТекущийПользователь Из ВсеАдресаты Цикл
		НовыйАдресат = НоваяРассылка.Адресаты.Добавить();
		НовыйАдресат.Пользователь = ТекущийПользователь;
	КонецЦикла;
	
	НоваяРассылка.ЗаполнитьПеременные();
	
	НоваяРассылка.Записать(РежимЗаписиДокумента.Проведение); // Не проводим
	
	// Завершаем
	
	Возврат ОтветКлиентуJSON(, Новый Структура("Рассылка", НоваяРассылка.Ссылка));
	
КонецФункции

Функция СоздатьСообщениеPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Сообщения");
	ПраваДляПроверки.Добавить("Форум");	
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем параметры запроса
	
	ПараметрыСообщения = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(Запрос.ПолучитьТелоКакСтроку(), "", ";", ":");
	
	Для каждого Элемент Из ПараметрыСообщения Цикл
		ВосстановитьСимволыСтрокиПараметров(ПараметрыСообщения[Элемент.Ключ]);
	КонецЦикла;
	
	НачатьТранзакцию();
	
	Попытка
		
		// Получаем тему сообщения
		
		Если НЕ ПараметрыСообщения.Свойство("topic")
			ИЛИ НЕ ЗначениеЗаполнено(ПараметрыСообщения.topic) Тогда
			
			Если НЕ ПараметрыСообщения.Свойство("textNewTopic")
				ИЛИ НЕ ПараметрыСообщения.Свойство("addressee")
				ИЛИ НЕ ПараметрыСообщения.Свойство("context")
				ИЛИ НЕ ПараметрыСообщения.Свойство("contextType") Тогда
				
				Возврат ОтветКлиентуJSON("errorData");
				
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(ПараметрыСообщения.textNewTopic)
				ИЛИ НЕ ЗначениеЗаполнено(ПараметрыСообщения.addressee)
				ИЛИ НЕ ЗначениеЗаполнено(ПараметрыСообщения.context)
				ИЛИ НЕ ЗначениеЗаполнено(ПараметрыСообщения.contextType) Тогда
				
				Возврат ОтветКлиентуJSON("errorData");
				
			КонецЕсли;		
			
			НоваяТемаОбъект = Справочники.ТемыСообщенийСУО.СоздатьЭлемент();
			НоваяТемаОбъект.Наименование = ПараметрыСообщения.textNewTopic;
			НоваяТемаОбъект.Кому         = Перечисления.АдресатыСообщенийСУО.ЗначениеИзСтроки(ПараметрыСообщения.addressee);
			
			Если ПараметрыСообщения.contextType = "user" Тогда
				НоваяТемаОбъект.Контекст     = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ПараметрыСообщения.context));
			КонецЕсли;
			
			Если ПараметрыСообщения.contextType = "forumCategory" Тогда
				
				НоваяТемаОбъект.Контекст = Справочники.РазделыФорумаСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ПараметрыСообщения.context));
				
				Если НЕ Справочники.РазделыФорумаСУО.ЕстьПравоСоздаватьТемыФорума(
					ДанныеСессии.Пользователь, НоваяТемаОбъект.Контекст) Тогда
					
					Возврат ОтветКлиентуJSON("noPermissions");
					
				КонецЕсли;
				
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(НоваяТемаОбъект.Контекст) Тогда
				Возврат ОтветКлиентуJSON("errorData");
			КонецЕсли;		
			
			НоваяТемаОбъект.Автор = ДанныеСессии.Пользователь;
			
			НоваяТемаОбъект.ДополнительныеСвойства.Вставить("НеОбновлятьДанныеВебКабинета", Истина);		
			НоваяТемаОбъект.Записать();
			
			Тема = НоваяТемаОбъект.Ссылка;
			
			ВебКабинетСУ.ОбновитьДанныеОбъекта(ОбщегоНазначения.МенеджерОбъектаПоСсылке(Тема), Тема, НоваяТемаОбъект.ДополнительныеСвойства);
			
			ПервоеСообщениеВТеме = Истина;
			
		Иначе
			
			Попытка
				ИдентификаторТемы = Новый УникальныйИдентификатор(ПараметрыСообщения.topic);
				Тема = Справочники.ТемыСообщенийСУО.ПолучитьСсылку(ИдентификаторТемы);
			Исключение
			КонецПопытки;
			
			ПервоеСообщениеВТеме = Ложь;
			
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Тема) Тогда
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;	
		
		// Получаем текст сообщения
		
		Если НЕ ПараметрыСообщения.Свойство("textNewMessage") Тогда
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;	
		
		ТекстСообщения = СокрЛП(ПараметрыСообщения.textNewMessage);
		
		Если НЕ ЗначениеЗаполнено(ТекстСообщения) Тогда
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;
		
		ФорматированныйДокумент = Новый ФорматированныйДокумент;
		ФорматированныйДокумент.УстановитьHTML(ТекстСообщения, Новый Структура);
		
		// Создаем новое сообщение	
			
		НовоеСообщениеОбъект = Документы.СообщениеСУО.СоздатьДокумент();
		НовоеСообщениеОбъект.Дата = ТекущаяДатаСеанса();
		НовоеСообщениеОбъект.Пользователь = ДанныеСессии.Пользователь;
		НовоеСообщениеОбъект.Тема = Тема;
		НовоеСообщениеОбъект.ФорматированныйДокумент = Новый ХранилищеЗначения(ФорматированныйДокумент);
		НовоеСообщениеОбъект.ИспользуетсяТекстовыйДокумент = Истина;
		НовоеСообщениеОбъект.ТекстовыйДокумент = ТекстСообщения;
		
		Если ПараметрыСообщения.Свойство("replyTo")
			И ЗначениеЗаполнено(ПараметрыСообщения.replyTo) Тогда
			
			НовоеСообщениеОбъект.РодительскоеСообщение = Документы.СообщениеСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ПараметрыСообщения.replyTo));
			
		КонецЕсли;	
		
		НовоеСообщениеОбъект.Записать(РежимЗаписиДокумента.Запись);
		
		// Прикрепляем файлы
		
		ЗагруженныеФайлы = Новый Массив;
		
		ФайлыДляЗаписи = ФайлыДляЗаписи(ПараметрыСообщения);
		
		Если ФайлыДляЗаписи <> Неопределено Тогда
			
			Для каждого ФайлДляЗаписи Из ФайлыДляЗаписи Цикл
			
				СсылкаНаФайл = ПрисоединенныеФайлы.ДобавитьФайл(НовоеСообщениеОбъект.Ссылка, ФайлДляЗаписи.ИмяФайлаБезРасширения, ФайлДляЗаписи.РасширениеФайлаБезТочки, ТекущаяДатаСеанса(), ФайлДляЗаписи.ВремяИзмененияФайла, ФайлДляЗаписи.АдресХраненияФайла,, ФайлДляЗаписи.ОписаниеФайла);
				
				Если НЕ ЗначениеЗаполнено(СсылкаНаФайл) Тогда
					Возврат ОтветКлиентуJSON("saveFileError");
				КонецЕсли;
				
				ЗагруженныеФайлы.Добавить(Новый Структура("name, ref, extension",
					ФайлДляЗаписи.ИмяФайла, Строка(СсылкаНаФайл.УникальныйИдентификатор()), ФайлДляЗаписи.РасширениеФайлаБезТочки));
				
			КонецЦикла;
			
		КонецЕсли;
		
		// Проводим документ
		
		НовоеСообщениеОбъект.ПервоеСообщениеВТеме = ПервоеСообщениеВТеме;
		
		НовоеСообщениеОбъект.ДополнительныеСвойства.Вставить("НеОбновлятьДанныеВебКабинета", Истина);
		НовоеСообщениеОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Оперативный);
		
		 
		
		// Обновляем данные веб-кабинета
		
		ВебКабинетСУ.ОбновитьДанныеОбъекта(ОбщегоНазначения.МенеджерОбъектаПоСсылке(НовоеСообщениеОбъект.Ссылка), НовоеСообщениеОбъект.Ссылка, НовоеСообщениеОбъект.ДополнительныеСвойства);
		
		// Записываем дату просмотра темы форума
		
		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Тема, "Кому") = Перечисления.АдресатыСообщенийСУО.НаФоруме Тогда
			ДатаПросмотра = НовоеСообщениеОбъект.Дата + 1;	
			Справочники.ТемыСообщенийСУО.ЗаписатьПользовательскиеНастройкиТемы(Тема,,, ДанныеСессии.Пользователь, ДатаПросмотра, Истина);	
			РегистрыСведений.НастройкиТемФорумаСУО.ОбновитьДанныеВебКабинетаЗаписи(ДанныеСессии.Пользователь, Тема);
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
		
	// Возвращаем результат
	
	Возврат ОтветКлиентуJSON(,Новый Структура("Сообщение, ЗагруженныеФайлы", НовоеСообщениеОбъект.Ссылка, ЗагруженныеФайлы));
	
КонецФункции

Функция ЗаписатьНастройкиТемыРазделаФорумаPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);

	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Сообщения");
	ПраваДляПроверки.Добавить("Форум");	
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные запроса
	
	Попытка
		ИдентификаторТемы = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("Тема"));
		Тема = Справочники.ТемыСообщенийСУО.ПолучитьСсылку(ИдентификаторТемы);
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(Тема) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	// Записываем настройки
	
	ДатаПросмотра = ТекущаяДатаСеанса();	
	Справочники.ТемыСообщенийСУО.ЗаписатьПользовательскиеНастройкиТемы(Тема,,, ДанныеСессии.Пользователь, ДатаПросмотра, Истина);	
	РегистрыСведений.НастройкиТемФорумаСУО.ОбновитьДанныеВебКабинетаЗаписи(ДанныеСессии.Пользователь, Тема);
	
	// Возвращаем результат
	
	Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена", Истина));
	
КонецФункции

Функция ЗаписатьНастройкиСообщенияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);

	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Сообщения");
	ПраваДляПроверки.Добавить("Форум");
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные запроса
	
	Попытка
		ИдентификаторСообщения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("Сообщение"));
		Сообщение = Документы.СообщениеСУО.ПолучитьСсылку(ИдентификаторСообщения);
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(Сообщение) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	НастройкиДляЗаписиJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если НЕ ЗначениеЗаполнено(НастройкиДляЗаписиJSON) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Попытка
		НастройкиДляЗаписи = ОбщегоНазначенияСУ.JSONВДанные(НастройкиДляЗаписиJSON);
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;
	
	ИмяНастройки      = Неопределено;
	ЗначениеНастройки = Неопределено;
	
	Если НастройкиДляЗаписи.Свойство("name") И НастройкиДляЗаписи.Свойство("value") Тогда
		Попытка
			ИмяНастройки      = ВебКабинетСУ.Перевод(НастройкиДляЗаписи.name, "ТипыДанныхВебКабинетаСУО");
			ЗначениеНастройки = НастройкиДляЗаписи.value; 
		Исключение
			Возврат ОтветКлиентуJSON("errorData");
		КонецПопытки;			
	КонецЕсли;
		
	ТекущаяДата = ТекущаяДатаСеанса();
	
	// Записываем настройки
		
	НачатьТранзакцию();
	
	Попытка
		
		РегистрыСведений.НастройкиЛичныхСообщенийСУО.ЗаписатьНастройки(Сообщение, ИмяНастройки, ЗначениеНастройки, ДанныеСессии.Пользователь, ТекущаяДата, Истина);
		РегистрыСведений.НастройкиТемОбщенияСУО.ЗаписатьНастройки(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сообщение, "Тема"),,,ДанныеСессии.Пользователь, ТекущаяДата);		
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
	// Возвращаем результат
	
	Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена", Истина));	
	
КонецФункции

// Библиотека

Функция ПолучитьБиблиотекуПользователяPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Библиотека");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Библиотеки
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БиблиотекиПользователя.Данные КАК Данные
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК БиблиотекиПользователя
		|ГДЕ
		|	БиблиотекиПользователя.Пользователь = &Пользователь
		|	И БиблиотекиПользователя.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.БиблиотекаПользователя)
		|	И БиблиотекиПользователя.Объект = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		Возврат ОтветКлиентуJSON(,);
		
	Иначе
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		ВыборкаДетальныеЗаписи.Следующий();
		
		Возврат ОтветКлиентуJSON(,ВыборкаДетальныеЗаписи.Данные);
		
	КонецЕсли;
	
КонецФункции

// Новости

Функция ПолучитьНовостиPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Новости");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем переменные
	
	ДатаНачала    = Дата("00010101");
	ДатаОкончания = Дата("00010101");
	Количество    = 0;
	
	Попытка
		ДатаНачала = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(Число(Запрос.ПараметрыURL.Получить("ДатаНачала")));
		ДатаОкончания = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(Число(Запрос.ПараметрыURL.Получить("ДатаОкончания")));
		Количество = Число(Запрос.ПараметрыURL.Получить("Количество"));
	Исключение
	КонецПопытки;
	
	// Получаем данные
	//
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	СписокОбщихНовостей.Данные КАК object,
		|	СписокОбщихНовостей.Период КАК date
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ОП КАК СписокОбщихНовостей
		|ГДЕ
		|	СписокОбщихНовостей.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.Новость)
		|	И СписокОбщихНовостей.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СписокНовостейПользователя.Данные,
		|	СписокНовостейПользователя.Период
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ПП КАК СписокНовостейПользователя
		|ГДЕ
		|	СписокНовостейПользователя.Пользователь = &Пользователь
		|	И СписокНовостейПользователя.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.Новость)
		|	И СписокНовостейПользователя.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
		|
		|УПОРЯДОЧИТЬ ПО
		|	date";
		
	Если ЗначениеЗаполнено(ДатаНачала) И ЗначениеЗаполнено(ДатаОкончания) Тогда
		
		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
		Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);		
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И СписокОбщихНовостей.Период МЕЖДУ &ДатаНачала И &ДатаОкончания", "");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И СписокНовостейПользователя.Период МЕЖДУ &ДатаНачала И &ДатаОкончания", "");
		
	КонецЕсли;		
	
	Если ЗначениеЗаполнено(Количество) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПЕРВЫЕ 1", "ПЕРВЫЕ " + ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(Количество));
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПЕРВЫЕ 1", "");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат ОтветКлиентуJSON(,РезультатЗапроса.Выгрузить());
	
КонецФункции

Функция ПолучитьТекстНовостиPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Новости");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем переменные
	//
	
	Попытка
		ИдентификаторНовости = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("Новость"));
		Новость = Документы.НовостьСУО.ПолучитьСсылку(ИдентификаторНовости);
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(Новость) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	
	
	// Получаем темы раздела форума
	//
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеВебКабинетаСУО_ОН.Данные КАК ТекстСообщения
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ДанныеВебКабинетаСУО_ОН
		|ГДЕ
		|	ДанныеВебКабинетаСУО_ОН.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.НовостьОписание)
		|	И ДанныеВебКабинетаСУО_ОН.Объект = &Новость";
		
	Запрос.УстановитьПараметр("Новость", Новость);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	РезультатТекстXML = "";
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РезультатТекстXML = РезультатТекстXML + ВыборкаДетальныеЗаписи.ТекстСообщения.Получить();
	КонецЦикла;
	
	Возврат ОтветКлиентуXML(РезультатТекстXML);
	
КонецФункции

Функция СоздатьНовостьPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;	
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Новости");
	ПраваДляПроверки.Добавить("ДобавлениеНовостей");
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;

	Права = ДанныеСессии.Права.Получить();
	
	// Получаем параметры запроса
	
	ПараметрыСообщения = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(Запрос.ПолучитьТелоКакСтроку(), "", ";", ":");
	
	Для каждого Элемент Из ПараметрыСообщения Цикл
		ВосстановитьСимволыСтрокиПараметров(ПараметрыСообщения[Элемент.Ключ]);
	КонецЦикла;
	
	// Получаем заголовок новости
	
	Если НЕ ПараметрыСообщения.Свойство("textTopic") Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	
	
	ЗаголовокНовости = СокрЛП(ПараметрыСообщения.textTopic);
	
	// Получаем тело новости
	
	Если НЕ ПараметрыСообщения.Свойство("textMessage") Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	
	
	ТекстНовости = СокрЛП(ПараметрыСообщения.textMessage);
	
	Если НЕ ЗначениеЗаполнено(ТекстНовости) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	ФорматированныйДокумент = Новый ФорматированныйДокумент;
	ФорматированныйДокумент.УстановитьHTML(ТекстНовости, Новый Структура);
	
	// Получаем учебную группу для которой создается новость
	
	Если НЕ ПараметрыСообщения.Свойство("idEduGroup")
		ИЛИ НЕ ПараметрыСообщения.Свойство("typeEduGroup") Тогда
		
		Возврат ОтветКлиентуJSON("errorData");
		
	КонецЕсли;	
	
	УчебнаяГруппа = Неопределено;
	
	Если ЗначениеЗаполнено(ПараметрыСообщения.idEduGroup)
		И ЗначениеЗаполнено(ПараметрыСообщения.typeEduGroup) Тогда
		
		МенеджерСправочникаГрупп = Справочники.УчебныеГруппыСУО.МенеджерСправочникаПоТипу(ПараметрыСообщения.typeEduGroup);
		
		УчебнаяГруппа = МенеджерСправочникаГрупп.ПолучитьСсылку(Новый УникальныйИдентификатор(ПараметрыСообщения.idEduGroup));
		
	КонецЕсли;	
	
	// Создаем новость
	
	НовостьОбъект = Документы.НовостьСУО.СоздатьДокумент();
	НовостьОбъект.Дата = ТекущаяДатаСеанса();
	НовостьОбъект.Заголовок = ЗаголовокНовости;
	НовостьОбъект.ФорматированныйДокумент = Новый ХранилищеЗначения(ФорматированныйДокумент);
	НовостьОбъект.ДатаПубликации = ТекущаяДатаСеанса();
	НовостьОбъект.Автор = ДанныеСессии.Пользователь; 
	
	Если ЗначениеЗаполнено(УчебнаяГруппа) Тогда
		
		Участники = МенеджерСправочникаГрупп.Участники(УчебнаяГруппа);
		
		Для каждого Строка Из Участники Цикл
			
			Если НЕ ЗначениеЗаполнено(Строка.Пользователь) Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрокаТЧ = НовостьОбъект.Получатели.Добавить();
			НоваяСтрокаТЧ.Пользователь = Строка.Пользователь;
		
		КонецЦикла;
		
	Иначе		
		
		Если НЕ Права.Свойство("КаталогПользователей") ИЛИ НЕ Права.КаталогПользователей Тогда
			
			ПолучателиНовости = КаталогПользователей(ДанныеСессии, Истина);
			
			Для каждого ПолучательНовости Из ПолучателиНовости Цикл
				
				Если НЕ ЗначениеЗаполнено(ПолучательНовости) Тогда
					Продолжить;
				КонецЕсли;				
				
				НоваяСтрокаТЧ = НовостьОбъект.Получатели.Добавить();
				НоваяСтрокаТЧ.Пользователь = ПолучательНовости;
			
			КонецЦикла;
			
		Иначе
			
			// Для всех пользователей базы (ТЧ не заполняем)
			
		КонецЕсли;

	КонецЕсли;
		
	НовостьОбъект.ДополнительныеСвойства.Вставить("НеОбновлятьДанныеВебКабинета", Истина);
	
	НовостьОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	ВебКабинетСУ.ОбновитьДанныеОбъекта(Документы.НовостьСУО, НовостьОбъект.Ссылка);
	
	// Завершаем
	
	Возврат ОтветКлиентуJSON(,Новый Структура("ДатаНовости", НовостьОбъект.Дата));
	
КонецФункции


Функция НаименованиеРекомендуемогоОтчета(ВариантОтчета, Размещение)
	
	ТребуемыеДанные = Новый Структура("ПолноеИмя, КлючВарианта, Наименование", "Отчет.ПолноеИмя", "КлючВарианта", "Наименование");
	ДанныеВарианта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ВариантОтчета, ТребуемыеДанные);
	ТаблицаОтчетов = ТаблицаРекомендуемыхОтчетов();
	
	ДанныеСтроки = ТаблицаОтчетов.НайтиСтроки(Новый Структура("ПолноеИмяОтчета, КлючВарианта, ДоступноКРазмещению", ДанныеВарианта.ПолноеИмя, ДанныеВарианта.КлючВарианта, Размещение));
	
	Если ДанныеСтроки.Количество() = 0 Тогда
		Возврат ДанныеВарианта.Наименование;	
	КонецЕсли;
	
	Возврат ДанныеСтроки[0].НаименованиеВарианта;
	

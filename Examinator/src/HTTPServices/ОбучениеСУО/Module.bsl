		Исключение
		КонецПопытки;
		
		Если ТипЗнч(ДанныеДляЗаписи) = Тип("Структура") И ДанныеДляЗаписи.Свойство("answer") Тогда			
			ОтветПользователя = ДанныеДляЗаписи.answer;
		КонецЕсли;		
		
	КонецЕсли;
	
	// Завершаем выполнение задания	
	
	ОписаниеВыполненияЗадания = ОбучениеСУО.ПриПрохожденииЗадания(
		ДанныеОбучения.ПрохождениеОбучения,
		ДанныеОбучения.Задание,
		,
		,
		Ложь,
		,
		,
		Истина,
		Истина,
		ОтветПользователя,
		Истина,
		ПопыткаВыполненияЗадания);
		
	ОбновитьДанныеПрохожденияОбученияВебКабинета(ДанныеОбучения.ПрохождениеОбучения);
	
	ВебКабинетСУ.ОбновитьДанныеОбъекта(Документы.ПопыткаВыполненияЗаданияСУО, ПопыткаВыполненияЗадания);
	
	// Возвращаем результат
	//
	
	Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена, РезультатВыполненияЗадания", Истина, ОписаниеВыполненияЗадания));
	
КонецФункции


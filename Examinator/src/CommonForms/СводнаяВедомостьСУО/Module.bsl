&НаКлиенте
Процедура ПоказыватьПриИзменении(Элемент)
	ЗаполнитьВедомость();
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЧНОГО ПОЛЯ Ведомость

&НаКлиенте
Процедура ВедомостьВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Если Найти(Поле.Имя, "Мероприятие_") = 1 Тогда
		
		ПрохождениеОбучения = ТекущиеДанные["Прохождение" + Поле.Имя];

		Если ЗначениеЗаполнено(ПрохождениеОбучения) Тогда
		
			ПоказатьЗначение(,ПрохождениеОбучения);
			
		Иначе
			
			ПоказатьЗначение(,ТекущиеДанные.Пользователь);
			
		КонецЕсли;
		
		
	Иначе
		
		ПоказатьЗначение(,ТекущиеДанные.Пользователь);
		
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура ВедомостьОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранноеЗначение) <> Тип("Массив") Тогда		
		Возврат;		
	КонецЕсли;
	
	Ведомость.Очистить();
	
	Для каждого ВыбранныйПользователь Из ВыбранноеЗначение Цикл		
			
		НоваяСтрока = Ведомость.Добавить();
		НоваяСтрока.Пользователь = ВыбранныйПользователь;
		
	КонецЦикла;
	
	ЗаполнитьВедомость();

КонецПроцедуры


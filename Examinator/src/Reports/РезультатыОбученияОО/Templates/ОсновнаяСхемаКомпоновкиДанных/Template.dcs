			<field>Статус</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>УчебнаяГруппа</dataPath>
			<field>УчебнаяГруппа</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ФормаОбучения</dataPath>
			<field>ФормаОбучения</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Студент</dataPath>
			<field>Студент</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Пользователь</dataPath>
			<field>Пользователь</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СтудентыООСрезПоследних.Пользователь КАК Студент,
	СтудентыООСрезПоследних.Курс,
	СтудентыООСрезПоследних.УчебнаяГруппа,
	СтудентыООСрезПоследних.Статус,
	СтудентыООСрезПоследних.Специализация,
	СтудентыООСрезПоследних.Специальность,
	СтудентыООСрезПоследних.ФормаОбучения,
	СтудентыООСрезПоследних.Отделение
ИЗ
	РегистрСведений.СтудентыОО.СрезПоследних(, ) КАК СтудентыООСрезПоследних</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>ПрохожденияЗаданий</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПрохождениеЗадания.ПроверяетсяПреподавателем</dataPath>
			<field>ЗаданиеПроверяетсяПреподавателем</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Задание требует проверки</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПроведениеОбучения</dataPath>
			<field>ПроведениеОбучения</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Проведение обучения</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Задание</dataPath>
			<field>Задание</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Задание</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:dimension>true</dcscom:dimension>

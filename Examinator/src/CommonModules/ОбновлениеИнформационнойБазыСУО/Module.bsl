	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		СтрокаТЭР = ТаблицаЭР.Найти(ВыборкаДетальныеЗаписи.ИдентификаторПакета, "ИдентификаторПакета");
		
		Если СтрокаТЭР <> Неопределено
			И ТипЗнч(СтрокаТЭР.СсылкаНаЭлемент) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда
		
			НаборЗаписей = РегистрыСведений.ИмпортированныеЭлементыПакетаSCORM.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.СсылкаНаЭлемент.Установить(ВыборкаДетальныеЗаписи.СсылкаНаЭлемент);
			НаборЗаписей.Прочитать();
			НаборЗаписей[0].ЭлектронныйРесурс = СтрокаТЭР.СсылкаНаЭлемент;
			
			НаборЗаписей.Записать();

		КонецЕсли;			
	
	КонецЦикла;
	
		
КонецПроцедуры


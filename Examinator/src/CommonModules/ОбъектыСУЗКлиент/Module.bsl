// ОБОЗРЕВАТЕЛЬ

// Процедура позволяет открыть обозреватель электронных
// Ресурсов для просмотра электронного ресурса (свода знаний).
//
Процедура ОткрытьОбозреватель(СводЗнаний=Неопределено,
	                          АдресОбъекта=Неопределено,
							  СкрытьНавигационноеДерево=Ложь,
							  ЭлементСодержания=Неопределено,
							  ПрохождениеОбучения=Неопределено,
							  Задание=Неопределено,
							  Вариант=Неопределено,
							  ДочернееОкно=Ложь,
							  РежимПросмотра=Ложь,
							  ТекущийПользователь=Неопределено,
							  РежимОткрытияОкна=Неопределено,
							  Заголовок=Неопределено,
							  Окно=Неопределено) Экспорт
							  
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("СводЗнаний", СводЗнаний);
	ПараметрыФормы.Вставить("АдресОбъекта", АдресОбъекта);
	ПараметрыФормы.Вставить("СкрытьНавигационноеДерево", СкрытьНавигационноеДерево);
	ПараметрыФормы.Вставить("ЭлементСодержания", ЭлементСодержания);
	ПараметрыФормы.Вставить("ПрохождениеОбучения", ПрохождениеОбучения);
	ПараметрыФормы.Вставить("Задание", Задание);
	ПараметрыФормы.Вставить("Вариант", Вариант);
	ПараметрыФормы.Вставить("ДочернееОкно", ДочернееОкно);
	ПараметрыФормы.Вставить("РежимПросмотра", РежимПросмотра);
	ПараметрыФормы.Вставить("ТекущийПользователь", ТекущийПользователь);
	ПараметрыФормы.Вставить("Заголовок", Заголовок);
	
	ОткрытьФорму("ОбщаяФорма.ОбозревательОбъектовСУЗ", ПараметрыФормы,,,Окно,,,РежимОткрытияОкна);
	
КонецПроцедуры

Процедура РедактироватьЭлектронныйРесурс(Знач ЭлектронныйРесурс) Экспорт
	
	Если  ТипЗнч(ЭлектронныйРесурс) = Тип("ДанныеФормыСтруктура") Тогда
		ПоказатьЗначение(, ЭлектронныйРесурс.Ссылка);
	КонецЕсли;
	
	Если ТипЗнч(ЭлектронныйРесурс) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда
		ПоказатьЗначение(, ЭлектронныйРесурс);
	КонецЕсли;
		
КонецПроцедуры


Функция ЗаписатьОценкиЗаданийОбученияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Преподавание");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные
	//	
	
	Попытка
		ИдентификаторПрохожденияОбучения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ПрохождениеОбучения"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторПрохожденияОбучения) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	
	
	ПрохождениеОбучения = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(ИдентификаторПрохожденияОбучения);
	
	// Получаем данные для записи
	//
	
	ДанныеДляЗаписиJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если НЕ ЗначениеЗаполнено(ДанныеДляЗаписиJSON) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Попытка
		ДанныеДляЗаписи = ОбщегоНазначенияСУ.JSONВДанные(ДанныеДляЗаписиJSON);
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;
	
	// Записываем данные
	//
	
	Для каждого Элемент Из ДанныеДляЗаписи Цикл
		
		Если НЕ ЗначениеЗаполнено(Элемент.task) Тогда
			Продолжить;
		КонецЕсли;
		
		Задание = Справочники.ЗаданияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.task));
		
		ПопыткаЗавершена = Неопределено;
		
		Оценка = Неопределено;
		
		Если Элемент.Свойство("mark") Тогда		
			
			Если ЗначениеЗаполнено(Элемент.mark) Тогда
				
				ПопыткаЗавершена = Истина;
				
				Оценка = Справочники.ЭлементыШкалыОценокСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.mark));
				
			Иначе
				
				ПопыткаЗавершена = Ложь;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Комментарий = Неопределено;
		
		Если Элемент.Свойство("comment") Тогда				
			Комментарий = ?(ЗначениеЗаполнено(Элемент.comment), Элемент.comment, "");
		КонецЕсли;
		
		ПричинаВозвратаЗадания = Неопределено;
		
		Если Элемент.Свойство("reasonToRevision")
			И ЗначениеЗаполнено(Элемент.reasonToRevision)
			И СтроковыеФункцииКлиентСервер.ЭтоУникальныйИдентификатор(Элемент.reasonToRevision) Тогда
			
			ПричинаВозвратаЗадания = Справочники.ПричиныВозвратаЗаданияНаДоработкуСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.reasonToRevision));
			
		КонецЕсли;
			
		ОписаниеПрохождения = ОбучениеСУО.ПриПрохожденииЗадания(
			ПрохождениеОбучения,
			Задание,
			Оценка,
			Комментарий,
			Истина,
			,
			,
			Истина,
			ПопыткаЗавершена,
			,
			,
			,
			ПричинаВозвратаЗадания,
			ДанныеСессии.Пользователь); 
		
		ВебКабинетСУ.ОбновитьДанныеОбъекта(Документы.ПопыткаВыполненияЗаданияСУО, ОписаниеПрохождения.ПопыткаВыполненияЗадания);
		
		Элемент.Вставить("taskActionResult", ОписаниеПрохождения)
		
	КонецЦикла;
	
	ОбновитьДанныеПрохожденияОбученияВебКабинета(ПрохождениеОбучения);
		
	// Возвращаем результат
	//
	
	Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена, Результат", Истина, ДанныеДляЗаписи));
	
КонецФункции

Функция ОбновитьДанныеПрохожденияОбученияВебКабинета(ПрохождениеОбучения, СтатусПрохождения = Неопределено)
	
	ОписаниеПрохождения = ОбучениеСУО.ПриПрохожденииМероприятия(ПрохождениеОбучения, СтатусПрохождения,,,,,Истина,,,Ложь);
	
	ВебКабинетСУО.ОбновитьДанныеПрохожденияОбученияВебКабинета(ПрохождениеОбучения, ОписаниеПрохождения);
	
	Возврат ОписаниеПрохождения;
	
КонецФункции

Функция ЗавершитьВыполнениеЗаданияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
		
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Обучение");
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;

	// Получаем данные
	//	
	
	Попытка
		ИдентификаторВыполненияЗадания = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ВыполнениеЗадания"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторВыполненияЗадания) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	ПопыткаВыполненияЗадания = Документы.ПопыткаВыполненияЗаданияСУО.ПолучитьСсылку(ИдентификаторВыполненияЗадания);
	ДанныеОбучения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПопыткаВыполненияЗадания, "ПрохождениеОбучения, Задание");
	
	ОтветПользователя = Неопределено;
	
	ДанныеДляЗаписиJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если ЗначениеЗаполнено(ДанныеДляЗаписиJSON) Тогда
		
		Попытка

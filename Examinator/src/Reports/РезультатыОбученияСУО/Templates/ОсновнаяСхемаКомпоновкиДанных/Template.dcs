						<dcscor:item>
							<dcscor:choiceParameter>Отбор.Родитель</dcscor:choiceParameter>
							<dcscor:value xsi:type="dcscor:DesignTimeValue">Справочник.ВидыКонтактнойИнформации.СправочникПользователи</dcscor:value>
						</dcscor:item>
						<dcscor:item>
							<dcscor:choiceParameter>Отбор.НаборСвойств</dcscor:choiceParameter>
							<dcscor:value xsi:type="dcscor:DesignTimeValue">Справочник.НаборыДополнительныхРеквизитовИСведений.Справочник_Пользователи</dcscor:value>
						</dcscor:item>
					</dcscor:value>
				</dcscor:item>
				<dcscor:item>
					<dcscor:parameter>ВыборГруппИЭлементов</dcscor:parameter>
					<dcscor:value xmlns:d6p1="http://v8.1c.ru/8.1/data/enterprise" xsi:type="d6p1:FoldersAndItemsUse">Items</dcscor:value>
				</dcscor:item>
			</inputParameters>

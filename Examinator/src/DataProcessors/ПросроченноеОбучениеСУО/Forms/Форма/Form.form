    </edit>
  </attributes>
  <attributes>
    <name>ПросроченныеМероприятия</name>
    <title>
      <key>ru</key>
      <value>Просроченные мероприятия</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПросроченныеМероприятия.Recorder</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	УчастникиОбученияСУО.Регистратор,
	УчастникиОбученияСУО.Пользователь,
	УчастникиОбученияСУО.Сценарий,
	УчастникиОбученияСУО.ПроведениеОбучения,
	УчастникиОбученияСУО.ДатаНачалаПрохождения
ИЗ
	РегистрСведений.УчастникиОбученияСУО КАК УчастникиОбученияСУО
ГДЕ
	(
	
	//Электронные, дистанционные 
		
	УчастникиОбученияСУО.МестоПроведения = ЗНАЧЕНИЕ(Перечисление.МестаПроведенияМероприятийСУО.Дистанционно)
	И УчастникиОбученияСУО.Электронное = ИСТИНА
	И УчастникиОбученияСУО.ПродолжительностьВСекундах > 0
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.Завершил)
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.Автомат)
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.НеЗавершил)
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.НеДопущен)
	И ДОБАВИТЬКДАТЕ(УчастникиОбученияСУО.ДатаНачалаПрохождения, СЕКУНДА, УчастникиОбученияСУО.ПродолжительностьВСекундах) &lt; &amp;ТекущаяДата
	
	) ИЛИ (
	
	//Электронные, дистанционные с датой контроля
	
	УчастникиОбученияСУО.МестоПроведения = ЗНАЧЕНИЕ(Перечисление.МестаПроведенияМероприятийСУО.Дистанционно)
	И УчастникиОбученияСУО.Электронное = ИСТИНА
	И УчастникиОбученияСУО.ДатаКонтроля &lt;> ДАТАВРЕМЯ(1,1,1)
	И УчастникиОбученияСУО.ДатаКонтроля &lt; &amp;ТекущаяДата
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.Завершил)
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.Автомат)
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.НеЗавершил)
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.НеДопущен)
	
	) ИЛИ (
	
	//Не электронные или проходящие в аудитории и без преподавателя
	
	(УчастникиОбученияСУО.МестоПроведения = ЗНАЧЕНИЕ(Перечисление.МестаПроведенияМероприятийСУО.Аудитория) ИЛИ УчастникиОбученияСУО.Электронное = ЛОЖЬ)
	И УчастникиОбученияСУО.Общее = ЛОЖЬ
	И ДОБАВИТЬКДАТЕ(УчастникиОбученияСУО.ДатаНачалаПрохождения, СЕКУНДА, УчастникиОбученияСУО.ПродолжительностьВСекундах) &lt; &amp;ТекущаяДата
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.Завершил)
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.Автомат)
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.НеЗавершил)
	И УчастникиОбученияСУО.Статус &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.НеДопущен)
	
	)</queryText>
      <mainTable>InformationRegister.УчастникиОбученияСУО</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>

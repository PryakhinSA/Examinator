<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>Оценки</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПроведениеОбучения</dataPath>
			<field>ПроведениеОбучения</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Участник</dataPath>
			<field>Участник</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаВыставления</dataPath>
			<field>ДатаВыставления</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Оценка</dataPath>
			<field>Оценка</field>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>ЧДЦ=2</v8:content>
						</v8:item>
					</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Комментарий</dataPath>
			<field>Комментарий</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Период.Месяц</dataPath>
			<field>ПериодМесяц</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Месяц</v8:content>
				</v8:item>
			</title>
			<presentationExpression>Выбор 
    Когда Месяц(Период.Месяц) = 1 Тогда "Январь"
    Когда Месяц(Период.Месяц) = 2 Тогда "Февраль"
    Когда Месяц(Период.Месяц) = 3 Тогда "Март"
    Когда Месяц(Период.Месяц) = 4 Тогда "Апрель"
    Когда Месяц(Период.Месяц) = 5 Тогда "Май"
    Когда Месяц(Период.Месяц) = 6 Тогда "Июнь"
    Когда Месяц(Период.Месяц) = 7 Тогда "Июль"
    Когда Месяц(Период.Месяц) = 8 Тогда "Август"
    Когда Месяц(Период.Месяц) = 9 Тогда "Сентябрь"
    Когда Месяц(Период.Месяц) = 10 Тогда "Октябрь"
    Когда Месяц(Период.Месяц) = 11 Тогда "Ноябрь"
    Когда Месяц(Период.Месяц) = 12 Тогда "Декабрь"
Конец</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Период.Год</dataPath>
			<field>ПериодГод</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Год</v8:content>
				</v8:item>
			</title>
			<presentationExpression>Формат(Период.Год, "ДФ=yyyy") + " год"</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Период.МесяцГода</dataPath>
			<field>ПериодМесяцГода</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Месяц года</v8:content>
				</v8:item>
			</title>
			<presentationExpression>Выбор 
    Когда Месяц(Период.МесяцГода) = 1 Тогда "Январь " + Формат(Период.Год, "ДФ=yyyy")
    Когда Месяц(Период.МесяцГода) = 2 Тогда "Февраль " + Формат(Период.Год, "ДФ=yyyy")
    Когда Месяц(Период.МесяцГода) = 3 Тогда "Март " + Формат(Период.Год, "ДФ=yyyy")
    Когда Месяц(Период.МесяцГода) = 4 Тогда "Апрель " + Формат(Период.Год, "ДФ=yyyy")
    Когда Месяц(Период.МесяцГода) = 5 Тогда "Май " + Формат(Период.Год, "ДФ=yyyy")
    Когда Месяц(Период.МесяцГода) = 6 Тогда "Июнь " + Формат(Период.Год, "ДФ=yyyy")
    Когда Месяц(Период.МесяцГода) = 7 Тогда "Июль " + Формат(Период.Год, "ДФ=yyyy")
    Когда Месяц(Период.МесяцГода) = 8 Тогда "Август " + Формат(Период.Год, "ДФ=yyyy")
    Когда Месяц(Период.МесяцГода) = 9 Тогда "Сентябрь " + Формат(Период.Год, "ДФ=yyyy")
    Когда Месяц(Период.МесяцГода) = 10 Тогда "Октябрь " + Формат(Период.Год, "ДФ=yyyy")
    Когда Месяц(Период.МесяцГода) = 11 Тогда "Ноябрь " + Формат(Период.Год, "ДФ=yyyy")
    Когда Месяц(Период.МесяцГода) = 12 Тогда "Декабрь " + Формат(Период.Год, "ДФ=yyyy")
Конец
</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Выставлена</dataPath>
			<field>Выставлена</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ОценкиКачестваОбученияСУО.ПроведениеОбучения КАК ПроведениеОбучения,
	ОценкиКачестваОбученияСУО.Участник КАК Участник,
	ОценкиКачестваОбученияСУО.Оценка КАК Оценка,
	ОценкиКачестваОбученияСУО.ДатаВыставления КАК ДатаВыставления,
	ОценкиКачестваОбученияСУО.Комментарий КАК Комментарий,
	НАЧАЛОПЕРИОДА(ОценкиКачестваОбученияСУО.ДатаВыставления, ГОД) КАК ПериодГод,
	НАЧАЛОПЕРИОДА(ОценкиКачестваОбученияСУО.ДатаВыставления, МЕСЯЦ) КАК ПериодМесяц,
	НАЧАЛОПЕРИОДА(ОценкиКачестваОбученияСУО.ДатаВыставления, МЕСЯЦ) КАК ПериодМесяцГода,
	ОценкиКачестваОбученияСУО.Выставлена КАК Выставлена
ИЗ
	РегистрСведений.ОценкиКачестваОбученияСУО КАК ОценкиКачестваОбученияСУО</query>
	</dataSet>

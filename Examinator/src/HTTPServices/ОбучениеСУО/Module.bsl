	ИдентификаторФайла     = Запрос.ПараметрыURL.Получить("ИдентификаторФайла");	
	ИмяФайла               = "";

	// Примечание: в УдалитьФайлPOST аналогичный алгоритм поиска файла
	
	Если ТипВладельца = "common" Тогда
		
		Файл = Справочники.Файлы.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторФайла));
		

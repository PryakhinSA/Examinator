	ТаблицаКонтактныхДанных = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(МассивПользователей);
	ТаблицаКонтактныхДанных.Колонки.Найти("Объект").Имя = "Ссылка";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 

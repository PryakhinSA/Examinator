	<calculatedField>
		<dataPath>ВремяПрохожденияВМинутах</dataPath>
		<expression>ВремяПрохожденияВСекундах / 60</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Время в минутах</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>

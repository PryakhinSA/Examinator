			<dataPath>СсылкаНаОбъектСУЗ</dataPath>
			<field>СсылкаНаОбъектСУЗ</field>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
			<attributeUseRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</attributeUseRestriction>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	РубрикиОбъектовСУЗ.Рубрикатор,
	РубрикиОбъектовСУЗ.ЭлементРубрикатора,
	РубрикиОбъектовСУЗ.СсылкаНаОбъектСУЗ
ИЗ
	РегистрСведений.РубрикиОбъектовСУЗ КАК РубрикиОбъектовСУЗ</query>
	</dataSet>
	<dataSetLink>
		<sourceDataSet>Вопросы</sourceDataSet>
		<destinationDataSet>ВариантыОтветов</destinationDataSet>
		<sourceExpression>Вопрос</sourceExpression>
		<destinationExpression>Вопрос</destinationExpression>

// Отправляет разработчику анонимную статистику использования продукта.
// Данная процедура не передает никакую персональную информацию.
// Она необходима, чтобы сделать продукт лучше.
// Пожалуйста, не модифицируйте данную процедуру.
// При необходимости отключите ее вызовы полностью,
// это не повлияет на функциональность продукта.
//
Процедура ОтправитьСтатистикуИспользования(ИмяСобытия) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВерсияФорматаДанных = "1";
	
	// Получаем данные для сохранения
	//
	
	СтруктураДанных = Новый Структура;
	
	// Событие
	
	СтруктураДанных.Вставить("Событие", Новый Структура("Дата, Имя, Версия", ТекущаяДатаСеанса(), ИмяСобытия, ВерсияФорматаДанных));
	
	// Конфигурация
	
	СтруктураДанных.Вставить("Конфигурация", Новый Структура("Имя, Версия", Метаданные.Имя, Метаданные.Версия));	
	
	// База
	
	СтруктураДанных.Вставить("База", Новый Структура);	
	
	СтруктураДанных.База.Вставить("ИдентификаторБазы", СтандартныеПодсистемыСервер.ИдентификаторИнформационнойБазы());
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	СтруктураДанных.База.Вставить("ФункциональныйПрофиль", Новый Структура);
	
	СтруктураДанных.База.ФункциональныйПрофиль.Вставить("Экзаменатор", ПолучитьФункциональнуюОпцию("ЭкзаменаторЭР"));
	СтруктураДанных.База.ФункциональныйПрофиль.Вставить("ПолныйИнтерфейс", ПолучитьФункциональнуюОпцию("ПолныйИнтерфейсСУО"));
	СтруктураДанных.База.ФункциональныйПрофиль.Вставить("ОбразовательнаяОрганизация", ПолучитьФункциональнуюОпцию("ОбразовательнаяОрганизацияОО"));
	
	//----------------------------------//
	
	СтруктураДанных.База.Вставить("ИнформационнаяБазаФайловая", ОбщегоНазначения.ИнформационнаяБазаФайловая());
	
	// Платформа и система
	
	СтруктураДанных.Вставить("Платформа", Новый Структура);
	
	СистемнаяИнформация = Новый СистемнаяИнформация();

	
	СтруктураДанных.Платформа.Вставить("ЭтоУчебнаяПлатформа", СтандартныеПодсистемыСервер.ЭтоУчебнаяПлатформа());
	СтруктураДанных.Платформа.Вставить("ВерсияОС", СистемнаяИнформация.ВерсияОС);
	СтруктураДанных.Платформа.Вставить("ВерсияПриложения", СистемнаяИнформация.ВерсияПриложения);
	СтруктураДанных.Платформа.Вставить("ИдентификаторКлиента", СистемнаяИнформация.ИдентификаторКлиента);
	СтруктураДанных.Платформа.Вставить("ИнформацияПрограммыПросмотра", СистемнаяИнформация.ИнформацияПрограммыПросмотра);
	СтруктураДанных.Платформа.Вставить("ОперативнаяПамять", СистемнаяИнформация.ОперативнаяПамять);
	СтруктураДанных.Платформа.Вставить("Процессор", СистемнаяИнформация.Процессор);
	СтруктураДанных.Платформа.Вставить("ТипПлатформы", СистемнаяИнформация.ТипПлатформы);
	
	// Веб-кабинет
	
	СтруктураДанных.Вставить("ВебКабинет", Неопределено);
	
	Если ВебКабинетСУ.Используется() Тогда
		
		СтруктураДанных.ВебКабинет = Новый Структура;
		
		ПубликацииВебКабинета = Новый Массив;		
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПубликацииВебКабинетаСУ.АдресВебСервера КАК Адрес,
			|	ПубликацииВебКабинетаСУ.РегистрационныйНомер КАК Номер
			|ИЗ
			|	Справочник.ПубликацииВебКабинетаСУ КАК ПубликацииВебКабинетаСУ";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ПубликацииВебКабинета.Добавить(Новый Структура("АдресВебСервера, РегистрационныйНомер", ВыборкаДетальныеЗаписи.Адрес, ВыборкаДетальныеЗаписи.Номер));
		КонецЦикла;
	
		СтруктураДанных.ВебКабинет.Вставить("Публикации", ПубликацииВебКабинета);
		
	КонецЕсли;	
	
	// Пользователь
	
	СтруктураДанных.Вставить("Пользователь", Неопределено);
	
	ТекущийПользователь = Пользователи.ТекущийПользователь();
	
	Если ЗначениеЗаполнено(ТекущийПользователь) Тогда
		
		СтруктураДанных.Пользователь = Новый Структура;
		
		СтруктураДанных.Пользователь.Вставить("Идентификатор", Пользователи.ТекущийПользователь().УникальныйИдентификатор());
		
		//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
		
		СтруктураДанных.Пользователь.Вставить("БазовыеРоли", Новый Массив);
		
		ПраваПользователя = ОбучениеСУОПовтИсп.СписокБазовыхПравПользователя();
		
		Для каждого Роль Из ПраваПользователя Цикл	
			СтруктураДанных.Пользователь.БазовыеРоли.Добавить(ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(Роль));	
		КонецЦикла;	

		//----------------------------------//		
		
	КонецЕсли;
	
	// Электронные ресурсы
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ СводыЗнанийСУЗ.Ссылка) КАК Количество
		|ИЗ
		|	Справочник.СводыЗнанийСУЗ КАК СводыЗнанийСУЗ
		|ГДЕ
		|	СводыЗнанийСУЗ.ПометкаУдаления = ЛОЖЬ
		|	И СводыЗнанийСУЗ.ЭтоГруппа = ЛОЖЬ";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	СтруктураДанных.Вставить("ЭлектронныеРесурсы", Новый Структура);
	СтруктураДанных.ЭлектронныеРесурсы.Вставить("Количество", ВыборкаДетальныеЗаписи.Количество);
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	// Обучение
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПроведениеОбученияСУО.Ссылка) КАК Количество
		|ИЗ
		|	Документ.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО
		|ГДЕ
		|	ПроведениеОбученияСУО.ПометкаУдаления = ЛОЖЬ
		|	И ПроведениеОбученияСУО.Проведен = ИСТИНА";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	СтруктураДанных.Вставить("Обучение", Новый Структура);
	СтруктураДанных.Обучение.Вставить("КоличествоПроведений", ВыборкаДетальныеЗаписи.Количество);	
	
	//----------------------------------//
	
	// Отсылаем данные
	//
	
	СтруктураДанныхJSON = ОбщегоНазначенияСУ.ДанныеВJSON(СтруктураДанных);	
	
	СтруктураURI = ОбщегоНазначенияКлиентСервер.СтруктураURI("https://sdo.1c.ru/conf/statistics/base/hs/put/data");	
	HTTPСоединение = Новый HTTPСоединение(СтруктураURI.Хост, СтруктураURI.Порт,,,, 10, Новый ЗащищенноеСоединениеOpenSSL()); 
		
	HTTPЗапрос = Новый HTTPЗапрос(СтруктураURI.ПутьНаСервере);
	HTTPЗапрос.УстановитьТелоИзСтроки(СтруктураДанныхJSON, КодировкаТекста.UTF8);
	
	Попытка
		ОтветСервера = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	Исключение
		// Не требуется
	КонецПопытки;	
	
	
КонецПроцедуры

// Выполняет обновление до версии 3.0.1.50
// 
//
Процедура ВыполнитьОбновлениеДоВерсии30150() Экспорт
	
	// Заполняем начальные данные СУО (в прошлых версиях была ошибка с их отсутствием)
	//
	
	ДвоичныеДанные = ПолучитьОбщийМакет(Метаданные.ОбщиеМакеты.ДанныеНачальногоЗаполненияСУО);
	
	ПутьКВременномуФайлуXML = ПолучитьИмяВременногоФайла(".xml");
	
	ДвоичныеДанные.Записать(ПутьКВременномуФайлуXML);
	
	ЧтениеXML = Новый ЧтениеXML();
	ЧтениеXML.ОткрытьФайл(ПутьКВременномуФайлуXML);		
	
	Пока ЧтениеXML.Прочитать() Цикл
		
		Пока ВозможностьЧтенияXML(ЧтениеXML) Цикл 
			
			ТекущийОбъект = ПрочитатьXML(ЧтениеXML);
			ТекущийОбъект.ОбменДанными.Загрузка = Истина;
			ТекущийОбъект.Записать();
			
		КонецЦикла;	
		
	КонецЦикла;	
	
	ЧтениеXML.Закрыть();  		
	
	УдалитьФайлы(ПутьКВременномуФайлуXML);	
	
	// Устанавливаем реквизиты БезСценария и НаОсновеМероприятия
	//
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПроведениеОбученияСУО.Ссылка,
		|	ПроведениеОбученияСУО.НаОсновеЭлектронногоРесурса,
		|	ПроведениеОбученияСУО.НаОсновеМероприятия,
		|	ПроведениеОбученияСУО.БезСценария
		|ИЗ
		|	Документ.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ВыборкаДетальныеЗаписи.НаОсновеЭлектронногоРесурса
			ИЛИ ВыборкаДетальныеЗаписи.НаОсновеМероприятия
			ИЛИ ВыборкаДетальныеЗаписи.БезСценария Тогда
			
			Продолжить; // Если хотя бы одно значение установлено, значит обновление было уже сделано ранее
			
		КонецЕсли;
		
		ДокументОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		
		ДокументОбъект.НаОсновеМероприятия = Истина;
		
		Попытка
			ДокументОбъект.Записать();
		Исключение
		КонецПопытки;

	КонецЦикла;
	
	// Устанавливаем статус документов ПроведениеМероприятияСУО (при обновлении с Экзаменатора)
	//
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПроведениеОбученияСУО.Ссылка
		|ИЗ
		|	Документ.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО";

	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	Для каждого Результат Из МассивРезультатов Цикл
	
		ВыборкаДетальныеЗаписи = Результат.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ДокументОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			
			Если ЗначениеЗаполнено(ДокументОбъект.Статус) Тогда
				Продолжить;
			КонецЕсли;
			
			ДокументОбъект.Статус = Перечисления.СтатусыПроведенияОбъектовСУО.Активно;
			
			Попытка
				ДокументОбъект.Записать();
			Исключение
			КонецПопытки;
			
		КонецЦикла;
	
	КонецЦикла;
	
	// Заполняем реквизит Сценарий для прохождений обучения и проведения обучения преподавателем.
	//
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрохождениеОбученияСУО.Ссылка,
		|	ПрохождениеОбученияСУО.ПроведениеОбучения
		|ИЗ
		|	Документ.ПрохождениеОбученияСУО КАК ПрохождениеОбученияСУО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПроведениеПреподавателемОбученияСУО.Ссылка,
		|	ПроведениеПреподавателемОбученияСУО.ПроведениеОбучения
		|ИЗ
		|	Документ.ПроведениеПреподавателемОбученияСУО КАК ПроведениеПреподавателемОбученияСУО";

	МассивРезультатов = Запрос.ВыполнитьПакет(); // Выбираем все документы, а не только проведенные
	
	Для каждого Результат Из МассивРезультатов Цикл
	
		ВыборкаДетальныеЗаписи = Результат.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ДокументОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			
			Если ЗначениеЗаполнено(ДокументОбъект.Сценарий) Тогда
				Продолжить; // Если заполнено, то пропускаем
			КонецЕсли;
			
			ДокументОбъект.Сценарий = Документы.ПроведениеОбученияСУО.СценарийОбучения(ВыборкаДетальныеЗаписи.ПроведениеОбучения);
				
			РежимЗаписи = РежимЗаписиДокумента.Запись; // Будет проведен ниже
				
			Попытка
				ДокументОбъект.Записать(РежимЗаписи);
			Исключение
			КонецПопытки;
			
		КонецЦикла;
	
	КонецЦикла;	
	
	// Устанавливаем реквизит РодительскоеПроведение в документе проведения обучения преподавателем.
	// В редакции 2.0 была ошибка с тем, что при зачислении преподавателя не проставлялся этот реквизит.
	//
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПроведениеПреподавателемОбученияСУО.Ссылка,
		|	ПроведениеПреподавателемОбученияСУО.Проведен,
		|	ПроведениеПреподавателемОбученияСУО.ПроведениеОбучения,
		|	ПроведениеПреподавателемОбученияСУО.Сценарий КАК Мероприятие,
		|	ПроведениеПреподавателемОбученияСУО.Пользователь КАК Преподаватель,
		|	ПроведениеПреподавателемОбученияСУО.Сценарий.Владелец.Мероприятие КАК ОбщееМероприятие
		|ИЗ
		|	Документ.ПроведениеПреподавателемОбученияСУО КАК ПроведениеПреподавателемОбученияСУО
		|ГДЕ
		|	ПроведениеПреподавателемОбученияСУО.РодительскоеПроведение = ЗНАЧЕНИЕ(Документ.ПроведениеПреподавателемОбученияСУО.ПустаяСсылка)
		|	И ПроведениеПреподавателемОбученияСУО.Сценарий.Владелец.Предопределенный = ЛОЖЬ
		|	И ТИПЗНАЧЕНИЯ(ПроведениеПреподавателемОбученияСУО.Сценарий) = ТИП(Справочник.КаталогМероприятийСУО)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ПроведениеПреподавателемОбученияОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		
		ПроведениеПреподавателемОбученияОбъект.РодительскоеПроведение = Документы.ПроведениеОбученияСУО.ПроведениеОбученияПреподавателем(ВыборкаДетальныеЗаписи.ПроведениеОбучения, ВыборкаДетальныеЗаписи.ОбщееМероприятие, ВыборкаДетальныеЗаписи.Преподаватель);
		
		Если ВыборкаДетальныеЗаписи.Проведен Тогда
			ПроведениеПреподавателемОбученияОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Иначе
			ПроведениеПреподавателемОбученияОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;		
		
	КонецЦикла;	
	
	// Устанавливаем реквизит ЗавершатьАвтоматически у вида обучения
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВидыМероприятийСУО.Ссылка
		|ИЗ
		|	Справочник.ВидыМероприятийСУО КАК ВидыМероприятийСУО
		|ГДЕ
		|	ВидыМероприятийСУО.ТребуетсяПреподаватель = ЛОЖЬ
		|	И ВидыМероприятийСУО.Электронное = ИСТИНА
		|	И ВидыМероприятийСУО.Общее = ЛОЖЬ";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ВидОбученияОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		ВидОбученияОбъект.ЗавершатьАвтоматически = Истина;
		ВидОбученияОбъект.Записать();
		
	КонецЦикла;	
	
	// Перепроводим документы
	//
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОтветНаВопросСУЗ.Ссылка
		|ИЗ
		|	Документ.ОтветНаВопросСУЗ КАК ОтветНаВопросСУЗ
		|ГДЕ
		|	ОтветНаВопросСУЗ.Проведен = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПроведениеОбученияСУО.Ссылка
		|ИЗ
		|	Документ.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО
		|ГДЕ
		|	ПроведениеОбученияСУО.Проведен = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПрохождениеОбученияСУО.Ссылка
		|ИЗ
		|	Документ.ПрохождениеОбученияСУО КАК ПрохождениеОбученияСУО
		|ГДЕ
		|	ПрохождениеОбученияСУО.Проведен = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПроведениеПреподавателемОбученияСУО.Ссылка
		|ИЗ
		|	Документ.ПроведениеПреподавателемОбученияСУО КАК ПроведениеПреподавателемОбученияСУО
		|ГДЕ
		|	ПроведениеПреподавателемОбученияСУО.Проведен = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СессияЭлектронногоРесурсаСУЗ.Ссылка
		|ИЗ
		|	Документ.СессияЭлектронногоРесурсаСУЗ КАК СессияЭлектронногоРесурсаСУЗ
		|ГДЕ
		|	СессияЭлектронногоРесурсаСУЗ.Проведен = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПопыткаВыполненияПодборкиВопросовСУЗ.Ссылка
		|ИЗ
		|	Документ.ПопыткаВыполненияПодборкиВопросовСУЗ КАК ПопыткаВыполненияПодборкиВопросовСУЗ
		|ГДЕ
		|	ПопыткаВыполненияПодборкиВопросовСУЗ.Проведен = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СообщениеСУО.Ссылка
		|ИЗ
		|	Документ.СообщениеСУО КАК СообщениеСУО
		|ГДЕ
		|	СообщениеСУО.Проведен = ИСТИНА";

	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	Для каждого Результат Из МассивРезультатов Цикл
	
		ВыборкаДетальныеЗаписи = Результат.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ДокументОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			РежимЗаписи = РежимЗаписиДокумента.Проведение;
			
			Попытка
				ДокументОбъект.Записать(РежимЗаписи);
			Исключение
			КонецПопытки;
			
		КонецЦикла;
	
	КонецЦикла;
		
	// Устанавливаем предопределенные данные
	//
	
	ТаблицаЭлементов = Новый ТаблицаЗначений;
	ТаблицаЭлементов.Колонки.Добавить("ИмяСправочника");
	ТаблицаЭлементов.Колонки.Добавить("ИмяПредопределенныхДанных");
	ТаблицаЭлементов.Колонки.Добавить("Ссылка");


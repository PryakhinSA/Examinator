&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "ЭтоГруппа", Истина);
	
	Если Параметры.ВыбратьМодуль Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "Владелец", Справочники.РесурсыСУЗ.Модули);		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "Родитель", Справочники.ФайлыСУЗ.ПустаяСсылка());
		
	КонецЕсли;
	
КонецПроцедуры


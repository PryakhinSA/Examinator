Процедура ПриОпределенииТипПубликацииПоУмолчанию(ТипПубликации) Экспорт	
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	Если ВебКабинетСУ.Используется() Тогда
		
		ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS;
		
	Иначе
		
	//----------------------------------//
		
		ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.HTML;
		
	КонецЕсли;	
	
КонецПроцедуры

Процедура ПриОпределенииДоступныхТиповПубликации(ТипыПубликацииДляИсключения) Экспорт
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	Если ВебКабинетСУ.Используется() Тогда
		
		ИндексТипа = ТипыПубликацииДляИсключения.Найти(Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS);
		
		Если ИндексТипа <> Неопределено Тогда
			ТипыПубликацииДляИсключения.Удалить(ИндексТипа); // Убираем публикацю для ВК из исключенных
		КонецЕсли;		

	КонецЕсли;	
	
	//----------------------------------//
	
КонецПроцедуры


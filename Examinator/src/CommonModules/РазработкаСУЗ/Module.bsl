// ВЕРСИИ ОБЪЕКТОВ

Функция ПоказатьКоличествоВерсийОбъектаНаФорме(Форма, Знач Объект, Знач ТипОбъекта = Неопределено) Экспорт
	                           
	Если ТипОбъекта <> Неопределено Тогда
		
		Если ТипЗнч(ТипОбъекта) = Тип("Строка") Тогда
			ТипОбъекта = Тип(ТипОбъекта);
		КонецЕсли;
		
		Объект = ДанныеФормыВЗначение(Объект, ТипОбъекта);
		
	КонецЕсли;
	
	НаборВерсий = ОбъектыСУЗ.ПолучитьНаборВерсий(Объект.Ссылка);
	
	КоличествоВерсий = НаборВерсий.Количество();
	
	Форма.Элементы.АрхивВерсий.Заголовок = "Архив (" + КоличествоВерсий + ")";
	
	Если КоличествоВерсий = 0 Тогда
		Форма.Элементы.АрхивВерсий.Доступность = Ложь;
	Иначе
		Форма.Элементы.АрхивВерсий.Доступность = Истина;
	КонецЕсли;
	
КонецФункции

// Возвращает предпочитаемого поставщика в ИБ.
//
// Параметры
//  Нет.
//
Функция ПолучитьСтруктуруНовойВерсииОбъекта(Знач Объект, Знач ТипОбъекта) Экспорт
	
	Если Константы.ПоказыватьПоследнююВерсиюСУЗ.Получить() Тогда
		Поставщик = Константы.ПредпочитатьПоставщикаСУЗ.Получить();
	Иначе
		Поставщик = Справочники.ПоставщикиСУЗ.ПустаяСсылка();
	КонецЕсли;		
	
	Если ТипЗнч(ТипОбъекта) = Тип("Строка") Тогда
		ТипОбъекта = Тип(ТипОбъекта);
	КонецЕсли;
	
	ОбъектСУЗ = ДанныеФормыВЗначение(Объект, ТипОбъекта);
	
	Если НЕ ОбъектСУЗ.ЭтоНовый() Тогда
		
		// Ищем, есть ли другие версии от предпочитаемого поставщика.
		
		СтруктураПоследнейВерсии = ОбъектыСУЗ.ПолучитьПоследнююВерсию(ОбъектСУЗ.Ссылка, Поставщик);
		
		Если СтруктураПоследнейВерсии.Поставщик = Поставщик Тогда // Есть версии предпочитаемого поставщика.
			Версия = СтруктураПоследнейВерсии.Версия + 1;
		Иначе
			Версия = 1;
		КонецЕсли;
		
	Иначе
		
		Версия = 1;
		
	КонецЕсли;
	
	СтруктураВерсии = Новый Структура();
	
	СтруктураВерсии.Вставить("Версия", Версия);
	СтруктураВерсии.Вставить("Поставщик", Поставщик);		
	
	Возврат СтруктураВерсии;
	
КонецФункции // ПолучитьСтруктуруНовойВерсииОбъекта()

// Используется при загрузке новой версии данных в форму.
//
// Параметры
// 	Форма  - Форма, где размещен визуальный редактор.
//
Процедура УстановитьДанныеВерсииОбъекта(Форма, Объект, Знач ТипОбъекта, ПерваяЗагрузка) Экспорт
	
	ПоказатьКоличествоВерсийОбъектаНаФорме(Форма, Объект, ТипОбъекта);
	
	ВсеКнопкиДанных = Форма.Элементы.ИмяРедактируемыхДанных.СписокВыбора;
	
	Если Форма.Объект.ИспользуетсяФорматированныйДокумент Тогда
		ИмяДанных = "ФорматированныйДокумент";
	Иначе
		ИмяДанных = "ТекстовыеДанные";
	КонецЕсли;
	
	// Получаем данные версии из базы данных.
	Для каждого ТекКнопка Из ВсеКнопкиДанных Цикл
		
		ДанныеВерсии = ОбъектыСУЗ.ПолучитьДанные(Объект.Ссылка, ТекКнопка.Значение, Ложь, ИмяДанных, Объект.Поставщик, Объект.Версия);
		
		Если Форма.Объект.ИспользуетсяФорматированныйДокумент Тогда
			
			Форма[ТекКнопка.Значение] = ДанныеВерсии;
		
		Иначе
			
			ТекстовыйДокумент = Новый ТекстовыйДокумент();
			ТекстовыйДокумент.УстановитьТекст(ДанныеВерсии);
			
			Форма[ТекКнопка.Значение] = ТекстовыйДокумент;
			
		КонецЕсли;
		
	КонецЦикла;
	
	РазработкаСУЗКлиентСервер.УстановитьЗаголовокДоступныхДанныхВизуальногоРедактора(Форма); 	
	
	Если Форма.Объект.ИспользуетсяФорматированныйДокумент Тогда
		Форма.ФорматированныйДокумент = Форма[Форма.ИмяРедактируемыхДанных]; // Загружаем форматированный документ
	Иначе
		Форма.ТекстовыйДокумент = Форма[Форма.ИмяРедактируемыхДанных]; // Загружаем текстовый документ
	КонецЕсли;
	
	Форма.ИмяЗагруженныхДанных = Форма.ИмяРедактируемыхДанных; // Отмечаем, что данные загружены в визуальный редактор
	
	Если НЕ ПерваяЗагрузка Тогда
		Форма.Модифицированность = Истина;
	КонецЕсли;
		
	Форма.Элементы.Поставщик.ТолькоПросмотр  = Истина;
	Форма.Элементы.Версия.ТолькоПросмотр     = Истина;
	Форма.Элементы.СоздатьВерсию.Доступность = Истина;
	
КонецПроцедуры

Процедура ЗаписатьДанныеВерсииОбъектаСУЗ(Объект, Данные, КодДанных, ИмяРеквизита="ТекстовыеДанные", Поставщик=Неопределено, Версия=Неопределено, РасширениеФайла = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Поставщик = Неопределено Тогда
		Поставщик = Объект.Поставщик;
	КонецЕсли;
	
	Если Версия = Неопределено Тогда
		Версия = Объект.Версия;
	КонецЕсли;	
	
	ИмяРегистраСДанными = ОбъектыСУЗ.ПолучитьИмяРегистраСДанными(Объект.Ссылка);
	НаборЗаписей = РегистрыСведений[ИмяРегистраСДанными].СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.СсылкаНаОбъектСУЗ.Установить(Объект.Ссылка);
	НаборЗаписей.Отбор.Поставщик.Установить(Поставщик);
	НаборЗаписей.Отбор.Версия.Установить(Версия);
	НаборЗаписей.Отбор.КодДанных.Установить(КодДанных);

	НоваяЗапись = НаборЗаписей.Добавить();
	
	ДвоичныеДанныеДляЗаписи = Неопределено;
	
	Если ИмяРеквизита = "ВсеРеквизиты" Тогда
		
		Для каждого ЭлементДанных Из Данные Цикл
			
			Если ЭлементДанных.Ключ = "ДвоичныеДанные" И ТипЗнч(ЭлементДанных.Значение) = Тип("ДвоичныеДанные") Тогда
				ДвоичныеДанныеДляЗаписи = ПоместитьДанныеФайлаВХранилищеЗначения(Объект, ЭлементДанных.Значение);
			Иначе
		    	НоваяЗапись[ЭлементДанных.Ключ] = ЭлементДанных.Значение;
			КонецЕсли;			
		
		КонецЦикла;
		
	Иначе
		
		Если ИмяРеквизита = "ДвоичныеДанные" Тогда
			
			ДвоичныеДанныеДляЗаписи = ПоместитьДанныеФайлаВХранилищеЗначения(Объект, Данные);
			
		ИначеЕсли ИмяРеквизита = "ФорматированныйДокумент"  Тогда			
			
			НоваяЗапись[ИмяРеквизита] = Новый ХранилищеЗначения(Данные);
			
		Иначе			
			
			НоваяЗапись[ИмяРеквизита] = Данные;			
			
		КонецЕсли;
				
	КонецЕсли;
	
	НоваяЗапись.КодДанных = КодДанных;
	НоваяЗапись.СсылкаНаОбъектСУЗ =  Объект.Ссылка;
	НоваяЗапись.Поставщик = Поставщик;
	НоваяЗапись.Версия = Версия;
	
	НоваяЗапись.ДатаИзменения = ТекущаяДата();

	
	Если ДвоичныеДанныеДляЗаписи <> Неопределено Тогда
		
		Если ИмяРегистраСДанными <> "ДанныеФайлыСУЗ" Тогда		
			ВызватьИсключение НСтр("ru = 'Невозможно сохранить двоичные данные в данный объект'");
		КонецЕсли;
		
		Если Объект.ТипФайла = Перечисления.ТипыФайловСУЗ.Video И ХранитьФайлыВБСП() Тогда
		
			// Помещаем двоичные данные в справочник БСП
			
			ПрисоединенныйФайл = РегистрыСведений.ДанныеФайлыСУЗ.ПрисоединенныйФайлЗаписи(НоваяЗапись.СсылкаНаОбъектСУЗ, НоваяЗапись.Поставщик, НоваяЗапись.Версия, НоваяЗапись.КодДанных);
			
			СтруктураИмениФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(Объект.ИмяФайла, Ложь);
			
			Если РасширениеФайла = Неопределено Тогда
				РасширениеБезТочки = ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(СтруктураИмениФайла.Расширение);
			Иначе
				РасширениеБезТочки = ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(РасширениеФайла);
			КонецЕсли;		
			
			Если ЗначениеЗаполнено(ПрисоединенныйФайл) Тогда			
				
				ПрисоединенныеФайлы.ОбновитьПрисоединенныйФайл(
					ПрисоединенныйФайл, 
					Новый Структура(
						"АдресФайлаВоВременномХранилище, АдресВременногоХранилищаТекста, ИмяБезРасширения, ДатаМодификацииУниверсальная, Расширение",					
						ПоместитьВоВременноеХранилище(ДвоичныеДанныеДляЗаписи),
						"",
						СтруктураИмениФайла.ИмяБезРасширения,
						Объект.ДатаИзменения,
						РасширениеБезТочки
					)
				);
				
							
			Иначе
				
				ПрисоединенныйФайл = ПрисоединенныеФайлы.ДобавитьФайл(Объект.Ссылка, СтруктураИмениФайла.ИмяБезРасширения, РасширениеБезТочки, Объект.ДатаИзменения, Объект.ДатаИзменения, ПоместитьВоВременноеХранилище(ДвоичныеДанныеДляЗаписи));
				
			КонецЕсли;
			
			НоваяЗапись.ДвоичныеДанные = Неопределено;
			НоваяЗапись.ПрисоединенныйФайл = ПрисоединенныйФайл;
			
		Иначе
			
			НоваяЗапись.ДвоичныеДанные = Новый ХранилищеЗначения(ДвоичныеДанныеДляЗаписи);
			
		КонецЕсли;
			
		НоваяЗапись.РасширениеФайла = РасширениеБезТочки;
		
	КонецЕсли;
	
	
	НаборЗаписей.Записать();
	
	Если ТипЗнч(Объект.Ссылка) = Тип("СправочникСсылка.ФайлыСУЗ")
		И Объект.ТипФайла = Перечисления.ТипыФайловСУЗ.Video
		И КодДанных = "ДвоичныеДанные" Тогда
		
		// Удаляем другие форматы видео при изменении основного
		
		ФорматыВидео = Справочники.ФайлыСУЗ.ДоступныеФорматыВидео();
		
		Для каждого Формат Из ФорматыВидео Цикл
			
			УдалитьДанныеВерсииОбъектаСУЗ(Объект, Формат, Поставщик, Версия);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьДанныеВерсииОбъектаСУЗ(Объект, КодДанных, Поставщик=Неопределено, Версия=Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	НачатьТранзакцию();
	
	Попытка	
	
		Если ОбщегоНазначения.ЭтоСсылка(ТипЗнч(Объект)) Тогда
			СсылкаНаОбъект = Объект;
		Иначе
			СсылкаНаОбъект = Объект.Ссылка;
		КонецЕсли;
		
		Если Поставщик = Неопределено Тогда
			Поставщик = Объект.Поставщик;
		КонецЕсли;
		
		Если Версия = Неопределено Тогда
			Версия = Объект.Версия;
		КонецЕсли;	
		
		ИмяРегистраСДанными = ОбъектыСУЗ.ПолучитьИмяРегистраСДанными(СсылкаНаОбъект);
		НаборЗаписей = РегистрыСведений[ИмяРегистраСДанными].СоздатьНаборЗаписей();
		
		НаборЗаписей.Отбор.СсылкаНаОбъектСУЗ.Установить(СсылкаНаОбъект);
		НаборЗаписей.Отбор.Поставщик.Установить(Поставщик);
		НаборЗаписей.Отбор.Версия.Установить(Версия);
		НаборЗаписей.Отбор.КодДанных.Установить(КодДанных);
		
		Если ИмяРегистраСДанными = "ДанныеФайлыСУЗ" Тогда
			
			НаборЗаписей.Прочитать();
			
			Для каждого Запись Из НаборЗаписей Цикл
			
				Если ЗначениеЗаполнено(Запись.ПрисоединенныйФайл) Тогда
					ПрисоединенныйФайлОбъект = Запись.ПрисоединенныйФайл.ПолучитьОбъект();
					ПрисоединенныйФайлОбъект.УстановитьПометкуУдаления(Истина, Истина);
				КонецЕсли;			
			
			КонецЦикла;
			
			НаборЗаписей.Очистить();
			
		КонецЕсли;		
		
		НаборЗаписей.Записать();
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ВызватьИсключение;

	КонецПопытки;
		
		
КонецПроцедуры

Функция ВерсияСуществуетВБазеДанных(Знач Объект, Знач ТипОбъекта) Экспорт
	
	Если ТипЗнч(ТипОбъекта) = Тип("Строка") Тогда
		ТипОбъекта = Тип(ТипОбъекта);
	КонецЕсли;
	
	Объект = ДанныеФормыВЗначение(Объект, ТипОбъекта);
	
	ИмяРегистраСДанными = ОбъектыСУЗ.ПолучитьИмяРегистраСДанными(Объект.Ссылка);
	НаборВерсий = РегистрыСведений[ИмяРегистраСДанными].СоздатьНаборЗаписей();
	НаборВерсий.Отбор.СсылкаНаОбъектСУЗ.Установить(Объект.Ссылка);
	НаборВерсий.Отбор.КодДанных.Установить("Описание");
	НаборВерсий.Отбор.Поставщик.Установить(Объект.Поставщик);
	НаборВерсий.Отбор.Версия.Установить(Объект.Версия);
	НаборВерсий.Прочитать();

	Если НаборВерсий.Количество() > 0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции


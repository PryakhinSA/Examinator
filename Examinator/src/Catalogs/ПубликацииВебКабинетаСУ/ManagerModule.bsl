						|	Справочник.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
						|ГДЕ
						|	ЗначенияСвойствОбъектов.Владелец = &Свойство
						|	И ЗначенияСвойствОбъектов.ПометкаУдаления = ЛОЖЬ
						|	И ЗначенияСвойствОбъектов.ЭтоГруппа = ЛОЖЬ";
					
					ЗапросДанных.УстановитьПараметр("Свойство", Строка.Реквизит);
					
					НоваяСтрока.variants = ЗапросДанных.Выполнить().Выгрузить();
					
				//----------------------------------//	
					
				ИначеЕсли ТипРеквизита.СодержитТип(Тип("Булево")) Тогда
					
					НоваяСтрока.typeValue = "boolean";
					НоваяСтрока.variants = NULL;
					
				ИначеЕсли ТипРеквизита.СодержитТип(Тип("Число")) Тогда
					
					НоваяСтрока.typeValue = "number";
					НоваяСтрока.variants = NULL;
					
				ИначеЕсли ТипРеквизита.СодержитТип(Тип("Дата")) Тогда
					
					НоваяСтрока.typeValue = "date";
					НоваяСтрока.variants = NULL;
					
					
				Иначе
					
					НоваяСтрока.typeValue = "string";
					НоваяСтрока.variants = NULL;

				КонецЕсли;					
				
				
			Иначе
				
				НоваяСтрока.typeValue = "string";
				НоваяСтрока.variants = NULL;
				
			КонецЕсли;
			
		КонецЦикла;
		
		НастройкиРегистрации.Вставить("form", ТаблицаПолейРегистрации);
		
		
		НастройкиВосстановленияПароля = Новый Структура;
		НастройкиВосстановленияПароля.Вставить("available", Объект.ДоступноВосстановлениеПароля); 
		НастройкиВосстановленияПароля.Вставить("url", Объект.АдресСтраницыВосстановленияПароля); 
		
		НастройкиАутентификации = Новый Структура;
		
			НастройкиСтандартнойАутентификации = Новый Структура;
			НастройкиСтандартнойАутентификации.Вставить("available", Объект.ДоступнаСтандартнаяАутентификация);
			
			НастройкиПоляЛогин = Новый Структура;
			НастройкиПоляЛогин.Вставить("title", Объект.НаименованиеПоляИмя);
			НастройкиПоляЛогин.Вставить("description", Объект.ОписаниеПоляИмя);
			НастройкиПоляЛогин.Вставить("placeholder", Объект.ОбразецЗаполненияПоляИмя);

			НастройкиСтандартнойАутентификации.Вставить("login", НастройкиПоляЛогин);
			
			НастройкиCASАутентификации = Новый Структура;
			НастройкиCASАутентификации.Вставить("available", Объект.ДоступнаАутентификацияCAS);
			НастройкиCASАутентификации.Вставить("url", Объект.АдресСервераCAS);
			НастройкиCASАутентификации.Вставить("service", Объект.ИмяСервисаCAS);
			НастройкиCASАутентификации.Вставить("name", Объект.ИмяСервераCAS);
			НастройкиCASАутентификации.Вставить("icon", Объект.ИконкаСервераCAS);
			
			НастройкиOpenIDАутентификации = Новый Структура;
			НастройкиOpenIDАутентификации.Вставить("available", Объект.ДоступнаАутентификацияOpenID);
			НастройкиOpenIDАутентификации.Вставить("provider", Объект.АдресПровайдераOpenID);
			НастройкиOpenIDАутентификации.Вставить("cancelAuthProvider", Объект.ОтменятьАутентификациюПровайдераOpenIDПриВыходе);
			НастройкиOpenIDАутентификации.Вставить("checkOnLoad", Объект.ПроверятьАутентификациюПровайдераOpenIDПослеЗагрузкиСтраниц);
			НастройкиOpenIDАутентификации.Вставить("name", Объект.ИмяПровайдераOpenID);
						
		НастройкиАутентификации.Вставить("standard", НастройкиСтандартнойАутентификации); 
		НастройкиАутентификации.Вставить("cas", НастройкиCASАутентификации); 
		НастройкиАутентификации.Вставить("openid", НастройкиOpenIDАутентификации); 
		
	НастройкаПользователей.Вставить("features", Новый Структура("registration, restore, authentication", НастройкиРегистрации, НастройкиВосстановленияПароля, НастройкиАутентификации));
	
		
	НастройкиСтатистики = Новый Структура;
	НастройкиСтатистики.Вставить("available", ЗначениеЗаполнено(Объект.ЧастотаСбораСтатистики));
	НастройкиСтатистики.Вставить("periodicity", Объект.ЧастотаСбораСтатистики);
	

#Если Сервер Тогда
	
Функция Значение(Элемент) Экспорт
	
	Если ТипЗнч(Элемент) = Тип("ПеречислениеСсылка.КатегорииДанныхВебКабинетаСУО") Тогда
		Возврат Элемент;
	КонецЕсли;
	
	Если ТипЗнч(Элемент) = Тип("Строка") Тогда
		Возврат Перечисления.КатегорииДанныхВебКабинетаСУО[ВебКабинетСУ.Перевод(Элемент, "КатегорииДанныхВебКабинетаСУО")];
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

#КонецЕсли
#Область ОписаниеПеременных

&НаКлиенте
Перем ТипОбъектаНаКлиенте; // Тип объекта метаданных в виде строки

&НаСервере
Перем ТипОбъектаНаСервере; // Тип объекта метаданных в виде строки

#КонецОбласти


#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Заполняем переменные
	
	Подборка           = Параметры.Подборка;
	ЭлементПодборки    = Параметры.ЭлементПодборки;
	ЭлементРубрикатора = Параметры.ЭлементРубрикатора;
	ПоставщикРубрики   = Параметры.ПоставщикРубрики;
	ЭлектронныйРесурс  = Параметры.ЭлектронныйРесурс;
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
		ТипЭлектронногоРесурса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлектронныйРесурс, "Тип");
	КонецЕсли;
	
	РазработкаСУЗ.УстановитьРодителяНовогоОбъекта(Объект, Параметры, "СправочникСсылка.ВопросыСУЗ");
	
	РазработкаСУЗ.УстановитьПредпочитаемогоПоставщика(Объект);
	
	Если Объект.Ссылка.Пустая() Тогда
		// Если объект уже записан, то процедура
		// Будет вызвана при загрузки версии.
		ЗагрузитьВерсиюНаСервере(Истина);
	КонецЕсли;

	ВесВопроса = 1;
	
	Если ЗначениеЗаполнено(Параметры.ЭлементПодборки) Тогда
		ВесВопроса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.ЭлементПодборки, "ВесВопроса");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ЭлементРубрикатора) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	РубрикиОбъектовСУЗ.ВесВопроса КАК ВесВопроса
			|ИЗ
			|	РегистрСведений.РубрикиОбъектовСУЗ КАК РубрикиОбъектовСУЗ
			|ГДЕ
			|	РубрикиОбъектовСУЗ.Рубрикатор = &Рубрикатор
			|	И РубрикиОбъектовСУЗ.ЭлементРубрикатора = &ЭлементРубрикатора
			|	И РубрикиОбъектовСУЗ.Поставщик = &Поставщик
			|	И РубрикиОбъектовСУЗ.СсылкаНаОбъектСУЗ = &СсылкаНаОбъектСУЗ";

		Запрос.УстановитьПараметр("Поставщик", Параметры.ПоставщикРубрики);
		Запрос.УстановитьПараметр("Рубрикатор", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.ЭлементРубрикатора, "Владелец"));
		Запрос.УстановитьПараметр("СсылкаНаОбъектСУЗ", Объект.Ссылка);
		Запрос.УстановитьПараметр("ЭлементРубрикатора", Параметры.ЭлементРубрикатора);

		Результат = Запрос.Выполнить();

		ВыборкаДетальныеЗаписи = Результат.Выбрать();

		Если ВыборкаДетальныеЗаписи.Следующий() Тогда
			ВесВопроса = ВыборкаДетальныеЗаписи.ВесВопроса;
		КонецЕсли;
		
	КонецЕсли;
	
	ДанныеНастроек = ХранилищеСистемныхНастроек.Загрузить(ИмяФормы+"/ТекущиеДанные");
	
	Если ДанныеНастроек <> Неопределено Тогда
		ПоказатьДополнительныеТипыВопросов = ДанныеНастроек.Получить("ПоказатьДополнительныеТипыВопросов");
	КонецЕсли;
	
	ДоступныеТипы = Новый Массив();
	ДоступныеТипы.Добавить(Тип("СправочникСсылка.РесурсыСУЗ"));
	
	Элементы.ЭлементActiveX.ОграничениеТипа = Новый ОписаниеТипов(ДоступныеТипы);
	
	Элементы.ВариантыОтветов.ДополнительныеПараметрыСоздания = Новый ФиксированнаяСтруктура(Новый Структура("Подборка", Подборка));
	
	Если Объект.Ссылка.Пустая() Тогда
		ЗаполнитьТаблицуСвязанныхЭлементов();
	КонецЕсли;
	
	// Устанавливаем доступность элементов
	
	УстановитьДоступностьЭлементовФормы();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	ЗагрузитьВерсиюНаСервере(Истина);	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	РазработкаСУЗКлиент.УстановитьКонтекстЭлектронногоРесурса(ЭтотОбъект);
	
	РазработкаСУЗКлиент.УстановитьДоступностьЭлементовВерсииДанных(ЭтотОбъект);

	ЗаполнитьТаблицуСвязанныхЭлементов();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоЗакрытие Тогда
		Возврат;
	КонецЕсли;
	
	Если Модифицированность Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Ссылка)
		И (Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.МногиеИзМногих")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ОдинИзМногих"))
		И НЕ ЕстьВерныйВариант(Объект.Ссылка) Тогда
		
		СтандартнаяОбработка = Ложь;
		Отказ = Истина;
		
		Оповещение = Новый ОписаниеОповещения("ПередЗакрытиемПродолжение", ЭтотОбъект, Параметры);
		ПоказатьВопрос(Оповещение, НСтр("ru = 'Отсутствуют верные варианты ответов. Продолжить?'"), РежимДиалогаВопрос.ДаНет, 0);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемПродолжение(Результат, Параметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ЭтоЗакрытие = Истина;
	    Закрыть();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	РазработкаСУЗКлиент.ИмяРедактируемыхДанныхПриЗаписи(ЭтотОбъект);
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если Объект.ИспользуетсяФорматированныйДокумент Тогда
		
		Если ТипЗнч(Вопрос) <> Тип("ФорматированныйДокумент")  Тогда
			Вопрос = Новый ФорматированныйДокумент;
		КонецЕсли;
		
		Если ТипЗнч(Ответ) <> Тип("ФорматированныйДокумент")  Тогда
			Ответ = Новый ФорматированныйДокумент;
		КонецЕсли;
		
		Если ТипЗнч(Подсказка) <> Тип("ФорматированныйДокумент")  Тогда
			Подсказка = Новый ФорматированныйДокумент;
		КонецЕсли;
		
		Если ТипЗнч(Описание) <> Тип("ФорматированныйДокумент")  Тогда
			Описание = Новый ФорматированныйДокумент;
		КонецЕсли;
		
		РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, Вопрос, "Вопрос", "ФорматированныйДокумент");
		РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, Ответ, "Ответ", "ФорматированныйДокумент");
		РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, Подсказка, "Подсказка", "ФорматированныйДокумент");
		РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, Описание, "Описание", "ФорматированныйДокумент");
		
	Иначе
		
		Если ТипЗнч(Вопрос) = Тип("ТекстовыйДокумент")  Тогда
			ВопросДляСохранения = Вопрос.ПолучитьТекст();
		Иначе
			ВопросДляСохранения = Вопрос;
		КонецЕсли;
		
		Если ТипЗнч(Ответ) = Тип("ТекстовыйДокумент")  Тогда
			ОтветДляСохранения = Ответ.ПолучитьТекст();
		Иначе
			ОтветДляСохранения = Ответ;
		КонецЕсли;
		
		Если ТипЗнч(Подсказка) = Тип("ТекстовыйДокумент")  Тогда
			ПодсказкаДляСохранения = Подсказка.ПолучитьТекст();
		Иначе
			ПодсказкаДляСохранения = Подсказка;
		КонецЕсли;
		
		Если ТипЗнч(Описание) = Тип("ТекстовыйДокумент")  Тогда
			ОписаниеДляСохранения = Описание.ПолучитьТекст();
		Иначе
			ОписаниеДляСохранения = Описание;
		КонецЕсли;
		
		РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, ВопросДляСохранения, "Вопрос", "ТекстовыеДанные");
		РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, ОтветДляСохранения, "Ответ", "ТекстовыеДанные");
		РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, ПодсказкаДляСохранения, "Подсказка", "ТекстовыеДанные");
		РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, ОписаниеДляСохранения, "Описание", "ТекстовыеДанные");
		
	КонецЕсли;
	
	// Сохраняем варианты ответов.
	
	// Примечание: варианты еще сохраняются в форме элемента справочника ВариантыОтветовНаВопросСУЗ после записи
	// Варианта, для версии, которая была последняя сохранена на момент записи варианта.
	
	Для каждого Строка Из ДанныеВариантовОтветов Цикл
		
		СтруктураДанныхВариантов = Новый Структура;
		СтруктураДанныхВариантов.Вставить("ТекстовыеДанные", Строка.Текст);
		СтруктураДанныхВариантов.Вставить("ВерныйКомментарий", Строка.ВерныйКомментарий);
		СтруктураДанныхВариантов.Вставить("ОшибочныйКомментарий", Строка.ОшибочныйКомментарий);
		
		РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, СтруктураДанныхВариантов, Строка.ВариантОтвета, "ВсеРеквизиты");	
	
	КонецЦикла;
	
	// Обновляем другие элементы
	
	Если ЗначениеЗаполнено(ЭлементПодборки) Тогда
		Справочники.ЭлементыПодборкиСУЗ.Перезаписать(ЭлементПодборки, ВесВопроса);	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭлементРубрикатора) Тогда
		РегистрыСведений.РубрикиОбъектовСУЗ.Перезаписать(ЭлементРубрикатора, ПоставщикРубрики, Объект.Ссылка, ВесВопроса);
	КонецЕсли;	
	
	ЗаписатьТаблицуСвязанныхЭлементов();
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	РазработкаСУЗ.ПоказатьКоличествоВерсийОбъектаНаФорме(ЭтотОбъект, ТекущийОбъект);
	
	УстановитьДоступностьЭлементовФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	РазработкаСУЗКлиент.УстановитьДоступностьЭлементовВерсииДанных(ЭтотОбъект);

	Оповестить("ОбъектСУЗЗаписан", Объект.Ссылка, ЭтотОбъект);
	Оповестить("ВопросЗаписан",,ЭтотОбъект);
	
	Если ЗначениеЗаполнено(Подборка) Тогда
		Оповестить("ПодборкаОбновлена", Подборка, ЭтотОбъект);
	КонецЕсли;	
	
КонецПроцедуры


#КонецОбласти



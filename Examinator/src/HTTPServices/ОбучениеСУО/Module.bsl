	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;

	// Получаем данные
	//	
	
	Попытка
		ИмяФорматаОтчета = Запрос.ПараметрыURL.Получить("Формат");
		ИдентификаторВариантаОтчета = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("Отчет"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИмяФорматаОтчета)

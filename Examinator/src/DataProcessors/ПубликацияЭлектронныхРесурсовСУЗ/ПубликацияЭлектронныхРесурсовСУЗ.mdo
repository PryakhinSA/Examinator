    </synonym>
    <type>
      <types>Boolean</types>
    </type>
    <toolTip>
      <key>ru</key>
      <value>Активность пользователя будет сохраняться в браузере и будет загружена при следующем открытии электронного ресурса</value>
    </toolTip>
    <minValue xsi:type="core:UndefinedValue"/>
    <maxValue xsi:type="core:UndefinedValue"/>
  </attributes>

#Если Сервер Тогда
	
Перем КаталогРесурсов;
Перем МассивВыгруженныхОбъектов;
Перем МассивЭлементовСодержания;
Перем МассивСсылок;
Перем МассивРесурсов;
Перем МассивПодборок;
Перем МассивВопросов;
Перем ТаблицаСтраницПодборок;
Перем МассивЭлектронныхКурсов;

// Основное

Функция ВыполнитьПубликацию(УникальныйИдентификаторФормы = Неопределено) Экспорт
	
	// Делаем проверки
		
	Если ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS
		И НЕ ЗначениеЗаполнено(ОбъектыСУЗПовтИсп.ПутьКОбщемуКаталогу()) Тогда
		
		ВызватьИсключение ОбщегоНазначенияСУПовтИсп.ТекстОНеобходимостиНастроитьОбщийКаталог();
		
	КонецЕсли;	
	
	// Получаем переменные
	
	ТаблицаПубликаций = Новый ТаблицаЗначений;
	ТаблицаПубликаций.Колонки.Добавить("ЭлектронныйРесурс");
	ТаблицаПубликаций.Колонки.Добавить("СвойстваПакета");
	
	ДатаПубликации = ТекущаяДатаСеанса();
	
	// Получаем публикации электронных ресурсов (таблица ТаблицаПубликаций)
	
	Для каждого Строка Из ЭлектронныеРесурсы Цикл
		
		ОбъектыСУЗ.ОбновитьДанныеДляИндексирования(Строка.ЭлектронныйРесурс);
		
		ДанныеЭлектронногоРесурса = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Строка.ЭлектронныйРесурс, "Наименование, Версия, Редакция, ДатаИзменения");
		
		СвойстваПакета = Новый Структура("Наименование, ИмяФайлаПакета, Код, Версия, КонтрольнаяСумма, АдресВоВременномХранилище, ДатаИзменения, Размер, КаталогДляСохранения, РазмещениеКнопкиВыхода");
		
		СвойстваПакета.Наименование           = ДанныеЭлектронногоРесурса.Наименование;
		СвойстваПакета.Код                    = Строка(Строка.ЭлектронныйРесурс.УникальныйИдентификатор());
		СвойстваПакета.Версия                 = Строка(ДанныеЭлектронногоРесурса.Редакция) + "." + Строка(ДанныеЭлектронногоРесурса.Версия);
		СвойстваПакета.ДатаИзменения          = ДанныеЭлектронногоРесурса.ДатаИзменения;
		СвойстваПакета.ИмяФайлаПакета         = ОбщегоНазначенияСУКлиентСервер.ЗаменитьЗапрещенныеСимволыВИмениФайла(СвойстваПакета.Наименование);		
		СвойстваПакета.РазмещениеКнопкиВыхода = Строка.РазмещениеКнопкиВыхода;
		
		Если ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS Тогда
	
			СвойстваПакета.КаталогДляСохранения = ПолучитьИмяВременногоФайла("");
			
			СоздатьКаталог(СвойстваПакета.КаталогДляСохранения);
				
		ИначеЕсли ЗначениеЗаполнено(КаталогДляСохранения) Тогда
			
			КаталогДляСохраненияПакета = Новый Файл(КаталогДляСохранения);
			
			Если НЕ КаталогДляСохраненияПакета.Существует() Тогда
				ВызватьИсключение НСтр("ru = 'Каталог для публикации не найден'")
			КонецЕсли;
			
			КаталогДляСохраненияПакета = Новый Файл(КаталогДляСохранения + СвойстваПакета.ИмяФайлаПакета + " (" + СвойстваПакета.Версия + ")");
			
			Если КаталогДляСохраненияПакета.Существует() Тогда
				
				Если УдалитьСтарыеПубликации Тогда
					УдалитьФайлы(КаталогДляСохраненияПакета.ПолноеИмя);
				Иначе
					КаталогДляСохраненияПакета = Новый Файл(ОбщегоНазначенияСУКлиентСервер.УникальноеИмяФайла(КаталогДляСохраненияПакета.ПолноеИмя));
				КонецЕсли;
				
			КонецЕсли;			
				
			СоздатьКаталог(КаталогДляСохраненияПакета.ПолноеИмя);			
			
			СвойстваПакета.КаталогДляСохранения = КаталогДляСохраненияПакета.ПолноеИмя;			
			
		КонецЕсли;
		
		ЭлементыДляЭкспорта = Новый ТаблицаЗначений();
		ЭлементыДляЭкспорта.Колонки.Добавить("СсылкаНаЭлемент");
		
		НоваяСтрока = ЭлементыДляЭкспорта.Добавить(); // Всегда один элемент для электронного ресурса
		НоваяСтрока.СсылкаНаЭлемент = Строка.ЭлектронныйРесурс; 
		
		ДлительныеОперации.СообщитьПрогресс(0,  СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Публикация: %1'"), СвойстваПакета.Наименование));
		
		Если ЭлектронныеРесурсы.Количество() = 1 Тогда
			ОпубликоватьПакетДанных(СвойстваПакета, ЭлементыДляЭкспорта, УникальныйИдентификаторФормы);
		Иначе
			ОпубликоватьПакетДанных(СвойстваПакета, ЭлементыДляЭкспорта, Неопределено);
		КонецЕсли;
		
		НоваяСтрока = ТаблицаПубликаций.Добавить();
		НоваяСтрока.ЭлектронныйРесурс = Строка.ЭлектронныйРесурс;
		НоваяСтрока.СвойстваПакета = СвойстваПакета;
		
	КонецЦикла;
	
	// Записываем результат публикаций
		
	Если ТаблицаПубликаций.Количество() = 0 Тогда
		ВызватьИсключение НСтр("ru = 'Таблица публикаций не заполнена'")
	КонецЕсли;
	
	РезультатПубликаций = Новый Структура("АдресВоВременномХранилище, ИмяФайлаПакета, Версия, КоличествоПубликаций, Размер", Неопределено, "", "", 0, 0);
	
	Если ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS Тогда
		
		НачатьТранзакцию();
		
		Для каждого Строка Из ТаблицаПубликаций Цикл
			
			ДанныеВыгрузки = Строка.СвойстваПакета;
			
			ДлительныеОперации.СообщитьПрогресс(0,  СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Сохранение: %1'"), ДанныеВыгрузки.Наименование));
			
			// Удаляем старые публикации
			
			Если УдалитьСтарыеПубликации Тогда
				
				НаборЗаписей = РегистрыСведений.ПубликацииЭлектронныхРесурсовСУЗ.СоздатьНаборЗаписей();				
				НаборЗаписей.Отбор.ЭлектронныйРесурс.Установить(Строка.ЭлектронныйРесурс);				
				НаборЗаписей.Записать();
				
			КонецЕсли;
			
			// Перемещаем публикацию в общий каталог из временного каталога
		
			ПутьККаталогуВыгрузки = ОбъектыСУЗПовтИсп.ПутьКОбщемуКаталогу();
			
			РезультатИнициализации = ЭлектронныеРесурсыСУЗ.ИнициализироватьКаталогЭлектронногоРесурса(Строка.ЭлектронныйРесурс, ДанныеВыгрузки.КонтрольнаяСумма, ПутьККаталогуВыгрузки, ДанныеВыгрузки.КаталогДляСохранения, УдалитьСтарыеПубликации);
					
			Если НЕ РезультатИнициализации.КаталогИнициализирован Тогда
				
				ТекстСообщения = НСтр("ru = 'Ошибка при копировании данных в общий каталог ""%1"". Причина ошибки: %2'");
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, ПутьККаталогуВыгрузки, РезультатИнициализации.ТекстОшибки);
				ВызватьИсключение ТекстСообщения;
				
			КонецЕсли;
			
			Попытка
				УдалитьФайлы(ДанныеВыгрузки.КаталогДляСохранения);
			Исключение
			КонецПопытки;
			
			// Размещаем данные веб-кабинета
			
			РазмещеныДанныеДляВебКабинета = РегистрыСведений.ПлеерКурсовВебКабинетаСУЗ.ВыгрузитьДанныеДляВебКабинета(
				Строка.ЭлектронныйРесурс, ДанныеВыгрузки.КонтрольнаяСумма, РезультатИнициализации, ДанныеВыгрузки.РазмещениеКнопкиВыхода);
			
			// Сохраняем публикацию в базе
			
			СвойстваСуществующейПубликации = ЭлектронныеРесурсыСУЗ.ПолучитьСвойстваПубликации(Строка.ЭлектронныйРесурс, ДанныеВыгрузки.КонтрольнаяСумма); 
			
			Если СвойстваСуществующейПубликации <> Неопределено Тогда
				НаборЗаписей = РегистрыСведений.ПубликацииЭлектронныхРесурсовСУЗ.СоздатьНаборЗаписей();				
				НаборЗаписей.Отбор.ЭлектронныйРесурс.Установить(Строка.ЭлектронныйРесурс);
				НаборЗаписей.Отбор.Период.Установить(СвойстваСуществующейПубликации.Период);
				НаборЗаписей.Записать(); // Удаляем старую запись о публикации
			КонецЕсли;
			
			СвойстваСуществующейПубликации = Неопределено;
			
			НаборЗаписей = РегистрыСведений.ПубликацииЭлектронныхРесурсовСУЗ.СоздатьНаборЗаписей();
			
			НаборЗаписей.Отбор.ЭлектронныйРесурс.Установить(Строка.ЭлектронныйРесурс);
			НаборЗаписей.Отбор.Период.Установить(ДатаПубликации);
			
			НоваяЗапись = НаборЗаписей.Добавить();
				
			НоваяЗапись.ЭлектронныйРесурс             = Строка.ЭлектронныйРесурс;
			НоваяЗапись.Период                        = ДатаПубликации;	
			НоваяЗапись.КонтрольнаяСумма              = ДанныеВыгрузки.КонтрольнаяСумма;
			НоваяЗапись.ДатаЭлектронногоРесурса       = ДанныеВыгрузки.ДатаИзменения;
			НоваяЗапись.Версия                        = ДанныеВыгрузки.Версия;
			НоваяЗапись.Наименование                  = ДанныеВыгрузки.Наименование;
			НоваяЗапись.Размер                        = ДанныеВыгрузки.Размер;
			НоваяЗапись.Описание                      = Описание;
			НоваяЗапись.РазмещениеКнопкиВыхода        = ДанныеВыгрузки.РазмещениеКнопкиВыхода;			
			НоваяЗапись.РазмещеныДанныеДляВебКабинета = РазмещеныДанныеДляВебКабинета;	
			
			НаборЗаписей.Записать();					
			
			// Сохраняем информацию о размере
			
			РезультатПубликаций.Размер = РезультатПубликаций.Размер + ДанныеВыгрузки.Размер;
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
		РезультатПубликаций.КоличествоПубликаций = ТаблицаПубликаций.Количество();
		
	Иначе
		
		Если НЕ ЗначениеЗаполнено(КаталогДляСохранения) Тогда
		
			ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru = 'Упаковка...'"));
			
			Если ТаблицаПубликаций.Количество() = 1 Тогда
				
				РезультатПубликаций.КоличествоПубликаций      = 1;
				РезультатПубликаций.АдресВоВременномХранилище = ТаблицаПубликаций[0].СвойстваПакета.АдресВоВременномХранилище;
				РезультатПубликаций.ИмяФайлаПакета            = ТаблицаПубликаций[0].СвойстваПакета.ИмяФайлаПакета;
				РезультатПубликаций.Версия                    = ТаблицаПубликаций[0].СвойстваПакета.Версия;
				РезультатПубликаций.Размер                    = ТаблицаПубликаций[0].СвойстваПакета.Размер;
				
			Иначе
			
				ВременныйКаталогПубликаций = ПолучитьИмяВременногоФайла();
				
				СоздатьКаталог(ВременныйКаталогПубликаций);
				
				ВременныйКаталогПубликаций = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(ВременныйКаталогПубликаций);
				
				Для каждого Строка Из ТаблицаПубликаций Цикл
				
					ДвоичныеДанныеПакета = ПолучитьИзВременногоХранилища(Строка.СвойстваПакета.АдресВоВременномХранилище);
					
					ДвоичныеДанныеПакета.Записать(ВременныйКаталогПубликаций + Строка.СвойстваПакета.ИмяФайлаПакета + " (" + Строка.СвойстваПакета.Версия + ")" + ".zip");
					
				КонецЦикла;
				
				ИмяАрхива = ПолучитьИмяВременногоФайла(".zip");
					
				Архиватор = Новый ЗаписьZipФайла(ИмяАрхива);
					
				Архиватор.Добавить(ВременныйКаталогПубликаций + "*", РежимСохраненияПутейZIP.СохранятьОтносительныеПути, РежимОбработкиПодкаталоговZIP.ОбрабатыватьРекурсивно);
				Архиватор.Записать();
				
				ДвоичныеДанныеАрхива = Новый ДвоичныеДанные(ИмяАрхива);
				
				РезультатПубликаций.АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанныеАрхива, УникальныйИдентификаторФормы);
				РезультатПубликаций.ИмяФайлаПакета            = НСтр("ru = 'Электронные ресурсы'") + " - " +ОбщегоНазначенияСУКлиентСервер.ЗаменитьЗапрещенныеСимволыВИмениФайла(Формат(ДатаПубликации, "ДФ=yyyy-MM-dd"));			
				РезультатПубликаций.Размер                    = ДвоичныеДанныеАрхива.Размер();
				
				Попытка
					УдалитьФайлы(ВременныйКаталогПубликаций);
					УдалитьФайлы(ИмяАрхива);
				Исключение
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЕсли;
			
	КонецЕсли;
		
	Возврат РезультатПубликаций;
	
КонецФункции

Процедура ОпубликоватьПакетДанных(СвойстваПакета, ЭлементыДляЭкспорта, УникальныйИдентификаторФормы) Экспорт	
	
	// Переменные
	//
	
	// Обнуляем переменные модуля
	
	МассивВыгруженныхОбъектов  = Новый Массив;
	МассивЭлементовСодержания  = Новый Массив;
	МассивСсылок               = Новый Массив;
	МассивРесурсов             = Новый Массив;
	МассивПодборок             = Новый Массив;
	МассивВопросов             = Новый Массив;
	МассивПрограммныхПродуктов = Новый Массив;
	МассивЭлектронныхКурсов    = Новый Массив;
	
	ТаблицаСтраницПодборок = Новый ТаблицаЗначений;
	ТаблицаСтраницПодборок.Колонки.Добавить("Подборка");
	ТаблицаСтраницПодборок.Колонки.Добавить("НомерСтраницы");
	ТаблицаСтраницПодборок.Колонки.Добавить("СсылкаНаСтраницу");
	ТаблицаСтраницПодборок.Колонки.Добавить("СсылкаНаОбъектСУЗ");
	ТаблицаСтраницПодборок.Колонки.Добавить("ВесВопроса");
	ТаблицаСтраницПодборок.Колонки.Добавить("ЭтоГруппа");
	ТаблицаСтраницПодборок.Колонки.Добавить("Подгруппы");
	ТаблицаСтраницПодборок.Колонки.Добавить("КоличествоВопросов");
	ТаблицаСтраницПодборок.Колонки.Добавить("ТипЭлемента");
	ТаблицаСтраницПодборок.Колонки.Добавить("ЭлементПодборкиИзРубрикатора");
	
	// Дополнительные переменные
	
	ПоказыватьПоследнююВерсию = Константы.ПоказыватьПоследнююВерсиюСУЗ.Получить();
	
	Если ПоказыватьПоследнююВерсию Тогда
		ПредпочитаемыйПоставщикБазы = Константы.ПредпочитатьПоставщикаСУЗ.Получить();
	Иначе
		ПредпочитаемыйПоставщикБазы = Неопределено;
	КонецЕсли;
	
	АвтоРубрикатор = Справочники.РубрикаторыСУЗ.ПолучитьСсылку(Новый УникальныйИдентификатор(СвойстваПакета.Код));
	Если НЕ ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(АвтоРубрикатор, Ложь) Тогда
		АвтоРубрикатор = Неопределено;
	КонецЕсли;
	
	// Создаем каталоги
	//	
	
	Если ЗначениеЗаполнено(СвойстваПакета.КаталогДляСохранения) Тогда		
		РабочийКаталог = СвойстваПакета.КаталогДляСохранения;
	Иначе		
		РабочийКаталог = ПолучитьИмяВременногоФайла("");		
	КонецЕсли;		

	ДобавитьСлешЕслиНужно(РабочийКаталог);
	
	СоздатьКаталог(РабочийКаталог);		
	
	Если ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.HTML И ВключитьБраузер Тогда
	
		КаталогКонтента = РабочийКаталог + "content\"; 
		
		КаталогКонтента = ОбщегоНазначенияСУКлиентСервер.ПривестиСлэши(КаталогКонтента);
		
		СоздатьКаталог(КаталогКонтента);
		
	Иначе
		
		КаталогКонтента = РабочийКаталог;
		
	КонецЕсли;		
	
	КаталогРесурсов = КаталогКонтента + "res\"; // Переменная модуля
	КаталогРесурсов = ОбщегоНазначенияСУКлиентСервер.ПривестиСлэши(КаталогРесурсов);	
	
	КаталогДанных   = КаталогКонтента + "data\";
	КаталогДанных   = ОбщегоНазначенияСУКлиентСервер.ПривестиСлэши(КаталогДанных);	
	
	СоздатьКаталог(КаталогДанных);
	
	// Распаковываем файлы проигрывателя
	//
	
	// Общий шаблон плеера
	
	Если ДляТестирования Тогда
		ДвоичныеДанныеШаблона = ПолучитьМакет("ШаблонДляТестирования");
	Иначе
		ДвоичныеДанныеШаблона = ПолучитьМакет("Шаблон");
	КонецЕсли;
	
	ПутьКАрхивуШаблона    = КаталогКонтента + "template.zip";
	

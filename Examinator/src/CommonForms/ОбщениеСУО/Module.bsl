&НаКлиенте
Процедура ПрикрепитьФайл(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПрикрепитьФайлПродолжение", ЭтотОбъект);
	
	ОткрытьФорму("ОбщаяФорма.ЗагрузкаФайловСУ", Новый Структура("УникальныйИдентификаторФормыВладельца, ИнформацияОПрикрепленныхФайлах", УникальныйИдентификатор, ИнформацияОПрикрепленныхФайлах),,,,,ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПрикрепитьФайлПродолжение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	МассивПрикрепленныхФайлов = Новый Массив;
	
	Для каждого Строка Из РезультатЗакрытия Цикл
		
		ОписаниеФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(Строка.ПолноеИмя);
		ОписаниеФайла.Вставить("Адрес", Строка.АдресВХранилище);
		
		МассивПрикрепленныхФайлов.Добавить(ОписаниеФайла);
	
	КонецЦикла;
	
	ИнформацияОПрикрепленныхФайлах = Новый ФиксированныйМассив(МассивПрикрепленныхФайлов); // Запоминаем в реквизите формы
	
	Элементы.ИнформацияОПрикрепленномФайле.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Прикреплено файлов: %1'"), ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(ИнформацияОПрикрепленныхФайлах.Количество()));
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьСообщение(Команда)
	
	Оповещение = Новый ОписаниеОповещения("ОбработкаВопросаОбОчисткеСообщения", ЭтотОбъект);
	
	ПоказатьВопрос(Оповещение, НСтр("ru = 'Очистить новое сообщение?'"), РежимДиалогаВопрос.ДаНет, 0);

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВопросаОбОчисткеСообщения(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
	    Возврат;
	КонецЕсли;	
	
	Сообщение.Удалить();
	ИнформацияОПрикрепленномФайле = Неопределено;
	Элементы.ИнформацияОПрикрепленномФайле.Заголовок = "";
	
КонецПроцедуры


&НаКлиенте
Процедура ДобавитьУчастника(Команда)
	
	Тема = ТекущаяТема;
	
	Оповещение = Новый ОписаниеОповещения("ОбработкаВыбораУчастникаДляДобавления", ЭтотОбъект, Тема);
	ПараметрыФормы = Новый Структура("РежимВыбора", Истина);
	
	ОткрытьФорму("Справочник.Пользователи.ФормаВыбора", ПараметрыФормы,,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбораУчастникаДляДобавления(ВыбранныйПользователь, Тема) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ВыбранныйПользователь) Тогда
		Возврат;
	КонецЕсли;
	
	ДобавитьИлиИсключитьУчастникаОбсуждения(Тема, ВыбранныйПользователь, "Добавить");
	
	Элементы.Участники.Обновить();
	
	ТекстПредупреждения = НСтр("ru = 'Пользователь ""%1"" добавлен к обсуждению'");
	ТекстПредупреждения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстПредупреждения, ВыбранныйПользователь);

	ПоказатьПредупреждение(,ТекстПредупреждения);
	
КонецПроцедуры

&НаКлиенте
Процедура ИсключитьУчастника(Команда)
	
	Тема = ТекущаяТема;
	
	СписокУчастниковОбсуждения = ПолучитьУчастниковОбсуждения(Тема);
	
	Оповещение = Новый ОписаниеОповещения("ОбработкаВыбораУчастникаДляИсключения", ЭтотОбъект, Тема);
	СписокУчастниковОбсуждения.ПоказатьВыборЭлемента(Оповещение, НСтр("ru = 'Выберите пользователя для исключения из обсуждения'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбораУчастникаДляИсключения(ВыбранноеЗначениеСписка, Тема) Экспорт
	
	Если ВыбранноеЗначениеСписка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДобавитьИлиИсключитьУчастникаОбсуждения(Тема, ВыбранноеЗначениеСписка.Значение, "Исключить");
	
	Элементы.Участники.Обновить();
	
	ТекстПредупреждения = НСтр("ru = 'Пользователь ""%1"" исключен из обсуждения'");
	ТекстПредупреждения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстПредупреждения, ВыбранноеЗначениеСписка.Значение);

	ПоказатьПредупреждение(,ТекстПредупреждения);
	
КонецПроцедуры


Функция УдалитьСообщениеФорумаМодераторомPOST(Запрос)
		
	УстановитьПривилегированныйРежим(Истина);

	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Форум");
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные запроса
	
	Попытка
		ИдентификаторСообщения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("Сообщение"));
		Сообщение = Документы.СообщениеСУО.ПолучитьСсылку(ИдентификаторСообщения);
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(Сообщение) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	// Удаляем сообщение
	
	СообщениеОбъект = Сообщение.ПолучитьОбъект();
	
	РазделФорума = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СообщениеОбъект.Тема, "Контекст");
	
	Если ТипЗнч(РазделФорума) <> Тип("СправочникСсылка.РазделыФорумаСУО") Тогда
		Возврат ОтветКлиентуJSON("errorData");	
	КонецЕсли;
	
	МодераторыРаздела = Справочники.РазделыФорумаСУО.МодераторыРаздела(РазделФорума);
	
	Если МодераторыРаздела.Найти(ДанныеСессии.Пользователь, "Пользователь") = Неопределено
		И СообщениеОбъект.Пользователь <> ДанныеСессии.Пользователь Тогда
		Возврат ОтветКлиентуJSON("noPermissions");
	КонецЕсли;
	
	СообщениеОбъект.УдаленоМодератором = Истина;
	СообщениеОбъект.ДатаУдаленияМодератором = ТекущаяДатаСеанса();
	СообщениеОбъект.УдалившийМодератор = ДанныеСессии.Пользователь;
	
	СообщениеОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	СообщениеОбъект.ДополнительныеСвойства.Вставить("НеОбновлятьДанныеВебКабинета", Истина);
	СообщениеОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
	// Обновляем данные веб-кабинета
		
	ВебКабинетСУ.ОбновитьДанныеОбъекта(ОбщегоНазначения.МенеджерОбъектаПоСсылке(СообщениеОбъект.Ссылка), СообщениеОбъект.Ссылка, СообщениеОбъект.ДополнительныеСвойства);
	РегистрыСведений.НастройкиТемФорумаСУО.ОбновитьДанныеВебКабинетаЗаписи(ДанныеСессии.Пользователь, СообщениеОбъект.Тема);
	
	// Возвращаем результат
	
	Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена", Истина));	
	
КонецФункции

// Личные сообщения

Функция ПолучитьЛичныеСообщенияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Сообщения");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные запроса
	//
	
	ДатаНачала = Дата("00010101");
	ДатаОкончания = Дата("00010101");
	
	Попытка
		Тип = Перечисления.ОтборыДанныхВебКабинетаСУО[ВебКабинетСУ.Перевод(Запрос.ПараметрыURL.Получить("Тип"), "ОтборыДанныхВебКабинетаСУО")];
		ИдентификаторТипа = Перечисления.ОтборыДанныхВебКабинетаСУО.Идентификатор(Тип);
		ДатаНачала = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(Число(Запрос.ПараметрыURL.Получить("ДатаНачала")));
		ДатаОкончания = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(Число(Запрос.ПараметрыURL.Получить("ДатаОкончания")));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторТипа) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	
	
	// Получаем сообщения
	//
	
	Запрос = Новый Запрос;	
		
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СписокСообщений.Данные КАК object,
		|	ПользовательскиеСвойстваСообщения.Данные КАК userDescription,
		|	СписокСообщений.Период КАК date,
		|	ОписаниеТем.Данные КАК topic
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ОП КАК СписокСообщений
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_П КАК ОтборСообщений
		|		ПО СписокСообщений.Объект = ОтборСообщений.Объект
		|			И (ОтборСообщений.Отбор = &ИдентификаторТипа)
		|			И (ОтборСообщений.Пользователь = &Пользователь)
		|			И (СписокСообщений.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.Сообщение))
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ПользовательскиеСвойстваСообщения
		|		ПО СписокСообщений.Объект = ПользовательскиеСвойстваСообщения.Объект
		|			И (ПользовательскиеСвойстваСообщения.Пользователь = &Пользователь)
		|			И (ПользовательскиеСвойстваСообщения.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.СообщениеОписание))
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборТем
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ОписаниеТем
		|			ПО ОтборТем.ОтборСсылка = ОписаниеТем.Объект
		|				И (ОписаниеТем.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.ТемаОбщенияОписание))
		|		ПО СписокСообщений.Объект = ОтборТем.Объект
		|ГДЕ
		|	СписокСообщений.Период МЕЖДУ &ДатаНачала И &ДатаОкончания";
		
	Запрос.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	Запрос.УстановитьПараметр("ИдентификаторТипа", ИдентификаторТипа);
	
	Если ЗначениеЗаполнено(ДатаНачала) И ЗначениеЗаполнено(ДатаОкончания) Тогда
	
		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
		Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "СписокСообщений.Период МЕЖДУ &ДатаНачала И &ДатаОкончания", "");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ", "");
		
	КонецЕсли;
		
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат ОтветКлиентуJSON(,РезультатЗапроса.Выгрузить());
	
КонецФункции


// УПРОЩЕННЫЙ ИНТЕРФЕЙС СУЗ

// Таблицы

Процедура РедактироватьЭлементТаблицыСУЗ(ТаблицаФормы, РеквизитЭлемента, ЭлектронныйРесурс=Неопределено, Подборка=Неопределено, Глоссарий=Неопределено) Экспорт
	
	ТекущиеДанные = ТаблицаФормы.ТекущиеДанные;
	
	Если НЕ ОбщегоНазначенияСУКлиент.ТекущиеДанныеТаблицыДоступны(ТекущиеДанные) Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементДляРедактирования = ТекущиеДанные[РеквизитЭлемента];
	
	Если (ТекущиеДанные.Свойство("ЭтоГруппа") И ТекущиеДанные.ЭтоГруппа) ИЛИ НЕ ЗначениеЗаполнено(ЭлементДляРедактирования) Тогда
		ПоказатьЗначение(,ТекущиеДанные.Ссылка);
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура();
	
	Если ТипЗнч(ЭлементДляРедактирования) = Тип("СправочникСсылка.РесурсыСУЗ") Тогда
		ПараметрыФормы.Вставить("ОткрытьФормуФайла", Истина);
	КонецЕсли;
	
	Если ТипЗнч(ТекущиеДанные.Ссылка) = Тип("СправочникСсылка.ЭлементыПодборкиСУЗ") Тогда
		ПараметрыФормы.Вставить("ЭлементПодборки", ТекущиеДанные.Ссылка);
	КонецЕсли;
	
	Если ТипЗнч(ТекущиеДанные.Ссылка) = Тип("СправочникСсылка.СодержаниеСУЗ") Тогда
		ПараметрыФормы.Вставить("ЭлементСодержания", ТекущиеДанные.Ссылка);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
		ПараметрыФормы.Вставить("ЭлектронныйРесурс", ЭлектронныйРесурс);	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Подборка) Тогда
		ПараметрыФормы.Вставить("Подборка", Подборка);	
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Глоссарий) Тогда
		ПараметрыФормы.Вставить("Глоссарий", Глоссарий);	
	КонецЕсли;	
	
	
	ОбщегоНазначенияСУКлиент.ОткрытьЗначениеВФорме(ЭлементДляРедактирования, ПараметрыФормы, ТаблицаФормы);
	
КонецПроцедуры

Процедура ДобавитьЭлементВТаблицуСУЗ(Форма, Таблица, ИмяСправочника, ПараметрыФормы=Неопределено) Экспорт
	
	Отказ = Ложь;
	
	ОбщегоНазначенияСУКлиент.ПередДобавлениемЭлементаПодчиненногоСправочника(Форма, Отказ);
	
	Если НЕ Отказ Тогда
		ОткрытьФорму("Справочник."+ИмяСправочника+".ФормаВыбора", ПараметрыФормы, Таблица,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;	
	
КонецПроцедуры

Процедура СоздатьЭлементТаблицыСУЗ(Форма, Таблица, ИмяЭлемента, ЭлектронныйРесурс=Неопределено, Подборка=Неопределено, Глоссарий=Неопределено) Экспорт
	
	Отказ = Ложь;
	
	ОбщегоНазначенияСУКлиент.ПередДобавлениемЭлементаПодчиненногоСправочника(Форма, Отказ);
	
	Если НЕ Отказ Тогда
		
		ПараметрыФормы = Новый Структура();
		
		ВыделеннаяГруппа = ОбщегоНазначенияСУКлиент.ВыделеннаяГруппаТаблицы(Таблица);
		
		Если ЗначениеЗаполнено(ВыделеннаяГруппа)
			И ТипЗнч(ВыделеннаяГруппа) = Тип("СправочникСсылка.СодержаниеСУЗ") Тогда
			
			ПараметрыФормы.Вставить("ГруппаЭлементаСодержания", ВыделеннаяГруппа);
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
			ПараметрыФормы.Вставить("ЭлектронныйРесурс", ЭлектронныйРесурс);	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Подборка) Тогда
			ПараметрыФормы.Вставить("Подборка", Подборка);	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Глоссарий) Тогда
			ПараметрыФормы.Вставить("Глоссарий", Глоссарий);	
		КонецЕсли;		
		
		Если ИмяЭлемента = "Глоссарий" Тогда
			ИмяСправочника = "ГлоссарииСУЗ";				
		КонецЕсли;
		
		Если ИмяЭлемента = "Файл" Тогда
			
			ИмяСправочника = "РесурсыСУЗ";
			
			ПараметрыФормы.Вставить("ОткрытьФормуФайла", Истина);
			
		КонецЕсли;
		
		Если ИмяЭлемента = "Документ" Тогда
			
			ИмяСправочника = "РесурсыСУЗ";
			
			ПараметрыФормы.Вставить("ОткрытьФормуДокумента", Истина);
			
		КонецЕсли;
		
		Если ИмяЭлемента = "Тест" Тогда
			
			ИмяСправочника = "ПодборкиСУЗ";
			
			ПараметрыФормы.Вставить("ЗначенияЗаполнения", Новый Структура("ЭтоТест", Истина));
			
		КонецЕсли;
			
		Если ИмяЭлемента = "Теория" Тогда
			
			ИмяСправочника = "ПодборкиСУЗ";
			
			ПараметрыФормы.Вставить("ЗначенияЗаполнения", Новый Структура("ЭтоТест", Ложь));
			
		КонецЕсли;
		
		Если ИмяЭлемента = "Вопрос" Тогда
			
			ИмяСправочника = "ВопросыСУЗ";
			
		КонецЕсли;
		
		Если ИмяЭлемента = "Страница" Тогда
			
			ИмяСправочника = "СтраницыСУЗ";
			
		КонецЕсли;
		
		
		Если ИмяЭлемента = "Термин" Тогда
			
			ИмяСправочника = "ТерминыСУЗ";
			
		КонецЕсли;
		
		
		Если ЗначениеЗаполнено(ИмяСправочника) Тогда
		
			ОткрытьФорму("Справочник."+ИмяСправочника+".ФормаОбъекта", ПараметрыФормы, Таблица);
			
		Иначе
			
			ПоказатьПредупреждение(, НСтр("ru = 'Неизветный элемент'"));
			
		КонецЕсли;
		
		// Примечание: запись элемента будет перехвачена обработчиком СодержаниеОбработкаЗаписиНового.

	КонецЕсли;		
	
КонецПроцедуры

Процедура ЗагрузитьЭлементыВТаблицуСУЗ(Форма, Таблица, ЭлектронныйРесурс=Неопределено, Подборка=Неопределено, Ресурс=Неопределено, Глоссарий=Неопределено, ТипКонтента=Неопределено, СкрыватьЭлементы=Ложь) Экспорт
	
	Отказ = Ложь;
	
	ОбщегоНазначенияСУКлиент.ПередДобавлениемЭлементаПодчиненногоСправочника(Форма, Отказ, Истина);
	
	Если НЕ Отказ Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузитьЭлементыВТаблицуСУЗПродолжение", ЭтотОбъект, Новый Структура("ТаблицаДляОбновления, Форма", Таблица, Форма));

		ВыделеннаяГруппа = ОбщегоНазначенияСУКлиент.ВыделеннаяГруппаТаблицы(Таблица);
		
		РазработкаСУЗКлиент.ЗагрузитьФайлы(ЭлектронныйРесурс, Подборка, Ресурс, Глоссарий, ВыделеннаяГруппа, ТипКонтента,, ОписаниеОповещения, СкрыватьЭлементы);
		
	КонецЕсли;	
	
КонецПроцедуры

Процедура ЗагрузитьЭлементыВТаблицуСУЗПродолжение(Результат, ДанныеФормы) Экспорт
	
	Если ДанныеФормы <> Неопределено Тогда
		
		Если ДанныеФормы.ТаблицаДляОбновления <> Неопределено Тогда
			ДанныеФормы.ТаблицаДляОбновления.Обновить();
		КонецЕсли;
		
		Если ДанныеФормы.Форма <> Неопределено Тогда
			ДанныеФормы.Форма.Прочитать();
		КонецЕсли;		
		
	КонецЕсли;
	
КонецПроцедуры

// Реквизиты

Процедура ОбработкаЗаписиНовогоЭлементаСУЗ(НовыйОбъект, Источник, Форма, СтандартнаяОбработка) Экспорт
	
	Если НЕ ЗначениеЗаполнено(НовыйОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ Источник.Параметры.Свойство("ИмяРеквизитаВладельца") Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Источник.Параметры.ИмяРеквизитаВладельца) Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Форма.Объект[Источник.Параметры.ИмяРеквизитаВладельца] = НовыйОбъект;
	
	Форма.Модифицированность = Истина;
	
	Форма.УстановитьДоступностьЭлементовФормы();
	
КонецПроцедуры

Процедура ОбработкаВыбораНовогоЭлементаСУЗ(ВыбранныйОбъект, Источник, Форма) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ВыбранныйОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ Источник.Параметры.Свойство("ИмяРеквизитаВладельца") Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Источник.Параметры.ИмяРеквизитаВладельца) Тогда
		Возврат;
	КонецЕсли;	
	
	Форма.Объект[Источник.Параметры.ИмяРеквизитаВладельца] = ВыбранныйОбъект;
	
	Форма.Модифицированность = Истина;
	
	Форма.УстановитьДоступностьЭлементовФормы();
	
КонецПроцедуры

Процедура СоздатьЭлементРеквизитаСУЗ(Форма, ИмяРеквизита, ИмяСправочника, НаименованиеЭлемента="", ЭлектронныйРесурс=Неопределено, Подборка=Неопределено) Экспорт
	
	Отказ = Ложь;
	
	ОбщегоНазначенияСУКлиент.ПередДобавлениемЭлементаПодчиненногоСправочника(Форма, Отказ);
	
	Если НЕ Отказ Тогда
	
		ОткрытьФорму("Справочник."+ИмяСправочника+".ФормаОбъекта", Новый Структура("ИмяРеквизитаВладельца, ЭлектронныйРесурс, Подборка, ЗначенияЗаполнения", ИмяРеквизита, ЭлектронныйРесурс, Подборка, Новый Структура("Наименование", НаименованиеЭлемента)), Форма);	
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОчиститьЭлементРеквизитаСУЗ(Форма, ИмяРеквизита) Экспорт
	
	Форма.Объект[ИмяРеквизита] = Неопределено;
	
	Форма.Модифицированность = Истина;
	
	Форма.УстановитьДоступностьЭлементовФормы();	
	
КонецПроцедуры

Процедура УдалитьЭлементРеквизитаСУЗ(Форма, ИмяРеквизита, ТекстВопроса="") Экспорт
	
	Если НЕ ЗначениеЗаполнено(ТекстВопроса) Тогда
		ТекстВопроса = НСтр("ru = 'Удалить элемент?'");
	КонецЕсли;
	
	ПараметрыПродолжения = Новый Структура("ИмяРеквизита, Форма", ИмяРеквизита, Форма);
	
	Оповещение = Новый ОписаниеОповещения("УдалитьЭлементРеквизитаСУЗПослеПодтверждения", ЭтотОбъект, ПараметрыПродолжения);
	
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 0);
	
КонецПроцедуры

Процедура УдалитьЭлементРеквизитаСУЗПослеПодтверждения(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	Форма = ДополнительныеПараметры.Форма;
	ИмяРеквизита = ДополнительныеПараметры.ИмяРеквизита;
	
	НоваяСтрока = Форма.ЭлементыДляУдаления.Добавить();	
	НоваяСтрока.Элемент = Форма.Объект[ИмяРеквизита];
	
	Форма.Объект[ИмяРеквизита] = Неопределено;
	
	Форма.Модифицированность = Истина;
	
	Форма.УстановитьДоступностьЭлементовФормы();
	
КонецПроцедуры	

Процедура РедактироватьЭлементРеквизитаСУЗ(Форма, ИмяРеквизита) Экспорт
	
	ПоказатьЗначение(,Форма.Объект[ИмяРеквизита]);
	
КонецПроцедуры

Процедура НайтиВСпискеЭлементРеквизитаСУЗ(Форма, ИмяРеквизита) Экспорт
	
	ИмяТаблица = ОбщегоНазначенияСУВызовСервера.ИмяТаблицыПоСсылке(Форма.Объект[ИмяРеквизита]);
	
	ОткрытьФорму(ИмяТаблица+".ФормаСписка", Новый Структура("ТекущаяСтрока", Форма.Объект[ИмяРеквизита]), Форма);
	
КонецПроцедуры

Процедура ДобавитьИзРанееСозданныхРеквизитСУЗ(Форма, ИмяРеквизита, ИмяСправочника) Экспорт
	
	ОткрытьФорму("Справочник."+ИмяСправочника+".ФормаВыбора", Новый Структура("ИмяРеквизитаВладельца", ИмяРеквизита), Форма);
	
КонецПроцедуры

// Устанавливает в форме электронный ресурс, в контексте которого открыта форма
//
Процедура УстановитьКонтекстЭлектронногоРесурса(Форма) Экспорт
	
	Если ТипЗнч(Форма) <> Тип("УправляемаяФорма") Тогда	
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Форма.ЭлектронныйРесурс) Тогда
		Возврат; // Уже есть контекст
	КонецЕсли;
	
	ФормаЭлектронногоРесурса = ОбщегоНазначенияСУКлиент.НайтиВладельцаУправляемойФормы(Форма.ВладелецФормы, "Справочник.СводыЗнанийСУЗ.Форма.ФормаЭлемента");
	
	Если ФормаЭлектронногоРесурса = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Форма.ЭлектронныйРесурс = ФормаЭлектронногоРесурса.Объект.Ссылка;
	
КонецПроцедуры

// РЕСУРСЫ ОБЪЕКТОВ

// Получает уникальный постфикс ресурса СУЗ на основе кода данных.
// Используется в том случае, когда "склеиваются" в одном объекте,
// например в вопросе, различные форматированные документы и требуется
// разнести ресурсы из разных документов в разные каталоги.
//
Функция ПолучитьПостфиксРесурса(КодДанных) Экспорт
	
	Если ЗначениеЗаполнено(КодДанных) Тогда
		Возврат "_" + ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(КодСимвола(КодДанных, 1))+Строка(СтрДлина(КодДанных));	
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

// Получает пустую структуру ресурса. Ресурсы выгружаются в локальный
// кэш на клиенте или на сервере. Структура используется
// для проверки необходимости выгрузки данных, и не содержит
// данные самого ресурса.
//
// В качестве ресурса могут выступать не только элементы справочника,
// РесурсыСУЗ, но и, например, документы "СообщениеОбсужденийСУЗ", которые
// содержат форматированный документ с картинками.
//
Функция ПолучитьСтруктуруРесурса(Ссылка, КодДанных = "") Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ТипЗнч(Ссылка) = Тип("СправочникСсылка.РесурсыСУЗ") Тогда
	
		ДанныеРесурса = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, "ДатаИзменения, ПодключитьAPI");
		
		Если ТипЗнч(ДанныеРесурса.ПодключитьAPI) <> Тип("Булево") Тогда
			ДанныеРесурса.ПодключитьAPI = Ложь;
		КонецЕсли;		
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ЗависимыеРесурсыСУЗ.Ресурс.ДатаИзменения КАК ДатаИзменения
			|ИЗ
			|	Справочник.ЗависимыеРесурсыСУЗ КАК ЗависимыеРесурсыСУЗ
			|ГДЕ
			|	ЗависимыеРесурсыСУЗ.Владелец = &Ресурс
			|	И ЗависимыеРесурсыСУЗ.ПометкаУдаления = ЛОЖЬ
			|	И ЗависимыеРесурсыСУЗ.Ресурс.ДатаИзменения > &ДатаИзмененияРесурса
			|
			|УПОРЯДОЧИТЬ ПО
			|	ДатаИзменения УБЫВ";
		
		Запрос.УстановитьПараметр("Ресурс", Ссылка);
		Запрос.УстановитьПараметр("ДатаИзмененияРесурса", ДанныеРесурса.ДатаИзменения);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если НЕ РезультатЗапроса.Пустой() Тогда
		
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			ВыборкаДетальныеЗаписи.Следующий();
			
			ДанныеРесурса.ДатаИзменения = ВыборкаДетальныеЗаписи.ДатаИзменения;
			
		КонецЕсли;
		
	Иначе
		
		ДанныеРесурса = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, "ДатаИзменения");
		
		ДанныеРесурса.Вставить("ПодключитьAPI", Ложь);
		
	КонецЕсли;
	
	СтруктураРесурса = Новый Структура();
	СтруктураРесурса.Вставить("Ссылка", Ссылка);
	СтруктураРесурса.Вставить("Идентификатор", Строка(Ссылка.УникальныйИдентификатор()));
	СтруктураРесурса.Вставить("ДатаИзменения", ДанныеРесурса.ДатаИзменения);
	СтруктураРесурса.Вставить("ПодключитьAPI", ДанныеРесурса.ПодключитьAPI);
	СтруктураРесурса.Вставить("КодДанных", КодДанных);
	СтруктураРесурса.Вставить("Постфикс", ПолучитьПостфиксРесурса(КодДанных));
	СтруктураРесурса.Вставить("Размер", 0); // Размер в МБ
	
	Возврат СтруктураРесурса;
	
КонецФункции

// Получает данные подсказки.
//
Функция ПолучитьСтруктуруПодсказки(Подсказка, Текст) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	СтруктураПодсказки = Новый Структура;
	СтруктураПодсказки.Вставить("Подсказка", Подсказка);
	СтруктураПодсказки.Вставить("Текст", Текст);
	
	Возврат СтруктураПодсказки;
	
КонецФункции

// Получает структуру ресурса "Общий" справочника "РесурсыСУЗ".
//
Функция ПолучитьСтруктуруОбщегоРесурса() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	СтруктураРесурса = ПолучитьСтруктуруРесурса(Справочники.РесурсыСУЗ.Общий);
	СтруктураРесурса.Идентификатор = ""; // Общий ресурс выгружается в корень кэша
	
	Возврат СтруктураРесурса;
	
КонецФункции

// Получает структуру ресурса "Модули" справочника "РесурсыСУЗ".
//
Функция ПолучитьСтруктуруРесурсаМодулей() Экспорт
	
	СтруктураРесурса = ПолучитьСтруктуруРесурса(Справочники.РесурсыСУЗ.Модули);
	СтруктураРесурса.Идентификатор = "plugins"; // Свой идентификатор
	
	Возврат СтруктураРесурса;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// КОНТЕКСТ ОБЪЕКТА

// Процедура добавляет в список шаблонов новый элемент.
//
// Параметры
//  ШаблонОбъекта  – ссылка на элемент справочника "ШаблоныСУЗ" или "ШаблоныСУО".
//  СписокШаблонов - массив.
//
// Возвращаемое значение:
//   Нет.
//
Процедура ДобавитьШаблонВСписокОбъекта(ШаблонОбъекта, СписокШаблонов) Экспорт

	Если СписокШаблонов.Найти(ШаблонОбъекта) = Неопределено Тогда
		СписокШаблонов.Добавить(ШаблонОбъекта);
	КонецЕсли;
	
КонецПроцедуры

// Добавляет ресурс (описание ресурса) в массив, если он не был добавлен в него ранее.
// Включая зависимые ресурсы для справочника РесурсыСУЗ.
//
Процедура ДобавитьРесурсВМассивРесурсов(Знач Ресурс, МассивРесурсов, КодДанных = "", ТаблицаЗависимыхРесурсов = Неопределено) Экспорт

	Если НЕ ЗначениеЗаполнено(Ресурс) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Ресурс) = Тип("СправочникСсылка.РесурсыСУЗ") Тогда
		
		ИдентичныйРесурс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ресурс, "ИдентичныйРесурс");		
		ДобавляемыйРесурс = ?(ЗначениеЗаполнено(ИдентичныйРесурс), ИдентичныйРесурс, Ресурс);
		
	Иначе
		
		ДобавляемыйРесурс = Ресурс;
		
	КонецЕсли;
	
	Для каждого Элемент Из МассивРесурсов Цикл
		Если Элемент.Ссылка = ДобавляемыйРесурс
			И Элемент.КодДанных = КодДанных Тогда
			Возврат; // Ресурс уже добавлен
		КонецЕсли;
	КонецЦикла;
	
	СтруктураРесурса = ПолучитьСтруктуруРесурса(ДобавляемыйРесурс, КодДанных);
	
	МассивРесурсов.Добавить(СтруктураРесурса);
	
	// Добавляем зависимые ресурсы
	
	Если ТипЗнч(ДобавляемыйРесурс) = Тип("СправочникСсылка.РесурсыСУЗ") Тогда
	
		Если ТаблицаЗависимыхРесурсов = Неопределено Тогда		
			ТаблицаЗависимыхРесурсов = ТаблицаЗависимыхРесурсов(ДобавляемыйРесурс);		
		КонецЕсли;
		
		Для каждого Строка Из ТаблицаЗависимыхРесурсов Цикл
			ДобавитьРесурсВМассивРесурсов(Строка.Ресурс, МассивРесурсов); // Рекурсия
		КонецЦикла;	
		
	КонецЕсли;
		
КонецПроцедуры

// Добавляет все ресурсы, подчиненные заданному объекту СУЗ.
// Подчиненные ресурсы сохраняются в справочнике "РесурсыОбъектовСУЗ".
//
Процедура ДобавитьРесурсыОбъектаВМассивРесурсов(Объект, СписокРесурсов, СписокПодсказок) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РесурсыОбъектовСУЗ.Ссылка,
		|	РесурсыОбъектовСУЗ.Ресурс,
		|	РесурсыОбъектовСУЗ.Текст,
		|	РесурсыОбъектовСУЗ.Подсказка
		|ИЗ
		|	Справочник.РесурсыОбъектовСУЗ КАК РесурсыОбъектовСУЗ
		|ГДЕ
		|	РесурсыОбъектовСУЗ.Владелец = &Владелец";

	Запрос.УстановитьПараметр("Владелец", Объект.Ссылка);

	Результат = Запрос.Выполнить();

	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ВыборкаДетальныеЗаписи.Подсказка Тогда
			ОбъектыСУЗ.ДобавитьПодсказкуВМассивПодсказок(ВыборкаДетальныеЗаписи.Ссылка, ВыборкаДетальныеЗаписи.Текст, СписокПодсказок);
		Иначе
			ОбъектыСУЗ.ДобавитьРесурсВМассивРесурсов(ВыборкаДетальныеЗаписи.Ресурс, СписокРесурсов);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Добавляет подсказку в общий массив подсказок
//
Процедура ДобавитьПодсказкуВМассивПодсказок(Подсказка, Текст, СписокПодсказок) Экспорт

	Если НЕ ЗначениеЗаполнено(Подсказка) Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого Элемент Из СписокПодсказок Цикл
		Если Элемент.Подсказка = Подсказка Тогда
			Возврат; // Подсказка уже добавлена
		КонецЕсли;
	КонецЦикла;
	
	СтруктураПодсказки = ПолучитьСтруктуруПодсказки(Подсказка, Текст);
	
	СписокПодсказок.Добавить(СтруктураПодсказки);
	
КонецПроцедуры

// Добавляет ссылку на объект в общий массив ссылок
//
Процедура ДобавитьСсылкиОбъектаВМассив(СсылкаНаОбъект, КонтекстВыполнения) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если КонтекстВыполнения.ПараметрыЭкспорта = Неопределено Тогда
		Возврат; // Ссылки нужны только при экспорте данных
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СсылкиОбъектовСУЗ.Ссылка
		|ИЗ
		|	Справочник.СсылкиОбъектовСУЗ КАК СсылкиОбъектовСУЗ
		|ГДЕ
		|	СсылкиОбъектовСУЗ.Владелец = &СсылкаНаОбъект";

	Запрос.УстановитьПараметр("СсылкаНаОбъект", СсылкаНаОбъект);

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если КонтекстВыполнения.СписокСсылок.Найти(ВыборкаДетальныеЗаписи.Ссылка) = Неопределено Тогда
			 КонтекстВыполнения.СписокСсылок.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
		 КонецЕсли;
		 
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьМодулиРесурса(Ресурс, СписокМодулей, ТаблицаЗависимыхРесурсов = Неопределено) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Ресурс) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Ресурс) = Тип("СправочникСсылка.РесурсыСУЗ") Тогда
		
		ИдентичныйРесурс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ресурс, "ИдентичныйРесурс");		
		ДобавляемыйРесурс = ?(ЗначениеЗаполнено(ИдентичныйРесурс), ИдентичныйРесурс, Ресурс);
		
	Иначе
		
		ДобавляемыйРесурс = Ресурс;
		
	КонецЕсли;
	
	
	Если ТаблицаЗависимыхРесурсов = Неопределено Тогда		
		ТаблицаЗависимыхРесурсов = ТаблицаЗависимыхРесурсов(ДобавляемыйРесурс);		
	КонецЕсли;
	
	Для каждого Строка Из ТаблицаЗависимыхРесурсов Цикл
		ДобавитьМодульВМассив(Строка.Модуль, СписокМодулей);
	КонецЦикла;	
	
КонецПроцедуры

// Объявляет модуль в общий массив модулей страницы.
//
Процедура ДобавитьМодульВМассив(Знач Модуль, СписокМодулей) Экспорт
	
	Если ТипЗнч(Модуль) = Тип("Строка") Тогда
		Модуль = ОбъектыСУЗПовтИсп.МодульПоИмени(Модуль);		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Модуль) И СписокМодулей.Найти(Модуль) = Неопределено Тогда
		СписокМодулей.Добавить(Модуль);
	КонецЕсли;
	
КонецПроцедуры

Функция ТаблицаЗависимыхРесурсов(Ресурс) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗависимыеРесурсыСУЗ.Модуль,
		|	ЗависимыеРесурсыСУЗ.Ресурс,
		|	ЗависимыеРесурсыСУЗ.Дополняет
		|ИЗ
		|	Справочник.ЗависимыеРесурсыСУЗ КАК ЗависимыеРесурсыСУЗ
		|ГДЕ
		|	ЗависимыеРесурсыСУЗ.ПометкаУдаления = ЛОЖЬ
		|	И ЗависимыеРесурсыСУЗ.Владелец = &Ресурс
		|	И ЗависимыеРесурсыСУЗ.Ресурс <> &Ресурс";

		
	Запрос.УстановитьПараметр("Ресурс", Ресурс);
		
	Результат = Запрос.Выполнить();

	Возврат Результат.Выгрузить();	
	
КонецФункции
	
////////////////////////////////////////////////////////////////////////////////
// ШАБЛОНЫ ОБЪЕКТОВ

// Функция возвращает ссылку на шаблон объекта.
//
// Параметры
//  Объект  – Экземпляр обработки "ОбъектСУЗ" или справочник объект.
//
// Возвращаемое значение:
//   Ссылка на элемент справочника "ШаблоныСУЗ" или "ШаблоныСУО"
//
Функция ПолучитьСсылкуНаXSLШаблонОбъекта(Ссылка) Экспорт
	
	Шаблон = Ссылка.Шаблон;
	
	Если ЗначениеЗаполнено(Шаблон) Тогда
		
		Возврат Шаблон;	
		
	Иначе
		
		ТипОбъекта = ПолучитьТипОбъектаСУЗ(Ссылка);
		
		Возврат Справочники.ШаблоныСУЗ[Строка(ТипОбъекта)+"ПоУмолчанию"];
		
	КонецЕсли;
	
КонецФункции

// Возвращает необходимые для воспроизведения объекта XSL шаблоны.
// Шаблоны хранятся в регистре "КэшШаблоновСУЗ" или "КэшШаблоновСУО".
//
// Параметры
//  Шаблон  – ссылка на элемент справочника ШаблоныСУЗ или ШаблоныСУО.
//
// Возвращаемое значение:
//   Структура, содержащая шаблон представления и скрипта.
//
Функция ПолучитьИзКэшаТекстШаблона(Шаблон, Префикс) Экспорт
	
	СтруктураДанныхШаблона = Новый Структура;
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	КэшШаблонов"+Префикс+".ШаблонПредставления,
	|	КэшШаблонов"+Префикс+".ШаблонСкрипта
	|ИЗ
	|	РегистрСведений.КэшШаблонов"+Префикс+" КАК КэшШаблонов"+Префикс+"
	|ГДЕ
	|	КэшШаблонов"+Префикс+".Шаблон = &Шаблон"); 
	
	
	Запрос.УстановитьПараметр("Шаблон", Шаблон); 
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Результат.Следующий();
	
	СтруктураДанныхШаблона.Вставить("ШаблонПредставления", Результат.ШаблонПредставления);
	СтруктураДанныхШаблона.Вставить("ШаблонСкрипта", Результат.ШаблонСкрипта);
	
	Возврат СтруктураДанныхШаблона;
		
КонецФункции

// Возвращает текст необходимых для отображения объекта стилей (CSS).
//
// Параметры
//  СписокШаблонов  – Массив - содержит участвующие в формировании объекта шаблоны.
//
// Возвращаемое значение:
//  Строка. 
//
Функция ПолучитьТекстСтилейОбъекта(СписокШаблонов) Экспорт

	// Получаем стили по умолчанию!
	ТекстСтилей = Справочники.ШаблоныСУЗ.ПредставлениеИнформации.ТаблицыСтилей;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("СправочникСсылка.ШаблоныСУЗ"));
	
	ОписаниеТипов = Новый ОписаниеТипов(МассивТипов); 
	
	ТаблицаШаблонов = Новый ТаблицаЗначений;
	ТаблицаШаблонов.Колонки.Добавить("Ссылка", ОписаниеТипов);
	
	Для каждого Шаблон Из СписокШаблонов Цикл
		НоваяСтрока = ТаблицаШаблонов.Добавить();
		НоваяСтрока.Ссылка = Шаблон;
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ВнешнийИсточник", ТаблицаШаблонов);
	Запрос.Текст =
	"ВЫБРАТЬ Ссылка
	|ПОМЕСТИТЬ ТаблицаШаблонов
	|ИЗ &ВнешнийИсточник КАК ВнешнийИсточник";
	Запрос.Выполнить();
	
	// Выбираем шаблоны СУЗ
	
	Запрос.Текст = "ВЫБРАТЬ
	|	КэшШаблоновСУЗ.ТаблицыСтилей КАК ТекстСтилей
	|ИЗ
	|	ТаблицаШаблонов КАК ТаблицаШаблонов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КэшШаблоновСУЗ КАК КэшШаблоновСУЗ
	|		ПО ТаблицаШаблонов.Ссылка = КэшШаблоновСУЗ.Шаблон";
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Пока Результат.Следующий() Цикл
		ТекстСтилей = ТекстСтилей + Результат.ТекстСтилей;
	КонецЦикла;
	
	Возврат ТекстСтилей;

КонецФункции // ПолучитьТекстСтилейОбъектаСУЗ()

// Обновляет кэш шаблонов для всех шаблонов или одного.
//
Процедура ОбновитьКэшШаблоновСУЗ(Шаблон = Неопределено) Экспорт
	
	Если Шаблон = Неопределено Тогда
		
		Запрос = Новый Запрос("
		|ВЫБРАТЬ
		|	ШаблоныСУЗ.Ссылка
		|ИЗ
		|	Справочник.ШаблоныСУЗ КАК ШаблоныСУЗ
		|ГДЕ
		|	ШаблоныСУЗ.ЭтоГруппа = ЛОЖЬ");
		
		ТаблицаШаблонов = Запрос.Выполнить().Выгрузить();
		
	Иначе
		
		ТаблицаШаблонов = Новый ТаблицаЗначений;
		ТаблицаШаблонов.Колонки.Добавить("Ссылка");
		
		НоваяСтрока = ТаблицаШаблонов.Добавить();
		НоваяСтрока.Ссылка = Шаблон;
		
		// Находим все шаблоны, которые зависят от текущего.

		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ШаблоныСУЗ.Ссылка
			|ИЗ
			|	Справочник.ШаблоныСУЗ КАК ШаблоныСУЗ
			|ГДЕ
			|	ШаблоныСУЗ.ДополняетШаблон = &ДополняетШаблон
			|	И ШаблоныСУЗ.ЭтоГруппа = ЛОЖЬ
			|	И ШаблоныСУЗ.ПометкаУдаления = ЛОЖЬ";

		Запрос.УстановитьПараметр("ДополняетШаблон", Шаблон);

		Результат = Запрос.Выполнить();

		ВыборкаДетальныеЗаписи = Результат.Выбрать();

		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НоваяСтрока = ТаблицаШаблонов.Добавить();
			НоваяСтрока.Ссылка = ВыборкаДетальныеЗаписи.Ссылка;
		КонецЦикла;
		
	КонецЕсли;
	
	Для каждого Строка Из ТаблицаШаблонов Цикл
	
		ЦепочкаШаблонов = СформироватьСписокДополняющихШаблонов(Строка.Ссылка);
		ДанныеШаблона   = ПолучитьСтруктуруДанныхXSLШаблона(ЦепочкаШаблонов);
		
		НаборЗаписей =  РегистрыСведений.КэшШаблоновСУЗ.СоздатьНаборЗаписей();
		
		НаборЗаписей.Отбор.Шаблон.Установить(Строка.Ссылка);

		НоваяЗапись = НаборЗаписей.Добавить();
		
		НоваяЗапись.Шаблон              = Строка.Ссылка;
		НоваяЗапись.ШаблонПредставления = ДанныеШаблона["ШаблонПредставления"];
		НоваяЗапись.ШаблонСкрипта       = ДанныеШаблона["ШаблонСкрипта"];
		НоваяЗапись.ТаблицыСтилей       = ДанныеШаблона["ТаблицыСтилей"];

		НаборЗаписей.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

// Если шаблон дополняет другой, то возвращается вся цепочка дополняющих друг-друга шаблонов.
//
Функция СформироватьСписокДополняющихШаблонов(Шаблон, МассивШаблонов = Неопределено)

	Если МассивШаблонов = Неопределено Тогда
		МассивШаблонов = Новый Массив();
	КонецЕсли;
	
	Если МассивШаблонов.Найти(Шаблон) = Неопределено Тогда
		Если ЗначениеЗаполнено(Шаблон.ДополняетШаблон) Тогда
			СформироватьСписокДополняющихШаблонов(Шаблон.ДополняетШаблон, МассивШаблонов);
		КонецЕсли;
		МассивШаблонов.Добавить(Шаблон);
	КонецЕсли;
	
	Возврат МассивШаблонов;
	
КонецФункции

// Получает итоговые данные всей цепочки шаблонов XSL.
//
Функция ПолучитьСтруктуруДанныхXSLШаблона(ЦепочкаШаблонов)
	
	ШаблонПредставления = "";
	ШаблонСкрипта       = "";
	ТаблицыСтилей       = "";
	
	XSLДанные = "<xsl:stylesheet version=""1.0"" "; // Записывается результирующий текст XSL шаблона.
		
	ТаблицаПространствИмен = Новый ТаблицаЗначений;
	ТаблицаПространствИмен.Колонки.Добавить("Префикс");
	ТаблицаПространствИмен.Колонки.Добавить("URI");
	
	НоваяСтрока = ТаблицаПространствИмен.Добавить();
	НоваяСтрока.Префикс = "xsl";
	НоваяСтрока.URI = "http://www.w3.org/1999/XSL/Transform";
	
	Для каждого Шаблон Из ЦепочкаШаблонов Цикл
		
		ПространствоИмен = Справочники.ПространстваИменШаблоновСУЗ.Выбрать(,Шаблон);
		
		Пока ПространствоИмен.Следующий() Цикл
			
			НоваяСтрока = ТаблицаПространствИмен.Добавить();
			НоваяСтрока.Префикс = СокрЛП(ПространствоИмен.Код);
			НоваяСтрока.URI = ПространствоИмен.Наименование;				
		
		КонецЦикла;
		
	КонецЦикла;
	
	Для каждого ПространствоИмен Из ТаблицаПространствИмен Цикл
	
		XSLДанные = XSLДанные + "
		|xmlns:"+ПространствоИмен.Префикс+"="""+ПространствоИмен.URI+"""";
	
	КонецЦикла;
	
	XSLДанные = XSLДанные + "> ";
	
	ШаблонПредставления = XSLДанные;
	ШаблонСкрипта = XSLДанные;

	ШаблонПредставления = ШаблонПредставления + "
	|<xsl:output method=""html""/>";
	ШаблонСкрипта = ШаблонСкрипта + "
	|<xsl:output method=""text""/>";
	
	XSLДанные = "
	|<xsl:template match=""/"">";
	
	// Добавляем вызов имеющихся шаблонов.
	Для каждого Шаблон Из ЦепочкаШаблонов Цикл
		ИдентификаторШаблона = Шаблон.УникальныйИдентификатор();
		XSLДанные = XSLДанные + "
		|<xsl:call-template name=""template_"+ ИдентификаторШаблона +"""/>";
	КонецЦикла;	
	
	XSLДанные = XSLДанные + "
	|</xsl:template>";
	
	ШаблонПредставления = ШаблонПредставления + XSLДанные;
	ШаблонСкрипта = ШаблонСкрипта + XSLДанные;

	// Порядок добавления шаблонов:
	// 1. Все основные шаблоны;
	// 2. Все дополнительные шаблоны.
	// Примечание: кроме стилей. Стили основных
	// Шаблонов добавляются после дополнительных,
	// Чтобы в них можно было переопределить стили доп. шаблонов.
	
	// 1. Добавляем текст основных шаблонов.
	Для каждого Шаблон Из ЦепочкаШаблонов Цикл
		ШаблонПредставления = ШаблонПредставления + Строка(Шаблон.ШаблонПредставления);
		ШаблонСкрипта       = ШаблонСкрипта + Строка(Шаблон.ШаблонСкрипта);
//		ТаблицыСтилей       = ТаблицыСтилей + Строка(Шаблон.ТаблицыСтилей); // Ниже добавляется
	КонецЦикла;	
	
	// 2. Добавляем дополнительные шаблоны.
	
	ТаблицаДопШаблонов = Новый ТаблицаЗначений;
	
	ТаблицаДопШаблонов.Колонки.Добавить("Ссылка");
	ТаблицаДопШаблонов.Колонки.Добавить("Match");
	ТаблицаДопШаблонов.Колонки.Добавить("Name");
	ТаблицаДопШаблонов.Колонки.Добавить("Priority");
	ТаблицаДопШаблонов.Колонки.Добавить("Mode");
	ТаблицаДопШаблонов.Колонки.Добавить("ТекстШаблона");
	ТаблицаДопШаблонов.Колонки.Добавить("ТекстСтилей");
	ТаблицаДопШаблонов.Колонки.Добавить("ДатаИзменения");
	ТаблицаДопШаблонов.Колонки.Добавить("Поставщик");
	ТаблицаДопШаблонов.Колонки.Добавить("ТипШаблона");
	
	Если Константы.ПоказыватьПоследнююВерсиюСУЗ.Получить() Тогда
		ПредпочитаемыйПоставщик = Константы.ПредпочитатьПоставщикаСУЗ.Получить();
	Иначе
		ПредпочитаемыйПоставщик = Неопределено;
	КонецЕсли;
	
	Для каждого Шаблон Из ЦепочкаШаблонов Цикл
		
		ВремТаблицаДопШаблонов = Новый ТаблицаЗначений; // Хранит все доп. шаблоны шаблона из цепочки.
	
		ВремТаблицаДопШаблонов.Колонки.Добавить("Ссылка");
		ВремТаблицаДопШаблонов.Колонки.Добавить("Match");
		ВремТаблицаДопШаблонов.Колонки.Добавить("Name");
		ВремТаблицаДопШаблонов.Колонки.Добавить("Priority");
		ВремТаблицаДопШаблонов.Колонки.Добавить("Mode");
		ВремТаблицаДопШаблонов.Колонки.Добавить("ТекстШаблона");
		ВремТаблицаДопШаблонов.Колонки.Добавить("ТекстСтилей");
		ВремТаблицаДопШаблонов.Колонки.Добавить("ДатаИзменения");
		ВремТаблицаДопШаблонов.Колонки.Добавить("Поставщик");
		ВремТаблицаДопШаблонов.Колонки.Добавить("ТипШаблона");
		
		ДопШаблон = Справочники.ДополнительныеШаблоныСУЗ.Выбрать(,Шаблон);
		
		Пока ДопШаблон.Следующий() Цикл // Заполняем таблицу ВремТаблицаДопШаблонов.
			
			// В рамках одного шаблона, при наличии двух доп. шаблонов
			// С одинаковым именем, шаблон от предпочитаемого поставщика
			// Заменяет другой шаблон.
			// Если невозможно определить предпочитаемый шаблон по поставщику,
			// То тот доп. шаблон, который был первым в цепочки будет предпочитаться.
			
			ТребуемоеДействие = ""; // Возможные значения: "Пропустить", "Заменить", "Добавить".
				
			Если ЗначениеЗаполнено(ДопШаблон.Name) Тогда
			
				Отбор = Новый Структура();
				Отбор.Вставить("ТипШаблона", ДопШаблон.ТипШаблона);
				Отбор.Вставить("Name", ДопШаблон.Name);
				
				// Находим все шаблоны того же типа, что и текущий и с таким же именем.
				НайденныеШаблоны = ВремТаблицаДопШаблонов.НайтиСтроки(Отбор);
				
				Если НайденныеШаблоны.Количество() > 0 Тогда // Должно быть всегда = 1
					
					ИмеющийсяШаблон = НайденныеШаблоны[0];
					
					Если ПредпочитаемыйПоставщик <> Неопределено
						И ИмеющийсяШаблон.Поставщик <> ДопШаблон.Поставщик Тогда
						
						Если ИмеющийсяШаблон.Поставщик = ПредпочитаемыйПоставщик Тогда
							ТребуемоеДействие = "Пропустить";
						КонецЕсли;
						
						Если ДопШаблон.Поставщик = ПредпочитаемыйПоставщик Тогда
							ТребуемоеДействие = "Заменить";
						КонецЕсли;
						
					КонецЕсли;
					
					Если ТребуемоеДействие = "" Тогда
						
//						Если ДопШаблон.ДатаИзменения >= ИмеющийсяШаблон.ДатаИзменения Тогда
//							ТребуемоеДействие = "Заменить";
//						Иначе
							ТребуемоеДействие = "Пропустить";
//						КонецЕсли;
						
					КонецЕсли;
					
				Иначе
					ТребуемоеДействие = "Добавить";
				КонецЕсли;
				
			Иначе
				ТребуемоеДействие = "Добавить";
			КонецЕсли;
			
			
			Если ТребуемоеДействие = "Пропустить" Тогда
				Продолжить;
			КонецЕсли;
			
			Если ТребуемоеДействие = "Добавить" Тогда
				НоваяСтрока = ВремТаблицаДопШаблонов.Добавить();
			КонецЕсли;
			
			Если ТребуемоеДействие = "Заменить" Тогда
				НоваяСтрока = ИмеющийсяШаблон;
			КонецЕсли;
			
			НоваяСтрока.Ссылка        = ДопШаблон.Ссылка;
			НоваяСтрока.Match         = ДопШаблон.Match;
			НоваяСтрока.Name          = ДопШаблон.Name;
			НоваяСтрока.Priority      = ДопШаблон.Priority;
			НоваяСтрока.Mode          = ДопШаблон.Mode;
			
			НоваяСтрока.ТекстШаблона  = ДопШаблон.ТекстШаблона;
			НоваяСтрока.ТекстСтилей   = ДопШаблон.ТекстСтилей;
			НоваяСтрока.ДатаИзменения = ДопШаблон.ДатаИзменения;
			НоваяСтрока.Поставщик     = ДопШаблон.Поставщик;
			НоваяСтрока.ТипШаблона    = ДопШаблон.ТипШаблона;
					
		КонецЦикла;
		
		
		// Объединяем доп. шаблоны текущего шаблона из цепочки
		// С другими, найденными для других шаблонов цепочки.
		// В цепочке если есть шаблоны с одинаковым именем,
		// Последующий заменяет предыдущий.
		// Цепочка составлена так, что дополняющие шаблоны
		// Находятся позже.
		
		Для каждого ВремШаблон Из ВремТаблицаДопШаблонов Цикл
			
			Если ЗначениеЗаполнено(ВремШаблон.Name) Тогда
				
				Отбор = Новый Структура();
				Отбор.Вставить("ТипШаблона", ВремШаблон.ТипШаблона);
				Отбор.Вставить("Name", ВремШаблон.Name);
				
				НайденныеСтроки = ТаблицаДопШаблонов.НайтиСтроки(Отбор);
				
				Если НайденныеСтроки.Количество() > 0 Тогда
					НоваяСтрока = НайденныеСтроки[0]; // Заменяем существующий шаблон с этим же именем
				Иначе
					НоваяСтрока = ТаблицаДопШаблонов.Добавить();
				КонецЕсли;
				
			Иначе
				// Если имя шаблона не указано, то просто добавляем его к общему списку.
				НоваяСтрока = ТаблицаДопШаблонов.Добавить();				
			КонецЕсли;
			
			
			НоваяСтрока.Ссылка        = ВремШаблон.Ссылка;
			НоваяСтрока.Match         = ВремШаблон.Match;
			НоваяСтрока.Name          = ВремШаблон.Name;
			НоваяСтрока.Priority      = ВремШаблон.Priority;
			НоваяСтрока.Mode          = ВремШаблон.Mode;
			
			НоваяСтрока.ТекстШаблона  = ВремШаблон.ТекстШаблона;
			НоваяСтрока.ТекстСтилей   = ВремШаблон.ТекстСтилей;
			НоваяСтрока.ДатаИзменения = ВремШаблон.ДатаИзменения;
			НоваяСтрока.Поставщик     = ВремШаблон.Поставщик;
			НоваяСтрока.ТипШаблона    = ВремШаблон.ТипШаблона;
			
		КонецЦикла;
		
	КонецЦикла;		
	
	Для каждого ДопШаблон Из ТаблицаДопШаблонов Цикл
	
		XSLДанные = "
		|<xsl:template ";
		
		Если ЗначениеЗаполнено(ДопШаблон.Name) Тогда
			XSLДанные = XSLДанные + "name=""" + ДопШаблон.Name + """ ";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДопШаблон.Match) Тогда
			XSLДанные = XSLДанные + "match=""" + ДопШаблон.Match + """ ";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДопШаблон.Priority) Тогда
			XSLДанные = XSLДанные + "priority=""" + Формат(ДопШаблон.Priority, "ЧРД="".""") + """ ";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДопШаблон.Mode) Тогда
			XSLДанные = XSLДанные + "mode=""" + ДопШаблон.Mode + """ ";
		КонецЕсли;
		
		
		XSLДанные = XSLДанные + ">";
		XSLДанные = XSLДанные + ДопШаблон.ТекстШаблона;
		XSLДанные = XSLДанные + "</xsl:template>";
		
		Если ДопШаблон.ТипШаблона = Перечисления.ТипыШаблоновСУЗ.Представление Тогда
			ШаблонПредставления = ШаблонПредставления + XSLДанные;
		КонецЕсли;
		
		Если ДопШаблон.ТипШаблона = Перечисления.ТипыШаблоновСУЗ.Скрипт Тогда
			ШаблонСкрипта = ШаблонСкрипта + XSLДанные;
		КонецЕсли;
		
		ТаблицыСтилей = ТаблицыСтилей + ДопШаблон.ТекстСтилей;
	
	КонецЦикла;
	
	XSLДанные = "</xsl:stylesheet>";		
	
	// 1. Добавляем текст стилей основных шаблонов.
	Для каждого Шаблон Из ЦепочкаШаблонов Цикл
		ТаблицыСтилей = ТаблицыСтилей + Строка(Шаблон.ТаблицыСтилей);
	КонецЦикла;	
	
	ШаблонПредставления = ШаблонПредставления + XSLДанные;
	ШаблонСкрипта       = ШаблонСкрипта + XSLДанные;
	
	СтруктураДанных = Новый Структура();
	
	СтруктураДанных.Вставить("ШаблонПредставления", ШаблонПредставления);
	СтруктураДанных.Вставить("ШаблонСкрипта", ШаблонСкрипта);
	СтруктураДанных.Вставить("ТаблицыСтилей", ТаблицыСтилей);
	
	Возврат СтруктураДанных;
	
	
КонецФункции

Функция ПрименитьШаблонКТексту(Знач Текст, Знач ШаблонТекста, Знач ИмяКаталогаРесурсов = "") Экспорт
	
	Если НЕ ЗначениеЗаполнено(Текст) Тогда
		Возврат Текст;
	КонецЕсли;
	
	ТекстШаблона = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ШаблонТекста, "ТекстШаблона");
	
	Если НЕ ЗначениеЗаполнено(ТекстШаблона) Тогда
		Возврат Текст;
	КонецЕсли;
	
	ТекстШаблона = СтрЗаменить(ТекстШаблона, "{{КаталогРесурсов}}", "<xsl:variable name=""КаталогРесурсов"">"+ИмяКаталогаРесурсов+"</xsl:variable>");
	
	Текст = "<body>" + Текст + "</body>";
	
	Текст = СтрЗаменить(Текст, "&", "#amp;");
	
	ПреобразованиеXSL = Новый ПреобразованиеXSL;
	ПреобразованиеXSL.ЗагрузитьИзСтроки(ТекстШаблона);
	
	РезультатПреобразования = ПреобразованиеXSL.ПреобразоватьИзСтроки(Текст);
	РезультатПреобразования	= СтрЗаменить(РезультатПреобразования, "#amp;", "&");
	
	Возврат РезультатПреобразования;
	
КонецФункции


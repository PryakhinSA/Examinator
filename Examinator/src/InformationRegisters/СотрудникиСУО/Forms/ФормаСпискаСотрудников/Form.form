  <attributes>
    <name>СписокПользователей</name>
    <title>
      <key>ru</key>
      <value>Список пользователей</value>
    </title>
    <id>5</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокПользователей.Пользователь</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СотрудникиСУОСрезПоследних.Пользователь,
	СотрудникиСУОСрезПоследних.Организация,
	СотрудникиСУОСрезПоследних.ПодразделениеПредприятия,
	СотрудникиСУОСрезПоследних.ПодразделениеОрганизации,
	СотрудникиСУОСрезПоследних.Должность,
	ВЫБОР
		КОГДА ИСТИНА
			ТОГДА 7
	КОНЕЦ КАК НомерКартинки,
	СотрудникиСУОСрезПоследних.Период,
	СотрудникиСУОСрезПоследних.Уволен,
	ПрохожденияОбученияСУОСрезПоследних.Статус,
	ВЫБОР
		КОГДА ПрохожденияОбученияСУОСрезПоследних.ВыставляетсяОценка
				И (ПрохожденияОбученияСУОСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.Завершил)
				ИЛИ ПрохожденияОбученияСУОСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.Автомат))
			ТОГДА ЭлементыШкалыОценокСУОЗначенияБаллов.Ссылка
		ИНАЧЕ NULL
	КОНЕЦ КАК Оценка,
	ПрохожденияОбученияСУОСрезПоследних.Баллы,
	ПрохожденияОбученияСУОСрезПоследних.ДатаНачалаПрохождения,
	ПрохожденияОбученияСУОСрезПоследних.ДатаОкончанияПрохождения
ИЗ
	РегистрСведений.СотрудникиСУО.СрезПоследних(&amp;Дата, ) КАК СотрудникиСУОСрезПоследних
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПрохожденияОбученияСУО.СрезПоследних(, ПроведениеОбучения = &amp;ПроведениеОбучения) КАК ПрохожденияОбученияСУОСрезПоследних
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЭлементыШкалыОценокСУО.ЗначенияБаллов КАК ЭлементыШкалыОценокСУОЗначенияБаллов
			ПО ПрохожденияОбученияСУОСрезПоследних.Баллы = ЭлементыШкалыОценокСУОЗначенияБаллов.Значение
				И ПрохожденияОбученияСУОСрезПоследних.ШкалаОценки = ЭлементыШкалыОценокСУОЗначенияБаллов.Ссылка.Владелец
		ПО СотрудникиСУОСрезПоследних.Пользователь = ПрохожденияОбученияСУОСрезПоследних.Пользователь</queryText>
      <mainTable>InformationRegister.СотрудникиСУО.SliceLast</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>

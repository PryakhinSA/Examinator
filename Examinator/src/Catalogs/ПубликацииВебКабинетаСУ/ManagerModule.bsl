Процедура ЗаполнитьОбъектНачальнымиДанными(Объект) Экспорт
	
	// Настройки
	//
	
	Объект.Код = "v8cabinet_"+ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(ОбщегоНазначенияСУ.СлучайноеЧисло(1, 99999));	
	Объект.СлужебныйПользовательУказанВПубликацииИнформационнойБазы = Истина;
	
	// Разделы
	//
	
	ЗаполнитьРазделыПоУмолчанию(Объект);
	ЗаполнитьПоляРегистрацииПоУмолчанию(Объект);
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	Если ПолучитьФункциональнуюОпцию("ОбразовательнаяОрганизацияОО")
		ИЛИ ПолучитьФункциональнуюОпцию("ЭкзаменаторЭР") Тогда
		
		Объект.ИспользоватьПинКодыДляРегистрации = Ложь;
		Объект.ПоказатьПинКодыНаГлавнойСтранице = Ложь;
		Объект.ПоказыватьРолиПреподавателей = Ложь;
		Объект.ДоступенКалендарьОбучения = Ложь;
		Объект.ДоступноОткрытоеОбучение = Ложь;
		Объект.ДоступныСертификатыОбучения = Ложь;
		
	КонецЕсли;
	
	//----------------------------------//
	
КонецПроцедуры


		            ВыборкаДетальныеЗаписи.ПоказатьПриСтатусеАктивно,
				    ВыборкаДетальныеЗаписи.ПоказатьПриСтатусеЗавершено) Тогда
				
				Продолжить; // Для этого статуса книгу не показываем
				
			КонецЕсли;
			
			КнигаXDTO = ФабрикаXDTO.Создать(КнигаXDTOТип);
			КнигаXDTO.Идентификатор = ВыборкаДетальныеЗаписи.Ссылка.УникальныйИдентификатор();
			КнигаXDTO.Наименование = ВыборкаДетальныеЗаписи.Наименование;
			
			// Добавляем авторов книги
			
			АвторыXDTO = ФабрикаXDTO.Создать(АвторыXDTOТип);
			
			ВыборкаАвторов = ВыборкаДетальныеЗаписи.АвторыКниги.Выбрать(); 
			

Функция ОписаниеПопыткиВыполненияЗаданияСтруктура(ПопыткаВыполненияЗадания, Зависимости = Неопределено, ПопыткаВыполненияЗаданияДанные = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ПопыткаВыполненияЗаданияДанные = Неопределено Тогда
		СвойстваВыполненияЗадания = ОписаниеПопыткиВыполненияЗаданияДанные(ПопыткаВыполненияЗадания);
	Иначе
		СвойстваВыполненияЗадания = ПопыткаВыполненияЗаданияДанные;
	КонецЕсли;
	
	// Здесь нельзя использовать свойства, зависимые от прохождения обучения,
	// так как получится циклическая зависимость. Следует получать сведения о 
	// прохождении обучения отдельным запросом. Исключение составляет свойство
	// НаименованиеРодительскогоСценария, так как оно не влияет на логику изучения.
	
	ШкалаОценки = Документы.ПроведениеОбученияСУО.ШкалаОценки(СвойстваВыполненияЗадания.ПроведениеОбучения);	
	ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(СвойстваВыполненияЗадания.ПроведениеОбучения, СвойстваВыполненияЗадания.Сценарий);
	
	ЗаданиеВыполнено = Выполнено(ПопыткаВыполненияЗадания, СвойстваВыполненияЗадания.ПопыткаЗавершена, СвойстваВыполненияЗадания.ПроверяетсяПреподавателем, СвойстваВыполненияЗадания.ПроверенПреподавателем, СвойстваВыполненияЗадания.Баллы, СвойстваВыполненияЗадания.ПроходнойБалл, СвойстваВыполненияЗадания.ДатаОкончанияДоступаКЗаданию);
	ПолученаОценка = ПолученаОценка(ПопыткаВыполненияЗадания, СвойстваВыполненияЗадания.ПопыткаЗавершена, СвойстваВыполненияЗадания.ПроверяетсяПреподавателем, СвойстваВыполненияЗадания.ПроверенПреподавателем, СвойстваВыполненияЗадания.ДатаОкончанияДоступаКЗаданию, СвойстваВыполненияЗадания.ВыставляетсяОценка);
	СтатусПроцессаОбучения = Документы.ПрохождениеОбученияСУО.СтатусПроцессаОбучения(СвойстваВыполненияЗадания.ПрохождениеОбучения);
	
	СтруктураДанных = НоваяПустаяСтруктураПопыткиВыполненияЗадания();
	
	// Простые свойства
	
	СтруктураДанных.ПопыткаВыполненияЗадания = Строка(ПопыткаВыполненияЗадания.УникальныйИдентификатор());
	СтруктураДанных.ПрохождениеОбучения = Строка(СвойстваВыполненияЗадания.ПрохождениеОбучения.УникальныйИдентификатор());
	СтруктураДанных.ПроведениеОбучения = Строка(СвойстваВыполненияЗадания.ПроведениеОбучения.УникальныйИдентификатор());
	СтруктураДанных.Задание = Строка(СвойстваВыполненияЗадания.Задание.УникальныйИдентификатор());
	СтруктураДанных.Наименование = СвойстваВыполненияЗадания.Наименование;
	СтруктураДанных.Вариант = Строка(СвойстваВыполненияЗадания.Вариант.УникальныйИдентификатор());
	СтруктураДанных.НаименованиеВарианта = Строка(СвойстваВыполненияЗадания.НаименованиеВарианта);
	СтруктураДанных.ЗавершеноВПроцентах = СвойстваВыполненияЗадания.ЗавершеноВПроцентах;
	СтруктураДанных.Выполнено = ЗаданиеВыполнено;
	СтруктураДанных.ПопыткаЗавершена = СвойстваВыполненияЗадания.ПопыткаЗавершена;
	СтруктураДанных.ТекстОписанияВарианта = СвойстваВыполненияЗадания.ТекстОписанияВарианта;
	СтруктураДанных.ТекстОписанияЗадания = СвойстваВыполненияЗадания.ТекстОписанияЗадания;
	СтруктураДанных.ТекстОтвета = СвойстваВыполненияЗадания.ТекстОтвета;
	СтруктураДанных.ПроверяетсяПреподавателем = СвойстваВыполненияЗадания.ПроверяетсяПреподавателем;
	СтруктураДанных.ПроверенПреподавателем = СвойстваВыполненияЗадания.ПроверенПреподавателем;
	СтруктураДанных.КомментарийПреподавателя = СвойстваВыполненияЗадания.КомментарийПреподавателя;
	СтруктураДанных.ДоступноПопыток = СвойстваВыполненияЗадания.ДоступноПопыток;	
	СтруктураДанных.НомерПопытки = 1; 
	СтруктураДанных.ФайлыЗадания = ФайлыШаблонаЗадания(СвойстваВыполненияЗадания);
	СтруктураДанных.ФайлыПользователя = ОбучениеСУО.ПрикрепленныеФайлыКОбъектуОбучения(ПопыткаВыполненияЗадания, Истина);
	СтруктураДанных.НаименованиеСценария = СвойстваВыполненияЗадания.НаименованиеСценария;
	СтруктураДанных.ЭлектронноеОбучение = Документы.ПроведениеОбученияСУО.ЭтоЭлектронноеОбучение(СвойстваВыполненияЗадания.ПроведениеОбучения,,СвойстваВыполненияЗадания.Сценарий);
	СтруктураДанных.ВозвращеноНаДоработку = СвойстваВыполненияЗадания.ВозвращеноНаДоработку;	
	СтруктураДанных.КонтролироватьПрикреплениеФайлаКОтвету = СвойстваВыполненияЗадания.КонтролироватьПрикреплениеФайлаКОтвету;	
	СтруктураДанных.РодительскийСценарий = СвойстваВыполненияЗадания.РодительскийСценарий;	
	СтруктураДанных.НаименованиеРодительскогоСценария = ?(ЗначениеЗаполнено(СвойстваВыполненияЗадания.НаименованиеРодительскогоПроведенияОбучения), СвойстваВыполненияЗадания.НаименованиеРодительскогоПроведенияОбучения, СвойстваВыполненияЗадания.НаименованиеРодительскогоСценария);
	СтруктураДанных.ДатаОтправкиНаПроверку = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(СвойстваВыполненияЗадания.ДатаОтправкиНаПроверку);
	СтруктураДанных.ПричинаВозвратаНаДоработку = СвойстваВыполненияЗадания.ПричинаВозвратаНаДоработку;
	СтруктураДанных.СкрытьПреподавателей = СвойстваВыполненияЗадания.СкрытьПреподавателей;	
	СтруктураДанных.ЗатраченоВремениВСекундах = СвойстваВыполненияЗадания.ЗатраченоВремениВСекундах;
	СтруктураДанных.ВариантОтображенияВремени = Перечисления.ВариантыОтображенияВремениИзученияЭлектронногоРесурсаСУО.ЗначениеВЧисло(ВидОбучения.ВремяИзученияЭлектронныхКурсов);
	СтруктураДанных.ПроходнойБалл = СвойстваВыполненияЗадания.ПроходнойБалл;
	
	Если СвойстваВыполненияЗадания.СкрытьПреподавателей Тогда
		СтруктураДанных.ПроверившийПреподаватель = Неопределено;
	Иначе		
		СтруктураДанных.ПроверившийПреподаватель = ВебКабинетСУО.ПользовательСтруктура(СвойстваВыполненияЗадания.ПроверившийПреподаватель);
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(СвойстваВыполненияЗадания.ПроверяющийПреподаватель)
		И ЗначениеЗаполнено(СвойстваВыполненияЗадания.ДатаПоследнейАктивностиПроверки) Тогда
		СтруктураДанных.ТекущаяАктивностьПреподавателя = Новый Структура("Преподаватель, ДлительностьАктивности");
		СтруктураДанных.ТекущаяАктивностьПреподавателя.Преподаватель = ВебКабинетСУО.ПользовательСтруктура(СвойстваВыполненияЗадания.ПроверяющийПреподаватель);
		СтруктураДанных.ТекущаяАктивностьПреподавателя.ДлительностьАктивности = ТекущаяДатаСеанса() - СвойстваВыполненияЗадания.ДатаПоследнейАктивностиПроверки;
	Иначе
		СтруктураДанных.ТекущаяАктивностьПреподавателя = Неопределено;
	КонецЕсли;
	
	// Пользователь
	
	СтруктураДанных.Пользователь = ВебКабинетСУО.ПользовательСтруктура(СвойстваВыполненияЗадания.Пользователь, СвойстваВыполненияЗадания.НаименованиеПользователя);
	
	// Оценка
	
	СтруктураДанных.ШкалаОценок = Справочники.ШкалыОценокСУО.ШкалаОценокСтруктура(ШкалаОценки);
	
	Если ПолученаОценка Тогда
		ПолученнаяОценка = УправлениеОбучениемСУОПовтИсп.ОценкаИзБаллов(СвойстваВыполненияЗадания.Баллы, ШкалаОценки);
		СтруктураДанных.Оценка = Новый Структура("Наименование, Идентификатор", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПолученнаяОценка, "Наименование"), Строка(ПолученнаяОценка.УникальныйИдентификатор()));
	Иначе
		СтруктураДанных.Оценка = Неопределено;
	КонецЕсли;	
	
	// Причины возврата на доработку
	
	СтруктураДанных.ПричиныВозвратаНаДоработку = Справочники.ПричиныВозвратаЗаданияНаДоработкуСУО.ПричиныВозвратаСтруктура();
	
	// Удаляем колонку "ПометкаУдаления" из таблицы ПользовательскиеФайлы за ненадобностью
	
	КолонкаПометкаУдаления = СтруктураДанных.ФайлыПользователя.Колонки.Найти("ПометкаУдаления");
	
	Если КолонкаПометкаУдаления <> Неопределено Тогда
		СтруктураДанных.ФайлыПользователя.Колонки.Удалить(КолонкаПометкаУдаления);
	КонецЕсли;
	
	// Зависимости
	
	Если Зависимости <> Неопределено Тогда

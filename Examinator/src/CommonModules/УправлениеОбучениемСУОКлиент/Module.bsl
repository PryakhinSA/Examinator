// ХАРАКТЕРИСТИКИ УЧЕБНЫХ ОБЪЕКТОВ

// Добавляет характеристику интерактивно
//
Процедура ДобавитьХарактеристику(Форма) Экспорт
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьХарактеристикуПродолжение", ЭтотОбъект, Форма);		
	
	ОткрытьФорму("ПланВидовХарактеристик.ХарактеристикиУчебныхОбъектовСУО.ФормаВыбора",,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	
КонецПроцедуры

Процедура ДобавитьХарактеристикуПродолжение(ВидХарактеристики, Форма) Экспорт
	
	Если ЗначениеЗаполнено(ВидХарактеристики) Тогда

		Если Форма.ОписаниеХарактеристик.НайтиСтроки(Новый Структура("ВидХарактеристики", ВидХарактеристики)).Количество() > 0 Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Характеристика уже существует'", "ru"));
		Иначе
			Форма.ДобавитьХарактеристикуНаСервере(ВидХарактеристики);	 
		КонецЕсли;	 
		
	КонецЕсли;
	
КонецПроцедуры	

// Удаляет характеристику интерактивно
//
Процедура УдалитьХарактеристику(Форма) Экспорт
	
	// Выберем удаляемый вид
	СписокВидов = Новый СписокЗначений;
	Для каждого ОписаниеХарактеристики Из Форма.ОписаниеХарактеристик Цикл
		ЭлементСпискаВидов = СписокВидов.Добавить();
		ЭлементСпискаВидов.Значение = ОписаниеХарактеристики.ПолучитьИдентификатор();
		ЭлементСпискаВидов.Представление = Строка(ОписаниеХарактеристики.ВидХарактеристики);
	КонецЦикла;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("УдалитьХарактеристикуПродолжение", ЭтотОбъект, Форма);
	
	СписокВидов.ПоказатьВыборЭлемента(ОписаниеОповещения, НСтр("ru = 'Удалить характеристику:'"));
	
КонецПроцедуры

Процедура УдалитьХарактеристикуПродолжение(ВыбранныйЭлемент, Форма) Экспорт
	
	Если ВыбранныйЭлемент <> Неопределено Тогда
		Форма.УдалитьХарактеристикуНаСервере(ВыбранныйЭлемент.Значение)
	КонецЕсли;
	
КонецПроцедуры	


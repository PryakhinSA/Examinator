Функция РесурсДоступенПользователю(Пользователь, Ресурс) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	БиблиотекаПользователейСУО.Регистратор
		|ИЗ
		|	РегистрСведений.БиблиотекаПользователейСУО КАК БиблиотекаПользователейСУО
		|ГДЕ
		|	БиблиотекаПользователейСУО.Пользователь = &Пользователь
		|	И БиблиотекаПользователейСУО.Ресурс = &Ресурс";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("Ресурс", Ресурс);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат НЕ РезультатЗапроса.Пустой();
	
КонецФункции

Функция ВыборкаБиблиотекПользователя(Пользователь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	БиблиотекаПользователейСУОСрезПоследних.Библиотека КАК ВладелецМетки,
		|	БиблиотекаПользователейСУОСрезПоследних.Библиотека.Наименование КАК Наименование
		|ИЗ
		|	РегистрСведений.БиблиотекаПользователейСУО.СрезПоследних(, Пользователь = &Пользователь) КАК БиблиотекаПользователейСУОСрезПоследних
		|
		|УПОРЯДОЧИТЬ ПО
		|	БиблиотекаПользователейСУОСрезПоследних.Библиотека.Предопределенный УБЫВ";

	Запрос.УстановитьПараметр("Пользователь", Пользователь);

	Результат = Запрос.Выполнить();

	Возврат Результат.Выбрать();	
	
КонецФункции

Функция РесурсыБиблиотекиПользователя() Экспорт
	
КонецФункции

Функция ВыборкаЭлементовБиблиотекиПользователя(Пользователь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БиблиотекаПользователейСУОСрезПоследних.Период КАК ДатаДобавления,
		|	БиблиотекаПользователейСУОСрезПоследних.Ресурс,
		|	БиблиотекаПользователейСУОСрезПоследних.Фрагмент,
		|	БиблиотекаПользователейСУОСрезПоследних.Метка,
		|	БиблиотекаПользователейСУОСрезПоследних.Библиотека,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(БиблиотекаПользователейСУОСрезПоследних.Ресурс КАК Справочник.ЗаданияСУО)) <> ЗНАЧЕНИЕ(Справочник.ЗаданияСУО.ПустаяСсылка)
		|				ИЛИ (ВЫРАЗИТЬ(БиблиотекаПользователейСУОСрезПоследних.Ресурс КАК Справочник.Файлы)) <> ЗНАЧЕНИЕ(Справочник.Файлы.ПустаяСсылка)
		|			ТОГДА БиблиотекаПользователейСУОСрезПоследних.Ресурс.Наименование
		|		ИНАЧЕ ВЫБОР
		|				КОГДА (ВЫРАЗИТЬ(БиблиотекаПользователейСУОСрезПоследних.Фрагмент КАК Справочник.СодержаниеСУЗ)) = ЗНАЧЕНИЕ(Справочник.СодержаниеСУЗ.ПустаяСсылка)
		|						ИЛИ (ВЫРАЗИТЬ(БиблиотекаПользователейСУОСрезПоследних.Фрагмент КАК Справочник.СодержаниеКнигиСУО)) = ЗНАЧЕНИЕ(Справочник.СодержаниеКнигиСУО.ПустаяСсылка)
		|					ТОГДА БиблиотекаПользователейСУОСрезПоследних.Ресурс.Наименование
		|				ИНАЧЕ БиблиотекаПользователейСУОСрезПоследних.Фрагмент.Наименование
		|			КОНЕЦ
		|	КОНЕЦ КАК Наименование,
		|	ВЫБОР
		|		КОГДА ТИПЗНАЧЕНИЯ(БиблиотекаПользователейСУОСрезПоследних.Ресурс) = ТИП(Справочник.Файлы)
		|			ТОГДА БиблиотекаПользователейСУОСрезПоследних.Ресурс.Расширение
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК Расширение,
		|	ВЫБОР
		|		КОГДА ТИПЗНАЧЕНИЯ(БиблиотекаПользователейСУОСрезПоследних.Ресурс) = ТИП(Справочник.СводыЗнанийСУЗ)
		|			ТОГДА 1
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Картинка
		|ИЗ
		|	РегистрСведений.БиблиотекаПользователейСУО.СрезПоследних(, Пользователь = &Пользователь) КАК БиблиотекаПользователейСУОСрезПоследних
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование";

	Запрос.УстановитьПараметр("Пользователь", Пользователь);

	Результат = Запрос.Выполнить();
	
	Возврат Результат.Выбрать();
	
КонецФункции

Функция РесурсДляДобавления(ВыборкаДетальныеЗаписи, ТаблицаПользовательскихМеток, ТекущаяБиблиотека, ТекущаяМетка, Пользователь) Экспорт
	
	РесурсДляДобавления = Ложь;
	
	Если ТекущаяБиблиотека = Пользователь Тогда
		
		Если ТаблицаПользовательскихМеток.НайтиСтроки(Новый Структура("Ресурс, Фрагмент, Метка", ВыборкаДетальныеЗаписи.Ресурс, ВыборкаДетальныеЗаписи.Фрагмент, ТекущаяМетка)).Количество() > 0 Тогда
			
			РесурсДляДобавления = Истина; // Ресурс помещен в пользовательскую библиотеку самим пользователем
			
		КонецЕсли;
		
		Если ВыборкаДетальныеЗаписи.Метка = ТекущаяМетка
			И ТаблицаПользовательскихМеток.НайтиСтроки(Новый Структура("Ресурс, Фрагмент", ВыборкаДетальныеЗаписи.Ресурс, ВыборкаДетальныеЗаписи.Фрагмент)).Количество() = 0
			И (ВыборкаДетальныеЗаписи.Библиотека = Неопределено
			ИЛИ ВыборкаДетальныеЗаписи.Библиотека = Пользователь) Тогда
			
			РесурсДляДобавления = Истина; // Ресурс явно помещен в пользовательскую библиотеку без пользовательской метки
			
		КонецЕсли;
		
	Иначе
		
		Если ВыборкаДетальныеЗаписи.Метка = ТекущаяМетка
			И ВыборкаДетальныеЗаписи.Библиотека = ТекущаяБиблиотека Тогда
			
			РесурсДляДобавления = Истина; 
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат РесурсДляДобавления;
	
КонецФункции

// ВЕБ-КАБИНЕТ

Процедура ОбновитьДанныеВебКабинета(Пользователь, ДополнительныеДанные = Неопределено) Экспорт
	
	// Данная процедура вызывается из других процедур обновления данных (не самостоятельно),
	// Кроме случая отработки зависимости.
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеБиблиотекПользователя = Новый Массив;
	Зависимости = Новый Массив;	
	
	// Получаем данные
	//
	
	Библиотеки = БиблиотекиПользователя(Пользователь);
	ТаблицаПользовательскихМеток = РегистрыСведений.БиблиотекаПользователейМеткиРесурсовСУО.ТаблицаПользовательскихМеток(Пользователь);
	ВыборкаЭлементов = РегистрыСведений.БиблиотекаПользователейСУО.ВыборкаЭлементовБиблиотекиПользователя(Пользователь);
	
	Для каждого Библиотека Из Библиотеки Цикл
	
		СтруктураБиблиотеки = Новый Структура("Идентификатор, Наименование, Тип, Метки, Ресурсы");					
		СтруктураБиблиотеки.Идентификатор = Строка(Библиотека.УникальныйИдентификатор());
		СтруктураБиблиотеки.Наименование  = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Библиотека, "Наименование");
		СтруктураБиблиотеки.Тип           = Библиотека.Метаданные().Имя;
		
		ДеревоМеток = Новый ДеревоЗначений;
		ДеревоМеток.Колонки.Добавить("Ссылка");
		ДеревоМеток.Колонки.Добавить("Порядок");
		ДеревоМеток.Колонки.Добавить("Наименование");
		ДеревоМеток.Колонки.Добавить("Ресурсы");
		
		Справочники.СтруктураБиблиотекиПользователейСУО.ЗаполнитьДеревоМеток(ДеревоМеток, Библиотека, Пользователь);
		
		ДобавитьРесурсыВДеревоМеток(ДеревоМеток.Строки, ТаблицаПользовательскихМеток, ВыборкаЭлементов, Библиотека, Пользователь, Зависимости);
		
		СтруктураБиблиотеки.Метки = ДеревоМеток;
		
		СтруктураБиблиотеки.Ресурсы = Новый Массив; // Для совместимости
				
		ДанныеБиблиотекПользователя.Добавить(СтруктураБиблиотеки);
		
	КонецЦикла;
	
	// Записываем данные
	//
	
	РегистрыСведений.ДанныеВебКабинетаСУО_ПН.ДобавитьДанные(
		Пользователь,
		Перечисления.ТипыДанныхВебКабинетаСУО.БиблиотекаПользователя,
		Пользователь,
		ОбщегоНазначенияСУ.ДанныеВJSON(ДанныеБиблиотекПользователя),
		Перечисления.ФорматыВебДанныхСУ.json);	
		
	// Записываем зависимости	
	//
	
	РегистрыСведений.ЗависимостиДанныхВебКабинетаСУ.ДобавитьДанные(Пользователь, "РегистрСведений.БиблиотекаПользователейСУО", Зависимости);	
	
КонецПроцедуры

Процедура ДобавитьРесурсыВДеревоМеток(СтрокиДерева, ТаблицаПользовательскихМеток, ВыборкаЭлементов, Библиотека, Пользователь, Зависимости)
	
	Для каждого Строка Из СтрокиДерева Цикл
		
		Строка.Ресурсы = Новый Массив;
		
		ВыборкаЭлементов.Сбросить();
		
		Пока ВыборкаЭлементов.Следующий() Цикл
			
			Если РегистрыСведений.БиблиотекаПользователейСУО.РесурсДляДобавления(
				ВыборкаЭлементов, ТаблицаПользовательскихМеток, Библиотека, Строка.Ссылка, Пользователь) Тогда				
				ДобавитьРесурсВДеревоМеток(ВыборкаЭлементов, Зависимости, Строка);					
			КонецЕсли;
			
		КонецЦикла;
		
		ДобавитьРесурсыВДеревоМеток(Строка.Строки, ТаблицаПользовательскихМеток, ВыборкаЭлементов, Библиотека, Пользователь, Зависимости); // Рекурсия
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьРесурсВДеревоМеток(СвойствоЭлемента, Зависимости, СтрокаМеток) 
	
	ОписаниеРесурса = Новый Структура("Наименование, Фрагмент, Ресурс, ДатаДобавления, Тип, Расширение");
	ЗаполнитьЗначенияСвойств(ОписаниеРесурса, СвойствоЭлемента);
	

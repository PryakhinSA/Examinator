&НаСервере
Функция ПолучитьТаблицуПользователейИБ()
	
	Если ТипЗнч(ТаблицаПользователейИБ) = Тип("ХранилищеЗначения") Тогда
		Возврат ТаблицаПользователейИБ.Получить();
	КонецЕсли;
	
	ПользователиИБ = ПользователиИнформационнойБазы.ПолучитьПользователей();
	
	ПользователиИБТаблица = Новый ТаблицаЗначений;
	ПользователиИБТаблица.Колонки.Добавить("АутентификацияOpenID");
	ПользователиИБТаблица.Колонки.Добавить("АутентификацияОС");
	ПользователиИБТаблица.Колонки.Добавить("АутентификацияСтандартная");
	ПользователиИБТаблица.Колонки.Добавить("ЗапрещеноИзменятьПароль");
	ПользователиИБТаблица.Колонки.Добавить("Имя");
	ПользователиИБТаблица.Колонки.Добавить("ПарольУстановлен");
	ПользователиИБТаблица.Колонки.Добавить("ПоказыватьВСпискеВыбора");
	ПользователиИБТаблица.Колонки.Добавить("УникальныйИдентификатор");
	
	Для каждого ПользовательИБ Из ПользователиИБ Цикл
		НоваяСтрокаТП = ПользователиИБТаблица.Добавить();
		НоваяСтрокаТП.АутентификацияOpenID = ПользовательИБ.АутентификацияOpenID;
		НоваяСтрокаТП.АутентификацияОС = ПользовательИБ.АутентификацияОС;
		НоваяСтрокаТП.АутентификацияСтандартная = ПользовательИБ.АутентификацияСтандартная;
		НоваяСтрокаТП.ЗапрещеноИзменятьПароль = ПользовательИБ.ЗапрещеноИзменятьПароль;
		НоваяСтрокаТП.Имя = ПользовательИБ.Имя;
		НоваяСтрокаТП.ПарольУстановлен = ПользовательИБ.ПарольУстановлен;
		НоваяСтрокаТП.ПоказыватьВСпискеВыбора = ПользовательИБ.ПоказыватьВСпискеВыбора;
		НоваяСтрокаТП.УникальныйИдентификатор = ПользовательИБ.УникальныйИдентификатор;
	КонецЦикла;	
	
	ПользователиИБТаблица.Индексы.Добавить("АутентификацияOpenID");
	ПользователиИБТаблица.Индексы.Добавить("АутентификацияОС");
	ПользователиИБТаблица.Индексы.Добавить("АутентификацияСтандартная");
	ПользователиИБТаблица.Индексы.Добавить("ЗапрещеноИзменятьПароль");
	ПользователиИБТаблица.Индексы.Добавить("Имя");
	ПользователиИБТаблица.Индексы.Добавить("ПарольУстановлен");
	ПользователиИБТаблица.Индексы.Добавить("ПоказыватьВСпискеВыбора");
	
	ТаблицаПользователейИБ = Новый ХранилищеЗначения(ПользователиИБТаблица);
	
	Возврат ПользователиИБТаблица;
	

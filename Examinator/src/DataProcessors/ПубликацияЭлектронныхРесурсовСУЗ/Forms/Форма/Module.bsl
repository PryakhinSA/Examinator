#КонецОбласти

#Область ОбработчикиКомандФормы

// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ВыполнитьЭкспорт(Команда)	
	
	// Делаем проверки
	//
	
	Если НЕ ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ПарольПользователя)
		И Объект.ПарольПользователя <> ПодтверждениеПароляПользователя Тогда
		
		ПоказатьПредупреждение(,НСтр("ru = 'Пароль пользователя и его подтверждение не совпадают'"));
		
		Возврат;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ПарольПреподавателя)
		И Объект.ПарольПреподавателя <> ПодтверждениеПароляПреподавателя Тогда
		
		ПоказатьПредупреждение(,НСтр("ru = 'Пароль преподавателя и его подтверждение не совпадают'"));
		
		Возврат;
		
	КонецЕсли;
	
	
	// Выбираем каталог для публикации
	
	Объект.КаталогДляСохранения = "";
	
	Если Объект.ТипПубликации = ПредопределенноеЗначение("Перечисление.ТипыПубликацийЭлектронныхРесурсовСУЗ.SCORM_1_3") Тогда
		МожноПубликоватьВКаталогНаКлиенте = Ложь;
	Иначе
		МожноПубликоватьВКаталогНаКлиенте = СтандартныеПодсистемыКлиентПовтИсп.ПараметрыРаботыКлиента().ИнформационнаяБазаФайловая;
	КонецЕсли;
	
	#Если НЕ ВебКлиент Тогда

	Если МожноПубликоватьВКаталогНаКлиенте
		И Объект.ТипПубликации = ПредопределенноеЗначение("Перечисление.ТипыПубликацийЭлектронныхРесурсовСУЗ.HTML") Тогда
		
		ДиалогОткрытияФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);		
		ДиалогОткрытияФайла.Каталог = Объект.КаталогДляСохранения;
		ДиалогОткрытияФайла.МножественныйВыбор = Ложь;
		ДиалогОткрытияФайла.Заголовок = НСтр("ru = 'Выберите каталог для копирования публикации'");
		
		Если ДиалогОткрытияФайла.Выбрать() Тогда
			
			Объект.КаталогДляСохранения = ДиалогОткрытияФайла.Каталог;			
			Объект.КаталогДляСохранения = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(Объект.КаталогДляСохранения);
			
		Иначе
			
		    Возврат;
			
		КонецЕсли;		
		
	КонецЕсли;
	
	#КонецЕсли
	
	// Делаем публикацию
	//	
	
	РезультатЭкспорта = ВыполнитьПубликацию();
	
	Если РезультатЭкспорта = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОбработчикаОжидания = Новый Структура;
	
	Если РезультатЭкспорта.ЗаданиеВыполнено Тогда		
		ЗагрузитьПодготовленныеДанные();
	Иначе		
		ПараметрыОбработчикаОжидания = Новый Структура(
		"МинимальныйИнтервал,МаксимальныйИнтервал,ТекущийИнтервал,КоэффициентУвеличенияИнтервала", 1, 5, 1, 1.1);
		ПодключитьОбработчикОжидания("Подключаемый_ПроверитьВыполнениеПубликации", 1, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Отменить(Команда)
	ОтменитьПроцессПубликации();
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьКаталогПубликации(Команда)
	
	Если ЗначениеЗаполнено(Объект.КаталогДляСохранения) Тогда
		ЗапуститьПриложение(Объект.КаталогДляСохранения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Сохранить(Команда)
	
	
	МассивФайлов = Новый Массив;
	
	Если ЗначениеЗаполнено(ДанныеВыгрузки.Версия) Тогда
		МассивФайлов.Добавить(Новый ОписаниеПередаваемогоФайла(ДанныеВыгрузки.ИмяФайлаПакета + " (" + ДанныеВыгрузки.Версия + ")", АдресХранилищаДополнительный));
	Иначе
		МассивФайлов.Добавить(Новый ОписаниеПередаваемогоФайла(ДанныеВыгрузки.ИмяФайлаПакета, АдресХранилищаДополнительный));
	КонецЕсли;	
	
	ОписаниеОповещенияПолученияФайлов = Новый ОписаниеОповещения("СохранитьПродолжение", ЭтотОбъект);
	
	ДиалогСохранения = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	ДиалогСохранения.Заголовок = НСтр("ru = 'Сохранение архива публикации'");
	ДиалогСохранения.МножественныйВыбор = Ложь;
	ДиалогСохранения.ПредварительныйПросмотр = Ложь;
	ДиалогСохранения.Фильтр = "Архив ZIP|*.zip";
	
	НачатьПолучениеФайлов(ОписаниеОповещенияПолученияФайлов, МассивФайлов, ДиалогСохранения, Истина);  
	
	
КонецПроцедуры

// Продолжение процедуры (см. выше).
// 
&НаКлиенте
Процедура СохранитьПродолжение(ПолученныеФайлы, ДополнительныеПараметры) Экспорт
	// Обработка не требуется.
КонецПроцедуры

//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//

&НаКлиенте
Процедура УдалитьСтарыеПубликации(Команда)
	УдалитьПубликацииНаСервере(Истина);
	ПоказатьПредупреждение(,НСтр("ru = 'Удаление устаревших публикаций завершено'"));
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВсеПубликации(Команда)

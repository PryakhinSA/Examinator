	// Конец ЭлектронныеРесурс
	
КонецПроцедуры

Процедура ПараметрыРаботыКлиентаПриЗапуске(Параметры) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);

	ПараметрыЭлектронныыеРесурсы = Новый Структура;
	
	ПараметрыЭлектронныыеРесурсы.Вставить("Версия", ВерсияПодсистемы());
	ПараметрыЭлектронныыеРесурсы.Вставить("ВерсияИБ", ОбновлениеИнформационнойБазы.ВерсияИБ(ЭлектронныеРесурсыПереопределяемый.ИмяПодсистемы()));
	ПараметрыЭлектронныыеРесурсы.Вставить("ИспользоватьОбщийКаталогВТонкомКлиенте", Константы.ИспользоватьОбщийКаталогВТонкомКлиентеСУЗ.Получить());
	ПараметрыЭлектронныыеРесурсы.Вставить("НомерБазовогоПакетаДанных", ПолучитьОбщийМакет("НомерБазовогоПакетаДанныхСУЗ").ПолучитьТекст());	
	
	Параметры.Вставить("ЭлектронныеРесурсы", ПараметрыЭлектронныыеРесурсы);
	Параметры.Вставить("ДатаПервогоЗапуска", Константы.ДатаПервогоЗапускаСУ.Получить());
	
	Если НЕ ЗначениеЗаполнено(Параметры.ДатаПервогоЗапуска) Тогда
		Константы.ДатаПервогоЗапускаСУ.Установить(ТекущаяДатаСеанса());	
	КонецЕсли;
	
КонецПроцедуры

Процедура ПараметрыРаботыКлиента(Параметры) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПараметрыРаботыКлиентаПриЗапуске(Параметры);
	
КонецПроцедуры

Функция ДанныеОПрохожденииЭлектронногоРесурса(ЭлектронныйРесурс, ФрагментЭлектронногоРесурса = Неопределено, Пользователь = Неопределено, ПрохождениеОбучения = Неопределено, Задание = Неопределено, МетодВыбораПопыткиПрохождения = Неопределено, ВидОбучения = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем необходимые переменные
	
	Если МетодВыбораПопыткиПрохождения = Неопределено Тогда		
		МетодВыбораПопыткиПрохождения = Перечисления.МетодВыбораПопыткиПрохожденияСУЗ.СНаибольшимРезультатом;		
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(Пользователь) Тогда
		ЭлектронныеРесурсыПереопределяемый.ПользовательОбучения(Пользователь, ПрохождениеОбучения);		
	КонецЕсли;
	
	Если ФрагментЭлектронногоРесурса = Неопределено Тогда
		ФрагментЭлектронногоРесурса = Справочники.СодержаниеСУЗ.ПустаяСсылка();
	КонецЕсли;
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//

	Если ПрохождениеОбучения = Неопределено Тогда
		ПрохождениеОбучения = Метаданные.ОпределяемыеТипы.ПрохождениеЭлектронногоОбучения.Тип.ПривестиЗначение(ПрохождениеОбучения);
	КонецЕсли;
	
	Если Задание = Неопределено Тогда
		Задание = Метаданные.ОпределяемыеТипы.ЗаданиеЭлектронногоОбучения.Тип.ПривестиЗначение(Задание);
	КонецЕсли;	
	
	Если ВидОбучения = Неопределено Тогда
		ДанныеПрохождения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, "ПроведениеОбучения, Сценарий");
		ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(ДанныеПрохождения.ПроведениеОбучения, ДанныеПрохождения.Сценарий);
	КонецЕсли;
		
	//----------------------------------//	
	
	
	//--# КОНСТРУКТОР КУРСОВ ДОБАВИТЬ #--//
	// ПрохождениеОбучения = "";
	// Задание = "";
	// ВидОбучения = "";
	//----------------------------------//	
	
	ЕстьНезавершенныеПопытки = Ложь;
	ЕстьНеРеализованныеДобавленныеПопытки = Ложь;
	ЗатраченоВремениВСекундах = 0;
	ПроверяетсяПреподавателем = Ложь;
	ПроверенПреподавателем = Истина;	
	ОбщийРезультат = 0;
	ТекущийРезультат = 0;
	ВыставляетсяОценка = Ложь;
	ПопыткаПрохожденияФрагмента = Неопределено;
	
	ПовторныеПрохождения = РегистрыСведений.ПовторноеПрохождениеЭлектронныхРесурсовСУЗ.ПовторныеПрохождения(Пользователь, ПрохождениеОбучения, Задание); 
	
	// Получаем элементы содержания
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СодержаниеСУЗ.Ссылка КАК Ссылка,
		|	СодержаниеСУЗ.СсылкаНаЭлемент КАК СсылкаНаОбъектСУЗ,
		|	ВЫБОР
		|		КОГДА СодержаниеСУЗ.СсылкаНаЭлемент ССЫЛКА Справочник.ПодборкиСУЗ
		|			ТОГДА ВЫРАЗИТЬ(СодержаниеСУЗ.СсылкаНаЭлемент КАК Справочник.ПодборкиСУЗ).НазначениеТестирования
		|	КОНЕЦ КАК НазначениеТестирования,
		|	ВЫБОР
		|		КОГДА СодержаниеСУЗ.СсылкаНаЭлемент ССЫЛКА Справочник.ПодборкиСУЗ
		|			ТОГДА ВЫРАЗИТЬ(СодержаниеСУЗ.СсылкаНаЭлемент КАК Справочник.ПодборкиСУЗ).ЭтоТест
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЭтоТест,
		|	ВЫБОР
		|		КОГДА СодержаниеСУЗ.СсылкаНаЭлемент ССЫЛКА Справочник.РесурсыСУЗ
		|			ТОГДА ВЫРАЗИТЬ(СодержаниеСУЗ.СсылкаНаЭлемент КАК Справочник.РесурсыСУЗ).SCO
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЭтоSCO
		|ИЗ
		|	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
		|ГДЕ
		|	СодержаниеСУЗ.ЭтоГруппа = ЛОЖЬ
		|	И СодержаниеСУЗ.ПометкаУдаления = ЛОЖЬ
		|	И СодержаниеСУЗ.Владелец = &ЭлектронныйРесурс
		|	И &ОтборПоСсылке";

	Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);

	Если ЗначениеЗаполнено(ФрагментЭлектронногоРесурса) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоСсылке", "СодержаниеСУЗ.Ссылка = &ФрагментЭлектронногоРесурса");
		Запрос.УстановитьПараметр("ФрагментЭлектронногоРесурса", ФрагментЭлектронногоРесурса);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоСсылке", "ИСТИНА");
	КонецЕсли;
	
	Результат = Запрос.Выполнить();

	ТаблицаСодержания = Результат.Выгрузить();	
	
	// Получаем данные о прохождении электронного ресурса
	
	Если ЗначениеЗаполнено(ФрагментЭлектронногоРесурса) Тогда
		
		Если ТаблицаСодержания.Количество() > 0 Тогда
			
			// Получаем все попытки прохождения фрагмента электронного ресурса
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Результат КАК Результат,
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ПроверяетсяПреподавателем КАК ПроверяетсяПреподавателем,
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ПроверенПреподавателем КАК ПроверенПреподавателем,
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Регистратор КАК ПопыткаПрохожденияФрагмента,
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Регистратор КАК ПопыткаВыполнения,
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ПопыткаЗавершена КАК ПопыткаЗавершена,
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.СсылкаНаОбъектСУЗ КАК СсылкаНаОбъектСУЗ,
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ЭлектронныйРесурс КАК ЭлектронныйРесурс,
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ДатаНачалаПрохождения КАК Дата,
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ЭлементСодержания КАК ЭлементСодержания,
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ВремяПрохожденияВСекундах КАК ВремяПрохожденияВСекундах,
				|	ВЫБОР
				|		КОГДА ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.СсылкаНаОбъектСУЗ ССЫЛКА Справочник.ПодборкиСУЗ
				|			ТОГДА ВЫРАЗИТЬ(ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.СсылкаНаОбъектСУЗ КАК Справочник.ПодборкиСУЗ).ЭтоТест
				|		ИНАЧЕ ЛОЖЬ
				|	КОНЕЦ КАК ЭтоТест,
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ВыставляетсяОценка КАК ВыставляетсяОценка
				|ИЗ
				|	РегистрСведений.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ КАК ПопыткиПрохожденияЭлектронныхРесурсовСУЗ
				|ГДЕ
				|	ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Пользователь = &Пользователь
				|	И ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ЭлементСодержания = &ЭлементСодержания
				|	И ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ПрохождениеОбучения = &ПрохождениеОбучения
				|	И ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Задание = &Задание";
			
			
			Запрос.УстановитьПараметр("Пользователь", Пользователь);
			Запрос.УстановитьПараметр("ЭлементСодержания", ФрагментЭлектронногоРесурса);
			Запрос.УстановитьПараметр("ПрохождениеОбучения", ПрохождениеОбучения);
			Запрос.УстановитьПараметр("Задание", Задание);
			
			Результат = Запрос.Выполнить();
			
			ТаблицаПопыток = Результат.Выгрузить();
			
			Если ТаблицаПопыток.Количество() > 0 Тогда
				ПопыткаДляСохранения = ПопыткаПрохожденияЭлементаСодержанияЭлектронногоРесурса(ТаблицаПопыток,,ФрагментЭлектронногоРесурса.СсылкаНаЭлемент, МетодВыбораПопыткиПрохождения, ПовторныеПрохождения);
				ЕстьНеРеализованныеДобавленныеПопытки = ЕстьНеРеализованныеДобавленныеПопытки(ТаблицаПопыток, Пользователь, ФрагментЭлектронногоРесурса, ПрохождениеОбучения, Задание);
			Иначе
				ПопыткаДляСохранения = Неопределено;
				ЕстьНеРеализованныеДобавленныеПопытки = Ложь;
			КонецЕсли;			
			
			Если ТаблицаПопыток.Найти(Ложь, "ПопыткаЗавершена") <> Неопределено Тогда
				ЕстьНезавершенныеПопытки = Истина;
			КонецЕсли;
			
			Если ПопыткаДляСохранения <> Неопределено Тогда
				
				ПроцентЗавершенных          = 100;
				ТекущийРезультат            = 0;
				ОбщийРезультат              = ПопыткаДляСохранения.Результат;
				ПопыткаПрохожденияФрагмента = ПопыткаДляСохранения.ПопыткаПрохожденияФрагмента;	
				
			КонецЕсли;	
			
			Для каждого СтрокаТП Из ТаблицаПопыток Цикл
				
				Если СтрокаТП.ПроверяетсяПреподавателем Тогда
					ПроверяетсяПреподавателем = Истина;
				КонецЕсли;
				
				Если СтрокаТП.ПроверяетсяПреподавателем И НЕ СтрокаТП.ПроверенПреподавателем Тогда
					ПроверенПреподавателем = Ложь;
				КонецЕсли;
				
				Если СтрокаТП.ВыставляетсяОценка Тогда
					ВыставляетсяОценка = Истина;
				КонецЕсли;
				
				ЗатраченоВремениВСекундах = ЗатраченоВремениВСекундах + СтрокаТП.ВремяПрохожденияВСекундах;
				
			КонецЦикла;			
			
			Если ПопыткаДляСохранения = Неопределено Тогда
				СтрокаТС = ТаблицаСодержания[0];
				ВыставляетсяОценкаЗаЭлемент = ВыставляетсяОценкаЗаЭлемент(
					СтрокаТС.ЭтоТест, СтрокаТС.НазначениеТестирования, СтрокаТС.ЭтоSCO, ПопыткаДляСохранения);				
				Если ВыставляетсяОценкаЗаЭлемент Тогда
					ВыставляетсяОценка = Истина;
				КонецЕсли;				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе		

		// Получаем попытки прохождения всех элементов содержания

		ТаблицаПопытокПрохождения = РегистрыСведений.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ПопыткиПрохождения(Пользователь, ПрохождениеОбучения, Задание, ЭлектронныйРесурс);  
		
		Если ТаблицаПопытокПрохождения.Найти(Ложь, "ПопыткаЗавершена") <> Неопределено Тогда
			ЕстьНезавершенныеПопытки = Истина;
		КонецЕсли;
		
		ЕстьНеРеализованныеДобавленныеПопытки = ЕстьНеРеализованныеДобавленныеПопытки(ТаблицаПопытокПрохождения, Пользователь,, ПрохождениеОбучения, Задание);
		
		// Получаем баллы
		
		ВсегоЭлементов        = 0;
		ЗавершеноЭлементов    = 0;
		СуммаБаллов           = 0;
		МаксимумБаллов        = 0;
		МаксимумТекущихБаллов = 0;
				
		Для каждого СтрокаТС Из ТаблицаСодержания Цикл
			
			// Считаем количество завершенных элементов и всего элементов
			
			ПопыткаПрохожденияЭС = ПопыткаПрохожденияЭлементаСодержанияЭлектронногоРесурса(ТаблицаПопытокПрохождения, СтрокаТС.Ссылка, СтрокаТС.СсылкаНаОбъектСУЗ, МетодВыбораПопыткиПрохождения, ПовторныеПрохождения);
			
			Если ЗначениеЗаполнено(ПопыткаПрохожденияЭС) Тогда
				ЗавершеноЭлементов = ЗавершеноЭлементов + 1;
			Иначе
				НезаконченнаяПопытка = ПопыткаПрохожденияЭлементаСодержанияЭлектронногоРесурса(ТаблицаПопытокПрохождения, СтрокаТС.Ссылка, СтрокаТС.СсылкаНаОбъектСУЗ, Перечисления.МетодВыбораПопыткиПрохожденияСУЗ.Последнюю, ПовторныеПрохождения, Ложь);
				Если ЗначениеЗаполнено(НезаконченнаяПопытка)
					И НезаконченнаяПопытка.ЗавершеноВПроцентах > 0 Тогда
					ЗавершеноЭлементов = ЗавершеноЭлементов + (НезаконченнаяПопытка.ЗавершеноВПроцентах / 100);
				КонецЕсли;
			КонецЕсли;	
			
			ВсегоЭлементов = ВсегоЭлементов + 1;
			
			// Считаем баллы за элементы
			
			ВыставляетсяОценкаЗаЭлемент = ВыставляетсяОценкаЗаЭлемент(
				СтрокаТС.ЭтоТест, СтрокаТС.НазначениеТестирования, СтрокаТС.ЭтоSCO, ПопыткаПрохожденияЭС);
			
			Если ВыставляетсяОценкаЗаЭлемент Тогда
				
				Если ЗначениеЗаполнено(ПопыткаПрохожденияЭС) Тогда
					СуммаБаллов = СуммаБаллов + ПопыткаПрохожденияЭС.Результат;
					МаксимумТекущихБаллов = МаксимумТекущихБаллов + 100;
					Если ПопыткаПрохожденияЭС.ВыставляетсяОценка Тогда
						ВыставляетсяОценка = Истина;
					КонецЕсли;
				Иначе
					ВыставляетсяОценка = Истина;
				КонецЕсли;
				
				МаксимумБаллов = МаксимумБаллов + 100;
				
			КонецЕсли;
						
		КонецЦикла;

		Если ВсегоЭлементов > 0 Тогда
			ПроцентЗавершенных = Окр((ЗавершеноЭлементов / ВсегоЭлементов)*100);
		Иначе
			ПроцентЗавершенных = 100;
		КонецЕсли;
		
		Если МаксимумБаллов > 0 Тогда 
			ОбщийРезультат = Окр((СуммаБаллов / МаксимумБаллов)*100);
		Иначе
			Если ПроцентЗавершенных = 100 Тогда
				ОбщийРезультат = 100;
			Иначе
				ОбщийРезультат = 0;
			КонецЕсли;
		КонецЕсли;
		
		Если МаксимумТекущихБаллов > 0 Тогда
			ТекущийРезультат = Окр((СуммаБаллов / МаксимумТекущихБаллов)*100);
		Иначе
			Если ПроцентЗавершенных = 100 Тогда
				ТекущийРезультат = 100;
			Иначе
				ТекущийРезультат = 0;
			КонецЕсли;
		КонецЕсли;
		
		// Определяем затраченное время и необходимость проверки
		// преподавателем. Важно это делать по всем попыткам, а не 
		// только тем, что учитываются выше в результате.
		
		ПопыткаПрохожденияФрагмента = Неопределено;		
		
		Для каждого СтрокаТП Из ТаблицаПопытокПрохождения Цикл
		
			Если СтрокаТП.ПроверяетсяПреподавателем Тогда
				ПроверяетсяПреподавателем = Истина;
			КонецЕсли;
			
			Если СтрокаТП.ПроверяетсяПреподавателем И НЕ СтрокаТП.ПроверенПреподавателем Тогда
				ПроверенПреподавателем = Ложь;
			КонецЕсли;
			
			ЗатраченоВремениВСекундах = ЗатраченоВремениВСекундах + СтрокаТП.ВремяПрохожденияВСекундах;
			
		КонецЦикла;		
		
	КонецЕсли;
	
	Если НЕ ПроверяетсяПреподавателем Тогда
		ПроверенПреподавателем = Ложь;
	КонецЕсли;		
		
	//3. Формируем структуру данных и возвращаем результат
	
	ДанныеОПрохождении = Новый Структура;
	ДанныеОПрохождении.Вставить("ЗавершеноВПроцентах", ПроцентЗавершенных);
	ДанныеОПрохождении.Вставить("Баллы", ОбщийРезультат);
	ДанныеОПрохождении.Вставить("ТекущиеБаллы", ТекущийРезультат);
	ДанныеОПрохождении.Вставить("ПопыткаПрохожденияФрагмента", ПопыткаПрохожденияФрагмента);
	ДанныеОПрохождении.Вставить("ЕстьНезавершенныеПопытки", ЕстьНезавершенныеПопытки);
	ДанныеОПрохождении.Вставить("ЕстьНеРеализованныеДобавленныеПопытки", ЕстьНеРеализованныеДобавленныеПопытки);
	ДанныеОПрохождении.Вставить("ПроверяетсяПреподавателем", ПроверяетсяПреподавателем);
	ДанныеОПрохождении.Вставить("ПроверенПреподавателем", ПроверенПреподавателем);		
	ДанныеОПрохождении.Вставить("ЗатраченоВремениВСекундах", ЗатраченоВремениВСекундах);
	ДанныеОПрохождении.Вставить("ВыставляетсяОценка", ВыставляетсяОценка);
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	Если НЕ ВидОбучения.ВыставляетсяОценка Тогда
		ДанныеОПрохождении.Вставить("ВыставляетсяОценка", Ложь);
	КонецЕсли;
	
	Если Справочники.ВидыМероприятийСУО.ЗаданияПроверяютсяВыборочно(ВидОбучения) Тогда	
		ДанныеОПрохождении.Вставить("ПроверяетсяПреподавателем", Ложь);
		ДанныеОПрохождении.Вставить("ПроверенПреподавателем", Ложь);		
	КонецЕсли;	
	//----------------------------------//
	
	Возврат ДанныеОПрохождении;	
	
КонецФункции

Функция ВыставляетсяОценкаЗаЭлемент(ЭтоТест, НазначениеТестирования, ЭтоSCO, ПопыткаПрохожденияЭС)
	
	Если ЭтоТест И НазначениеТестирования = Перечисления.НазначенияТестированийСУЗ.Аттестация Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЭтоSCO И ПопыткаПрохожденияЭС = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЭтоSCO И ПопыткаПрохожденияЭС <> Неопределено И ПопыткаПрохожденияЭС.ВыставляетсяОценка Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;	
	
КонецФункции

Функция ПопыткаПрохожденияЭлементаСодержанияЭлектронногоРесурса(ТаблицаПопыток, ЭлементСодержания = Неопределено, СсылкаНаОбъектСУЗ, Знач МетодВыбораПопыткиПрохождения, ПовторныеПрохождения, ТолькоЗавершенные = Истина) Экспорт
	
	Если НЕ ЗначениеЗаполнено(МетодВыбораПопыткиПрохождения) Тогда
		МетодВыбораПопыткиПрохождения = Перечисления.МетодВыбораПопыткиПрохожденияСУЗ.СНаибольшимРезультатом;
	КонецЕсли;	
	
	ПопыткаДляСохранения = Неопределено;
	
	Для каждого Строка Из ТаблицаПопыток Цикл

		Если ТолькоЗавершенные И НЕ Строка.ПопыткаЗавершена Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЭлементСодержания <> Неопределено Тогда		
			Если Строка.ЭлементСодержания <> ЭлементСодержания Тогда
				Продолжить;
			КонецЕсли;			
		КонецЕсли;
		
		// Примечание: учет параметра СсылкаНаОбъектСУЗ необходим, так как
		// могут быть случаи, когда элемент содержания состоит из нескольких элементов,
		// а учитывать для анализа требуется только основной, который указан как фрагмент.
		
		Если Строка.СсылкаНаОбъектСУЗ <> СсылкаНаОбъектСУЗ Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаВТаблицеПовторныхПрохождений = ПовторныеПрохождения.Найти(Строка.ЭлементСодержания, "ЭлементСодержания");
		
		Если СтрокаВТаблицеПовторныхПрохождений <> Неопределено
			И СтрокаВТаблицеПовторныхПрохождений.Дата > Строка.Дата Тогда
			
			Продолжить; // Не учитываем попытки до даты, когда надо пройти элемент повторно
			
		КонецЕсли;
		
		Если МетодВыбораПопыткиПрохождения = Перечисления.МетодВыбораПопыткиПрохожденияСУЗ.Последнюю Тогда
			
			Если ПопыткаДляСохранения = Неопределено ИЛИ ПопыткаДляСохранения.Дата < Строка.Дата Тогда
				ПопыткаДляСохранения = Строка;
			КонецЕсли;
			
		КонецЕсли;
		
		Если МетодВыбораПопыткиПрохождения = Перечисления.МетодВыбораПопыткиПрохожденияСУЗ.СНаибольшимРезультатом Тогда
			
			Если ПопыткаДляСохранения = Неопределено ИЛИ ПопыткаДляСохранения.Результат < Строка.Результат Тогда
				ПопыткаДляСохранения = Строка;
			КонецЕсли;
			
		КонецЕсли;
		
		Если МетодВыбораПопыткиПрохождения = Перечисления.МетодВыбораПопыткиПрохожденияСУЗ.СНаименьшимРезультатом Тогда
			
			Если ПопыткаДляСохранения = Неопределено ИЛИ ПопыткаДляСохранения.Результат > Строка.Результат Тогда
				ПопыткаДляСохранения = Строка;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ПопыткаДляСохранения;
	
КонецФункции

Функция ЕстьНеРеализованныеДобавленныеПопытки(ТаблицаПопыток, Пользователь, ЭлементСодержания, ПрохождениеОбучения, Задание)
	
	// Находим дату последней попытки
	
	ДатаПоследнейПопытки = Дата("00010101");
	
	Для каждого Строка Из ТаблицаПопыток Цикл

		Если Строка.Дата > ДатаПоследнейПопытки И Строка.ПопыткаЗавершена Тогда
			ДатаПоследнейПопытки = Строка.Дата;
		КонецЕсли;

	КонецЦикла;
	
	// Ищем добавленную попытку после даты последней попытки
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДополнительныеПопыткиПрохожденияТестовСУЗ.Период
		|ИЗ
		|	РегистрСведений.ДополнительныеПопыткиПрохожденияТестовСУЗ КАК ДополнительныеПопыткиПрохожденияТестовСУЗ
		|ГДЕ
		|	ДополнительныеПопыткиПрохожденияТестовСУЗ.Период > &ДатаПоследнейПопытки
		|	И ДополнительныеПопыткиПрохожденияТестовСУЗ.Пользователь = &Пользователь
		|	И ДополнительныеПопыткиПрохожденияТестовСУЗ.ПрохождениеОбучения = &ПрохождениеОбучения";
		
	Если ЗначениеЗаполнено(Задание)	Тогда
		
		Запрос.Текст = Запрос.Текст + "
		|	И ДополнительныеПопыткиПрохожденияТестовСУЗ.Задание = &Задание";
		
		Запрос.УстановитьПараметр("Задание", Задание);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭлементСодержания)	Тогда 
		
		Запрос.Текст = Запрос.Текст + "
		|	И ДополнительныеПопыткиПрохожденияТестовСУЗ.ЭлементСодержания = &ЭлементСодержания";

		Запрос.УстановитьПараметр("ЭлементСодержания", ЭлементСодержания);
		
	КонецЕсли;	
		
	Запрос.УстановитьПараметр("ДатаПоследнейПопытки", ДатаПоследнейПопытки);
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("ПрохождениеОбучения", ПрохождениеОбучения);

	Результат = Запрос.Выполнить();

	Если Результат.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

Функция АдресПубликацииЭлектронногоРесурса(СтрокаПараметровЗапроса, БазовыйАдрес, АдресВыхода) Экспорт
	
	// Получаем переменные
	
	Результат = Новый Структура("Адрес, ОписаниеОшибки, КодОшибки, РазмещеныДанныеДляВебКабинета, КонтрольнаяСумма", "", "", "", Ложь, "");
	
	СтруктураПараметровСтраницы         = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(СтрокаПараметровЗапроса);
	ИдентификаторЭлектронногоРесурса    = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "res");
	ИдентификаторПрохожденияОбучения    = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "userActivity");
	ИдентификаторПроведенияОбучения     = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "providingEducation");
	ИдентификаторЗадания                = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "task");
	ЦелевоеОкно                         = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "window");
	ИдентификаторПользователя           = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "user");
	
	ИдентификаторЭлементаСодержания     = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "item");
	ИдентификаторЭлементаПодборки       = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "idGroup");
	ИдентификаторЭлементаГлоссария      = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "elementGlossary");
	ИдентификаторОбъектаСУЗ             = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "object");
	СловаДляВыделенияСУЗ                = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "highlight");
	ТолькоПросмотр                      = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураПараметровСтраницы, "readonly");
	
	// Делаем базовые проверки
	
	Если ЗначениеЗаполнено(ИдентификаторЭлектронногоРесурса) Тогда
		ЭлектронныйРесурс = Справочники.СводыЗнанийСУЗ.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторЭлектронногоРесурса));
	Иначе
		Результат.КодОшибки = "errorData";
		Результат.ОписаниеОшибки = НСтр("ru = 'Идентификатор электронного ресурса не задан'");
		Возврат Результат;
	КонецЕсли;
	
	СвойстваПубликации = ЭлектронныеРесурсыСУЗ.ПолучитьСвойстваПубликации(ЭлектронныйРесурс);
	
	Если СвойстваПубликации = Неопределено Тогда
		Результат.КодОшибки = "publicationNotFound";
		Результат.ОписаниеОшибки = НСтр("ru = 'Публикация не найдена'");
		Возврат Результат;
	КонецЕсли;
	
	Если РазработкаСУЗ.ИспользоватьВстроенныйПлеерКурсовВебКабинета() Тогда
		
		Если ЗначениеЗаполнено(ИдентификаторПрохожденияОбучения)
			ИЛИ ЗначениеЗаполнено(ИдентификаторПроведенияОбучения) Тогда
			
			Если ЗначениеЗаполнено(ИдентификаторПрохожденияОбучения) Тогда
				// Задание
				ПрохождениеОбучения = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторПрохожденияОбучения));
				ПроведениеОбучения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПрохождениеОбучения, "ПроведениеОбучения");
				ПлеерПроведенияОбучения = Документы.ПроведениеОбученияСУО.ПлеерВебКабинетаЗадания(ПроведениеОбучения, ЭлектронныйРесурс);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ИдентификаторПроведенияОбучения) Тогда
				// Дополнительные материалы
				ПроведениеОбучения = Документы.ПроведениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторПроведенияОбучения));
				ПлеерПроведенияОбучения = Документы.ПроведениеОбученияСУО.ПлеерВебКабинетаДополнительногоМатериала(ПроведениеОбучения, ЭлектронныйРесурс);			
			КонецЕсли;
			
			Если ПлеерПроведенияОбучения = Перечисления.ПлеерыКурсовВебКабинетаСУЗ.Встроенный Тогда
				Если НЕ СвойстваПубликации.РазмещеныДанныеДляВебКабинета Тогда
					Результат.КодОшибки = "publicationNotFound";
					Результат.ОписаниеОшибки = НСтр("ru = 'Публикация данных встроенного плеера не найдена'");
					Возврат Результат;	
				КонецЕсли;
				Результат.РазмещеныДанныеДляВебКабинета	= Истина;
			Иначе		
				Результат.РазмещеныДанныеДляВебКабинета	= Ложь;
			КонецЕсли;
			
		Иначе			
			// Библиотека
			Результат.РазмещеныДанныеДляВебКабинета = СвойстваПубликации.РазмещеныДанныеДляВебКабинета;
		КонецЕсли;
	Иначе
		
		Результат.РазмещеныДанныеДляВебКабинета = Ложь;
		
	КонецЕсли;
	
	Результат.КонтрольнаяСумма = СвойстваПубликации.КонтрольнаяСумма;
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	// Делаем проверки прохождения обучения
	
	Если ЗначениеЗаполнено(ИдентификаторПрохожденияОбучения)
		И ЗначениеЗаполнено(ИдентификаторЗадания)
		И ТолькоПросмотр <> "true"
		И НЕ ЗначениеЗаполнено(ИдентификаторПользователя) Тогда
		
		ПрохождениеОбучения = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(
			Новый УникальныйИдентификатор(ИдентификаторПрохожденияОбучения));
						
		РезультатПрохожденияЗадания = ОбучениеСУО.ПриПрохожденииЗадания(ПрохождениеОбучения, ЭлектронныйРесурс,,,,,,Истина);
		
		Если РезультатПрохожденияЗадания.ОписаниеПрохожденияМероприятия.ВремяИстекло Тогда
			
			ВебКабинетСУ.ОбновитьДанныеОбъекта(Документы.ПопыткаВыполненияЗаданияСУО, РезультатПрохожденияЗадания.ПопыткаВыполненияЗадания);
			ВебКабинетСУО.ОбновитьДанныеПрохожденияОбученияВебКабинета(ПрохождениеОбучения, РезультатПрохожденияЗадания.ОписаниеПрохожденияМероприятия);
			
			Результат.КодОшибки = "expiredTime";
			Результат.ОписаниеОшибки = НСтр("ru = 'Закончилось отведенное время'");
			Возврат Результат;	
			
		КонецЕсли;
		
	КонецЕсли;
	
	//----------------------------------//
	
	// Получаем адрес электронного ресурса
	
	АдресЭлектронногоРесурса = ЭлектронныеРесурсыСУЗКлиентСервер.ПутьККаталогуПубликацииЭлектронногоРесурса(ЭлектронныйРесурс, СвойстваПубликации.КонтрольнаяСумма, БазовыйАдрес, "");
	АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "index.html?";
	
	АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "api=ws";
	
	Если ЗначениеЗаполнено(ИдентификаторПрохожденияОбучения) Тогда
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&userActivity=" + Строка(ИдентификаторПрохожденияОбучения);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИдентификаторПроведенияОбучения) Тогда
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&providingEducation=" + Строка(ИдентификаторПроведенияОбучения);
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ИдентификаторЗадания) Тогда
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&task=" + Строка(ИдентификаторЗадания);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЦелевоеОкно) Тогда
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&window=" + ЦелевоеОкно;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИдентификаторПользователя) Тогда
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&user=" + ИдентификаторПользователя;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИдентификаторЭлементаСодержания) Тогда
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&item=" + ИдентификаторЭлементаСодержания;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИдентификаторЭлементаПодборки) Тогда
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&idGroup=" + ИдентификаторЭлементаПодборки;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИдентификаторЭлементаГлоссария) Тогда
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&elementGlossary=" + ИдентификаторЭлементаГлоссария;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИдентификаторОбъектаСУЗ) Тогда
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&object=" + ИдентификаторОбъектаСУЗ;
	КонецЕсли;
	
	Если ТипЗнч(СловаДляВыделенияСУЗ) = Тип("Строка")
		И ЗначениеЗаполнено(СловаДляВыделенияСУЗ) Тогда
		
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&highlight=" + СловаДляВыделенияСУЗ;
		
	КонецЕсли;
	
	Если ТипЗнч(СловаДляВыделенияСУЗ) = Тип("Массив")
		И СловаДляВыделенияСУЗ.Количество() > 0 Тогда
		
		Для каждого СловоДляВыделения Из СловаДляВыделенияСУЗ Цикл
			АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&highlight=" + СловоДляВыделения;	
		КонецЦикла;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(АдресВыхода) Тогда
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&closeURL=" + АдресВыхода;
	КонецЕсли;
	
	Если ТолькоПросмотр = "true" Тогда
		АдресЭлектронногоРесурса = АдресЭлектронногоРесурса + "&readonly=true";
	КонецЕсли;
	
	Результат.Адрес = АдресЭлектронногоРесурса;
	
	Возврат Результат;
	
КонецФункции

Функция ИнициализироватьКаталогЭлектронногоРесурса(Знач ЭлектронныйРесурс, Знач КонтрольнаяСумма, Знач ПутьККаталогуВыгрузки,  Знач ПутьККаталогуПубликации, Знач ОчиститьКаталогПубликаций = Ложь) Экспорт
	
	РезультатИнициализации = Новый Структура("КаталогИнициализирован, ТекстОшибки, ПутьККаталогуПубликации", Ложь, "", "");
	
	// Делаем проверки
	//
	
	Если НЕ ЗначениеЗаполнено(ПутьККаталогуВыгрузки)
		ИЛИ НЕ ЗначениеЗаполнено(ЭлектронныйРесурс)
		ИЛИ НЕ ЗначениеЗаполнено(КонтрольнаяСумма) Тогда
		
		РезультатИнициализации.ТекстОшибки = НСтр("ru = 'Ошибка: не заданы обязательные параметры инициализации каталога'");
		
		Возврат РезультатИнициализации; 
		
	КонецЕсли;
	
	ПутьККаталогуПубликацииЭлектронногоРесурса = ЭлектронныеРесурсыСУЗКлиентСервер.ПутьККаталогуПубликацииЭлектронногоРесурса(ЭлектронныйРесурс, КонтрольнаяСумма, ПутьККаталогуВыгрузки);
	
	РезультатИнициализации.ПутьККаталогуПубликации = ПутьККаталогуПубликацииЭлектронногоРесурса;
	
	Если НЕ ОчиститьКаталогПубликаций Тогда
		
		КаталогПубликацииЭлектронногоРесурса = Новый Файл(ПутьККаталогуПубликацииЭлектронногоРесурса);
		
		Если КаталогПубликацииЭлектронногоРесурса.Существует() И КаталогПубликацииЭлектронногоРесурса.ЭтоКаталог() Тогда
			РезультатИнициализации.КаталогИнициализирован = Истина;
			Возврат РезультатИнициализации; // Каталог публикации уже инициализирован			
		КонецЕсли;
		
	КонецЕсли;
	
	// Создаем недостающие и удаляем старые каталоги
	//
	
	ПутьККаталогуЭлектронныхРесурсов           = ЭлектронныеРесурсыСУЗКлиентСервер.ПутьККаталогуЭлектронныхРесурсов(ПутьККаталогуВыгрузки);
	ПутьККаталогуПубликацийЭлектронногоРесурса = ЭлектронныеРесурсыСУЗКлиентСервер.ПутьККаталогуПубликацийЭлектронногоРесурса(ЭлектронныйРесурс, ПутьККаталогуВыгрузки);
	
	РезультатПроверки = ОбщегоНазначенияСУКлиентСервер.ПроверитьДоступностьКаталогаДляЗаписи(ПутьККаталогуВыгрузки);
	
	Если НЕ РезультатПроверки.ДоступенДляЗаписи Тогда
		РезультатИнициализации.ТекстОшибки = НСтр("ru = 'Ошибка инициализации каталога публикации электронного ресурса %1. Возможная причина: %2'");	
		РезультатИнициализации.ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			РезультатИнициализации.ТекстОшибки, ПутьККаталогуВыгрузки, РезультатПроверки.ОписаниеОшибки);
		Возврат РезультатИнициализации;
	КонецЕсли;
	
	КаталогЭлектронныхРесурсов = Новый Файл(ПутьККаталогуЭлектронныхРесурсов);
	
	Если НЕ КаталогЭлектронныхРесурсов.Существует() ИЛИ НЕ КаталогЭлектронныхРесурсов.ЭтоКаталог() Тогда
		СоздатьКаталог(ПутьККаталогуЭлектронныхРесурсов);
	КонецЕсли;
	
	КаталогПубликацийЭлектронногоРесурса = Новый Файл(ПутьККаталогуПубликацийЭлектронногоРесурса);
	
	Если НЕ КаталогПубликацийЭлектронногоРесурса.Существует() ИЛИ НЕ КаталогПубликацийЭлектронногоРесурса.ЭтоКаталог() Тогда
		
		СоздатьКаталог(ПутьККаталогуПубликацийЭлектронногоРесурса);
		
	Иначе
	
		Если ОчиститьКаталогПубликаций Тогда
			Попытка
				УдалитьФайлы(ОбщегоНазначенияСУКлиентСервер.УбратьКонечныйРазделительПути(ПутьККаталогуПубликацийЭлектронногоРесурса));
			Исключение
				ТекстСообщения = НСтр("ru = 'Во время удаления каталога %1 произошла ошибка'");
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, ПутьККаталогуПубликацийЭлектронногоРесурса);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			КонецПопытки;
		КонецЕсли;
		
	КонецЕсли;
	
	СоздатьКаталог(ПутьККаталогуПубликацииЭлектронногоРесурса);
	
	// Размещаем файл res.js
	//
	
	Обработки.ПубликацияЭлектронныхРесурсовСУЗ.РазместитьФайлResJS(ПутьККаталогуЭлектронныхРесурсов);
	
	// Выгружаем файлы публикации
	//
	
	Если ЗначениеЗаполнено(ПутьККаталогуПубликации) Тогда		
		ОбщегоНазначенияСУКлиентСервер.СкопироватьКаталог(ПутьККаталогуПубликации, ПутьККаталогуПубликацииЭлектронногоРесурса);		
	Иначе				
		ВызватьИсключение НСтр("ru = 'Путь к каталогу публикации не задан'");		
	КонецЕсли;
		
	// Завершаем
	//
	
	РезультатИнициализации.КаталогИнициализирован = Истина;
	Возврат РезультатИнициализации;
	

	
КонецФункции

Процедура ОтменитьПрохождениеЗадания(Знач ПрохождениеОбучения, Знач Задание) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОтветНаВопросСУЗ.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ОтветНаВопросСУЗ КАК ОтветНаВопросСУЗ
		|ГДЕ
		|	ОтветНаВопросСУЗ.СессияВыполненияТеста.Задание = &Задание
		|	И ОтветНаВопросСУЗ.СессияВыполненияТеста.ПрохождениеОбучения = &ПрохождениеОбучения
		|	И ОтветНаВопросСУЗ.Проведен = &Проведен
		|	И ОтветНаВопросСУЗ.Отменено = &Отменено
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПопыткаВыполненияАктивногоРесурсаSCORM.Ссылка
		|ИЗ
		|	Документ.ПопыткаВыполненияАктивногоРесурсаSCORM КАК ПопыткаВыполненияАктивногоРесурсаSCORM
		|ГДЕ
		|	ПопыткаВыполненияАктивногоРесурсаSCORM.ПрохождениеОбучения = &ПрохождениеОбучения
		|	И ПопыткаВыполненияАктивногоРесурсаSCORM.Задание = &Задание
		|	И ПопыткаВыполненияАктивногоРесурсаSCORM.Проведен = &Проведен
		|	И ПопыткаВыполненияАктивногоРесурсаSCORM.Отменено = &Отменено
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПопыткаВыполненияПодборкиВопросовСУЗ.Ссылка
		|ИЗ
		|	Документ.ПопыткаВыполненияПодборкиВопросовСУЗ КАК ПопыткаВыполненияПодборкиВопросовСУЗ
		|ГДЕ
		|	ПопыткаВыполненияПодборкиВопросовСУЗ.Проведен = &Проведен
		|	И ПопыткаВыполненияПодборкиВопросовСУЗ.ПрохождениеОбучения = &ПрохождениеОбучения
		|	И ПопыткаВыполненияПодборкиВопросовСУЗ.Задание = &Задание
		|	И ПопыткаВыполненияПодборкиВопросовСУЗ.Отменено = &Отменено
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПопыткаВыполненияСтатичногоОбъектаСУЗ.Ссылка
		|ИЗ
		|	Документ.ПопыткаВыполненияСтатичногоОбъектаСУЗ КАК ПопыткаВыполненияСтатичногоОбъектаСУЗ
		|ГДЕ
		|	ПопыткаВыполненияСтатичногоОбъектаСУЗ.Проведен = &Проведен
		|	И ПопыткаВыполненияСтатичногоОбъектаСУЗ.Задание = &Задание
		|	И ПопыткаВыполненияСтатичногоОбъектаСУЗ.ПрохождениеОбучения = &ПрохождениеОбучения
		|	И ПопыткаВыполненияСтатичногоОбъектаСУЗ.Отменено = &Отменено
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СессияЭлектронногоРесурсаСУЗ.Ссылка
		|ИЗ
		|	Документ.СессияЭлектронногоРесурсаСУЗ КАК СессияЭлектронногоРесурсаСУЗ
		|ГДЕ
		|	СессияЭлектронногоРесурсаСУЗ.Проведен = &Проведен
		|	И СессияЭлектронногоРесурсаСУЗ.Задание = &Задание
		|	И СессияЭлектронногоРесурсаСУЗ.ПрохождениеОбучения = &ПрохождениеОбучения
		|	И СессияЭлектронногоРесурсаСУЗ.Отменено = &Отменено";
	
	Запрос.УстановитьПараметр("Задание", Задание);
	Запрос.УстановитьПараметр("Проведен", Истина);
	Запрос.УстановитьПараметр("Отменено", Ложь);
	Запрос.УстановитьПараметр("ПрохождениеОбучения", ПрохождениеОбучения);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	НачатьТранзакцию();
	
	Попытка
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ДокументОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			ДокументОбъект.Отменено = Истина;
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		КонецЦикла;		
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецПроцедуры


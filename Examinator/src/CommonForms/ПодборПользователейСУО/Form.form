    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДокументПрохождениеОбученияСУО.Ссылка,
	ДокументПрохождениеОбученияСУО.ПометкаУдаления,
	ДокументПрохождениеОбученияСУО.Номер,
	ДокументПрохождениеОбученияСУО.Дата,
	ДокументПрохождениеОбученияСУО.Проведен,
	ДокументПрохождениеОбученияСУО.Сценарий,
	ДокументПрохождениеОбученияСУО.ПроведениеОбучения,
	ДокументПрохождениеОбученияСУО.ДатаНачалаПрохождения,
	ДокументПрохождениеОбученияСУО.ДатаОкончанияПрохождения,
	ДокументПрохождениеОбученияСУО.РодительскоеПрохождение,
	ДокументПрохождениеОбученияСУО.Баллы,
	ДокументПрохождениеОбученияСУО.Статус,
	ДокументПрохождениеОбученияСУО.ЗавершеноВПроцентах,
	ДокументПрохождениеОбученияСУО.УчебнаяГруппа,
	ДокументПрохождениеОбученияСУО.Заявка,
	ДокументПрохождениеОбученияСУО.Пользователь КАК Пользователь,
	ДокументПрохождениеОбученияСУО.Отменено,
	ДокументПрохождениеОбученияСУО.МоментВремени,
	ВЫБОР
		КОГДА УчастникиОбученияСУО.Регистратор ЕСТЬ NULL 
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК Активный
ИЗ
	Документ.ПрохождениеОбученияСУО КАК ДокументПрохождениеОбученияСУО
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УчастникиОбученияСУО КАК УчастникиОбученияСУО
		ПО ДокументПрохождениеОбученияСУО.Пользователь = УчастникиОбученияСУО.Пользователь
			И ДокументПрохождениеОбученияСУО.Ссылка = УчастникиОбученияСУО.Регистратор
			И ДокументПрохождениеОбученияСУО.ПроведениеОбучения = УчастникиОбученияСУО.ПроведениеОбучения
			И ДокументПрохождениеОбученияСУО.Сценарий = УчастникиОбученияСУО.Сценарий
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЭлементыШкалыОценокСУО.ЗначенияБаллов КАК ЭлементыШкалыОценокСУОЗначенияБаллов
		ПО ДокументПрохождениеОбученияСУО.Баллы = ЭлементыШкалыОценокСУОЗначенияБаллов.Значение
			И ДокументПрохождениеОбученияСУО.Сценарий.ШкалаОценки = ЭлементыШкалыОценокСУОЗначенияБаллов.Ссылка.Владелец
ГДЕ
	ДокументПрохождениеОбученияСУО.ПроведениеОбучения = &amp;ПроведениеОбучения
	И ДокументПрохождениеОбученияСУО.Сценарий = &amp;Сценарий</queryText>
      <mainTable>Document.ПрохождениеОбученияСУО</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>

&НаКлиенте
Процедура ЭлектронныеЗаданияПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	УстановитьРеквизитыПоУмолчаниюТаблицыЭлектронныеЗадания();
	
КонецПроцедуры

&НаКлиенте
Процедура ЭлектронныеЗаданияПриИзменении(Элемент)
	УстановитьВидимостьЭлементовЗакладкиЗаданий(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ЭлектронныеЗаданияПередУдалением(Элемент, Отказ)
		
	ВыделенныеСтроки = Элементы.ЭлектронныеЗадания.ВыделенныеСтроки;
	
	Если ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Отказ = Истина;
	ОписаниеОповещения = Новый ОписаниеОповещения("УдалениеЗаданияПродолжение", ЭтотОбъект, ВыделенныеСтроки);
	ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'Удалить выделенные задания?'"), РежимДиалогаВопрос.ДаНет, 0);
	
КонецПроцедуры

&НаКлиенте
Процедура УдалениеЗаданияПродолжение(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да
		И ТипЗнч(Параметры) = Тип("Массив") Тогда
		
		МассивСтрок = Новый Массив;
		Для каждого ИндексСтроки Из Параметры Цикл
			МассивСтрок.Добавить(ЭлектронныеЗадания.НайтиПоИдентификатору(ИндексСтроки));
		КонецЦикла;
		
		Для каждого Строка Из МассивСтрок Цикл
			ЭлектронныеЗадания.Удалить(Строка);
		КонецЦикла;
		
		Модифицированность = Истина;
		
    КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЭлектронныеЗаданияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	НачатьВыборПродолжительностиЗадания(Элемент);
КонецПроцедуры

&НаКлиенте
Процедура НачатьВыборПродолжительностиЗадания(Элемент)
	
	Если Элемент.ТекущийЭлемент = Неопределено ИЛИ Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Элемент.ТекущийЭлемент.Имя <> "ЭлектронныеЗаданияПродолжительностьСтрока" Тогда
		Возврат;
	КонецЕсли;
	
	ПродолжительностьСтруктура = Новый Структура;
	ПродолжительностьСтруктура.Вставить("ДатаНачала", Элемент.ТекущиеДанные.ДатаНачалаДоступаКЗаданию); 
	ПродолжительностьСтруктура.Вставить("ДатаОкончания", Элемент.ТекущиеДанные.ДатаОкончанияДоступаКЗаданию);
	ПродолжительностьСтруктура.Вставить("СкрытьВремя", Элемент.ТекущиеДанные.СкрытьВремяДоступаКЗаданию);
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("НачальноеЗначение", ПродолжительностьСтруктура);
	ПараметрыФормы.Вставить("ФиксированныеДаты", Истина);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ИзменитьПродолжительностьЗаданиеПродолжение", ЭтотОбъект, Элемент.ТекущиеДанные);			
	ОткрытьФорму("ОбщаяФорма.ВводПериодаСУ", ПараметрыФормы,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПродолжительностьЗаданиеПродолжение(Период, ДополнительныеПараметры) Экспорт
	
	Если Период = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	ТекущиеДанные = ДополнительныеПараметры;
	ТекущиеДанные.ДатаНачалаДоступаКЗаданию = Период.ДатаНачала;
	ТекущиеДанные.ДатаОкончанияДоступаКЗаданию = Период.ДатаОкончания;
	ТекущиеДанные.СкрытьВремяДоступаКЗаданию = Период.СкрытьВремя;		
	ТекущиеДанные.ПродолжительностьСтрока = ОбщегоНазначенияСУКлиентСервер.ПериодВСтроку(
		Период.ДатаНачала, Период.ДатаОкончания, Период.СкрытьВремя);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ПровестиИЗакрытьДокумент(Команда)
	Отказ = Ложь;
	ПараметрыЗаписи = Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	ВыполнитьПроверкуПередЗаписью(Отказ, ПараметрыЗаписи, Истина);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	Если Записать(ПараметрыЗаписи) Тогда
		Закрыть();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьИнтервалЗаписиНаМероприятие(Команда)
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода();
	Диалог.Период.ДатаНачала    = Объект.ДатаОткрытияЗаписи;
	Диалог.Период.ДатаОкончания = Объект.ДатаЗакрытияЗаписи;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("УстановитьИнтервалЗаписиНаМероприятиеПродолжение", ЭтотОбъект);
	
	Диалог.Показать(ОписаниеОповещения);

КонецПроцедуры

&НаКлиенте
Процедура УстановитьИнтервалЗаписиНаМероприятиеПродолжение(Период, ДополнительныеПараметры) Экспорт
			
	Если Период = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Объект.ДатаОткрытияЗаписи = Период.ДатаНачала;	
	ДатаНачалаЗаписи = Объект.ДатаОткрытияЗаписи;
	ВремяНачалаЗаписи = Объект.ДатаОткрытияЗаписи;
	
	Объект.ДатаЗакрытияЗаписи = Период.ДатаОкончания;
	ДатаОкончанияЗаписи	= Объект.ДатаЗакрытияЗаписи;
	ВремяОкончанияЗаписи = Объект.ДатаЗакрытияЗаписи;
		
КонецПроцедуры

&НаКлиенте
Процедура УстановитьИнтервалПроведенияОбучения(Команда)
		
	Диалог = Новый ДиалогРедактированияСтандартногоПериода();
	Если ЭлектронноДистанционное Тогда
		Диалог.Период.ДатаНачала    = Объект.ДатаНачалаДоступа;
		Диалог.Период.ДатаОкончания = Объект.ДатаКонтроля;
	Иначе
		Диалог.Период.ДатаНачала    = Объект.ДатаНачалаПроведения;
		Диалог.Период.ДатаОкончания = Объект.ДатаОкончанияПроведения;		
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("УстановитьИнтервалПроведенияОбученияПродолжение", ЭтотОбъект);
	
	Диалог.Показать(ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьИнтервалПроведенияОбученияПродолжение(Период, ДополнительныеПараметры) Экспорт
	
	Если Период = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭлектронноДистанционное Тогда
		
		Объект.ДатаНачалаДоступа    = Период.ДатаНачала;
		Объект.ДатаКонтроля = Период.ДатаОкончания;

		ДатаНачалаДоступа = Объект.ДатаНачалаДоступа;
		ВремяНачалаДоступа = Объект.ДатаНачалаДоступа;
		
		ДатаКонтроля = Объект.ДатаКонтроля;
		ВремяКонтроля = Объект.ДатаКонтроля;		
		
	Иначе
		
		Объект.ДатаНачалаПроведения    = Период.ДатаНачала;
		Объект.ДатаОкончанияПроведения = Период.ДатаОкончания;

		ДатаНачалаПроведения = Объект.ДатаНачалаПроведения;
		ВремяНачалаПроведения = Объект.ДатаНачалаПроведения;
		
		ДатаОкончанияПроведения = Объект.ДатаОкончанияПроведения;
		ВремяОкончанияПроведения = Объект.ДатаОкончанияПроведения;		
		
	КонецЕсли;
		
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПодчиненныеМероприятие(Команда)
	
	Отказ = Ложь;
	
	ОбщегоНазначенияСУКлиент.ПередДобавлениемЭлементаПодчиненногоСправочника(ЭтотОбъект, Отказ);
	
	Если НЕ ЗначениеЗаполнено(Объект.Мероприятие) Тогда
		Текст = НСтр("ru = 'Укажите мероприятие'");
		Поле = "Мероприятие";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст,,Поле,"Объект",Отказ);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.СхемаПроведения) Тогда
		Текст = НСтр("ru = 'Укажите схему проведения'");
		Поле = "СхемаПроведения";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст,,Поле,"Объект",Отказ);
	КонецЕсли;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗаполнитьПодчиненныеМероприятиеПродолжение", ЭтотОбъект);		
		
	ПоказатьВопрос(ОписаниеОповещения, Нстр("ru = 'Список подчиненных мероприятий будет заменен. Продолжить?'"), РежимДиалогаВопрос.ДаНет, 0);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПодчиненныеМероприятиеПродолжение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
	    Возврат;
	КонецЕсли;
	
	ЗаполнитьПодчиненныеМероприятия(Объект.Ссылка, Объект.Мероприятие, Объект.СхемаПроведения);
	
	Элементы.ПроведениеПодчиненныхМероприятий.Обновить();	
	
КонецПроцедуры	

&НаКлиенте
Процедура ПерейтиКИнтернетРесурсу(Команда)
	
	Если ЗначениеЗаполнено(Объект.АдресВИнтернете) Тогда
		ПерейтиПоНавигационнойСсылке(Объект.АдресВИнтернете);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПодобратьУчастников(Команда)
	
	СпроситьПередЗачислениемУчастников("ПодобратьУчастниковПродолжение");
		
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьУчастниковПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПередЗачислениемУчастников(Отказ);
	
	Если НЕ Отказ Тогда
		
		АдресСпискаВХранилище = ПоместитьСписокУчастниковВХранилище();
		
		ПараметрыФормы = Новый Структура("ПараметрыРасширеннойФормыПодбора, РасширенныйПодбор", АдресСпискаВХранилище, Истина);

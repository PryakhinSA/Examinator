&НаКлиенте
Функция ВыбранныеПрохожденияОбучения()
	
	ПрохожденияДляОтмены = Новый Массив;
	
	Если Элементы.Участники.ВыделенныеСтроки = Неопределено Тогда
		Возврат ПрохожденияДляОтмены;
	КонецЕсли;
		
	Для каждого ВыделеннаяСтрока Из Элементы.Участники.ВыделенныеСтроки Цикл	
		Если ТипЗнч(ВыделеннаяСтрока) = Тип("ДокументСсылка.ПрохождениеОбученияСУО") Тогда
			ПрохожденияДляОтмены.Добавить(ВыделеннаяСтрока);
		КонецЕсли;	
	КонецЦикла;	
	
	Возврат ПрохожденияДляОтмены;
	
КонецФункции

&НаКлиенте
Процедура ОтменитьОбучениеУчастника(Команда)
	
	ПрохожденияДляОтмены = ВыбранныеПрохожденияОбучения();
	ПрохожденияДляОтмены = Новый ФиксированныйМассив(ПрохожденияДляОтмены);	
	УстановитьСнятьОтменуПрохожденияНаСервере(ПрохожденияДляОтмены);
				
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьЗаданияУчастника(Команда)
	
	ВыбранныеПрохождения = ВыбранныеПрохожденияОбучения();
	
	Если ВыбранныеПрохождения.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыВопросаПродолжение = Новый Структура();
	ПараметрыВопросаПродолжение.Вставить("ПрохожденияДляОтмены", Новый ФиксированныйМассив(ВыбранныеПрохождения));
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОтменитьЗаданияУчастников", ЭтотОбъект, ПараметрыВопросаПродолжение);
	ПараметрыФормы = Новый Структура("ПроведениеОбучения", Объект.Ссылка);
	ОткрытьФорму("Документ.ПроведениеОбученияСУО.Форма.ФормаВыбораЗаданияНаПроверку", ПараметрыФормы,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	

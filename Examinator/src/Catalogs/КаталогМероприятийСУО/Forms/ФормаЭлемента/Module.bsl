	УправлениеОбучениемСУОКлиент.УдалитьХарактеристику(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура СписокХарактеристик(Команда)
	ОткрытьФорму("ПланВидовХарактеристик.ХарактеристикиУчебныхОбъектовСУО.ФормаСписка",,,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПродолжительностьОбучения(Команда)
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("НачальноеЗначение", Объект.ПродолжительностьВСекундах);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ИзменитьПродолжительностьОбученияПродолжение", ЭтотОбъект);		
	
	ОткрытьФорму("ОбщаяФорма.ВводПериодаСУ", ПараметрыФормы,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПродолжительностьОбученияПродолжение(НоваяСтруктураПериода, ДополнительныеПараметры) Экспорт
	
	Если НоваяСтруктураПериода <> Неопределено Тогда
		
		Объект.ПродолжительностьВСекундах = ОбъектыSCORM.ПолучитьКоличествоСекундИзСтруктурыВременногоИнтервала(НоваяСтруктураПериода);
		Объект.Продолжительность = ОбъектыSCORM.ПолучитьПолнуюСтрокуИзКоличестваСекунд(Объект.ПродолжительностьВСекундах);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиКИнтернетРесурсу(Команда)
	
	Если ЗначениеЗаполнено(Объект.АдресВИнтернете) Тогда
		ПерейтиПоНавигационнойСсылке(Объект.АдресВИнтернете);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НесколькоПреподавателей(Команда)
	
	Если Элементы.НесколькоПреподавателей.Пометка
		И Объект.ДополнительныеПреподаватели.Количество() > 0 Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("НесколькоПреподавателейОчисткаСписка", ЭтотОбъект);		
		
		ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'Очистить список дополнительных преподавателей?'"), РежимДиалогаВопрос.ДаНет, 0);
		
	КонецЕсли;
	
	Элементы.НесколькоПреподавателей.Пометка = ?(Элементы.НесколькоПреподавателей.Пометка, Ложь, Истина);
	
	УстановитьДоступностьЭлементовФормыНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура НесколькоПреподавателейОчисткаСписка(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
	    Возврат;
	КонецЕсли;

	Объект.ДополнительныеПреподаватели.Очистить();
	
	УстановитьДоступностьЭлементовФормыНаСервере();
	
КонецПроцедуры	

&НаКлиенте
Процедура СоздатьНовыйФайл(Команда)

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Процедура УстановитьДоступностьЭлементовФормыНаСервере()
	
	ЭтоПодчиненное = Справочники.КаталогМероприятийСУО.ЭтоПодчиненное(Объект.Владелец);
	
	
	
	// Вид
	
	МассивПараметровВыбора = Новый Массив();
	МассивПараметровВыбора.Добавить(Новый ПараметрВыбора("Отбор.Скрыть", Ложь));
	
	Если ЭтоПодчиненное Тогда
		МассивПараметровВыбора.Добавить(Новый ПараметрВыбора("Отбор.Общее", Ложь));
	КонецЕсли;
	
	Элементы.Вид.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметровВыбора);
	
	// Владелец
	
	Если ЗначениеЗаполнено(Объект.Вид) И ЭтоПодчиненное Тогда
		Элементы.Владелец.Видимость = Истина;
	Иначе
		Элементы.Владелец.Видимость = Ложь;
	КонецЕсли;
	
	// Шкала оценки
	
	Если ЗначениеЗаполнено(Объект.Вид) И Объект.Вид.ВыставляетсяОценка Тогда
		Элементы.ШкалаОценки.Видимость = Истина;
	Иначе
		Элементы.ШкалаОценки.Видимость = Ложь;
	КонецЕсли;
		
	// Значимость
	
	Если ЗначениеЗаполнено(Объект.Вид) И ЭтоПодчиненное Тогда
		Элементы.Значимость.Видимость = Истина;
	Иначе
		Элементы.Значимость.Видимость = Ложь;
	КонецЕсли;
	
	// Группа "Проведение"
	
	Если ЗначениеЗаполнено(Объект.Вид) Тогда		
		Элементы.ГруппаПроведение.Видимость = Истина;				
	Иначе		
		Элементы.ГруппаПроведение.Видимость = Ложь;		
	КонецЕсли;
	
	// Место проведения
	
	Если Объект.Вид.Общее Тогда
		Элементы.МестоПроведения.Видимость = Ложь;
	Иначе
		Элементы.МестоПроведения.Видимость = Истина;
	КонецЕсли;
	
	// Тип аудитории
	
	Если НЕ Объект.Вид.Общее И
		Объект.МестоПроведения = Перечисления.МестаПроведенияМероприятийСУО.Аудитория Тогда
		
		Элементы.ТипАудитории.Видимость = Истина;
	Иначе
		
		Элементы.ТипАудитории.Видимость = Ложь;
		
	КонецЕсли;	
	
	// Роль преподавателя
		
	Если ЗначениеЗаполнено(Объект.Вид) 
		И Объект.Вид.ТребуетсяПреподаватель 
		И ПолучитьФункциональнуюОпцию("РасширеннаяФункциональностьСУО") Тогда
		Элементы.ГруппаРолиПреподавателей.Видимость = Истина;
	Иначе
		Элементы.ГруппаРолиПреподавателей.Видимость = Ложь;
	КонецЕсли;
	
	// Адрес в интернет
	
	Если НЕ Объект.Вид.Общее И Объект.МестоПроведения = Перечисления.МестаПроведенияМероприятийСУО.Дистанционно Тогда
		Элементы.ГруппаАдресВИнтернете.Видимость = Истина;
	Иначе
		Элементы.ГруппаАдресВИнтернете.Видимость = Ложь;
	КонецЕсли;
	
	// Схемы мероприятий
	
	Если ЗначениеЗаполнено(Объект.Вид) И Объект.Вид.Общее Тогда
		Элементы.СтраницаВариантыПроведенияОбучения.Видимость = Истина;
		ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(СхемыМероприятий, Объект.Ссылка, "Мероприятие");
		ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(СхемыМероприятий, Ложь, "Предопределенный");
	Иначе
		Элементы.СтраницаВариантыПроведенияОбучения.Видимость = Ложь;
	КонецЕсли;
	
	// Темы
	
	Если ЗначениеЗаполнено(Объект.Вид) И ЭтоПодчиненное Тогда
		
		Элементы.СтраницаТемы.Видимость = Истина;
		
		МассивПараметровВыбора = Новый Массив();
		МассивПараметровВыбора.Добавить(Новый ПараметрВыбора("Отбор.Владелец", Объект.Владелец.Мероприятие));
		Элементы.ТемыТема.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметровВыбора);
		
		Если Объект.ВсеТемы Тогда
			Элементы.Темы.Доступность = Ложь;
		Иначе
			Элементы.Темы.Доступность = Истина;
		КонецЕсли;
		
	Иначе
		
		Элементы.СтраницаТемы.Видимость = Ложь;
		
	КонецЕсли;
	
	// Содержание
	
	Если ЗначениеЗаполнено(Объект.Вид) И НЕ ЭтоПодчиненное Тогда
		Элементы.СтраницаСодержание.Видимость = Истина;
		ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(Содержание, Объект.Ссылка);
	Иначе
		Элементы.СтраницаСодержание.Видимость = Ложь;
	КонецЕсли;
	
	// Задания
	
	Если ЗначениеЗаполнено(Объект.Вид) И НЕ Объект.Вид.Общее И Объект.Вид.ВыставляетсяОценка Тогда
		
		Элементы.СтраницаЗадания.Видимость = Истина;
		
		ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(Задания, Объект.Ссылка);
		
		Если Объект.Вид.Электронное Тогда
			Элементы.ПоследовательноеПрохождениеЗаданий.Видимость = Истина;
		Иначе
			Элементы.ПоследовательноеПрохождениеЗаданий.Видимость = Ложь;
		КонецЕсли;
		
	Иначе
		
		Элементы.СтраницаЗадания.Видимость = Ложь;
		
	КонецЕсли;
				
	// Дополнительные преподаватели
	
	Если Объект.ДополнительныеПреподаватели.Количество() > 0 Тогда
		Элементы.НесколькоПреподавателей.Пометка = Истина;
	КонецЕсли;
	
	Если Элементы.НесколькоПреподавателей.Пометка Тогда
		Элементы.СтраницаДополнительныеПреподаватели.Видимость = Истина;
	Иначе
		Элементы.СтраницаДополнительныеПреподаватели.Видимость = Ложь;
	КонецЕсли;
	
	// Ресурсы
	
	Элементы.ГруппаКниги.Видимость = ПолучитьФункциональнуюОпцию("РасширеннаяФункциональностьСУО");
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьХарактеристикуНаСервере(ВидХарактеристики) Экспорт
	УправлениеОбучениемСУО.ДобавитьХарактеристикуНаСервере(ЭтотОбъект, ВидХарактеристики);
КонецПроцедуры

&НаСервере
Процедура УдалитьХарактеристикуНаСервере(ВыбранныйЭлемент) Экспорт
	УправлениеОбучениемСУО.УдалитьХарактеристикуНаСервере(ЭтотОбъект, ВыбранныйЭлемент);
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовок() Экспорт
	
	Если Объект.Ссылка.Пустая() И ЗначениеЗаполнено(Объект.Вид) Тогда
		
		АвтоЗаголовок = Ложь;
		
		Заголовок = НСтр("ru = '%1 (создание)'");
		
		Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Заголовок, ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Вид, "Наименование"));
		
	Иначе
		
		Заголовок = "";
		АвтоЗаголовок = Истина;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура РесурсыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока И НЕ Копирование И Элемент.ТекущиеДанные <> Неопределено Тогда
		Элемент.ТекущиеДанные.ПоказатьПриСтатусеЗапланировано = Ложь;
		Элемент.ТекущиеДанные.ПоказатьПриСтатусеАктивно = Истина;
		Элемент.ТекущиеДанные.ПоказатьПриСтатусеЗавершено = Истина;
	КонецЕсли;		
КонецПроцедуры



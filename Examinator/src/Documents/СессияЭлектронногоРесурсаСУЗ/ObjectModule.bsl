		Движение.НомерРегистратора      = Номер;
		
		ЭлектронныеРесурсыПереопределяемый.ПроведениеОбучения(Движение.ПроведениеОбучения, ПрохождениеОбучения);
		
		Если ЗначениеЗаполнено(СтруктураДанных.item) Тогда
			Движение.ЭлементСодержания = Справочники.СодержаниеСУЗ.ПолучитьСсылку(Новый УникальныйИдентификатор(СтруктураДанных.item));
		КонецЕсли;
		
		Движение.ДатаНачалаПрохождения     = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(СтруктураДанных.startDate);
		Движение.ДатаОкончанияПрохождения  = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(СтруктураДанных.endDate);
		
		ЗаполнитьДвижениеПопыткиSCORM(Движение, СтруктураДанных);
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПараметрSCORMИспользуется(НастройкиПакетаSCORM, Параметр)
	
	
	СтрокаТН = НастройкиПакетаSCORM.ТаблицаНастроек.Найти(Параметр, "Параметр");
	
	Если СтрокаТН = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат СтрокаТН.Используется;
	
КонецФункции

Процедура ЗаполнитьДвижениеПопыткиSCORM(Движение, ДанныеПопыткиSCO) Экспорт
	
	// Заполняем таблицу
	//
	
	ТаблицаСтатистикиПараметровSCORM = Перечисления.ИспользуемыеПараметрыSCORM.НоваяТаблицаСтатистикиПараметровSCORM();
	
	Если ДополнительныеСвойства.Свойство("ЭтоПолучениеСтатистикиSCORM")
		И ДополнительныеСвойства.ЭтоПолучениеСтатистикиSCORM Тогда
		НастройкиПакетаSCORM  = Справочники.РесурсыСУЗ.НастройкиSCORMДляПолученияСтатистики();
	Иначе
		НастройкиПакетаSCORM  = Справочники.РесурсыСУЗ.НастройкиПакетаSCORM(Движение.СсылкаНаОбъектСУЗ);
	КонецЕсли;	
	
	// Завершено
	
	ЗавершеноПередано = Ложь;
	ЗавершеноПереданоСОшибкой = Ложь;
	ЗавершеноЗначениеПеречисления = Неопределено;
	
	Если ЗначениеЗаполнено(ДанныеПопыткиSCO.completion_status)
		И ПараметрSCORMИспользуется(НастройкиПакетаSCORM, Перечисления.ИспользуемыеПараметрыSCORM.completion_status) Тогда
		
		ЗавершеноПередано = Истина;
		
		Попытка
			ЗавершеноЗначениеПеречисления = Перечисления.СостоянияВыполненияОбъектовSCORM[ДанныеПопыткиSCO.completion_status];
		Исключение
			ЗавершеноПереданоСОшибкой = Истина
		КонецПопытки;
		
	КонецЕсли;
	
	Перечисления.ИспользуемыеПараметрыSCORM.ДобавитьСтрокуВТаблицуСтатистики(
		ТаблицаСтатистикиПараметровSCORM,
		ЭлектронныйРесурс,
		Движение.ЭлементСодержания,
		Перечисления.ИспользуемыеПараметрыSCORM.completion_status,
		ЗавершеноПередано,
		ЗавершеноПереданоСОшибкой,
		ДанныеПопыткиSCO.completion_status);						
	
	// Оценка
	
	РезультатВПроцентах = 0;
	РезультатПередан = Ложь;
	РезультатПереданСОшибкой = Ложь;
	
	Если (ЗначениеЗаполнено(ДанныеПопыткиSCO.score.scaled)
		ИЛИ ЗначениеЗаполнено(ДанныеПопыткиSCO.score.min)
		ИЛИ ЗначениеЗаполнено(ДанныеПопыткиSCO.score.max)
		ИЛИ ЗначениеЗаполнено(ДанныеПопыткиSCO.score.raw))
		И ПараметрSCORMИспользуется(НастройкиПакетаSCORM, Перечисления.ИспользуемыеПараметрыSCORM.score) Тогда
		
		РезультатПередан = Истина;						

		Если ЗначениеЗаполнено(ДанныеПопыткиSCO.score.scaled) Тогда
			
			РезультатПередан = Истина;
			
			Попытка
				РезультатВПроцентах = Число(ДанныеПопыткиSCO.score.scaled);
			Исключение
				РезультатПереданСОшибкой = Истина;
			КонецПопытки;				
			
		Иначе
			
			Попытка
				Если (ДанныеПопыткиSCO.score.min + ДанныеПопыткиSCO.score.max) > 0 Тогда
					РезультатВПроцентах = (ДанныеПопыткиSCO.score.raw / (ДанныеПопыткиSCO.score.min + ДанныеПопыткиSCO.score.max));
				КонецЕсли;			
			Исключение
				РезультатПереданСОшибкой = Истина;
			КонецПопытки;				
			
		КонецЕсли;
		
	КонецЕсли;					
					
	Если РезультатВПроцентах < 0 Тогда
		РезультатВПроцентах = 0;
		РезультатПереданСОшибкой = Истина;
	КонецЕсли;			
	
	Если РезультатВПроцентах > 1 Тогда
		РезультатВПроцентах = 1;
		РезультатПереданСОшибкой = Истина;
	КонецЕсли;						
	
	Перечисления.ИспользуемыеПараметрыSCORM.ДобавитьСтрокуВТаблицуСтатистики(
		ТаблицаСтатистикиПараметровSCORM,
		ЭлектронныйРесурс,
		Движение.ЭлементСодержания,
		Перечисления.ИспользуемыеПараметрыSCORM.score,
		РезультатПередан,
		РезультатПереданСОшибкой,
		ДанныеПопыткиSCO.score); 
		
	РезультатВПроцентах = РезультатВПроцентах * 100;
		
	// Прогресс
	
	ПрогрессПередан = Ложь;
	ПрогрессПереданСОшибкой = Ложь;
	ЗавершеноВПроцентах = Неопределено;
	
	Если ЗначениеЗаполнено(ДанныеПопыткиSCO.progress_measure)
		И ПараметрSCORMИспользуется(НастройкиПакетаSCORM, Перечисления.ИспользуемыеПараметрыSCORM.progress_measure) Тогда
		
		ПрогрессПередан = Истина;
		Если ОбщегоНазначенияСУКлиентСервер.ЭтоЧисло(ДанныеПопыткиSCO.progress_measure) Тогда
			ЗавершеноВПроцентах = Число(ДанныеПопыткиSCO.progress_measure) * 100;
		Иначе
			ЗавершеноВПроцентах = 0;
			ПрогрессПереданСОшибкой = Истина;
		КонецЕсли;
		Если ЗавершеноВПроцентах > 100 Тогда
			ЗавершеноВПроцентах = 100;
			ПрогрессПереданСОшибкой = Истина;
		КонецЕсли;
		Если ЗавершеноВПроцентах < 0 Тогда
			ЗавершеноВПроцентах = 0;
			ПрогрессПереданСОшибкой = Истина;
		КонецЕсли;
		
	Иначе
		ЗавершеноВПроцентах = 0;
	КонецЕсли;
	
	Перечисления.ИспользуемыеПараметрыSCORM.ДобавитьСтрокуВТаблицуСтатистики(
		ТаблицаСтатистикиПараметровSCORM,
		ЭлектронныйРесурс,
		Движение.ЭлементСодержания,
		Перечисления.ИспользуемыеПараметрыSCORM.progress_measure,
		ПрогрессПередан,
		ПрогрессПереданСОшибкой,
		ДанныеПопыткиSCO.progress_measure);
							
	// Время сессии
	
	ВремяСессииПередано = Ложь;
	ВремяСессииПереданоСОшибкой = Ложь;
	
	Если ЗначениеЗаполнено(ДанныеПопыткиSCO.session_time)
		И ПараметрSCORMИспользуется(НастройкиПакетаSCORM, Перечисления.ИспользуемыеПараметрыSCORM.session_time) Тогда
		
		ВремяСессииПередано = Истина;

		Попытка
			ОбъектыSCORM.ПолучитьКоличествоСекундВременногоИнтервалаSCORM(ДанныеПопыткиSCO.session_time);
		Исключение
			ВремяСессииПереданоСОшибкой = Истина;
		КонецПопытки;
		
	КонецЕсли;
	
	Перечисления.ИспользуемыеПараметрыSCORM.ДобавитьСтрокуВТаблицуСтатистики(
		ТаблицаСтатистикиПараметровSCORM,
		ЭлектронныйРесурс,
		Движение.ЭлементСодержания,
		Перечисления.ИспользуемыеПараметрыSCORM.session_time,
		ВремяСессииПередано,
		ВремяСессииПереданоСОшибкой,
		ДанныеПопыткиSCO.session_time);						
	
	// Выход
	
	ВыходПередан = Ложь;
	ВыходЗначение = "suspend";
	
	Если ПараметрSCORMИспользуется(НастройкиПакетаSCORM, Перечисления.ИспользуемыеПараметрыSCORM.exit) Тогда		
		ВыходПередан = Истина;
		ВыходЗначение = ДанныеПопыткиSCO.exit;	
	КонецЕсли;
	
	Перечисления.ИспользуемыеПараметрыSCORM.ДобавитьСтрокуВТаблицуСтатистики(
		ТаблицаСтатистикиПараметровSCORM,
		ЭлектронныйРесурс,
		Движение.ЭлементСодержания,
		Перечисления.ИспользуемыеПараметрыSCORM.exit,
		ВыходПередан,
		Ложь,
		ДанныеПопыткиSCO.exit);
	
	// Успех
	
	УспехПередан = Ложь;
	УспехПереданСОшибкой = Ложь;
	УспехЗначениеПеречисления = Неопределено;
	
	Если ЗначениеЗаполнено(ДанныеПопыткиSCO.success_status)
		И ПараметрSCORMИспользуется(НастройкиПакетаSCORM, Перечисления.ИспользуемыеПараметрыSCORM.success_status) Тогда
		
		УспехПередан = Истина;
		
		Попытка
			УспехЗначениеПеречисления = Перечисления.СостоянияПрохожденияОбъектовSCORM[ДанныеПопыткиSCO.success_status];
		Исключение
			УспехПереданСОшибкой = Истина;
		КонецПопытки;						
		
	КонецЕсли;					

	Перечисления.ИспользуемыеПараметрыSCORM.ДобавитьСтрокуВТаблицуСтатистики(
		ТаблицаСтатистикиПараметровSCORM,
		ЭлектронныйРесурс,
		Движение.ЭлементСодержания,
		Перечисления.ИспользуемыеПараметрыSCORM.success_status,
		УспехПередан,
		УспехПереданСОшибкой,
		ДанныеПопыткиSCO.success_status);		
		
	// Заполняем движения
	//
	
	// ПопыткаЗавершена
	
	ПопыткаЗавершена = Ложь;
	
	Если ЗавершеноПередано И НЕ ЗавершеноПереданоСОшибкой Тогда
		Если ЗавершеноЗначениеПеречисления = Перечисления.СостоянияВыполненияОбъектовSCORM.completed Тогда			
			ПопыткаЗавершена = Истина;
		КонецЕсли;
	Иначе
		Если УспехПередан И НЕ УспехПереданСОшибкой Тогда
			Если УспехЗначениеПеречисления = Перечисления.СостоянияПрохожденияОбъектовSCORM.failed
				ИЛИ УспехЗначениеПеречисления = Перечисления.СостоянияПрохожденияОбъектовSCORM.passed Тогда
				ПопыткаЗавершена = Истина;
			КонецЕсли;
		КонецЕсли;
		Если ПрогрессПередан И НЕ ПрогрессПереданСОшибкой Тогда
			Если ЗавершеноВПроцентах = 100 Тогда
				ПопыткаЗавершена = Истина;
			КонецЕсли;
		КонецЕсли;
		Если РезультатПередан И НЕ РезультатПереданСОшибкой Тогда
			ПопыткаЗавершена = Истина;	
		КонецЕсли;
	КонецЕсли;
	
	Если ВыходПередан Тогда
		Если ВыходЗначение = "suspend" Тогда
			ПопыткаЗавершена = Ложь;
		Иначе
			ПопыткаЗавершена = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Движение.ПопыткаЗавершена = ПопыткаЗавершена;

	// ВыставляетсяОценка
	
	Движение.ВыставляетсяОценка = ?(РезультатПередан И НЕ РезультатПереданСОшибкой, Истина, Ложь);	
	
	// Результат
	
	Движение.Результат = 0;
	
	Если ПопыткаЗавершена Тогда
		Если Движение.ВыставляетсяОценка Тогда
			Движение.Результат = РезультатВПроцентах;		
		Иначе
			Движение.Результат = 100;
		КонецЕсли;
	КонецЕсли;
	
	// Завершено в процентах
	
	Если Движение.ПопыткаЗавершена Тогда
		Движение.ЗавершеноВПроцентах = 100;
	Иначе
		Если ПрогрессПередан И НЕ ПрогрессПереданСОшибкой Тогда
			Движение.ЗавершеноВПроцентах = ЗавершеноВПроцентах;	
		Иначе
			Движение.ЗавершеноВПроцентах = 0;
		КонецЕсли;
	КонецЕсли;
	
	// ВремяПрохожденияВСекундах
	
	Движение.ВремяПрохожденияВСекундах = 0;
	
	Если ВремяСессииПередано И НЕ ВремяСессииПереданоСОшибкой Тогда
		Если ДанныеПопыткиSCO.Свойство("total_time") Тогда
			Движение.ВремяПрохожденияВСекундах = ОбъектыSCORM.ПолучитьКоличествоСекундВременногоИнтервалаSCORM(ДанныеПопыткиSCO.total_time);
		КонецЕсли;
		Если ДанныеПопыткиSCO.Свойство("total_time_sec") Тогда
			Движение.ВремяПрохожденияВСекундах = ДанныеПопыткиSCO.total_time_sec / 100; // Сантисекунды в секунды
		КонецЕсли;
	Иначе		
		Если ДанныеПопыткиSCO.Свойство("historySessions") Тогда			
			Для каждого ДанныеСессии Из ДанныеПопыткиSCO.historySessions Цикл
				Если НЕ ДанныеСессии.Свойство("startDate") Тогда
					Продолжить;
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(ДанныеСессии.startDate) Тогда
					Продолжить;
				КонецЕсли;
				Если НЕ ДанныеСессии.Свойство("endDate") Тогда
					Продолжить;
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(ДанныеСессии.endDate) Тогда
					Продолжить;
				КонецЕсли;				
				Движение.ВремяПрохожденияВСекундах = Движение.ВремяПрохожденияВСекундах
					+ Окр((ДанныеСессии.endDate - ДанныеСессии.startDate) / 1000);				
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти


#КонецЕсли
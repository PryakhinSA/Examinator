		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ИспользоватьПинКодыВПерсональныхНастройках", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ПоказатьПинКодыНаГлавнойСтранице", Ложь);
	КонецЕсли;
		
	//----------------------------------//
	
	Если Форма.Объект.Редакция = Перечисления.РедакцииВебКабинетаСУ.Редакция30 Тогда
		
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ВариантКалендаря", Ложь);	
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "СтраницаРазделы", Ложь);
		
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ПоказыватьПользователейОнлайн", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ПоказыватьПользователейОнлайнВМеню", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ДоступенПолныйКаталогПользователей", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "СтраницаЭлектронныеРесурсы", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ОткрыватьЭлементыБиблиотекиВНовомОкне", Ложь);
		
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ДоступенСписокОбучения", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ПоказыватьСтатусОбучения", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ДоступнаКарточкаОбучения", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ПоказыватьРолиПреподавателей", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ОткрыватьЭлектронныеРесурсыОбученияВНовомОкне", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ВариантКалендаря", Ложь);
		
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ПоказыватьКоличествоЭлементовРазделаБиблиотеки", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ДоступнаОтправкаЛичныхСообщенийИзКарточкиПользователя", Ложь);
		
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ДоступныРезультатыОбучения", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ДоступенРазделПроверкиЗаданий", Ложь);
		
	КонецЕсли;
	
	Если Форма.Объект.Редакция = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
		
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "АдресКаталогаКартинок", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "СтраницаИнтеграция", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "РазрешенноеЧислоМинутНеактивности", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ПоказатьПинКодыНаГлавнойСтранице", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ЧастотаСбораСтатистики", Ложь);
		
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "НаименованиеПоляИмя", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ОписаниеПоляИмя", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ОбразецЗаполненияПоляИмя", Ложь);
		
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ЗапретитьИзменятьФотографиюПрофиля", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ЗапретитьИзменятьКонтактнуюИнформациюВПрофиле", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ЗапретитьИзменятьДополнительнуюИнформациюВПрофиле", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ЗапретитьИзменятьНастройкиРассылокВПрофиле", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ГруппаОтзывЗадания", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ОформлениеКомандыПрофиля", Ложь);		
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "СтраницаРазмещениеОтчетов", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "ГруппировкиОбучений", Ложь);
		ОбщегоНазначенияСУКлиентСервер.УстановитьВидимостьЭлементаФормы(Форма, "СкрыватьПустыеПапкиБиблиотеки", Ложь);
		
	КонецЕсли;
	
КонецПроцедуры

Функция СформироватьФайлНастроек(Объект, УникальныйИдентификатор = Неопределено, ПутьДляЗаписи = Неопределено) Экспорт
	
	ТекстФайлаНастроек = ""; // Переменная формы
	
	// Настройки кабинета
	
	НастройкиКабинета = Новый Структура;
	
	НастройкиКабинета.Вставить("name", Объект.Код);
	НастройкиКабинета.Вставить("host", Объект.АдресВебСервера);
	НастройкиКабинета.Вставить("title", Объект.Наименование);	
	НастройкиКабинета.Вставить("basePortal", Объект.АдресПубликации);
	НастройкиКабинета.Вставить("baseDesktop", Объект.АдресКаталогаКабинета);
	НастройкиКабинета.Вставить("baseAdmin", Объект.АдресПубликацииИБ);
	НастройкиКабинета.Вставить("baseRes", Объект.АдресПубликацийРесурсов);
	НастройкиКабинета.Вставить("baseImages", Объект.АдресКаталогаКартинок);
	НастройкиКабинета.Вставить("baseFiles", Объект.АдресКаталогаФайлов);
	НастройкиКабинета.Вставить("startPage", Объект.СтартоваяСтраница);
	НастройкиКабинета.Вставить("sentry", Объект.ИдентификаторСервисаSentry);
	НастройкиКабинета.Вставить("yandexMetrika", Объект.СчетчикЯндексМетрики);
	НастройкиКабинета.Вставить("displayLog", Объект.ВыводитьСведенияВКонсоль);	
	НастройкиКабинета.Вставить("cookiesExpires", 7);	
	НастройкиКабинета.Вставить("idle", Объект.РазрешенноеЧислоМинутНеактивности);
	
	Если Объект.Редакция = Перечисления.РедакцииВебКабинетаСУ.Редакция30 Тогда
		НастройкиКабинета.Вставить("availablePinCodesOnStartPage", Объект.ПоказатьПинКодыНаГлавнойСтранице);
	КонецЕсли;

	Если Объект.Редакция = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
		
		ТаблицаРазделов = Новый ТаблицаЗначений;
		ТаблицаРазделов.Колонки.Добавить("container");
		ТаблицаРазделов.Колонки.Добавить("label");
		ТаблицаРазделов.Колонки.Добавить("icon");
		ТаблицаРазделов.Колонки.Добавить("page");
		ТаблицаРазделов.Колонки.Добавить("hash");
		ТаблицаРазделов.Колонки.Добавить("visibility");
		ТаблицаРазделов.Колонки.Добавить("verifyPermissions");
		ТаблицаРазделов.Колонки.Добавить("additionalPermissions");
			
		Для каждого Строка Из Объект.Разделы Цикл
		
			НоваяСтрока = ТаблицаРазделов.Добавить();	
			НоваяСтрока.container = Строка.Контейнер;
			НоваяСтрока.label = Строка.Имя;
			НоваяСтрока.icon = Строка.Иконка;
			НоваяСтрока.page = Строка.Страница;
			НоваяСтрока.hash = Строка.Якорь;
			НоваяСтрока.visibility = Новый Структура("public, private", Строка.ДоступенПублично, Строка.ДоступенПослеАвторизации);		
			НоваяСтрока.verifyPermissions = Строка.ПроверятьПрава;			
			НоваяСтрока.additionalPermissions = Новый Массив;
			
			Если Строка.Страница = "education" Тогда
				НоваяСтрока.additionalPermissions.Добавить("teaching");
			КонецЕсли;
			
		КонецЦикла;
		
		НастройкиКабинета.Вставить("navbar", ТаблицаРазделов);	
		
	КонецЕсли;
		
	НастройкиКабинета.Вставить("logo", Объект.АдресЛоготипа);
	Если ЗначениеЗаполнено(Объект.НижнийКолонтитул) Тогда
		НастройкиКабинета.Вставить("footer", Объект.НижнийКолонтитул);
	Иначе
		НастройкиКабинета.Вставить("footer", Метаданные.Справочники.ПубликацииВебКабинетаСУ.Реквизиты.НижнийКолонтитул.ЗначениеЗаполнения);
	КонецЕсли;
	
	Если Объект.Редакция = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
		Язык = ?(ЗначениеЗаполнено(Объект.Язык) И Объект.Язык <> Перечисления.ЯзыкиВебКабинетаСУ.Авто,
			Объект.Язык, Перечисления.ЯзыкиВебКабинетаСУ.ruRU);
		НастройкиКабинета.Вставить("language", ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(Язык));
	Иначе
		Если ЗначениеЗаполнено(Объект.Язык) И Объект.Язык <> Перечисления.ЯзыкиВебКабинетаСУ.Авто Тогда
			НастройкиКабинета.Вставить("language", ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(Объект.Язык));
		Иначе
			НастройкиКабинета.Вставить("language", "");
		КонецЕсли;
	КонецЕсли;	
	
	НастройкиКабинетаJSON = ОбщегоНазначенияСУ.ДанныеВJSON(НастройкиКабинета);

	ТекстФайлаНастроек = ТекстФайлаНастроек + "
	|oSettingsPortal = " + НастройкиКабинетаJSON + ";";
	
	Если Объект.Редакция = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
		
		ТекстФайлаНастроек = ТекстФайлаНастроек + "
			|oSettingsPortal.storageName = function (name) {
			|		return oSettingsPortal.name + ""_"" + name;
			|};";
		
	Иначе
		
		ПубликацияСтаройРедакции = Справочники.ПубликацииВебКабинетаСУ.ЕдинственнаяПубликацияВОбщемКаталоге(Перечисления.РедакцииВебКабинетаСУ.Редакция20);
		
		Если ЗначениеЗаполнено(ПубликацияСтаройРедакции) Тогда
			КодРедакции2 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПубликацияСтаройРедакции, "Код");
			ТекстФайлаНастроек = ТекстФайлаНастроек + "
				|oSettingsPortal.storageName = function (name) {
				|		return """+ КодРедакции2 +""" + ""_"" + name;
				|};";
		Иначе
			ТекстФайлаНастроек = ТекстФайлаНастроек + "
				|oSettingsPortal.storageName = function (name) {
				|		return oSettingsPortal.name + ""_"" + name;
				|};";
		КонецЕсли;
		
	КонецЕсли;
	
		
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	// Настройки обучение
	
	НастройкиОбучения = Новый Структура;
	
	НастройкиОбучения.Вставить("url", Объект.АдресСервисаОбучения); 
	НастройкиОбучения.Вставить("user", ЛогинСлужебногоПользователя(Объект)); 
	НастройкиОбучения.Вставить("password", ПарольСлужебногоПользователя(Объект)); 
	
	НастройкиУчебныхАктивностей = Новый Структура;
	НастройкиУчебныхАктивностей.Вставить("availableDescriptionPage", Объект.ДоступнаКарточкаОбучения); 
	НастройкиУчебныхАктивностей.Вставить("availableActivePage", Объект.ДоступенСписокОбучения); 
	НастройкиУчебныхАктивностей.Вставить("availableCalendarPage", Объект.ДоступенКалендарьОбучения); 
	НастройкиУчебныхАктивностей.Вставить("openResInNewWindow", Объект.ОткрыватьЭлектронныеРесурсыОбученияВНовомОкне); 
	НастройкиУчебныхАктивностей.Вставить("availableResultsPage", Объект.ДоступныРезультатыОбучения); 
	НастройкиУчебныхАктивностей.Вставить("availableCertificatesPage", Объект.ДоступныСертификатыОбучения); 
	НастройкиУчебныхАктивностей.Вставить("availableOpenEduPage", Объект.ДоступноОткрытоеОбучение); 
	НастройкиУчебныхАктивностей.Вставить("availableStatusActivities", Объект.ПоказыватьСтатусОбучения); 
	Если Объект.Редакция = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
		НастройкиУчебныхАктивностей.Вставить("typeCalendar", Перечисления.ВариантыКалендаряВебКабинетаСУО.ПереводВарианта(Объект.ВариантКалендаря));
	КонецЕсли;
	НастройкиУчебныхАктивностей.Вставить("activeCalendar", Ложь); // Устарело (оставлено для совместимости)
	НастройкиУчебныхАктивностей.Вставить("displayTeachersRole", Объект.ПоказыватьРолиПреподавателей);
	НастройкиУчебныхАктивностей.Вставить("availableToCheckPage", Объект.ДоступенРазделПроверкиЗаданий);
	НастройкиУчебныхАктивностей.Вставить("timeToCancelTaskAnswer", Объект.ВремяНаОтзывОтветаНаЗадание);
		
	Если Объект.Редакция = Перечисления.РедакцииВебКабинетаСУ.Редакция30 Тогда
		
		НастройкиУчебныхАктивностей.Вставить("hideEmptyLibraryElements", Объект.СкрыватьПустыеПапкиБиблиотеки);
		
		ГруппировкиОбучений = Новый Структура("studentActivitiesFilters", Новый Массив);
		Для каждого СтрокаГО Из Объект.ГруппировкиОбучений Цикл
			Если НЕ СтрокаГО.Использовать Тогда
				Продолжить;
			КонецЕсли;			
			НоваяНастройкаГруппировки = Новый Структура("name, titles",
				Перечисления.ГруппировкиОбученийВебКабинетаСУО.ИмяГруппировкиДляНастройкиВебКабинета(СтрокаГО.Группировка),
				Новый Структура("en, ru", СтрокаГО.Наименование_en, СтрокаГО.Наименование_ru));
			ГруппировкиОбучений.studentActivitiesFilters.Добавить(НоваяНастройкаГруппировки);
		КонецЦикла;
		НастройкиУчебныхАктивностей.Вставить("filters", ГруппировкиОбучений);
		
	КонецЕсли;
	
	НастройкиНовостей = Новый Структура;
	НастройкиНовостей.Вставить("fromLastDays", Объект.СкрыватьНовостиСтарее);
	
	НастройкиКоммуникаций = Новый Структура;
	НастройкиКоммуникаций.Вставить("availableMessagesFromUserProfile", Объект.ДоступнаОтправкаЛичныхСообщенийИзКарточкиПользователя);
	
	НастройкиБиблиотеки = Новый Структура;
	НастройкиБиблиотеки.Вставить("openItemsInNewWindow", Объект.ОткрыватьЭлементыБиблиотекиВНовомОкне);	
	НастройкиБиблиотеки.Вставить("displayCountItems", Объект.ПоказыватьКоличествоЭлементовРазделаБиблиотеки);		
	
	НастройкиСтраницыПользователей = Новый Структура;
	НастройкиСтраницыПользователей.Вставить("displayOnline", Объект.ПоказыватьПользователейОнлайн);	
	НастройкиСтраницыПользователей.Вставить("displayOnlineInMenu", Объект.ПоказыватьПользователейОнлайнВМеню);	
	
	НастройкиСтраницыПользователей.Вставить("disableProfilePhoto", Объект.ЗапретитьИзменятьФотографиюПрофиля);	
	НастройкиСтраницыПользователей.Вставить("disableProfileContacts", Объект.ЗапретитьИзменятьКонтактнуюИнформациюВПрофиле);	
	НастройкиСтраницыПользователей.Вставить("disableProfileAdditional", Объект.ЗапретитьИзменятьДополнительнуюИнформациюВПрофиле);	
	НастройкиСтраницыПользователей.Вставить("disableProfileNotice", Объект.ЗапретитьИзменятьНастройкиРассылокВПрофиле);	
	НастройкиСтраницыПользователей.Вставить("profileCommandVariant", Перечисления.ВариантыОформленияКомандыПрофиляВебКабинетаСУО.ЗначениеВТекст(Объект.ОформлениеКомандыПрофиля));	
	
	НастройкиКаталогаЭР = Новый Структура;
	НастройкиКаталогаЭР.Вставить("displaySearch", Объект.ИспользоватьПоискПоЭлектроннымРесурсам);	
	
	НастройкиОтчетов = Новый Структура;
	НастройкиОтчетов.Вставить("allocations", Новый Массив);
	НастройкиОтчетов.Вставить("formats", Новый Массив);
	
	Если Объект.ПодключитьОтчеты Тогда
	
		ВариантыРазмещенияОтчетов = Новый СписокЗначений;
		ВариантыРазмещенияОтчетов.Добавить(Перечисления.ВариантыРазмещенияОтчетовВебКабинетаСУО.СтраницаПреподавателя, "teacherPage");

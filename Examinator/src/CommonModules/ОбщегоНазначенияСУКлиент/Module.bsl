// Вызывает диалог перед добавлением элемента подчиненного справочника,
// если основной элемент не записан.
//
Процедура ПередДобавлениемЭлементаПодчиненногоСправочника(Форма, Отказ, ПроверитьМодифицированность = Ложь) Экспорт
	
	Если Форма.Объект.Ссылка.Пустая() ИЛИ (ПроверитьМодифицированность И Форма.Модифицированность) Тогда
		
		Отказ = Истина;
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПередДобавлениемЭлементаПодчиненногоСправочникаПродолжение", ЭтотОбъект, Форма);
		
		ТекстВопроса = НСтр("ru = 'Данные еще не записаны.
		|Действие можно выполнить только после записи данных.
		|Выполнить запись?'", "ru");
		
		
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 0);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПередДобавлениемЭлементаПодчиненногоСправочникаПродолжение(Результат, Форма) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Форма.Записать();
	КонецЕсли;
	
КонецПроцедуры

// Обрабатывает событие выбора элемента подчиненного справочника
//
Процедура ПередВыборомЭлементаПодчиненногоСправочника(Форма, СтандартнаяОбработка) Экспорт
	
	Отказ = Ложь;
	
	ПередДобавлениемЭлементаПодчиненногоСправочника(Форма, Отказ, Истина);
	
	Если Отказ Тогда
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

// Возвращает форму из которой была открыта форма (владельца).
//
Функция	НайтиВладельцаУправляемойФормы(ВладелецФормы, ИмяФормы = Неопределено) Экспорт
	
	Если ВладелецФормы = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТипЗнч(ВладелецФормы) = Тип("УправляемаяФорма") Тогда
		Если (ЗначениеЗаполнено(ИмяФормы) И ИмяФормы = ВладелецФормы.ИмяФормы) ИЛИ НЕ ЗначениеЗаполнено(ИмяФормы) Тогда
			Возврат ВладелецФормы;
		Иначе
			Возврат НайтиВладельцаУправляемойФормы(ВладелецФормы.ВладелецФормы, ИмяФормы); // Рекурсивный вызов
		КонецЕсли;
	Иначе
		Возврат НайтиВладельцаУправляемойФормы(ВладелецФормы.Родитель, ИмяФормы); // Рекурсивный вызов
	КонецЕсли;
	
КонецФункции

// Определяет, можно ли обращаться к данным текущей строки таблицы.
//
Функция ТекущиеДанныеТаблицыДоступны(ТекущиеДанные) Экспорт
	
	Если ТекущиеДанные = Неопределено
		ИЛИ ТекущиеДанные.Свойство("ГруппировкаСтроки") Тогда
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура ОткрытьЗначениеВФорме(Знач Значение, Знач ПараметрыФормы = Неопределено, Знач Владелец = Неопределено, Знач ОписаниеОповещения = Неопределено) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Значение) Тогда
		Возврат;
	КонецЕсли;
	
	ИмяТаблицы = ОбщегоНазначенияСУВызовСервера.ИмяТаблицыПоСсылке(Значение);
	
	Если ПараметрыФормы = Неопределено Тогда
		ПараметрыФормы = Новый Структура();
	КонецЕсли;
	
	ПараметрыФормы.Вставить("Ключ", Значение);
	
	ОткрытьФорму(ИмяТаблицы + ".ФормаОбъекта", ПараметрыФормы, Владелец,,,, ОписаниеОповещения);
	
КонецПроцедуры

Функция ВыделеннаяГруппаТаблицы(ТаблицаФормы) Экспорт
	
	ТекущиеДанные = ТаблицаФормы.ТекущиеДанные; 
	
	Если ОбщегоНазначенияСУКлиент.ТекущиеДанныеТаблицыДоступны(ТекущиеДанные) И ТекущиеДанные.Свойство("ЭтоГруппа") Тогда
		
		Если ТекущиеДанные.ЭтоГруппа Тогда 
			Группа = ТекущиеДанные.Ссылка;
		Иначе 
			Группа = ТекущиеДанные.Родитель;
		КонецЕсли;
		
	Иначе
		
		Группа = Неопределено
		
	КонецЕсли;
	
	Возврат Группа;
	
КонецФункции


<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>Вопросы</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Версия</dataPath>
			<field>Версия</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаИзменения</dataPath>
			<field>ДатаИзменения</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>МетодРасчетаРезультата</dataPath>
			<field>МетодРасчетаРезультата</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Поставщик</dataPath>
			<field>Поставщик</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>РазрешенРазвернутыйОтвет</dataPath>
			<field>РазрешенРазвернутыйОтвет</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТипВопроса</dataPath>
			<field>ТипВопроса</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ФасетныйВопрос</dataPath>
			<field>ФасетныйВопрос</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Вопрос</dataPath>
			<field>Вопрос</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТекстовыеДанныеВопроса</dataPath>
			<field>ТекстовыеДанныеВопроса</field>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ФорматированныйДокументВопроса</dataPath>
			<field>ФорматированныйДокументВопроса</field>
			<useRestriction>
				<field>true</field>
			</useRestriction>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВопросыСУЗ.Ссылка КАК Вопрос,
	ВопросыСУЗ.Версия,
	ВопросыСУЗ.ДатаИзменения,
	ВопросыСУЗ.ТипВопроса,
	ВопросыСУЗ.Поставщик,
	ВопросыСУЗ.РазрешенРазвернутыйОтвет,
	ВопросыСУЗ.МетодРасчетаРезультата,
	ВопросыСУЗ.ФасетныйВопрос,
	ДанныеВопросыСУЗ.ТекстовыеДанные КАК ТекстовыеДанныеВопроса,
	ДанныеВопросыСУЗ.ФорматированныйДокумент КАК ФорматированныйДокументВопроса
ИЗ
	РегистрСведений.ДанныеВопросыСУЗ КАК ДанныеВопросыСУЗ
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВопросыСУЗ КАК ВопросыСУЗ
		ПО ДанныеВопросыСУЗ.СсылкаНаОбъектСУЗ = ВопросыСУЗ.Ссылка
			И ДанныеВопросыСУЗ.Поставщик = ВопросыСУЗ.Поставщик
			И ДанныеВопросыСУЗ.Версия = ВопросыСУЗ.Версия
ГДЕ
	ВопросыСУЗ.ЭтоГруппа = ЛОЖЬ
	И ВопросыСУЗ.ПометкаУдаления = ЛОЖЬ
	И ДанныеВопросыСУЗ.КодДанных = "Вопрос"</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>ВариантыОтветов</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Вариант</dataPath>
			<field>Вариант</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Вопрос</dataPath>
			<field>Вопрос</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаИзменения</dataPath>
			<field>ДатаИзменения</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Поставщик</dataPath>
			<field>Поставщик</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТекстВарианта</dataPath>
			<field>ТекстВарианта</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВерныйВариант</dataPath>
			<field>ВерныйВариант</field>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="xs:string">БЛ=; БИ=+</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НаименованиеВарианта</dataPath>
			<field>НаименованиеВарианта</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НомерВарианта</dataPath>
			<field>НомерВарианта</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВариантыОтветовНаВопросСУЗ.Ссылка КАК Вариант,
	ВариантыОтветовНаВопросСУЗ.Владелец КАК Вопрос,
	ВариантыОтветовНаВопросСУЗ.Код КАК НомерВарианта,
	ВариантыОтветовНаВопросСУЗ.Наименование КАК НаименованиеВарианта,
	ВариантыОтветовНаВопросСУЗ.Верный КАК ВерныйВариант,
	ВариантыОтветовНаВопросСУЗ.Поставщик,
	ВариантыОтветовНаВопросСУЗ.ДатаИзменения,
	ДанныеВопросыСУЗ.ТекстовыеДанные КАК ТекстВарианта
ИЗ
	РегистрСведений.ДанныеВопросыСУЗ КАК ДанныеВопросыСУЗ
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВариантыОтветовНаВопросСУЗ КАК ВариантыОтветовНаВопросСУЗ
		ПО ДанныеВопросыСУЗ.КодДанных = ВариантыОтветовНаВопросСУЗ.Ссылка
ГДЕ
	ВариантыОтветовНаВопросСУЗ.ПометкаУдаления = ЛОЖЬ
	И ВариантыОтветовНаВопросСУЗ.ЭтоГруппа = ЛОЖЬ</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Рубрики</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Рубрикатор</dataPath>
			<field>Рубрикатор</field>
		</field>
		<field xsi:type="DataSetFieldField">

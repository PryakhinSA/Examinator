				<dcscor:value xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>ЧДЦ=2; ЧН=0</v8:content>
					</v8:item>
				</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>ПрохождениеОбучения.ПродолжительностьОбученияВУчебныхЧасах</dataPath>
		<expression>ПрохождениеОбучения.ПродолжительностьВСекундах / (60 * 45)</expression>

		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/core" name="Фрагмент" type="d3p1:UUID"/>
		<property name="Завершено" type="xs:boolean"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/3/EduMarks" name="Оценка" type="d3p1:Оценка"/>
		<property name="Значимость" type="xs:integer"/>
		<property name="Наименование" type="xs:string"/>
		<property name="Описание" type="xs:string"/>
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/core" name="ПопыткаВыполнения" type="d3p1:UUID"/>
		<property name="ЗавершеноВПроцентах" type="xs:integer"/>
		<property name="ПроверяетсяПреподавателем" type="xs:boolean"/>
		<property name="ПроверенПреподавателем" type="xs:boolean"/>
		<property name="КомментарийПреподавателя" type="xs:string"/>
		<property name="ВозвращеноНаДоработку" type="xs:boolean"/>
		<property name="ПроходнойБалл" type="xs:integer"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/3/EduMarks" name="ПроходнаяОценка" type="d3p1:Оценка"/>
		<property name="Баллы" type="xs:integer"/>
		<property name="Выполнено" type="xs:boolean"/>
		<property name="ПолученаОценка" type="xs:boolean"/>
		<property name="НаОсновеЭлектронногоКурса" type="xs:boolean"/>
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/core" name="ЭлектронныйКурс" type="d3p1:UUID"/>
		<property name="ЗатраченоВремениВСекундах" type="xs:integer"/>
		<property name="НеЖдатьПроверки" type="xs:boolean"/>
		<property name="ДатаОтправкиНаПроверку" type="xs:integer"/>
		<property name="ДатаВозвратаНаДоработку" type="xs:integer"/>
		<property name="ДатаНачалаДоступаКЗаданию" type="xs:integer"/>
		<property name="ДатаОкончанияДоступаКЗаданию" type="xs:integer"/>
		<property name="СкрытьВремяДоступаКЗаданию" type="xs:boolean"/>
	</objectType>
	<objectType name="Ресурсы">
		<property xmlns:d3p1="http://v8.1c.ru/lms/1/ElectronicResource" name="ЭлектронныеРесурсы" type="d3p1:ЭлектронныеРесурсы"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/1/Book" name="Книги" type="d3p1:Книги"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/3/EduFiles" name="Файлы" type="d3p1:Файлы"/>
	</objectType>
	<objectType name="Задания">
		<property xmlns:d3p1="http://v8.1c.ru/lms/1/UserActivity" name="Задание" type="d3p1:Задание" lowerBound="0" upperBound="-1"/>
	</objectType>
	<objectType name="НезаполненныеСвойстваУчастника">
		<property xmlns:d3p1="http://v8.1c.ru/lms/1/UserActivity" name="Свойство" type="d3p1:НезаполненноеСвойствоУчастника" lowerBound="0" upperBound="-1"/>
	</objectType>
	<objectType name="НезаполненноеСвойствоУчастника">
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/core" name="Идентификатор" type="d3p1:UUID"/>

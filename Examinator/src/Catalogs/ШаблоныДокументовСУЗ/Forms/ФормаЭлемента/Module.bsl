#Область ОбработчикиКомандФормы

// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ЗагрузитьШаблон(Команда)
	
	ДиалогВыбораШаблона = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбораШаблона.Заголовок = НСтр("ru = 'Выберите файл шаблона'");
	ДиалогВыбораШаблона.МножественныйВыбор = Ложь;
	ДиалогВыбораШаблона.Фильтр = "Шаблон Word(*.dot;*.dotm;*.dotx)|*.dot;*.dotm;*.dotx";
	ДиалогВыбораШаблона.ПредварительныйПросмотр = Истина;
	
	ОписаниеОповещенияПолученияКартинки = Новый ОписаниеОповещения("ЗагрузитьШаблонПродолжение", ЭтотОбъект);
	
	НачатьПомещениеФайлов(ОписаниеОповещенияПолученияКартинки,, ДиалогВыбораШаблона, Истина, УникальныйИдентификатор);	
	

КонецПроцедуры

// Продолжение процедуры (см. выше).
// 
&НаКлиенте
Процедура ЗагрузитьШаблонПродолжение(ПолученныеФайлы, ДополнительныеПараметры) Экспорт
	
	Если ПолученныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ФайлШаблона = Новый Файл(ПолученныеФайлы[0].Имя);
	
	АдресШаблона = ПолученныеФайлы[0].Хранение;
	
	Если НЕ ЗначениеЗаполнено(Объект.Наименование) Тогда
		Объект.Наименование = ФайлШаблона.ИмяБезРасширения;
	КонецЕсли;
	
	Объект.ИмяФайла = ФайлШаблона.Имя;
	
	Статус = НСтр("ru = 'Файл помещен во временное хранилище'");
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьШаблон(Команда)
	
	МассивФайлов = Новый Массив;	
	
	Если ЗначениеЗаполнено(АдресШаблона) И ЭтоАдресВременногоХранилища(АдресШаблона) Тогда
		МассивФайлов.Добавить(Новый ОписаниеПередаваемогоФайла(Объект.ИмяФайла, АдресШаблона));	
	Иначе
		
		Если Объект.Ссылка.Пустая() Тогда
			
			ПоказатьПредупреждение(, НСтр("ru = 'Элемент не сохранен'"));
			
		Иначе
			
			АдресФайлаОригинала = ПолучитьНавигационнуюСсылку(Объект.Ссылка, "ДвоичныеДанные");			
			МассивФайлов.Добавить(Новый ОписаниеПередаваемогоФайла(Объект.ИмяФайла, АдресФайлаОригинала));
			
		КонецЕсли;					
		
	КонецЕсли;	
	
	ОписаниеОповещенияПолученияФайлов = Новый ОписаниеОповещения("СохранитьПродолжение", ЭтотОбъект);
	
	ДиалогСохранения = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	ДиалогСохранения.Заголовок = НСтр("ru = 'Сохранение шаблона'");
	ДиалогСохранения.МножественныйВыбор = Ложь;
	ДиалогСохранения.ПредварительныйПросмотр = Ложь;
	
	НачатьПолучениеФайлов(ОписаниеОповещенияПолученияФайлов, МассивФайлов, ДиалогСохранения, Истина);	
	
КонецПроцедуры

// Продолжение процедуры (см. выше).
// 
&НаКлиенте
Процедура СохранитьПродолжение(ПолученныеФайлы, ДополнительныеПараметры) Экспорт
	// Обработка не требуется.
КонецПроцедуры



// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Читаем настройки
	
	ДанныеНастроек = ХранилищеСистемныхНастроек.Загрузить(ИмяФормы+"/ТекущиеДанные");
	
	Если ДанныеНастроек <> Неопределено Тогда
		Масштаб = ДанныеНастроек.Получить("Масштаб");
		Период  = ДанныеНастроек.Получить("Период");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.Период) Тогда
		Период = Параметры.Период; // Период в параметре имеет большую важность
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Масштаб) Тогда
		Масштаб = "День";
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Период) Тогда
		Период.Вариант = ВариантСтандартногоПериода.ЭтаНеделя;
	КонецЕсли;
	
	// Задаем облать построения диаграммы
	
	Расписание.ПоддержкаМасштаба = ПоддержкаМасштабаДиаграммыГанта.Авто;
	
	// Формируем диаграмму Ганта и таблицу
	
	СформироватьРасписаниеПоАудиториям();	
	
	// Заголовок
	
	Если ЗначениеЗаполнено(Параметры.Аудитория)
		ИЛИ ЗначениеЗаполнено(Параметры.Территория) Тогда
		
		АвтоЗаголовок = Ложь;
		Заголовок     = НСтр("ru = 'Расписание по аудиториям (установлен дополнительный отбор)'");
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ЗначениеЗаполнено(Параметры.Период) Тогда
		Период = Параметры.Период;
	КонецЕсли;
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаКлиенте
Процедура ПериодПриИзменении(Элемент)
	СформироватьРасписаниеПоАудиториям();
КонецПроцедуры

&НаКлиенте
Процедура МасштабПриИзменении(Элемент)
	СформироватьРасписаниеПоАудиториям();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьРасписание(Команда)
	СформироватьРасписаниеПоАудиториям();
КонецПроцедуры

&НаКлиенте
Процедура РасписаниеВыбор(Элемент, Значения, СтандартнаяОбработка, Дата)
	
	Если ТипЗнч(Значения) = Тип("Массив")
		И Значения.Количество() > 0 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Масштаб = "Месяц" Тогда
		ОкругленнаяДата = НачалоДня(Дата);
	КонецЕсли;
	
	Если Масштаб = "Неделя" Тогда
		ОкругленнаяДата = НачалоДня(Дата);
	КонецЕсли;
	
	Если Масштаб = "День" Тогда
		ОкругленнаяДата = НачалоДня(Дата);
	КонецЕсли;
	
	Если Масштаб = "Час" Тогда
		ОкругленнаяДата = НачалоЧаса(Дата);
	КонецЕсли;
	
	Если Масштаб = "Минута" Тогда
		ОкругленнаяДата = НачалоМинуты(Дата);
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", Новый Структура("ДатаНачалаПроведения", ОкругленнаяДата));
	
	Если ТипЗнч(Значения) = Тип("ЗначениеДиаграммыГанта") Тогда
		ПараметрыФормы.ЗначенияЗаполнения.Вставить("Аудитория", Значения.Точка.Значение);
	КонецЕсли;
	
	ОткрытьФорму("Документ.ПроведениеОбученияСУО.ФормаОбъекта", ПараметрыФормы);
	
КонецПроцедуры


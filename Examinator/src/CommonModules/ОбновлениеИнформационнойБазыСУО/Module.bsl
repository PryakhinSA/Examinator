// Выполняет обновление до версии 3.0.9.85
//
Процедура ВыполнитьОбновлениеДоВерсии30985() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ШкалаНеОценивается = Справочники.ШкалыОценокСУО.ПолучитьСсылку(Новый УникальныйИдентификатор("e127fba9-b63b-11e6-9008-8ca9823f12e0"));		
	
	Если ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(ШкалаНеОценивается, Ложь) Тогда
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ШкалыОценокСУО.Ссылка
			|ИЗ
			|	Справочник.ШкалыОценокСУО КАК ШкалыОценокСУО
			|ГДЕ
			|	ШкалыОценокСУО.ИмяПредопределенныхДанных = &ИмяПредопределенныхДанных";
		
		Запрос.УстановитьПараметр("ИмяПредопределенныхДанных", "НеОценивается");
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() И НЕ ЗначениеЗаполнено(ШкалаНеОценивается.ИмяПредопределенныхДанных) Тогда
			ШкалаНеОцениваетсяОбъект = ШкалаНеОценивается.ПолучитьОбъект();
			ШкалаНеОцениваетсяОбъект.ИмяПредопределенныхДанных = "НеОценивается";
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ШкалаНеОцениваетсяОбъект);
		КонецЕсли;
		
	Иначе
		
		ШкалаНеОцениваетсяОбъект = Справочники.ШкалыОценокСУО.СоздатьЭлемент();
		ШкалаНеОцениваетсяОбъект.УстановитьСсылкуНового(ШкалаНеОценивается);
		
		ШкалаНеОцениваетсяОбъект.ИмяПредопределенныхДанных = "НеОценивается";
		ШкалаНеОцениваетсяОбъект.Наименование = НСтр("ru = 'Не оценивается'");
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(ШкалаНеОцениваетсяОбъект);
		
		ОценкаСсылка = Справочники.ЭлементыШкалыОценокСУО.ПолучитьСсылку(Новый УникальныйИдентификатор("e7e7ae95-b63b-11e6-9008-8ca9823f12e0"));
		
		Если НЕ ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(ОценкаСсылка, Ложь) Тогда
			ОценкаОбъект = Справочники.ЭлементыШкалыОценокСУО.СоздатьЭлемент();
			ОценкаОбъект.УстановитьСсылкуНового(ОценкаСсылка);
			ОценкаОбъект.Владелец = ШкалаНеОценивается;
			ОценкаОбъект.Наименование = НСтр("ru = 'Зачет'");
			
			Для ЗначениеБалла = 0 По 100 Цикл
			
				НоваяСтрокаТЧ = ОценкаОбъект.ЗначенияБаллов.Добавить();
				НоваяСтрокаТЧ.Значение = ЗначениеБалла;
			
			КонецЦикла;
			
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ОценкаОбъект);
			
		КонецЕсли;
		
		
	КонецЕсли;
	
	
	
КонецПроцедуры


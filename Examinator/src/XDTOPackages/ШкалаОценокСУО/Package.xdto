<package xmlns="http://v8.1c.ru/8.1/xdto" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://v8.1c.ru/lms/3/EduMarks">
	<import namespace="http://v8.1c.ru/8.1/data/core"/>
	<import namespace="http://v8.1c.ru/8.1/data/enterprise/current-config"/>
	<objectType name="ШкалаОценок">
		<property name="Наименование" type="xs:string"/>
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/core" name="Идентификатор" type="d3p1:UUID"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/3/EduMarks" name="Оценки" type="d3p1:Оценки"/>
	</objectType>
	<objectType name="Оценки">
		<property xmlns:d3p1="http://v8.1c.ru/lms/3/EduMarks" name="Оценка" type="d3p1:Оценка" lowerBound="0" upperBound="-1"/>
	</objectType>
	<objectType name="Оценка">
		<property name="Наименование" type="xs:string"/>
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/core" name="Идентификатор" type="d3p1:UUID"/>
	</objectType>
</package>
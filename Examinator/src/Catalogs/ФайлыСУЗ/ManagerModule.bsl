#Если Сервер ИЛИ ТолстыйКлиентОбычноеПриложение ИЛИ ВнешнееСоединение Тогда
	

#Область ПрограммныйИнтерфейс

// ПРОГРАММНЫЙ ИНТЕРФЕЙС

Функция ТипОбъектаСУЗ() Экспорт
	
	Возврат Перечисления.ТипыОбъектовСУЗ.file;
	
КонецФункции

// Позволяет получить XML данные объекта.
//
// Параметры
//  ОбъектСУЗ          - экземпляр обработки ОбъектСУЗ.
//  ПараметрыСсылки    – Структура, содержит параметры ссылки по которой вызывается вопрос.
//  КонтекстВыполнения - Структура, содержит параметры контекста выполнения объекта.
//
// Возвращаемое значение:
//   Строка – содержит XML представление объекта СУЗ.
//
Функция ПолучитьXMLПредставление(Файл, ПараметрыСсылки, КонтекстВыполнения) Экспорт
	
	ДанныеФайла = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Файл, "Владелец, ТипФайла, ИмяФайла, ОткрыватьПоСсылке, Наименование, FlashВерсия, FlashЦветФона, Выравнивать, Высота, Ширина, ОткрыватьПоСсылке, ОткрыватьВнешнимПриложением, ПроигрыватьАвтоматически, ВнешнийФайл");
	
	Если НЕ ДанныеФайла.ВнешнийФайл Тогда
		ДанныеФайла.ИмяФайла = Справочники.ФайлыСУЗ.ИмяФайлаДляВыгрузки(Файл, ДанныеФайла.ИмяФайла, ДанныеФайла.ТипФайла, КонтекстВыполнения.ПараметрыЭкспорта);
	КонецЕсли;
	
	// Примечание: добавление владельца к списку ресурсов необходимо, так как файл может
	// быть вставлен отдельно без ресурса, но для его отображения необходимы все файлы ресурса.
	ОбъектыСУЗ.ДобавитьРесурсВМассивРесурсов(ДанныеФайла.Владелец, КонтекстВыполнения.СписокРесурсов);
	
	ИдентификаторСводаЗнаний = Справочники.СводыЗнанийСУЗ.ИдентификаторКаталога(КонтекстВыполнения.ЭлектронныйРесурс);
	ИмяОбъектаСУЗ            = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ТипОбъектаСУЗ());
	ИмяТипаФайла             = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ДанныеФайла.ТипФайла);
	ОбъектЗапуска            = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "object");
	ПараметрыЗапуска         = Строка(ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "ПараметрыЗапуска"));
	ПоставщикСводаЗнаний     = Справочники.СводыЗнанийСУЗ.Поставщик(КонтекстВыполнения.ЭлектронныйРесурс);
	
	Если ОбъектЗапуска = "file" И ДанныеФайла.ТипФайла <> Перечисления.ТипыФайловСУЗ.DataProcessor Тогда
		
		// Если файл запускается из свода знаний непосредственно,
		// То есть не вложен в другой объект (подборку или ресурс),
		// То отображаем его всегда во фрейме.
		
		ЗапускатьВоФрейме = Истина;
		
	ИначеЕсли КонтекстВыполнения.Свойство("ВозможноПоказатьОдинФайл") И ДанныеФайла.ТипФайла = Перечисления.ТипыФайловСУЗ.Document Тогда
		
		ЗапускатьВоФрейме = Истина;
		
	Иначе
		
		// Если файл вложен в другой объект, то этот объект сам решает можно ли
		// Отобразить файл во фрейме и передает эту информацию через параметр
		// "ЗапускатьВоФрейме" контекста выполнения.
		
		Если КонтекстВыполнения.Свойство("ЗапускатьВоФрейме") И НЕ ДанныеФайла.ОткрыватьПоСсылке Тогда
			ЗапускатьВоФрейме = КонтекстВыполнения.ЗапускатьВоФрейме; 			
		Иначе
			ЗапускатьВоФрейме = Ложь;
		КонецЕсли;
		
	КонецЕсли;		
	
	Если КонтекстВыполнения.Свойство("ВозможноПоказатьОдинФайл") И НЕ ЗапускатьВоФрейме И (ДанныеФайла.ТипФайла = Перечисления.ТипыФайловСУЗ.Default ИЛИ ДанныеФайла.ТипФайла = Перечисления.ТипыФайловСУЗ.DataProcessor) Тогда
		КонтекстВыполнения.ВозможноПоказатьОдинФайл = Ложь; // Чтобы были поля при отображении ссылки на файл
	КонецЕсли;	
	
	АльтернативныйТекст = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "alt");
	
	Если ПустаяСтрока(АльтернативныйТекст) Тогда
		АльтернативныйТекст = ДанныеФайла.Наименование;
	КонецЕсли;
	
	Если КонтекстВыполнения.Свойство("СтатичноеПредставление") И КонтекстВыполнения.СтатичноеПредставление Тогда
		СтатичноеПредставление = Истина;
	Иначе
		СтатичноеПредставление = Ложь;
	КонецЕсли;
	
	// Определяем путь к файлу
	
	ОтносительныйПутьКФайлу = ПолучитьОтносительныйПутьКФайлу(Файл, КонтекстВыполнения.ПараметрыЭкспорта);
	ПолныйПутьКФайлу        = ПолучитьПолныйПутьКФайлу(Файл, ОтносительныйПутьКФайлу, ИдентификаторСводаЗнаний, КонтекстВыполнения);
	
	Если ПараметрыСеанса.ИспользуетсяЛокальныйКэшНаКлиентеСУЗ И КонтекстВыполнения.ПараметрыЭкспорта = Неопределено И НЕ ДанныеФайла.ВнешнийФайл Тогда
		ПолныйПутьКФайлу = "file://" + ПолныйПутьКФайлу;
	КонецЕсли;
	
	// Формируем XML
	
	ФайлXDTOТип  = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/File","Файл");
	ФайлXDTO     = ФабрикаXDTO.Создать(ФайлXDTOТип);
	
	ФайлXDTO.object                = ИмяОбъектаСУЗ;
	ФайлXDTO.id                    = Файл.УникальныйИдентификатор();
	ФайлXDTO.Тип                   = ИмяТипаФайла;
	ФайлXDTO.Путь                  = ПолныйПутьКФайлу;
	ФайлXDTO.ОтносительныйПуть     = ОтносительныйПутьКФайлу;
	ФайлXDTO.Якорь                 = Строка(ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "anchor"));
	ФайлXDTO.ПараметрыЗапуска      = ПараметрыЗапуска;
	ФайлXDTO.Каталог               = Лев(ОтносительныйПутьКФайлу, СтрДлина(ОтносительныйПутьКФайлу)-СтрДлина(ДанныеФайла.ИмяФайла));
	ФайлXDTO.Расширение            = НРег(ОбщегоНазначенияКлиентСервер.ПолучитьРасширениеИмениФайла(ДанныеФайла.ИмяФайла));
	ФайлXDTO.РежимЭкспорта         = ?(КонтекстВыполнения.ПараметрыЭкспорта = Неопределено, Ложь, Истина);
	ФайлXDTO.ПодключитьAPI         = КонтекстВыполнения.ПодключитьAPI;	
	ФайлXDTO.МожноОтключитьFlash   = МожноОтключитьFlash(КонтекстВыполнения, ФайлXDTO.Расширение);
	ФайлXDTO.ИдентификаторYouTube  = "";
	
	Если ДанныеФайла.ВнешнийФайл И Файл.ТипФайла = Перечисления.ТипыФайловСУЗ.Video Тогда		
		ИдентификаторYouTube = ОбъектыСУЗКлиентСервер.ИдентификаторВидеоYouTubeИзURI(ФайлXDTO.ОтносительныйПуть);
		Если ЗначениеЗаполнено(ИдентификаторYouTube) Тогда
			Если ФайлXDTO.МожноОтключитьFlash ИЛИ КонтекстВыполнения.ПараметрыЭкспорта <> Неопределено Тогда
				ФайлXDTO.ИдентификаторYouTube = ИдентификаторYouTube;
			Иначе
				ФайлXDTO.Тип = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(Перечисления.ТипыФайловСУЗ.Default);
			КонецЕсли;
		КонецЕсли;		
	КонецЕсли;
	
	ВладелецXDTOТип = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/KnowledgeSources","ОбъектСУЗ");
	ВладелецXDTO    = ФабрикаXDTO.Создать(ВладелецXDTOТип);
	ВладелецXDTO.id = ДанныеФайла.Владелец.УникальныйИдентификатор();
	
	ФайлXDTO.Владелец = ВладелецXDTO;
	
	НастройкиXDTOТип = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/File", "Представление");
	НастройкиXDTO    = ФабрикаXDTO.Создать(НастройкиXDTOТип);
	
	НастройкиXDTO.Ширина                      = ДанныеФайла.Ширина;
	НастройкиXDTO.Высота                      = ДанныеФайла.Высота;
	НастройкиXDTO.Выравнивание                = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ДанныеФайла.Выравнивать); 
	НастройкиXDTO.ЦветФона                    = ДанныеФайла.FlashЦветФона;
	НастройкиXDTO.ВерсияПлагина               = ДанныеФайла.FlashВерсия;
	НастройкиXDTO.ИдентификаторОбластиДанных  = "file_" + СтрЗаменить(ФайлXDTO.id, "-", "");
	НастройкиXDTO.СтатичноеПредставление      = СтатичноеПредставление;
	НастройкиXDTO.АльтернативныйТекст         = АльтернативныйТекст;
	НастройкиXDTO.ЗапускатьВоФрейме           = ЗапускатьВоФрейме;
	НастройкиXDTO.ОдинФайл                    = ?(КонтекстВыполнения.Свойство("ВозможноПоказатьОдинФайл") И КонтекстВыполнения.ВозможноПоказатьОдинФайл, Истина, Ложь);
	НастройкиXDTO.ПроигрыватьАвтоматически    = ДанныеФайла.ПроигрыватьАвтоматически;
	НастройкиXDTO.ОткрыватьВнешнимПриложением = ДанныеФайла.ОткрыватьВнешнимПриложением;
    НастройкиXDTO.ОткрыватьПоСсылке           = ?(ОбъектЗапуска = "file", Ложь, ДанныеФайла.ОткрыватьПоСсылке);
	
	Если Файл.ТипФайла = Перечисления.ТипыФайловСУЗ.Video
		И ЕстьМиниатюра(Файл) Тогда
		
		НастройкиXDTO.ПутьКМиниатюре = ИмяФайлаМиниатюры(ПолныйПутьКФайлу);
		
	КонецЕсли;
	
	ФайлXDTO.Настройки = НастройкиXDTO;
	
	// Добавляем модули
	
	Если ДанныеФайла.ТипФайла = Перечисления.ТипыФайловСУЗ.Document Тогда
		// Модуль подсказок всегда подключается к документам
		ОбъектыСУЗ.ДобавитьМодульВМассив("qtip2", КонтекстВыполнения.СписокМодулей);
	КонецЕсли;
	
	// Формируем XML
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();
	ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, ФайлXDTO);
	XMLДанные = ЗаписьXML.Закрыть();
	
	ШаблонОбъекта = ОбъектыСУЗ.ПолучитьСсылкуНаXSLШаблонОбъекта(Файл);
	ОбъектыСУЗ.ДобавитьШаблонВСписокОбъекта(ШаблонОбъекта, КонтекстВыполнения.СписокШаблонов);
	
	Возврат XMLДанные;
	
КонецФункции

Функция МожноОтключитьFlash(КонтекстВыполнения, Расширение = Неопределено) Экспорт
	
	ИспользуетсяСовременныйБраузерВоВсехСлучаях = ОбъектыСУЗПовтИсп.ИспользуетсяСовременныйБраузерВоВсехСлучаях();
	
	ЭтоСтандартноеВидеоАудиоВВебКлиенте = (
		(Расширение = "mp4"
		ИЛИ Расширение = "webm"
		ИЛИ Расширение = "mp3"
		ИЛИ Расширение = Неопределено)
		И СтандартныеПодсистемыСервер.ПараметрыКлиентаНаСервере().Получить("ЭтоВебКлиент"));
										
	ЭтоВстроенныйWeKit = (КонтекстВыполнения.Свойство("ЭтоВстроенныйWeKit") И КонтекстВыполнения.ЭтоВстроенныйWeKit = Истина);
										
	Возврат (ИспользуетсяСовременныйБраузерВоВсехСлучаях ИЛИ ЭтоСтандартноеВидеоАудиоВВебКлиенте ИЛИ ЭтоВстроенныйWeKit);
	
КонецФункции

// Функция возвращает путь к файлу относительно каталога ресурсов.
//
Функция ПолучитьОтносительныйПутьКФайлу(Файл, ПараметрыЭкспорта=Неопределено) Экспорт
	
	Если Файл.ВнешнийФайл Тогда
		Возврат Файл.ИмяФайла;
	КонецЕсли;
	     
	ТекстЗапроса = "ВЫБРАТЬ
	               |	ФайлыСУЗ.Ссылка КАК Ссылка,
	               |	ФайлыСУЗ.ИмяФайла КАК ИмяФайла,
	               |	ФайлыСУЗ.ТипФайла,
	               |	ФайлыСУЗ.ВнешнийФайл
	               |ИЗ
	               |	Справочник.ФайлыСУЗ КАК ФайлыСУЗ
	               |ГДЕ
	               |	ФайлыСУЗ.Ссылка = &Ссылка
	               |ИТОГИ ПО
	               |	Ссылка ТОЛЬКО ИЕРАРХИЯ";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", Файл);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	// Относительный путь к файлу включает и каталог ресурса этого файла.
	СсылкаНаФайл = Справочники.РесурсыСУЗ.ИмяКаталогаРесурса(Файл.Владелец);
	
	Если ЗначениеЗаполнено(СсылкаНаФайл) Тогда
		СсылкаНаФайл = СсылкаНаФайл +  "/";
	КонецЕсли;
	
	Пока Результат.Следующий() Цикл		
		Если НЕ ПустаяСтрока(Результат.ИмяФайла) Тогда
			СсылкаНаФайл = СсылкаНаФайл + Справочники.ФайлыСУЗ.ИмяФайлаДляВыгрузки(Результат.Ссылка, Результат.ИмяФайла, Результат.ТипФайла, ПараметрыЭкспорта) + "/";
		КонецЕсли;
	КонецЦикла;
	
	СсылкаНаФайл = Сред(СсылкаНаФайл, 1, СтрДлина(СсылкаНаФайл)-1); // Убираем последний слэш
	
	Возврат СсылкаНаФайл;   
	
КонецФункции

Функция ПолучитьПолныйПутьКФайлу(Файл, ОтносительныйПутьКФайлу, ИдентификаторСводаЗнаний, КонтекстВыполнения) Экспорт
	
	Если КонтекстВыполнения.ПараметрыЭкспорта <> Неопределено
		ИЛИ (Файл.ВнешнийФайл И Найти( ОтносительныйПутьКФайлу, "://") > 0) Тогда
		
		ПолныйПутьКФайлу = ОтносительныйПутьКФайлу;
		
	Иначе
		
		ПолныйПутьКФайлу = Справочники.РесурсыСУЗ.АдресКаталогаРесурсов(ИдентификаторСводаЗнаний) + ОтносительныйПутьКФайлу;
		ПолныйПутьКФайлу = ОбщегоНазначенияСУКлиентСервер.ПривестиСлэши(ПолныйПутьКФайлу);
		
	КонецЕсли;
	
	Возврат ПолныйПутьКФайлу;
	
КонецФункции

// Изменяет имя файла, если необходимо.
// Примечание: необходимо обеспечить, чтобы функция не вызывалась
// для внешних файлов, так как это не имеет смысла.
//
Функция ИмяФайлаДляВыгрузки(Знач Файл, Знач ИмяФайла, Знач ТипФайла, ПараметрыЭкспорта = Неопределено) Экспорт

	// Заменяем русские символы в имени файлы на английские (только для экспорта)
	
	ТребуетсяЗаменитьРусскиеСимволы = Ложь;
	
	Если ПараметрыЭкспорта <> Неопределено Тогда
				
		ТребуемыеДанныеРесурса = Новый Структура("ФайлЗапуска, ИмяФайлаЗапуска", "Владелец.ФайлЗапуска", "Владелец.ФайлЗапуска.ИмяФайла");
		ДанныеРесурса = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Файл, ТребуемыеДанныеРесурса);		
		РасширениеИмени = ОбщегоНазначенияКлиентСервер.ПолучитьРасширениеИмениФайла(ДанныеРесурса.ИмяФайлаЗапуска);
				
		Если ЗначениеЗаполнено(ДанныеРесурса.ФайлЗапуска) 
			И РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлHTML(РасширениеИмени) Тогда
			ТребуетсяЗаменитьРусскиеСимволы = Ложь;
		Иначе
			ТребуетсяЗаменитьРусскиеСимволы = Истина;	
		КонецЕсли;
				
	КонецЕсли;
	
	Если ТребуетсяЗаменитьРусскиеСимволы Тогда
	
		СписокСимволов = Новый СписокЗначений;
		СписокСимволов.Добавить("а","A");
		СписокСимволов.Добавить("б","B");
		СписокСимволов.Добавить("в","V");
		СписокСимволов.Добавить("г","G");
		СписокСимволов.Добавить("д","D");		
		СписокСимволов.Добавить("е","E");
		СписокСимволов.Добавить("ё","EO");
		СписокСимволов.Добавить("ж","ZH");
		СписокСимволов.Добавить("з","Z");
		СписокСимволов.Добавить("и","I");
		СписокСимволов.Добавить("й","Y");
		СписокСимволов.Добавить("к","K");
		СписокСимволов.Добавить("л","L");
		СписокСимволов.Добавить("м","M");
		СписокСимволов.Добавить("н","N");
		СписокСимволов.Добавить("о","O");
		СписокСимволов.Добавить("п","P");
		СписокСимволов.Добавить("р","R");
		СписокСимволов.Добавить("с","S");
		СписокСимволов.Добавить("т","T");
		СписокСимволов.Добавить("у","U");
		СписокСимволов.Добавить("ф","F");
		СписокСимволов.Добавить("х","H");
		СписокСимволов.Добавить("ц","TS");
		СписокСимволов.Добавить("ч","CH");
		СписокСимволов.Добавить("ш","SH");
		СписокСимволов.Добавить("щ","SCH");
		СписокСимволов.Добавить("ь","");
		СписокСимволов.Добавить("ы","Y");
		СписокСимволов.Добавить("ъ","");
		СписокСимволов.Добавить("э","E");
		СписокСимволов.Добавить("ю","YU");
		СписокСимволов.Добавить("я","YA");
		
		СписокСимволов.Добавить("№","N");
		
		ИмяФайла = НРег(ИмяФайла);
		
		Для Каждого Строка Из СписокСимволов Цикл  
		    ИмяФайла = СтрЗаменить(ИмяФайла, Строка.Значение, НРег(Строка.Представление));
		КонецЦикла;
		
		Если Лев(ИмяФайла, 7) = "folder_" Тогда
			
			// Сокращаем имя папки, если это папка, созданная при загрузке файлов
			
			СвойстваФайла = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Файл, "ЭтоГруппа, Родитель, Владелец");
			
			Если СвойстваФайла.ЭтоГруппа Тогда
			
				СокращенноеИмя = Сред(ИмяФайла, 1, 6);
		
				Запрос = Новый Запрос;
				Запрос.Текст = 
					"ВЫБРАТЬ
					|	ФайлыСУЗ.Ссылка
					|ИЗ
					|	Справочник.ФайлыСУЗ КАК ФайлыСУЗ
					|ГДЕ
					|	ФайлыСУЗ.Ссылка <> &Файл
					|	И ФайлыСУЗ.ПометкаУдаления = ЛОЖЬ
					|	И ФайлыСУЗ.Владелец = &Ресурс
					|	И ФайлыСУЗ.Родитель = &Родитель
					|	И ФайлыСУЗ.ЭтоГруппа = ИСТИНА
					|	И ФайлыСУЗ.ИмяФайла = &СокращенноеИмяФайла";
				
				Запрос.УстановитьПараметр("Ресурс", СвойстваФайла.Владелец);
				Запрос.УстановитьПараметр("Родитель", СвойстваФайла.Родитель);
				Запрос.УстановитьПараметр("СокращенноеИмяФайла", СокращенноеИмя);
				Запрос.УстановитьПараметр("Файл", Файл);
				
				РезультатЗапроса = Запрос.Выполнить();
				
				Если РезультатЗапроса.Пустой() Тогда
					ИмяФайла = СокращенноеИмя;				
				КонецЕсли;
				
			КонецЕсли;
				
		КонецЕсли;
		
	КонецЕсли;
	
	// Заменяем расширение
	
	Если ТипФайла = Перечисления.ТипыФайловСУЗ.Video Тогда
		
		БазовыйФормат = БазовыйФорматВидеоФайла(ИмяФайла);
		
		ПредпочтительныйФормат = ФорматВидеоФайлаДляОтображения(Файл, ИмяФайла, ПараметрыЭкспорта);
		
		Если ПредпочтительныйФормат <> БазовыйФормат Тогда			
			ИмяФайла = Лев(ИмяФайла, СтрДлина(ИмяФайла) - СтрДлина("."+БазовыйФормат)) + "." +НРег(ПредпочтительныйФормат);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ТипФайла = Перечисления.ТипыФайловСУЗ.Document Тогда
		РасширениеФайла = ОбщегоНазначенияКлиентСервер.ПолучитьРасширениеИмениФайла(ИмяФайла);
		ИмяФайла = Лев(ИмяФайла, СтрДлина(ИмяФайла) - СтрДлина("."+РасширениеФайла));
		Пока Прав(ИмяФайла, 1) = "." И СтрДлина(ИмяФайла) > 1 Цикл
			ИмяФайла = Лев(ИмяФайла, СтрДлина(ИмяФайла) - 1); // Если стоит две точки
		КонецЦикла;
	КонецЕсли;
	
	Возврат ИмяФайла;
	
КонецФункции

Функция ФорматыВидеоФайлов(Файл=Неопределено, Версия=Неопределено, Поставщик=Неопределено) Экспорт
	
	// Получаем таблицу видео файлов
	
	Если Файл = Неопределено Тогда
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ФайлыСУЗ.Ссылка КАК Файл,
			|	ФайлыСУЗ.Поставщик,
			|	ФайлыСУЗ.Версия,
			|	ФайлыСУЗ.ИмяФайла
			|ИЗ
			|	Справочник.ФайлыСУЗ КАК ФайлыСУЗ
			|ГДЕ
			|	ФайлыСУЗ.ПометкаУдаления = ЛОЖЬ
			|	И ФайлыСУЗ.ЭтоГруппа = ЛОЖЬ
			|	И ФайлыСУЗ.ТипФайла = ЗНАЧЕНИЕ(Перечисление.ТипыФайловСУЗ.Video)
			|	И ФайлыСУЗ.ВнешнийФайл = ЛОЖЬ";
		
		ТаблицаФайлов = Запрос.Выполнить().Выгрузить();
		
	Иначе
		
		ТаблицаФайлов = Новый ТаблицаЗначений;
		ТаблицаФайлов.Колонки.Добавить("Файл", Новый ОписаниеТипов("СправочникСсылка.ФайлыСУЗ"));
		ТаблицаФайлов.Колонки.Добавить("Версия", Новый ОписаниеТипов("Число"));
		ТаблицаФайлов.Колонки.Добавить("Поставщик", Новый ОписаниеТипов("СправочникСсылка.ПоставщикиСУЗ"));
		ТаблицаФайлов.Колонки.Добавить("ИмяФайла", Новый ОписаниеТипов("Строка"));
		
		НовыйФайл = ТаблицаФайлов.Добавить();
		НовыйФайл.Файл = Файл;
		НовыйФайл.Версия = Версия;
		НовыйФайл.Поставщик = Поставщик;
		НовыйФайл.ИмяФайла = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Файл, "ИмяФайла");
		
	КонецЕсли;
	
	// Выбираем форматы видео
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("ВнешнийИсточник", ТаблицаФайлов);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Файлы.Файл,
	|	Файлы.Версия,
	|	Файлы.Поставщик
	|ПОМЕСТИТЬ ТаблицаФайлов
	|ИЗ
	|	&ВнешнийИсточник КАК Файлы
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Файл";
	
	Запрос.Выполнить();

	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеФайлыСУЗ.КодДанных,
		|	ТаблицаФайлов.Файл
		|ИЗ
		|	ТаблицаФайлов КАК ТаблицаФайлов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеФайлыСУЗ КАК ДанныеФайлыСУЗ
		|		ПО ТаблицаФайлов.Файл = ДанныеФайлыСУЗ.СсылкаНаОбъектСУЗ
		|			И ТаблицаФайлов.Поставщик = ДанныеФайлыСУЗ.Поставщик
		|			И ТаблицаФайлов.Версия = ДанныеФайлыСУЗ.Версия";
	
		
	ТаблицаФорматов = Запрос.Выполнить().Выгрузить();
	
	// Заполняем базовый формат
	
	ТаблицаФайлов.Колонки.Добавить("БазовыйФормат");
	
	Для каждого Строка Из ТаблицаФайлов Цикл	
		Строка.БазовыйФормат = БазовыйФорматВидеоФайла(Строка.ИмяФайла);
	КонецЦикла;		
	
	// Заполняем значения форматов
	
	ФорматыВидео = ДоступныеФорматыВидео();
	
	Для каждого Формат Из ФорматыВидео Цикл	
		ТаблицаФайлов.Колонки.Добавить(Формат);	
	КонецЦикла;
	
	Для каждого Строка Из ТаблицаФайлов Цикл	
		
		ФорматыФайла = ТаблицаФорматов.НайтиСтроки(Новый Структура("Файл", Строка.Файл));
		
		Для каждого СтрокаФФ Из ФорматыФайла Цикл
			
			Если ФорматыВидео.Найти(СтрокаФФ.КодДанных) <> Неопределено Тогда
				Строка[СтрокаФФ.КодДанных] = Истина;
			КонецЕсли;
			
		КонецЦикла;	
		
	КонецЦикла;	
	
	//Возвращаем таблицу
	
	Возврат ТаблицаФайлов;		
		
КонецФункции


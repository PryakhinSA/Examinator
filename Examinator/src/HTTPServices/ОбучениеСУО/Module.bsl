		Если ТипВладельца = "message" Тогда
			ВладелецФайла = Документы.СообщениеСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));
			ШаблонСообщения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВладелецФайла, "Шаблон");
			Если ЗначениеЗаполнено(ШаблонСообщения) И ТипЗнч(ШаблонСообщения) = Тип("СправочникСсылка.ШаблоныСообщенийСУО") Тогда
				ВладелецФайла = ШаблонСообщения; // Ищем файлы в шаблоне
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ВладелецФайла) Тогда
			ИмяСправочникаХраненияФайлов = РаботаСФайламиСлужебный.ИмяСправочникаХраненияФайлов(ВладелецФайла);		
			Файл = Справочники[ИмяСправочникаХраненияФайлов].ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторФайла));
			ДвоичныеДанные = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(Файл);
			ДанныеФайла = ПрисоединенныеФайлы.ПолучитьДанныеФайла(Файл,,Ложь,Ложь);
			ИмяФайла = ДанныеФайла.ИмяФайла;
			РасширениеФайла = "." + ДанныеФайла.Расширение;
		КонецЕсли;
			
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ИмяФайла) Тогда
		Возврат ОтветКлиентуДвоичныеДанные(404);
	КонецЕсли;
	
	MIMEТипфайла = ОбщегоНазначенияСУКлиентСервер.MIMEТипПоРасширению(РасширениеФайла);
	
	Возврат ОтветКлиентуДвоичныеДанные(0, ДвоичныеДанные, MIMEТипфайла);
	
КонецФункции

// Подготовливает файлы, полученные из кабинета для записи в базу
//
Функция ФайлыДляЗаписи(ПараметрыФайла)
	
	ФайлыДляЗаписи = Новый Массив;
	
	МассивСвойствФайла = Новый Массив;
	МассивСвойствФайла.Добавить("fileName");
	МассивСвойствФайла.Добавить("fileSize");
	МассивСвойствФайла.Добавить("fileDateModified");
	МассивСвойствФайла.Добавить("fileBase64Data");
	
	Для каждого ИмяСвойства Из МассивСвойствФайла Цикл
	
		Если НЕ ПараметрыФайла.Свойство(ИмяСвойства) Тогда
			Возврат Неопределено; // Ничего не делаем
		КонецЕсли;
		
		Если ТипЗнч(ПараметрыФайла[ИмяСвойства]) <> Тип("Массив") Тогда
			НовыйМассив = Новый Массив;
			НовыйМассив.Добавить(ПараметрыФайла[ИмяСвойства]);
			ПараметрыФайла[ИмяСвойства] = НовыйМассив;
		КонецЕсли;
		
	КонецЦикла;
	
	КоличествоФайлов = ПараметрыФайла.fileName.Количество();
	НомерФайла       = 0;
	ВерсияКабинета = ВебКабинетСУ.ВерсияAPI();
	
	Для каждого ИмяФайла Из ПараметрыФайла.fileName Цикл
		
		// Имя Файлы
		
		ИмяФайла = ПараметрыФайла.fileName[НомерФайла];
		
		ИмяФайла = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыВИмениФайла(ИмяФайла, "_");
		ВосстановитьСимволыСтрокиПараметров(ИмяФайла);
		
		РасширениеФайла         = ОбщегоНазначенияКлиентСервер.ПолучитьРасширениеИмениФайла(ИмяФайла);
		РасширениеФайлаБезТочки = ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(РасширениеФайла);
		ИмяФайлаБезРасширения   = Сред(ИмяФайла, 1, СтрДлина(ИмяФайла) - СтрДлина(РасширениеФайла) - 1);
		
		// Двоичные данные файла
		
		Если НЕ ЗначениеЗаполнено(ПараметрыФайла.fileBase64Data[НомерФайла]) Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Попытка
			ДвоичныеДанныеФайла = Base64Значение(ПараметрыФайла.fileBase64Data[НомерФайла]);
		Исключение
			Возврат Неопределено;
		КонецПопытки;	
		
		АдресХраненияФайла = ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла);
		
		// Дата файла
		
		ДатаФайлаУниверсальная  = Число(ПараметрыФайла.fileDateModified[НомерФайла]);
		ВремяИзмененияФайла     = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(ДатаФайлаУниверсальная);
		
		// Описание файла
		
		ОписаниеФайла = НСтр("ru = 'Файл загружен через веб-кабинет'");
		
		ФайлыДляЗаписи.Добавить(Новый Структура("
		|ИмяФайла,
		|РасширениеФайла,
		|РасширениеФайлаБезТочки,
		|ИмяФайлаБезРасширения,
		|АдресХраненияФайла,
		|ВремяИзмененияФайла,
		|ОписаниеФайла",
		ИмяФайла,
		РасширениеФайла,
		РасширениеФайлаБезТочки,
		ИмяФайлаБезРасширения,
		АдресХраненияФайла,
		ВремяИзмененияФайла,
		ОписаниеФайла));
		
		// Следующая итерация
		
		НомерФайла = НомерФайла + 1;
		
	КонецЦикла;
	
	Возврат ФайлыДляЗаписи;
	
КонецФункции


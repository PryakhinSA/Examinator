	<objectType name="ПрохождениеОбучения" ordered="false">
		<property name="Наименование" type="xs:string"/>
		<property name="СтатусОбучения" type="xs:integer"/>
		<property name="СтатусПрохождения" type="xs:integer"/>
		<property name="Актуально" type="xs:boolean"/>
		<property name="ДатаНачалаПрохожденияЧисло" type="xs:integer"/>
		<property name="ДатаОкончанияПрохожденияЧисло" type="xs:integer"/>
		<property name="ПериодСтрока" type="xs:string" lowerBound="0"/>
		<property name="СкрытьВремяПроведения" type="xs:boolean"/>
		<property name="ДатаКонтроляЧисло" type="xs:integer"/>
		<property name="ДатаКонтроляСтрока" type="xs:string"/>
		<property name="Аудитория" type="xs:string"/>
		<property name="Территория" type="xs:string"/>
		<property name="КомментарийУчастникуОтМенеджера" type="xs:string"/>
		<property name="КомментарийУчастникуОтМенеджераКонтекстный" type="xs:string"/>
		<property name="КомментарийУчастникуОтПреподавателя" type="xs:string"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/3/EduMarks" name="Оценка" type="d3p1:Оценка"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/3/EduMarks" name="ТекущаяОценка" type="d3p1:Оценка"/>
		<property name="ЗавершаетУчащийся" type="xs:boolean"/>
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/enterprise/current-config" name="ПрохождениеОбучения" type="d3p1:DocumentRef.ПрохождениеОбученияСУО"/>
		<property name="РазрешеноПрикреплятьФайлы" type="xs:boolean"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/3/EduFiles" name="ФайлыПользователя" type="d3p1:Файлы" lowerBound="0"/>
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/enterprise/current-config" name="ПроведениеОбучения" type="d3p1:DocumentRef.ПроведениеОбученияСУО"/>
		<property name="ДоступенСписокУчастников" type="xs:boolean"/>
		<property name="ДоступенСписокПреподавателей" type="xs:boolean"/>
		<property name="ДоступенРазделФорума" type="xs:boolean"/>
		<property name="АдресВИнтернете" type="xs:string"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/1/UserActivity" name="Ресурсы" type="d3p1:Ресурсы"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/1/UserActivity" name="Задания" type="d3p1:Задания" lowerBound="0"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/1/UserActivity" name="ОписанияЗаданий" type="d3p1:Задания" lowerBound="0"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/1/UserActivity" name="ЕдинственноеЗадание" type="d3p1:Задание"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/1/UserActivity" name="ОписаниеЕдинственногоЗадания" type="d3p1:Задание"/>
		<property name="ЗаданияДоступны" type="xs:boolean"/>
		<property name="ЭлектронноеОбучение" type="xs:boolean"/>
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/User" name="Пользователь" type="d3p1:Пользователь"/>
		<property name="ПроверяетсяПреподавателем" type="xs:boolean"/>
		<property name="ПроверенПреподавателем" type="xs:boolean"/>
		<property name="ВыставляетсяОценка" type="xs:boolean"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/3/EduMarks" name="ШкалаОценок" type="d3p1:ШкалаОценок"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/3/EduTemplate" name="Сценарий" type="d3p1:Сценарий"/>
		<property name="Баллы" type="xs:integer"/>
		<property name="ТекущиеБаллы" type="xs:integer"/>
		<property name="ПоказыватьРезультатыТестирования" type="xs:boolean"/>
		<property name="ПоказыватьОтветыВРезультатахТестирования" type="xs:boolean" lowerBound="0"/>
		<property name="ПоказыватьОценкуВРезультатахТестирования" type="xs:boolean" lowerBound="0"/>
		<property name="ПодчиненныеМероприятияДоступны" type="xs:boolean"/>
		<property name="ПоследовательноеПрохождениеЗаданий" type="xs:boolean"/>
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/enterprise/current-config" name="Сертификат" type="d3p1:DocumentRef.СертификатСУО"/>
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/enterprise/current-config" name="РодительскоеПрохождение" type="d3p1:DocumentRef.ПрохождениеОбученияСУО"/>
		<property name="НаименованиеРодительскогоПрохождения" type="xs:string"/>
		<property name="ЕстьДополнительныеРеквизиты" type="xs:boolean"/>
		<property name="ЗаданияПроверяютсяВыборочно" type="xs:boolean"/>
		<property xmlns:d3p1="http://v8.1c.ru/lms/1/UserActivity" name="НезаполненныеСвойстваУчастника" type="d3p1:НезаполненныеСвойстваУчастника" lowerBound="0"/>
		<property name="ПоказыватьБаллы" type="xs:boolean"/>
		<property name="ПоказыватьПодробныеСведенияОЗадании" type="xs:boolean"/>
		<property name="Картинка" type="xs:string"/>
		<property name="ВариантОтображенияВремени" type="xs:integer"/>
		<property name="ЗавершеноВПроцентах" type="xs:integer"/>
		<property name="ДатаНачалаОтсчетаПродолжительности" type="xs:integer"/>
		<property name="ПродолжительностьВСекундах" type="xs:integer"/>
		<property name="ВариантПродолжительности" type="xs:integer"/>
		<property name="ПродолжительностьСтрока" type="xs:string"/>
		<property name="ОсталосьВремениСтрока" type="xs:string"/>
		<property name="ВозвращеноНаДоработку" type="xs:boolean"/>
		<property name="ДоступноОцениваниеКачестваОбучения" type="xs:boolean"/>
		<property name="ОценкаКачестваОбучения" type="xs:integer" lowerBound="0"/>
		<property name="КомментарийКачестваОбучения" type="xs:string" lowerBound="0"/>
		<property name="ОписаниеБлокаОценкиКачестваОбучения" type="xs:string" lowerBound="0"/>
		<property name="ЗаголовокБлокаОценкиКачестваОбучения" type="xs:string" lowerBound="0"/>
		<property name="ПоказыватьОценкиИКомментарииВсехУчастников" type="xs:boolean"/>
	</objectType>
	<objectType name="Задание">
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/core" name="ЭлектронныйРесурс" type="d3p1:UUID"/>
		<property name="НаОсновеЭлектронногоРесурса" type="xs:boolean"/>

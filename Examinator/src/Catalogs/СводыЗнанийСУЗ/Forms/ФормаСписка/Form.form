  <attributes>
    <name>Список</name>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Родитель</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Ссылка</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Тип</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ЭтоГруппа</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СправочникСводыЗнанийСУЗ.Ссылка КАК Ссылка,
	СправочникСводыЗнанийСУЗ.ПометкаУдаления КАК ПометкаУдаления,
	СправочникСводыЗнанийСУЗ.Родитель КАК Родитель,
	СправочникСводыЗнанийСУЗ.ЭтоГруппа КАК ЭтоГруппа,
	СправочникСводыЗнанийСУЗ.Наименование КАК Наименование,
	СправочникСводыЗнанийСУЗ.Версия КАК Версия,
	СправочникСводыЗнанийСУЗ.ДатаИзменения КАК ДатаИзменения,
	СправочникСводыЗнанийСУЗ.Поставщик КАК Поставщик,
	СправочникСводыЗнанийСУЗ.Редакция КАК Редакция,
	СправочникСводыЗнанийСУЗ.Тип КАК Тип,
	ПубликацииСрезПоследних.Период КАК ДатаПубликации,
	ВЫБОР
		КОГДА НЕ ПубликацииСрезПоследних.Период ЕСТЬ NULL
				И (ПубликацииСрезПоследних.Период >= СправочникСводыЗнанийСУЗ.ДатаИзменения
						И ПлеерКурсовВебКабинетаСУЗ.ДатаИзменения ЕСТЬ NULL
					ИЛИ ПубликацииСрезПоследних.Период >= СправочникСводыЗнанийСУЗ.ДатаИзменения
						И ПубликацииСрезПоследних.Период >= ПлеерКурсовВебКабинетаСУЗ.ДатаИзменения)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ПубликацияАктуальна,
	ВЫБОР
		КОГДА ПубликацииСрезПоследних.Период ЕСТЬ NULL
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ПубликацияОтсутствует,
	ВЫБОР
		КОГДА СправочникСводыЗнанийСУЗ.ЭтоГруппа
			ТОГДА &amp;ПустаяСтрока
		КОГДА ПубликацииСрезПоследних.Период ЕСТЬ NULL
			ТОГДА &amp;Отсутствует
		КОГДА ПубликацииСрезПоследних.Период &lt; СправочникСводыЗнанийСУЗ.ДатаИзменения
					И ПлеерКурсовВебКабинетаСУЗ.ДатаИзменения ЕСТЬ NULL
				ИЛИ ПубликацииСрезПоследних.Период &lt; СправочникСводыЗнанийСУЗ.ДатаИзменения
					ИЛИ ПубликацииСрезПоследних.Период &lt; ПлеерКурсовВебКабинетаСУЗ.ДатаИзменения
			ТОГДА &amp;ТребуетОбновления			
		КОГДА ПубликацииСрезПоследних.Период &lt; &amp;ДатаСущественныхИзмененийМакетов
			ТОГДА &amp;ЖелательноОбновить
		КОГДА ПубликацииСрезПоследних.Период >= СправочникСводыЗнанийСУЗ.ДатаИзменения
					И ПлеерКурсовВебКабинетаСУЗ.ДатаИзменения ЕСТЬ NULL
				ИЛИ ПубликацииСрезПоследних.Период >= СправочникСводыЗнанийСУЗ.ДатаИзменения
					И ПубликацииСрезПоследних.Период >= ПлеерКурсовВебКабинетаСУЗ.ДатаИзменения
			ТОГДА &amp;Актуальна
		ИНАЧЕ &amp;ТребуетОбновления
	КОНЕЦ КАК СтатусПубликации,
	ВЫБОР
		КОГДА ПлеерКурсовВебКабинетаСУЗ.ДатаИзменения ЕСТЬ NULL
			ТОГДА ЗНАЧЕНИЕ(Перечисление.ПлеерыКурсовВебКабинетаСУЗ.Автономный)
		ИНАЧЕ ПлеерКурсовВебКабинетаСУЗ.Плеер
	КОНЕЦ КАК ПлеерВебКабинета
ИЗ
	Справочник.СводыЗнанийСУЗ КАК СправочникСводыЗнанийСУЗ
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПубликацииЭлектронныхРесурсовСУЗ.СрезПоследних КАК ПубликацииСрезПоследних
		ПО (ПубликацииСрезПоследних.ЭлектронныйРесурс = СправочникСводыЗнанийСУЗ.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПлеерКурсовВебКабинетаСУЗ КАК ПлеерКурсовВебКабинетаСУЗ
		ПО (ПлеерКурсовВебКабинетаСУЗ.ЭлектронныйРесурс = СправочникСводыЗнанийСУЗ.Ссылка)</queryText>
      <mainTable>Catalog.СводыЗнанийСУЗ</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>

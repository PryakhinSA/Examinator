  <attributes>
    <name>Список</name>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ДатаКонтроля</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ДатаНачалаДоступа</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ДатаНачалаПроведения</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ДатаОкончанияПроведения</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Статус</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДокументПроведениеОбученияСУО.Ссылка КАК Ссылка,
	ДокументПроведениеОбученияСУО.ПометкаУдаления КАК ПометкаУдаления,
	ДокументПроведениеОбученияСУО.Номер КАК Номер,
	ДокументПроведениеОбученияСУО.Дата КАК Дата,
	ДокументПроведениеОбученияСУО.Проведен КАК Проведен,
	ВЫБОР
		КОГДА ДокументПроведениеОбученияСУО.ПроведениеПрограммыОбучения = ЗНАЧЕНИЕ(Документ.ПроведениеПрограммыОбученияСУО.ПустаяСсылка)
			ТОГДА &quot;Без программы обучения&quot;
		ИНАЧЕ ДокументПроведениеОбученияСУО.ПроведениеПрограммыОбучения
	КОНЕЦ КАК ПроведениеПрограммыОбучения,
	ДокументПроведениеОбученияСУО.СхемаПроведения КАК СхемаПроведения,
	ДокументПроведениеОбученияСУО.ОткрытоеМероприятие КАК Открытое,
	ДокументПроведениеОбученияСУО.ДатаОткрытияЗаписи КАК ДатаОткрытияЗаписи,
	ДокументПроведениеОбученияСУО.ДатаЗакрытияЗаписи КАК ДатаЗакрытияЗаписи,
	ДокументПроведениеОбученияСУО.ТребуетсяЗаявка КАК ТребуетсяЗаявка,
	ДокументПроведениеОбученияСУО.МаксимальноеКоличествоУчастников КАК МаксимальноеКоличествоУчастников,
	ДокументПроведениеОбученияСУО.КомментарийДляУчастника КАК КомментарийДляУчастника,
	ДокументПроведениеОбученияСУО.КомментарийДляПреподавателя КАК КомментарийДляПреподавателя,
	ДокументПроведениеОбученияСУО.КомментарийДляМенеджера КАК КомментарийДляМенеджера,
	ДокументПроведениеОбученияСУО.МоментВремени КАК МоментВремени,
	ДокументПроведениеОбученияСУО.ОткрытоДляВсех КАК ОткрытоДляВсех,
	ВЫБОР
		КОГДА ГОД(ПроведениеОбученияСУО.ДатаНачалаПроведения) > 1
			ТОГДА ПроведениеОбученияСУО.ДатаНачалаПроведения
		ИНАЧЕ ПроведениеОбученияСУО.ДатаНачалаДоступа
	КОНЕЦ КАК ДатаНачалаОбучения,
	ВЫБОР
		КОГДА ГОД(ПроведениеОбученияСУО.ДатаНачалаПроведения) > 1
				И (ЧАС(ПроведениеОбученияСУО.ДатаНачалаПроведения) > 0
					ИЛИ МИНУТА(ПроведениеОбученияСУО.ДатаНачалаПроведения) > 0)
			ТОГДА ПроведениеОбученияСУО.ДатаНачалаПроведения
		КОГДА ГОД(ПроведениеОбученияСУО.ДатаНачалаДоступа) > 1
				И (ЧАС(ПроведениеОбученияСУО.ДатаНачалаДоступа) > 0
					ИЛИ МИНУТА(ПроведениеОбученияСУО.ДатаНачалаДоступа) > 0)
			ТОГДА ПроведениеОбученияСУО.ДатаНачалаДоступа
		ИНАЧЕ &quot;&quot;
	КОНЕЦ КАК ВремяНачалаОбучения,
	ВЫБОР
		КОГДА ГОД(ПроведениеОбученияСУО.ДатаОкончанияПроведения) > 1
			ТОГДА ПроведениеОбученияСУО.ДатаОкончанияПроведения
		ИНАЧЕ ПроведениеОбученияСУО.ДатаКонтроля
	КОНЕЦ КАК ДатаОкончанияОбучения,
	ВЫБОР
		КОГДА ГОД(ПроведениеОбученияСУО.ДатаОкончанияПроведения) > 1
				И (ЧАС(ПроведениеОбученияСУО.ДатаОкончанияПроведения) &lt;> 23
					И МИНУТА(ПроведениеОбученияСУО.ДатаОкончанияПроведения) &lt;> 59)
			ТОГДА ПроведениеОбученияСУО.ДатаОкончанияПроведения
		КОГДА ГОД(ПроведениеОбученияСУО.ДатаКонтроля) > 1
				И (ЧАС(ПроведениеОбученияСУО.ДатаКонтроля) &lt;> 23
					И МИНУТА(ПроведениеОбученияСУО.ДатаКонтроля) &lt;> 59)
			ТОГДА ПроведениеОбученияСУО.ДатаКонтроля
		ИНАЧЕ &quot;&quot;
	КОНЕЦ КАК ВремяОкончанияОбучения,
	ПроведениеОбученияСУО.ДатаНачалаПроведения КАК ДатаПроведения,
	ПроведениеОбученияСУО.ДатаНачалаДоступа КАК ДатаНачалаДоступа,
	ДокументПроведениеОбученияСУО.ДатаНачалаПроведения КАК ДатаНачалаПроведения,
	ПроведениеОбученияСУО.ДатаОкончанияПроведения КАК ДатаОкончанияПроведения,
	ПроведениеОбученияСУО.ДатаКонтроля КАК ДатаКонтроля,
	ВЫБОР
		КОГДА ДокументПроведениеОбученияСУО.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПроведенияОбъектовСУО.Запланировано)
				И (ГОД(ПроведениеОбученияСУО.ДатаНачалаПроведения) > 1
						И НЕ ПроведениеОбученияСУО.ДатаНачалаПроведения ЕСТЬ NULL
						И ПроведениеОбученияСУО.ДатаНачалаПроведения &lt;= &amp;ЭтотДень
					ИЛИ ГОД(ПроведениеОбученияСУО.ДатаНачалаДоступа) > 1
						И НЕ ПроведениеОбученияСУО.ДатаНачалаДоступа ЕСТЬ NULL
						И ПроведениеОбученияСУО.ДатаНачалаДоступа &lt;= &amp;ЭтотДень)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ТребуетсяСменитьСтатусЗапланировано,
	ВЫБОР
		КОГДА &amp;ПоказатьТребуетсяСменитьСтатусЗапланировано
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ПоказатьТребуетсяСменитьСтатусЗапланировано,
	ВЫБОР
		КОГДА ДокументПроведениеОбученияСУО.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПроведенияОбъектовСУО.Активно)
				И (ГОД(ПроведениеОбученияСУО.ДатаОкончанияПроведения) > 1
						И НЕ ПроведениеОбученияСУО.ДатаОкончанияПроведения ЕСТЬ NULL
						И ПроведениеОбученияСУО.ДатаОкончанияПроведения &lt; &amp;ЭтотДень
					ИЛИ ГОД(ПроведениеОбученияСУО.ДатаКонтроля) > 1
						И НЕ ПроведениеОбученияСУО.ДатаКонтроля ЕСТЬ NULL
						И ПроведениеОбученияСУО.ДатаКонтроля &lt; &amp;ЭтотДень)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ТребуетсяСменитьСтатусАктивно,
	ВЫБОР
		КОГДА &amp;ПоказатьТребуетсяСменитьСтатусАктивно
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ПоказатьТребуетсяСменитьСтатусАктивно,
	ВЫБОР
		КОГДА ДокументПроведениеОбученияСУО.Наименование &lt;> &quot;&quot;
			ТОГДА ДокументПроведениеОбученияСУО.Наименование
		КОГДА ДокументПроведениеОбученияСУО.НаОсновеЭлектронногоРесурса
			ТОГДА ДокументПроведениеОбученияСУО.ЭлектронныйРесурс
		КОГДА ДокументПроведениеОбученияСУО.НаОсновеМероприятия
			ТОГДА ДокументПроведениеОбученияСУО.Мероприятие
		ИНАЧЕ &quot;Обучение&quot;
	КОНЕЦ КАК Наименование,
	ВЫБОР
		КОГДА ДокументПроведениеОбученияСУО.НаОсновеМероприятия
			ТОГДА ДокументПроведениеОбученияСУО.Мероприятие.Вид
		ИНАЧЕ ДокументПроведениеОбученияСУО.ВидОбучения
	КОНЕЦ КАК Вид,
	ДокументПроведениеОбученияСУО.НаОсновеЭлектронногоРесурса КАК НаОсновеЭлектронногоРесурса,
	ДокументПроведениеОбученияСУО.АвтозачислениеНаОбучение КАК Автозачисление,
	ДокументПроведениеОбученияСУО.ДоступноВнешнимПользователям КАК ДоступноВнешнимПользователям,
	ДокументПроведениеОбученияСУО.Статус КАК Статус,
	ВЫБОР
		КОГДА ГОД(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 1
				ИЛИ ПроведениеОбученияСУО.ДатаНачалаПроведения ЕСТЬ NULL
			ТОГДА &quot;Без даты&quot;
		ИНАЧЕ ГОД(ПроведениеОбученияСУО.ДатаНачалаПроведения)
	КОНЕЦ КАК ГодПроведения,
	ВЫБОР
		КОГДА ГОД(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 1
				ИЛИ ПроведениеОбученияСУО.ДатаНачалаПроведения ЕСТЬ NULL
			ТОГДА &quot;Без даты&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 1
			ТОГДА &quot;01. Январь&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 2
			ТОГДА &quot;02. Февраль&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 3
			ТОГДА &quot;03. Март&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 4
			ТОГДА &quot;04. Апрель&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 5
			ТОГДА &quot;05. Май&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 6
			ТОГДА &quot;06. Июнь&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 7
			ТОГДА &quot;07. Июль&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 8
			ТОГДА &quot;08. Август&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 9
			ТОГДА &quot;09. Сентябрь&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 10
			ТОГДА &quot;10. Октябрь&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 11
			ТОГДА &quot;11. Ноябрь&quot;
		КОГДА МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения) = 12
			ТОГДА &quot;12. Декабрь&quot;
		ИНАЧЕ МЕСЯЦ(ПроведениеОбученияСУО.ДатаНачалаПроведения)
	КОНЕЦ КАК МесяцПроведения,
	ДокументПроведениеОбученияСУО.Дисциплина КАК Дисциплина,
	ВЫБОР
		КОГДА ДокументПроведениеОбученияСУО.НаОсновеМероприятия
			ТОГДА ДокументПроведениеОбученияСУО.Мероприятие
		КОГДА ДокументПроведениеОбученияСУО.НаОсновеЭлектронногоРесурса
			ТОГДА ДокументПроведениеОбученияСУО.ЭлектронныйРесурс
		ИНАЧЕ &quot;Без сценария&quot;
	КОНЕЦ КАК Сценарий,
	ДокументПроведениеОбученияСУО.НаОсновеМероприятия КАК НаОсновеМероприятия,
	ДокументПроведениеОбученияСУО.ЗапретитьОбщениеМеждуУчастниками КАК ЗапретитьОбщениеМеждуУчастниками,
	СоставыГруппПроведенийОбученияСУО.ГруппаПроведенийОбучения КАК ГруппаПроведенийОбучения,
	ВЫБОР
		КОГДА СоставыГруппПроведенийОбученияСУО.ГруппаПроведенийОбучения = &amp;ГруппаПроведенийОбучения
				ИЛИ &amp;ПоказатьВсеПроведения
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ВходитВГруппу,
	ДокументПроведениеОбученияСУО.ГруппаСлушателей КАК ГруппаСлушателей,
	ДокументПроведениеОбученияСУО.ПрограммаОбучения КАК ПрограммаОбучения,
	ДокументПроведениеОбученияСУО.АктивироватьАвтоматически КАК АктивироватьАвтоматически
ИЗ
	Документ.ПроведениеОбученияСУО КАК ДокументПроведениеОбученияСУО
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО
		ПО (ПроведениеОбученияСУО.Регистратор = ДокументПроведениеОбученияСУО.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СоставыГруппПроведенийОбученияСУО КАК СоставыГруппПроведенийОбученияСУО
		ПО (СоставыГруппПроведенийОбученияСУО.ПроведениеОбучения = ДокументПроведениеОбученияСУО.Ссылка)
			И (СоставыГруппПроведенийОбученияСУО.ГруппаПроведенийОбучения = &amp;ГруппаПроведенийОбучения)</queryText>
      <mainTable>Document.ПроведениеОбученияСУО</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>

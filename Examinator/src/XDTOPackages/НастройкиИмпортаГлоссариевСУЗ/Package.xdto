<package xmlns="http://v8.1c.ru/8.1/xdto" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://v8.1c.ru/kms/1/ImportGlossarySettings">
	<import namespace="http://v8.1c.ru/8.1/data/enterprise/current-config"/>
	<import namespace="http://v8.1c.ru/8.1/data/core"/>
	<objectType name="Файлы">
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/ImportGlossarySettings" name="Файл" type="d3p1:Файл" lowerBound="0" upperBound="-1"/>
	</objectType>
	<objectType name="Файл">
		<property name="Имя" type="xs:string"/>
		<property name="СформироватьГлоссарии" type="xs:boolean" lowerBound="0"/>
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/ImportGlossarySettings" name="Колонки" type="d3p1:Колонки"/>
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/ImportGlossarySettings" name="Листы" type="d3p1:Листы" lowerBound="0"/>
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/ImportGlossarySettings" name="Термины" type="d3p1:Термины" lowerBound="0"/>
	</objectType>
	<objectType name="Колонки">
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/ImportGlossarySettings" name="Колонка" type="d3p1:Колонка" lowerBound="0" upperBound="-1"/>
	</objectType>
	<objectType name="Колонка">
		<property name="Имя" type="xs:string"/>
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/enterprise/current-config" name="Значение" type="d3p1:EnumRef.ПеременныеТерминовСУЗ"/>
	</objectType>
	<objectType name="Листы">
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/ImportGlossarySettings" name="Лист" type="d3p1:Лист" lowerBound="0" upperBound="-1"/>
	</objectType>
	<objectType name="Лист">
		<property name="Номер" type="xs:integer"/>
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/enterprise/current-config" name="Глоссарий" type="d3p1:CatalogRef.ГлоссарииСУЗ"/>
		<property name="Скрыть" type="xs:boolean" lowerBound="0"/>
	</objectType>
	<objectType name="Термины">
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/ImportGlossarySettings" name="Термин" type="d3p1:Термин" lowerBound="0" upperBound="-1"/>
	</objectType>
	<objectType name="Термин">
		<property name="Наименование" type="xs:string"/>
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/enterprise/current-config" name="Термин" type="d3p1:CatalogRef.ТерминыСУЗ"/>
	</objectType>
</package>
// Данные для расширения

&НаСервереБезКонтекста
Функция ДанныеДляДополнения(ЭлектронныйРесурс)
	
	СтруктураДанных = Новый Структура("Items, hiddenRes", Новый Массив, Новый Массив);
	
	// Элементы содержания
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СодержаниеСУЗ.Ссылка КАК Ссылка,
		|	СодержаниеСУЗ.СсылкаНаЭлемент КАК СсылкаНаЭлемент,
		|	СодержаниеСУЗ.Наименование,
		|	СодержаниеСУЗ.ЭтоГруппа,
		|	СодержаниеСУЗ.Карта,
		|	СодержаниеСУЗ.Родитель,
		|	СодержаниеСУЗ.Владелец КАК ЭлектронныйРесурс
		|ИЗ
		|	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
		|ГДЕ
		|	СодержаниеСУЗ.Владелец = &ЭлектронныйРесурс
		|	И СодержаниеСУЗ.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	СодержаниеСУЗ.Код ИЕРАРХИЯ";

	Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);

	Результат = Запрос.Выполнить();

	ДеревоЭлементовСодержания = Результат.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	ДобавитьЭлементСодержанияВСписок(СтруктураДанных.Items, ДеревоЭлементовСодержания.Строки);
	
	// Скрытые ресурсы
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СводыЗнанийСУЗСкрытыеРесурсы.Ресурс
		|ИЗ
		|	Справочник.СводыЗнанийСУЗ.СкрытыеРесурсы КАК СводыЗнанийСУЗСкрытыеРесурсы
		|ГДЕ
		|	СводыЗнанийСУЗСкрытыеРесурсы.Ссылка = &ЭлектронныйРесурс
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки";
		
	Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);
		
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		РесурсДляПросмотра = Справочники.СводыЗнанийСУЗ.СкрытыйРесурсДляПросмотра(ВыборкаДетальныеЗаписи.Ресурс);
		РесурсДляРедактирования = Справочники.СводыЗнанийСУЗ.СкрытыйРесурсДляРедактирования(ВыборкаДетальныеЗаписи.Ресурс);
		ТипРесурсаДляРедактирования = Справочники.СводыЗнанийСУЗ.ТипСкрытогоРесурсаДляРедактирования(РесурсДляРедактирования);
		
		ОписаниеЭлемента = Новый Структура(
			"ID, NAME, TYPE",
			ОбъектыСУЗПовтИсп.СсылкаНаОбъектСУЗ(РесурсДляПросмотра, ""),
			ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РесурсДляРедактирования, "Наименование"),
			ТипРесурсаДляРедактирования
		);
		
		СтруктураДанных.hiddenRes.Добавить(ОписаниеЭлемента);
		
	КонецЦикла;

	
	Возврат СтруктураДанных;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ДобавитьЭлементСодержанияВСписок(МассивЭлементов, СтрокиДерева)
	
	Если СтрокиДерева.Количество() > 0 Тогда
			
		Для каждого Строка Из СтрокиДерева Цикл
			
			Если Строка.ЭтоГруппа Тогда
				СсылкаНаЭлемент = ОбъектыСУЗПовтИсп.СсылкаНаОбъектСУЗ(Строка.Ссылка, "");
			Иначе
				СсылкаНаЭлемент = ОбъектыСУЗПовтИсп.СсылкаНаОбъектСУЗ(Строка.СсылкаНаЭлемент, "");
			КонецЕсли;
			
			ОписаниеЭлемента = Новый Структура("ID, NAME, ITEMS", СсылкаНаЭлемент, Строка.Наименование, Новый Массив);
			
			Если Строка.ЭтоГруппа Тогда
				ДобавитьЭлементСодержанияВСписок(ОписаниеЭлемента.ITEMS, Строка.Строки)
			КонецЕсли;
			
			МассивЭлементов.Добавить(ОписаниеЭлемента);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры



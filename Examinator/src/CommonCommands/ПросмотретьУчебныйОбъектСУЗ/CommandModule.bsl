
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	Если ТипЗнч(ПараметрКоманды) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда
		ОбъектыСУЗКлиент.ОткрытьОбозреватель(ПараметрКоманды);
	Иначе
		ОбъектыСУЗКлиент.ОткрытьОбозреватель(,ПараметрКоманды, Истина);
	КонецЕсли;
		
КонецПроцедуры

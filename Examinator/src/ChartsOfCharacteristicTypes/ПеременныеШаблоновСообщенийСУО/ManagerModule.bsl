Функция ПодсказкаКПеременной(Переменная, ТаблицаПодсказок = Неопределено) Экспорт
	
	Если ТаблицаПодсказок = Неопределено Тогда
		ТаблицаПодсказок = ТаблицаПодсказок();
	КонецЕсли;
	
	НайденнаяСтрока = ТаблицаПодсказок.Найти(Переменная, "Переменная");
	
	Если НайденнаяСтрока = Неопределено Тогда
		Возврат "";
	Иначе
		Возврат НайденнаяСтрока.Подсказка;
	КонецЕсли;
	
КонецФункции

Функция КодПеременной(Переменная) Экспорт
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Переменная, "Код");
КонецФункции

Функция ТаблицаПеременныхАвтоматическойРассылки(ТипАвтоматическойРассылки) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПеременныеШаблоновСообщенийСУО.Ссылка КАК Переменная,
		|	ПеременныеШаблоновСообщенийСУО.Код
		|ИЗ
		|	ПланВидовХарактеристик.ПеременныеШаблоновСообщенийСУО КАК ПеременныеШаблоновСообщенийСУО";
	
	ТаблицаДанных = Запрос.Выполнить().Выгрузить();
	
	ТаблицаПодсказок = ТаблицаПодсказок();
	
	ТаблицаПеременных = Новый ТаблицаЗначений;
	ТаблицаПеременных.Колонки.Добавить("Переменная");
	ТаблицаПеременных.Колонки.Добавить("Код");
	ТаблицаПеременных.Колонки.Добавить("Подсказка");	
	
	РасширеннаяФункциональность = ПолучитьФункциональнуюОпцию("РасширеннаяФункциональностьСУО");
	ПолныйИнтерфейс = ПолучитьФункциональнуюОпцию("ПолныйИнтерфейсСУО");
	
	Если ТипАвтоматическойРассылки = Перечисления.ТипыАвтоматическихРассылокСУО.ВажнаяНовость Тогда
		// Не требуется
	КонецЕсли;
	
	Если ТипАвтоматическойРассылки = Перечисления.ТипыАвтоматическихРассылокСУО.ВосстановлениеПароля Тогда
		ЗаполнитьСтрокуТаблицыПеременных(ПланыВидовХарактеристик.ПеременныеШаблоновСообщенийСУО.Пользователь, ТаблицаПеременных, ТаблицаДанных, ТаблицаПодсказок);
		ЗаполнитьСтрокуТаблицыПеременных(ПланыВидовХарактеристик.ПеременныеШаблоновСообщенийСУО.УчебнаяГруппа, ТаблицаПеременных, ТаблицаДанных, ТаблицаПодсказок);		
		ЗаполнитьСтрокуТаблицыПеременных(ПланыВидовХарактеристик.ПеременныеШаблоновСообщенийСУО.АдресДляПерехода, ТаблицаПеременных, ТаблицаДанных, ТаблицаПодсказок);
		ЗаполнитьСтрокуТаблицыПеременных(ПланыВидовХарактеристик.ПеременныеШаблоновСообщенийСУО.КодПодтверждения, ТаблицаПеременных, ТаблицаДанных, ТаблицаПодсказок);
	КонецЕсли;
	
	Если ТипАвтоматическойРассылки = Перечисления.ТипыАвтоматическихРассылокСУО.КонтрольНепрочитанныхЛичныхСообщений Тогда
		ЗаполнитьСтрокуТаблицыПеременных(ПланыВидовХарактеристик.ПеременныеШаблоновСообщенийСУО.Пользователь, ТаблицаПеременных, ТаблицаДанных, ТаблицаПодсказок);
		ЗаполнитьСтрокуТаблицыПеременных(ПланыВидовХарактеристик.ПеременныеШаблоновСообщенийСУО.УчебнаяГруппа, ТаблицаПеременных, ТаблицаДанных, ТаблицаПодсказок);				
		ЗаполнитьСтрокуТаблицыПеременных(ПланыВидовХарактеристик.ПеременныеШаблоновСообщенийСУО.КоличествоСообщений, ТаблицаПеременных, ТаблицаДанных, ТаблицаПодсказок);
	КонецЕсли;
	
	Если ТипАвтоматическойРассылки = Перечисления.ТипыАвтоматическихРассылокСУО.КонтрольНепрочитанныхТемФорума Тогда
		ЗаполнитьСтрокуТаблицыПеременных(ПланыВидовХарактеристик.ПеременныеШаблоновСообщенийСУО.Пользователь, ТаблицаПеременных, ТаблицаДанных, ТаблицаПодсказок);
		ЗаполнитьСтрокуТаблицыПеременных(ПланыВидовХарактеристик.ПеременныеШаблоновСообщенийСУО.УчебнаяГруппа, ТаблицаПеременных, ТаблицаДанных, ТаблицаПодсказок);		
	КонецЕсли;
	

		"Преподаватель",
		ВидСравненияКомпоновкиДанных.Равно,
		ДанныеСессии.Пользователь,
		Неопределено,
		Истина,
		РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный);	
		
	РезультатФормирования = ВариантыОтчетов.СформироватьОтчет(ПараметрыОтчета, Ложь, Ложь);		
	
	Если НЕ РезультатФормирования.Успех Тогда
		Возврат ОтветКлиентуJSON("errorData", Новый Структура("description", РезультатФормирования.ТекстОшибки));
	КонецЕсли;
	
	ИмяФайлаБезРасширения = Строка(ДанныеСессии.Пользователь) + "_" + Формат(ТекущаяДатаСеанса(), "ДФ=yyyy-MM-dd");
	

// Выполняет обновление до версии 3.0.11.116
//
Процедура ВыполнитьОбновлениеДоВерсии3011116() Экспорт
			
	// Заполняем реквизиты ДатаНачалаОбучения и ДатаОкончанияОбучения
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрохождениеОбученияСУО.Ссылка КАК Ссылка,
		|	ПрохождениеОбученияСУО.ДатаПоследнейАктивности КАК ДатаПоследнейАктивности,
		|	ПрохождениеОбученияСУО.ДатаОкончанияПрохождения КАК ДатаОкончанияПрохождения,
		|	ПрохождениеОбученияСУО.ДатаИзменения КАК ДатаИзменения,
		|	ПрохождениеОбученияСУО.ДатаНачалаПрохождения КАК ДатаНачалаПрохождения,
		|	ПрохождениеОбученияСУО.Дата КАК Дата,
		|	ПрохождениеОбученияСУО.Статус КАК Статус
		|ИЗ
		|	Документ.ПрохождениеОбученияСУО КАК ПрохождениеОбученияСУО
		|ГДЕ
		|	ПрохождениеОбученияСУО.ДатаОкончанияОбучения = &ПустаяДата
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПрохождениеОбученияСУО.Ссылка,
		|	ПрохождениеОбученияСУО.ДатаПоследнейАктивности,
		|	ПрохождениеОбученияСУО.ДатаОкончанияПрохождения,
		|	ПрохождениеОбученияСУО.ДатаИзменения,
		|	ПрохождениеОбученияСУО.ДатаНачалаПрохождения,
		|	ПрохождениеОбученияСУО.Дата,
		|	ПрохождениеОбученияСУО.Статус
		|ИЗ
		|	Документ.ПрохождениеОбученияСУО КАК ПрохождениеОбученияСУО
		|ГДЕ
		|	ПрохождениеОбученияСУО.ДатаНачалаОбучения = &ПустаяДата";
	
	Запрос.УстановитьПараметр("ПустаяДата", Дата("00010101"));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ПрохождениеОбученияОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		
		Если НЕ ЗначениеЗаполнено(ПрохождениеОбученияОбъект.ДатаНачалаОбучения) Тогда
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ДатаНачалаПрохождения) Тогда
				ПрохождениеОбученияОбъект.ДатаНачалаОбучения = ВыборкаДетальныеЗаписи.ДатаНачалаПрохождения;
			Иначе
				ПрохождениеОбученияОбъект.ДатаНачалаОбучения = ВыборкаДетальныеЗаписи.Дата;
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ПрохождениеОбученияОбъект.ДатаОкончанияОбучения)
			И Документы.ПрохождениеОбученияСУО.Пройдено(ВыборкаДетальныеЗаписи.Статус) Тогда
			
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ДатаОкончанияПрохождения) Тогда
				ПрохождениеОбученияОбъект.ДатаОкончанияОбучения = ВыборкаДетальныеЗаписи.ДатаОкончанияПрохождения;	
			ИначеЕсли ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ДатаПоследнейАктивности) Тогда
				ПрохождениеОбученияОбъект.ДатаОкончанияОбучения = ВыборкаДетальныеЗаписи.ДатаПоследнейАктивности;
			Иначе
				ПрохождениеОбученияОбъект.ДатаОкончанияОбучения = ВыборкаДетальныеЗаписи.ДатаИзменения;
			КонецЕсли;
			
		КонецЕсли;
			
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(ПрохождениеОбученияОбъект);
		
	КонецЦикла;
	
КонецПроцедуры


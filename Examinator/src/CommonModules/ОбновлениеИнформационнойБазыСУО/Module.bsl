	// Заполняем реквизит ЭлектронныйРесурс регистра ИмпортированныеЭлементыПакетаSCORM
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИмпортированныеЭлементыПакетаSCORM.СсылкаНаЭлемент,
		|	ИмпортированныеЭлементыПакетаSCORM.ИдентификаторПакета
		|ИЗ

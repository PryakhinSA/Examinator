		<property xmlns:d3p1="http://v8.1c.ru/kms/1/SCORM/DataModel" name="objectives" type="d3p1:objectives" lowerBound="0" upperBound="-1"/>
		<property name="progress_measure" type="xs:string" lowerBound="0"/>
		<property name="scaled_passing_score" type="xs:string" lowerBound="0"/>
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/SCORM/DataModel" name="score" type="d3p1:score" lowerBound="0"/>
		<property name="session_time" type="xs:string" lowerBound="0"/>
		<property name="success_status" type="xs:string" lowerBound="0"/>
		<property name="suspend_data" type="xs:string" lowerBound="0"/>
		<property name="time_limit_action" type="xs:string" lowerBound="0"/>

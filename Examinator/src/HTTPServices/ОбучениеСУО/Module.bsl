	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Обучение");
	ПраваДляПроверки.Добавить("Преподавание");
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные запроса
	//	
	
	ИдентификаторПроведенияОбучения = Запрос.ПараметрыURL.Получить("ПроведениеОбучения");
		
	Попытка
		ПроведениеОбучения = Документы.ПроведениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторПроведенияОбучения));
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;	

	ДанныеДляЗаписиJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если НЕ ЗначениеЗаполнено(ДанныеДляЗаписиJSON) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Попытка
		ДанныеДляЗаписи = ОбщегоНазначенияСУ.JSONВДанные(ДанныеДляЗаписиJSON);
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;
	
	// Делаем проверку возможности подать заявку
	//
		
	Если Документы.ЗаявкаНаОбучениеСУО.МожноПодатьЗаявку(ПроведениеОбучения, ДанныеСессии.Пользователь) Тогда
		
		НачатьТранзакцию();
		
		Попытка
			
			ТекстЗаявки = ?(ДанныеДляЗаписи.Свойство("text"), ДанныеДляЗаписи.text, "");
		
			ЗаявкаНаОбучение = ОбучениеСУО.ПодатьЗаявкуНаОбучение(ПроведениеОбучения, ДанныеСессии.Пользователь, ТекстЗаявки, Истина);
			
			Если ДанныеДляЗаписи.Свойство("additionalInfo") И ТипЗнч(ДанныеДляЗаписи.additionalInfo) = Тип("Массив") И ДанныеДляЗаписи.additionalInfo.Количество() > 0 Тогда
				УправлениеСвойствами.ЗаписатьСвойстваУОбъекта(ЗаявкаНаОбучение, СформироватьТаблицуДополнительныхСвойств(ДанныеДляЗаписи.additionalInfo));
			КонецЕсли;
			
			ВебКабинетСУ.ОбновитьДанныеОбъекта(ОбщегоНазначения.МенеджерОбъектаПоСсылке(ЗаявкаНаОбучение), ЗаявкаНаОбучение);
			
			ЗафиксироватьТранзакцию();
		
		Исключение
		
		 	ОтменитьТранзакцию();
			ВызватьИсключение;
			
		КонецПопытки;
		
	Иначе
		
		Возврат ОтветКлиентуJSON("applicationNewError");
		
	КонецЕсли;
	
	// Возвращаем результат
	//
	
	Возврат ОтветКлиентуJSON(, Новый Структура("Заявка", ЗаявкаНаОбучение));
	

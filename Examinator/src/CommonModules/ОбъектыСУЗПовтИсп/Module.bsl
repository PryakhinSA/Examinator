
////////////////////////////////////////////////////////////////////////////////
// ОБЪЕКТЫ

Функция ПолучитьПредставление(Ссылка, ПараметрыСсылки, КонтекстВыполнения) Экспорт
	Возврат ОбъектыСУЗ.ПолучитьПредставление(Ссылка, ПараметрыСсылки, КонтекстВыполнения);
КонецФункции

Функция ОбъектМожноПолучитьИзКэша(ИмяОбъекта, Ссылка) Экспорт
	
	Если ИмяОбъекта = "collection" Тогда
		
		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ЭтоТест") Тогда
			Возврат Ложь;
		Иначе
			Возврат Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ИмяОбъекта = "file" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ИмяОбъекта = "frame" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ИмяОбъекта = "glossary" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ИмяОбъекта = "knowledgeBase" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ИмяОбъекта = "map" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ИмяОбъекта = "page" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ИмяОбъекта = "question" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ИмяОбъекта = "res" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ИмяОбъекта = "search" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ИмяОбъекта = "term" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ТерминыГлоссария(Глоссарий, ПолучатьОпределение, Дата=Неопределено) Экспорт
	
	// Примечание: параметр Дата нужен для того, чтобы
	// Функция использовалась повторно только, пока открыта
	// Форма обозревателя. При повторном открытии формы, термины
	// Будут обновлены.
	
	Возврат Справочники.ГлоссарииСУЗ.Термины(Глоссарий, ПолучатьОпределение);
	
КонецФункции

Функция ИспользуютсяОграниченияНаДоступКЭлектроннымКурсам() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);

	Если НЕ УправлениеДоступом.ОграничиватьДоступНаУровнеЗаписей() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПрофилиГруппДоступаВидыДоступа.Ссылка
		|ИЗ
		|	Справочник.ПрофилиГруппДоступа.ВидыДоступа КАК ПрофилиГруппДоступаВидыДоступа
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(ПрофилиГруппДоступаВидыДоступа.ВидДоступа) = ТИП(Справочник.СводыЗнанийСУЗ)";
	
	Возврат НЕ Запрос.Выполнить().Пустой();	
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// МОДУЛИ ОБЪЕКТОВ

Функция МодульПоИмени(ИмяМодуля) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем каталог файлов модуля
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ФайлыСУЗ.Ссылка
		|ИЗ
		|	Справочник.ФайлыСУЗ КАК ФайлыСУЗ
		|ГДЕ
		|	ФайлыСУЗ.Владелец = ЗНАЧЕНИЕ(Справочник.РесурсыСУЗ.Модули)
		|	И ФайлыСУЗ.ЭтоГруппа = ИСТИНА
		|	И ФайлыСУЗ.Родитель = ЗНАЧЕНИЕ(Справочник.ФайлыСУЗ.ПустаяСсылка)
		|	И ФайлыСУЗ.ПометкаУдаления = ЛОЖЬ
		|	И ФайлыСУЗ.Наименование = &ИмяМодуля";

	Запрос.УстановитьПараметр("ИмяМодуля", ИмяМодуля);
		
	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Если ВыборкаДетальныеЗаписи.Количество() = 1 Тогда
		
		ВыборкаДетальныеЗаписи.Следующий();
		
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
		
	КонецЕсли;	
	
	Возврат Неопределено;
	
КонецФункции

Функция ФайлыМодуля(Знач Модуль, Дата) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Примечание: параметр Дата нужен для того, чтобы
	// Функция использовалась повторно только, пока открыта
	// Форма обозревателя. При повторном открытии формы,
	// Файлы модуля будут обновлены.
	
	Если ТипЗнч(Модуль) = Тип("Строка") Тогда
		Модуль = МодульПоИмени(Модуль);		
	КонецЕсли;
	
	ФайлыМодуля = Новый Массив();
	
	Если ЗначениеЗаполнено(Модуль) Тогда 
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ФайлыСУЗ.Ссылка,
			|	ФайлыСУЗ.ИмяФайла
			|ИЗ
			|	Справочник.ФайлыСУЗ КАК ФайлыСУЗ
			|ГДЕ
			|	ФайлыСУЗ.Ссылка В ИЕРАРХИИ(&КаталогМодуля)
			|	И ФайлыСУЗ.ЭтоГруппа = ЛОЖЬ
			|	И ФайлыСУЗ.ПометкаУдаления = ЛОЖЬ";

		Запрос.УстановитьПараметр("КаталогМодуля", Модуль);

		Результат = Запрос.Выполнить();

		ВыборкаДетальныеЗаписи = Результат.Выбрать();

		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ДанныеФайла = Новый Структура("Ссылка, ОтносительныйПуть, Расширение", ВыборкаДетальныеЗаписи.Ссылка, Справочники.ФайлыСУЗ.ПолучитьОтносительныйПутьКФайлу(ВыборкаДетальныеЗаписи.Ссылка), ОбщегоНазначенияСУКлиентСервер.РасширениеИмениФайла(ВыборкаДетальныеЗаписи.ИмяФайла));
			
			ФайлыМодуля.Добавить(ДанныеФайла);
			
		КонецЦикла;

	КонецЕсли;

	Возврат ФайлыМодуля;	
	
КонецФункции


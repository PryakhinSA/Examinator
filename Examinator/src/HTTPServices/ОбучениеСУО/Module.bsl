	Возврат ОтветКлиентуJSON(, РезультатОтмены);
	
КонецФункции

Функция ПолучитьОписаниеВыполненияЗаданияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
		
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Обучение");
	ПраваДляПроверки.Добавить("Преподавание");
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные
	//	
	
	Попытка
		ИдентификаторПрохожденияОбучения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ПрохождениеОбучения"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторПрохожденияОбучения) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	ПрохождениеОбучения = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(ИдентификаторПрохожденияОбучения);
	
	Попытка
		ИдентификаторЗадания = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("Задание"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторЗадания) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Задание = Справочники.ЗаданияСУО.ПолучитьСсылку(ИдентификаторЗадания);
	
	ПерваяЗагрузка = Ложь;
	ЭтоПроверкаПреподавателем = Неопределено;
	
	ДанныеДляЗаписиJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если ЗначениеЗаполнено(ДанныеДляЗаписиJSON) Тогда
		
		Попытка
			ДанныеДляЗаписи = ОбщегоНазначенияСУ.JSONВДанные(ДанныеДляЗаписиJSON);
		Исключение
		КонецПопытки;
		
		Если ТипЗнч(ДанныеДляЗаписи) = Тип("Структура")
			И ДанныеДляЗаписи.Свойство("firstLoad")
			И ОбщегоНазначенияСУКлиентСервер.СтрокаВБулево(ДанныеДляЗаписи.firstLoad) Тогда
			
			ПерваяЗагрузка = Истина;
			
		КонецЕсли;
		
		Если ТипЗнч(ДанныеДляЗаписи) = Тип("Структура")
			И ДанныеДляЗаписи.Свойство("typeActivity") Тогда
			
			ЭтоПроверкаПреподавателем = ?(ДанныеДляЗаписи.typeActivity = "check" ИЛИ ДанныеДляЗаписи.typeActivity = "teaching", Истина, Ложь);
			
		КонецЕсли;
		
	КонецЕсли;
	
	ПопыткаВыполненияЗадания = ОбучениеСУО.ПоследнееПрохождениеЗадания(ПрохождениеОбучения, Задание);
	
	Если ПерваяЗагрузка И НЕ ЗначениеЗаполнено(ПопыткаВыполненияЗадания) Тогда
		
		// Когда выполняется загрузка карточки следует
		// вызывать событие ПриПрохожденииЗадания, чтобы
		// создать прохождение, если его нет.
		// В других случаях, когда надо получить свежие
		// данные данные карточки это событие не вызываем.
		
		// Событие владельца не вызываем. Это будет сделано при
		// завершении задания.
		
		// Выполняем действия при выполнении задания
		
		ОписаниеПрохождения = ОбучениеСУО.ПриПрохожденииЗадания(ПрохождениеОбучения, Задание,,,Ложь,,,Истина);
		
		// Делаем дополнительные проверки прав
		
		Если ОписаниеПрохождения.Пользователь <> ДанныеСессии.Пользователь Тогда
			
			Права = ДанныеСессии.Права.Получить();
		
			Если НЕ Права.Свойство("Преподавание") ИЛИ НЕ Права.Преподавание Тогда
				Возврат ОтветКлиентуJSON("noPermissions");
			КонецЕсли;		
			
		КонецЕсли;	
		
		// Обновляем данные веб-кабинета после транзакции
		
		ВебКабинетСУ.ОбновитьДанныеОбъекта(Документы.ПопыткаВыполненияЗаданияСУО, ОписаниеПрохождения.ПопыткаВыполненияЗадания);
		
		ПопыткаВыполненияЗадания = ОписаниеПрохождения.ПопыткаВыполненияЗадания;
		ПользовательЗадания = ОписаниеПрохождения.Пользователь;
		ПроверенПреподавателем = Ложь;
		
	Иначе		
		
		ДанныеПопыткиЗадания = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПопыткаВыполненияЗадания, Новый Структура("ПользовательЗадания, ПроверенПреподавателем", "ПрохождениеОбучения.Пользователь", "ПроверенПреподавателем"));
		
		ПользовательЗадания = ДанныеПопыткиЗадания.ПользовательЗадания;
		ПроверенПреподавателем = ДанныеПопыткиЗадания.ПроверенПреподавателем;
		
	КонецЕсли;
	
	Если ЭтоПроверкаПреподавателем = Истина И НЕ ПроверенПреподавателем Тогда
		
		// Записываем преподавателя, который проверяет задание
		
		Попытка
			ОписаниеПрохождения = ОбучениеСУО.ПриПрохожденииЗадания(ПрохождениеОбучения, Задание,,,Ложь,,,Истина,,,,,,ДанныеСессии.Пользователь);
		Исключение
			// Это не очень важная функция, поэтому исключений не выбрасываем
			ЗаписьЖурналаРегистрации(
				НСТр("ru = 'Веб-кабинет. При начале проверки задания'"),
				УровеньЖурналаРегистрации.Ошибка,
				,
				ПрохождениеОбучения,
				НСТр("ru = 'Не удалось указать проверяющего преподавателя. '") + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));			
		КонецПопытки;
		
		Попытка
			ВебКабинетСУ.ОбновитьДанныеОбъекта(Документы.ПопыткаВыполненияЗаданияСУО, ПопыткаВыполненияЗадания);
		Исключение
			// Это не очень важная функция, поэтому исключений не выбрасываем
			ЗаписьЖурналаРегистрации(
				НСТр("ru = 'Веб-кабинет. При начале проверки задания'"),
				УровеньЖурналаРегистрации.Ошибка,
				,
				ПрохождениеОбучения,
				НСТр("ru = 'Не удалось обновить данные при начале проверки задания. '") + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));						
		КонецПопытки;			
		
	КонецЕсли;
	
	ЗапросДанных = Новый Запрос;
	ЗапросДанных.Текст = 
		"ВЫБРАТЬ
		|	ДанныеВебКабинетаСУО.Данные КАК data
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО
		|ГДЕ
		|	ДанныеВебКабинетаСУО.Пользователь = &Пользователь
		|	И ДанныеВебКабинетаСУО.Тип = &Тип
		|	И ДанныеВебКабинетаСУО.Объект = &Объект";
	
	ЗапросДанных.УстановитьПараметр("Объект", ПопыткаВыполненияЗадания);
	ЗапросДанных.УстановитьПараметр("Пользователь", ПользовательЗадания);
	ЗапросДанных.УстановитьПараметр("Тип", Перечисления.ТипыДанныхВебКабинетаСУО.ВыполнениеЗаданияОписание);
	
	РезультатЗапроса = ЗапросДанных.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		Возврат ОтветКлиентуJSON("errorData");
		
	Иначе
		
		Возврат ОтветКлиентуJSON(,РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("data")[0]);
		
	КонецЕсли;

КонецФункции


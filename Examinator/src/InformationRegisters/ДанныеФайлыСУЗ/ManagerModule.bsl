#Если Сервер ИЛИ ТолстыйКлиентОбычноеПриложение ИЛИ ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции

Функция ПрисоединенныйФайлЗаписи(СсылкаНаЭлемент, Поставщик, Версия, КодДанных) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеФайлов.ПрисоединенныйФайл КАК ПрисоединенныйФайл
		|ИЗ
		|	РегистрСведений.ДанныеФайлыСУЗ КАК ДанныеФайлов
		|ГДЕ
		|	ДанныеФайлов.СсылкаНаОбъектСУЗ = &СсылкаНаЭлементКурса
		|	И ДанныеФайлов.Поставщик = &Поставщик
		|	И ДанныеФайлов.Версия = &Версия
		|	И ДанныеФайлов.КодДанных = &КодДанных";
	
	Запрос.УстановитьПараметр("Версия", Версия);
	Запрос.УстановитьПараметр("КодДанных", КодДанных);
	Запрос.УстановитьПараметр("Поставщик", Поставщик);
	Запрос.УстановитьПараметр("СсылкаНаЭлементКурса", СсылкаНаЭлемент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		Возврат Неопределено;
		
	Иначе
	
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
		ВыборкаДетальныеЗаписи.Следующий();
		
		Возврат ВыборкаДетальныеЗаписи.ПрисоединенныйФайл;
		
	КонецЕсли;
	
	
КонецФункции

Функция АдресХраненияДвоичныхДанных(СсылкаНаЭлемент, Поставщик, Версия, КодДанных, ИдентификаторФормы = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеФайлов.ПрисоединенныйФайл КАК ПрисоединенныйФайл
		|ИЗ
		|	РегистрСведений.ДанныеФайлыСУЗ КАК ДанныеФайлов
		|ГДЕ
		|	ДанныеФайлов.СсылкаНаОбъектСУЗ = &СсылкаНаЭлементКурса
		|	И ДанныеФайлов.Поставщик = &Поставщик
		|	И ДанныеФайлов.Версия = &Версия
		|	И ДанныеФайлов.КодДанных = &КодДанных";
	
	Запрос.УстановитьПараметр("Версия", Версия);
	Запрос.УстановитьПараметр("КодДанных", КодДанных);
	Запрос.УстановитьПараметр("Поставщик", Поставщик);
	Запрос.УстановитьПараметр("СсылкаНаЭлементКурса", СсылкаНаЭлемент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		Возврат Неопределено;
		
	Иначе
	
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
		ВыборкаДетальныеЗаписи.Следующий();
		
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ПрисоединенныйФайл) Тогда
			
			ДанныеФайла = ПрисоединенныеФайлы.ПолучитьДанныеФайла(ВыборкаДетальныеЗаписи.ПрисоединенныйФайл, ИдентификаторФормы, Истина); 
				
			Возврат ДанныеФайла.СсылкаНаДвоичныеДанныеФайла;				
				
		Иначе
			
			КлючЗаписи = РегистрыСведений.ДанныеФайлыСУЗ.СоздатьКлючЗаписи(
				Новый Структура("СсылкаНаОбъектСУЗ, Поставщик, Версия, КодДанных", СсылкаНаЭлемент, Поставщик, Версия, КодДанных)
			);
			
			Возврат ПолучитьНавигационнуюСсылку(КлючЗаписи, "ДвоичныеДанные");			
			
		КонецЕсли;
		
		
	КонецЕсли;
	
	
КонецФункции

Функция ДанныеФайловРазмещенныеВБСП() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеФайлов.СсылкаНаОбъектСУЗ КАК СсылкаНаЭлементКурса,
		|	ДанныеФайлов.Поставщик КАК Поставщик,
		|	ДанныеФайлов.Версия КАК Версия,
		|	ДанныеФайлов.КодДанных КАК КодДанных,
		|	ДанныеФайлов.СсылкаНаОбъектСУЗ.ИмяФайла КАК ИмяФайла,
		|	ДанныеФайлов.СсылкаНаОбъектСУЗ.ДатаИзменения КАК ДатаИзменения
		|ИЗ
		|	РегистрСведений.ДанныеФайлыСУЗ КАК ДанныеФайлов
		|ГДЕ
		|	ДанныеФайлов.ПрисоединенныйФайл <> &ПрисоединенныйФайлПустаяСсылка";
	
	Запрос.УстановитьПараметр("ПрисоединенныйФайлПустаяСсылка", Справочники.ФайлыСУЗПрисоединенныеФайлы.ПустаяСсылка());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выбрать();
	
КонецФункции


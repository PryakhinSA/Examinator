			<c>
				<i>1</i>
				<c>
					<f>4</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Новое в сборке 3.0.14.15</v8:content>
						</v8:item>
					</tl>

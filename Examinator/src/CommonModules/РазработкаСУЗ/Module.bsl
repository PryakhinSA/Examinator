// Получает таблицу доступности данных поставщика
//
Функция ПолучитьТаблицуДоступностиДанныхПоставщика() Экспорт
	
	ТаблицаДоступностиДанныхПоставщика = Новый ТаблицаЗначений();
	ТаблицаДоступностиДанныхПоставщика.Колонки.Добавить("ЭлементФормы");
	ТаблицаДоступностиДанныхПоставщика.Колонки.Добавить("Свойство");
	ТаблицаДоступностиДанныхПоставщика.Колонки.Добавить("Значение");
	ТаблицаДоступностиДанныхПоставщика.Колонки.Добавить("Выполнить");
	
	Возврат ТаблицаДоступностиДанныхПоставщика;
	
КонецФункции

Функция ПолучитьПредпочитаемогоПоставщика() Экспорт
	
	Если Константы.ПоказыватьПоследнююВерсиюСУЗ.Получить() Тогда
		Возврат Константы.ПредпочитатьПоставщикаСУЗ.Получить();
	Иначе
		Возврат Справочники.ПоставщикиСУЗ.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

// Устанавливает доступность элементов формы, которые
// запрещено редактировать, так как они созданы сторонним поставщиком.
//
Процедура УстановитьДоступностьДанныхОтПоставщика(Форма, ТаблицаДоступностиДанныхПоставщика = Неопределено, ЕстьВерсии = Ложь, ИмяРеквизитаСДанными = "Объект") Экспорт
	
	// Примечание: вызывается перед "ЗагрузитьВерсию()" и после "УстановитьДоступностьЭлементовФормы()"
	
	Если НЕ Константы.ПоказыватьПоследнююВерсиюСУЗ.Получить() Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ Константы.ИзменятьДанныеТолькоПредпочитаемогоПоставщикаСУЗ.Получить() Тогда
		Возврат;
	КонецЕсли;
	
	Если Форма[ИмяРеквизитаСДанными].Поставщик = Константы.ПредпочитатьПоставщикаСУЗ.Получить() Тогда
		Если ЕстьВерсии Тогда
			Если ОбъектыСУЗ.СуществуютВерсииДругихПоставщиков(Форма[ИмяРеквизитаСДанными].Ссылка, Форма[ИмяРеквизитаСДанными].Поставщик) Тогда
				ПолноеИзменениеДоступно = Ложь;
			Иначе
				ПолноеИзменениеДоступно = Истина;
			КонецЕсли;
		Иначе		
			ПолноеИзменениеДоступно = Истина;
		КонецЕсли;
	Иначе
		ПолноеИзменениеДоступно = Ложь;
	КонецЕсли;
	
	Если ПолноеИзменениеДоступно Тогда
		Возврат;
	КонецЕсли;
	
	// Делаем все не доступными
	
	Для каждого ЭлементФормы Из Форма.Элементы Цикл
		
		// Возможные типы элементов:
		// ГруппаФормы, ДекорацияФормы, КнопкаФормы, ТаблицаФормы, ПолеФормы,
		
		Если ТипЗнч(ЭлементФормы) = Тип("ГруппаФормы") Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(ЭлементФормы) = Тип("ДекорацияФормы") Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(ЭлементФормы) = Тип("КнопкаФормы") Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементФормы.ТолькоПросмотр = Истина;
				
	КонецЦикла;
	
	Если ТаблицаДоступностиДанныхПоставщика <> Неопределено Тогда
		
		Для каждого СтрокаТаблицы Из ТаблицаДоступностиДанныхПоставщика Цикл
			Если ЗначениеЗаполнено(СтрокаТаблицы["Значение"]) Тогда
				СтрокаТаблицы.ЭлементФормы[СтрокаТаблицы.Свойство] = СтрокаТаблицы["Значение"];
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

// Устанавливает предпочитаемого поставщика.
// Обычно используется при создании нового объекта
// СУЗ в форме элемента справочника.
//
// Параметры
//  ОбъектСУЗ  – Объект элемента справочника.
//
Процедура УстановитьПредпочитаемогоПоставщика(Объект) Экспорт
	
	// Если объект уже записан в базу, то выходим.
	
	Если ТипЗнч(Объект) = Тип("ДанныеФормыСтруктура") Тогда
		
		Если Объект.Свойство("Ссылка") И НЕ Объект.Ссылка.Пустая() Тогда
			Возврат;
		КонецЕсли;
		
		Если Объект.Свойство("ИсходныйКлючЗаписи") И НЕ Объект.ИсходныйКлючЗаписи.Пустой() Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;

	Объект.Поставщик = ПолучитьПредпочитаемогоПоставщика();

КонецПроцедуры // УстановитьПредпочитаемогоПоставщика()

Процедура ПереименоватьАвтоРодителей(Объект) Экспорт
	
	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ГруппыОбъектовСУЗ.Группа КАК Группа
		|ИЗ
		|	РегистрСведений.ГруппыОбъектовСУЗ КАК ГруппыОбъектовСУЗ
		|ГДЕ
		|	ГруппыОбъектовСУЗ.СсылкаНаОбъектСУЗ = &СсылкаНаОбъектСУЗ
		|	И ГруппыОбъектовСУЗ.Группа.Наименование <> &Наименование";
	
	Запрос.УстановитьПараметр("СсылкаНаОбъектСУЗ", Объект.Ссылка);
	Запрос.УстановитьПараметр("Наименование", Объект.Наименование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ГруппаОбъект = ВыборкаДетальныеЗаписи.Группа.ПолучитьОбъект();
		ГруппаОбъект.Наименование = Объект.Наименование;
		ГруппаОбъект.Записать();
		
	КонецЦикла;
		
КонецПроцедуры

// Процедура устанавливает реквизит "Родитель" для нового элемента.
//
Процедура УстановитьРодителяНовогоОбъекта(Объект, Параметры, ИмяСправочника) Экспорт
	
	Если НЕ Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Объект.Родитель) Тогда
		Возврат;
	КонецЕсли;
	
	Если Параметры.Свойство("Подборка") И ЗначениеЗаполнено(Параметры.Подборка) Тогда
		
		Если Параметры.Свойство("ЭлектронныйРесурс") И ЗначениеЗаполнено(Параметры.ЭлектронныйРесурс) Тогда
			Объект.Родитель = Справочники.ПодборкиСУЗ.ГруппаПодчиненныхЭлементов(Параметры.Подборка, ИмяСправочника, Параметры.ЭлектронныйРесурс);
		Иначе
			Объект.Родитель = Справочники.ПодборкиСУЗ.ГруппаПодчиненныхЭлементов(Параметры.Подборка, ИмяСправочника);
		КонецЕсли;
		
	ИначеЕсли Параметры.Свойство("ЭлектронныйРесурс") И ЗначениеЗаполнено(Параметры.ЭлектронныйРесурс) Тогда
		
		Объект.Родитель = Справочники.СводыЗнанийСУЗ.ГруппаДляХраненияПодчиненныхЭлементов(Параметры.ЭлектронныйРесурс, ИмяСправочника);
		
	ИначеЕсли Параметры.Свойство("Глоссарий") И ЗначениеЗаполнено(Параметры.Глоссарий) Тогда
		
		Если Параметры.Свойство("ЭлектронныйРесурс") И ЗначениеЗаполнено(Параметры.ЭлектронныйРесурс) Тогда
			Объект.Родитель = Справочники.ГлоссарииСУЗ.ГруппаПодчиненныхЭлементов(Параметры.Глоссарий, ИмяСправочника, Параметры.ЭлектронныйРесурс);
		Иначе
			Объект.Родитель = Справочники.ГлоссарииСУЗ.ГруппаПодчиненныхЭлементов(Параметры.Глоссарий, ИмяСправочника);
		КонецЕсли;		
		
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьДоступностьКомандРеквизитаСУЗ(Форма, ИмяРеквизита) Экспорт
	
	Если ЗначениеЗаполнено(Форма.Объект[ИмяРеквизита]) Тогда
		Форма.Элементы[ИмяРеквизита + "Создать"].Видимость = Ложь;
		Форма.Элементы[ИмяРеквизита + "ДобавитьИзРанееСозданных"].Видимость = Ложь;
		Форма.Элементы[ИмяРеквизита + "Редактировать"].Видимость = Истина;
		Форма.Элементы[ИмяРеквизита + "Удалить"].Видимость = Истина;
		Форма.Элементы[ИмяРеквизита + "НайтиВСписке"].Видимость = Истина;
		Форма.Элементы[ИмяРеквизита + "Декорация"].Видимость = Истина;
		Форма.Элементы[ИмяРеквизита + "Очистить"].Видимость = Истина;
	Иначе
		Форма.Элементы[ИмяРеквизита + "Создать"].Видимость = Истина;
		Форма.Элементы[ИмяРеквизита + "ДобавитьИзРанееСозданных"].Видимость = Истина;
		Форма.Элементы[ИмяРеквизита + "Редактировать"].Видимость = Ложь;
		Форма.Элементы[ИмяРеквизита + "Удалить"].Видимость = Ложь;
		Форма.Элементы[ИмяРеквизита + "НайтиВСписке"].Видимость = Ложь;
		Форма.Элементы[ИмяРеквизита + "Декорация"].Видимость = Ложь;
		Форма.Элементы[ИмяРеквизита + "Очистить"].Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьЭлементПослеЗаписи(ЭлементыДляУдаления) Экспорт
	
	Для каждого Строка Из ЭлементыДляУдаления Цикл
		ОбщегоНазначенияСУ.УдалитьЭлементСправочника(Строка.Элемент);
	КонецЦикла;
	
	ЭлементыДляУдаления.Очистить();	
	
КонецПроцедуры

Процедура УстановитьДоступностьРедактора(Форма) Экспорт
	
	Если Форма.Объект.ИспользуетсяФорматированныйДокумент Тогда
		
		Форма.Элементы.ТекстовыйДокумент.Видимость             = Ложь;
		Форма.Элементы.ГруппаФорматированныйДокумент.Видимость = Истина;
		
	Иначе
		
		Форма.Элементы.ТекстовыйДокумент.Видимость             = Истина;
		Форма.Элементы.ГруппаФорматированныйДокумент.Видимость = Ложь;		
		
	КонецЕсли;	
	
КонецПроцедуры

Процедура ПереместитьЭлемент(Направление, Элемент) Экспорт
	
	ДанныеЭлемента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Элемент, "Код, Родитель, Владелец");
	
	// Ищем соседний элемент
	
	ИмяТаблицы = Элемент.Метаданные().Имя;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ТаблицаЭлемента.Ссылка,
		|	ТаблицаЭлемента.Код
		|ИЗ
		|	Справочник."+ИмяТаблицы+" КАК ТаблицаЭлемента
		|ГДЕ
		|	ТаблицаЭлемента.Родитель = &Родитель
		|	И ТаблицаЭлемента.Код "+?(Направление = "Вверх", "<=", ">=")+" &Код
		|   И ТаблицаЭлемента.Владелец = &Владелец
		|   И ТаблицаЭлемента.ПометкаУдаления = ЛОЖЬ
		|   И ТаблицаЭлемента.Ссылка <> &Элемент
		| УПОРЯДОЧИТЬ ПО Код "+?(Направление = "Вверх", "УБЫВ", "")+"";

	Запрос.УстановитьПараметр("Код", ДанныеЭлемента.Код);
	Запрос.УстановитьПараметр("Родитель", ДанныеЭлемента.Родитель);
	Запрос.УстановитьПараметр("Владелец", ДанныеЭлемента.Владелец);
	Запрос.УстановитьПараметр("Элемент", Элемент);

	Результат = Запрос.Выполнить();

	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	ВыборкаДетальныеЗаписи.Следующий();

	СоседнийЭлемент = ВыборкаДетальныеЗаписи.Ссылка;
	
	//
	
	НовыйКодЭлемента = ВыборкаДетальныеЗаписи.Код;
	НовыйКодСоседнегоЭлемента = ДанныеЭлемента.Код;
	
	Если НовыйКодЭлемента = НовыйКодСоседнегоЭлемента Тогда
		
		Если Направление = "Вверх" Тогда
			НовыйКодЭлемента = НовыйКодЭлемента + 1;
		Иначе
			НовыйКодСоседнегоЭлемента = НовыйКодСоседнегоЭлемента + 1;
		КонецЕсли;
		
	КонецЕсли;
	
	НачатьТранзакцию();
	
	СоседнийЭлементОбъект = СоседнийЭлемент.ПолучитьОбъект();
	СоседнийЭлементОбъект.Код = НовыйКодСоседнегоЭлемента;
	СоседнийЭлементОбъект.Записать();
	
	ЭлементОбъект     = Элемент.ПолучитьОбъект();
	ЭлементОбъект.Код = НовыйКодЭлемента;
	ЭлементОбъект.Записать();
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

Процедура СкопироватьЭлементыСодержания(Знач ЭлектронныйРесурс, Знач МассивЭлементовСодержания, Знач Группа, МассивСкопированных=Неопределено) Экспорт
	
	Если МассивСкопированных = Неопределено Тогда
		МассивСкопированных = Новый Массив;
	КонецЕсли;
	
	Для каждого ЭлементСодержания Из МассивЭлементовСодержания Цикл
		
		// Делаем проверки
		
		Если ТипЗнч(ЭлементСодержания) <> Тип("СправочникСсылка.СодержаниеСУЗ")
			ИЛИ НЕ ЗначениеЗаполнено(ЭлементСодержания) Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		Если МассивСкопированных.Найти(ЭлементСодержания) = Неопределено Тогда
			МассивСкопированных.Добавить(ЭлементСодержания);
		Иначе
			Продолжить; // Уже был скопирован ранее
		КонецЕсли;		
		
		Если ЗначениеЗаполнено(Группа) Тогда
		
			ДанныеГруппы = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Группа, "ЭтоГруппа, Родитель");
			
			Если НЕ ДанныеГруппы.ЭтоГруппа Тогда
				Группа = ДанныеГруппы.Родитель; 
			КонецЕсли;
			
		КонецЕсли;
		
		// Копируем элемент
		
		НовыйЭлементОбъект = ЭлементСодержания.Скопировать();
		НовыйЭлементОбъект.Владелец = ЭлектронныйРесурс;
		НовыйЭлементОбъект.Родитель = Группа;
		НовыйЭлементОбъект.Записать();
		
		// Копируем рекурсивно подчиненные элементы групп
		
		Если НовыйЭлементОбъект.ЭтоГруппа Тогда
			
			СозданнаяГруппаСсылка = НовыйЭлементОбъект.Ссылка;

			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	СодержаниеСУЗ.Ссылка
				|ИЗ
				|	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
				|ГДЕ
				|	СодержаниеСУЗ.ПометкаУдаления = ЛОЖЬ
				|	И СодержаниеСУЗ.Родитель = &Родитель";

			Запрос.УстановитьПараметр("Родитель", ЭлементСодержания);

			Результат = Запрос.Выполнить();

			ВыборкаДетальныеЗаписи = Результат.Выбрать();

			МассивПодчиненныхЭлементов = Новый Массив();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				МассивПодчиненныхЭлементов.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
			КонецЦикла;

			СкопироватьЭлементыСодержания(ЭлектронныйРесурс, МассивПодчиненныхЭлементов, СозданнаяГруппаСсылка, МассивСкопированных); // Рекурсия			
			
		КонецЕсли;		
		
	
	КонецЦикла;	
	
КонецПроцедуры

Процедура ОбновитьГиперссылкиОбъектаСУЗ(Владелец, Гиперссылки, Поставщик = Неопределено) Экспорт
	
	Если Поставщик = Неопределено Тогда
		Поставщик = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Владелец, "Поставщик");
	КонецЕсли;
	
	// Получаем таблицу существующих ссылок объекта
	// в т.ч. и помеченные на удаление
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СсылкиОбъектовСУЗ.Ссылка,
		|	СсылкиОбъектовСУЗ.СсылкаНаОбъектСУЗ,
		|	СсылкиОбъектовСУЗ.ЭлементПодборки,
		|	СсылкиОбъектовСУЗ.ПометкаУдаления
		|ИЗ
		|	Справочник.СсылкиОбъектовСУЗ КАК СсылкиОбъектовСУЗ
		|ГДЕ
		|	СсылкиОбъектовСУЗ.Владелец = &Владелец";
		
	Запрос.УстановитьПараметр("Владелец", Владелец);
	
	ТаблицаСсылокОбъектаСУЗ = Запрос.Выполнить().Выгрузить();
	
	ТаблицаСсылокОбъектаСУЗ.Колонки.Добавить("Актуально", Новый ОписаниеТипов("Булево"));
	
	Для каждого Гиперссылка Из Гиперссылки Цикл
		
		Если Лев(Гиперссылка, 11) = "javascript:"
			И СтрЧислоВхождений(Гиперссылка, "%22") = 2 Тогда
			
			Гиперссылка = Сред(Гиперссылка, Найти(Гиперссылка, "%22") + 3);			
			Гиперссылка = Лев(Гиперссылка, Найти(Гиперссылка, "%22") - 1);
			
			СтруктураСсылки = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(Гиперссылка);
			
		Иначе
			
			СтруктураСсылки = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(Гиперссылка);
			
		КонецЕсли;
		
		ИдентификаторОбъекта = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "id");
		ИмяОбъекта = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "object");
		ЦелевоеОкно = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "window");			
		
		Если ЗначениеЗаполнено(ИдентификаторОбъекта)
			И ЗначениеЗаполнено(ИмяОбъекта) Тогда
			
			СсылкаНаОбъектСУЗ = ОбъектыСУЗ.ПолучитьСсылкуПоИдентификатору(ИмяОбъекта, ИдентификаторОбъекта);
			
			Если НЕ ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(СсылкаНаОбъектСУЗ) Тогда
				Продолжить;
			КонецЕсли;
			
			ЭлементПодборки = Неопределено;
			
			Если ТипЗнч(СсылкаНаОбъектСУЗ) = Тип("СправочникСсылка.ПодборкиСУЗ") Тогда
				
				НомерГруппыПодборки = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "numGroup");
				
				Если ЗначениеЗаполнено(НомерГруппыПодборки) Тогда
					ЭлементПодборки = Справочники.ПодборкиСУЗ.СтраницаПодборкиПоНомеру(СсылкаНаОбъектСУЗ, НомерГруппыПодборки);
				КонецЕсли;
				
				ИдентификаторГруппыПодборки = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "idGroup");
				
				Если ЗначениеЗаполнено(ИдентификаторГруппыПодборки) Тогда
					ЭлементПодборки = Справочники.ЭлементыПодборкиСУЗ.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторГруппыПодборки));
				КонецЕсли;					
					
			КонецЕсли;				
			
			// Ищем ссылку в справочнике
			
			СтруктураПоиска = Новый Структура("СсылкаНаОбъектСУЗ", СсылкаНаОбъектСУЗ);
			
			Если ЗначениеЗаполнено(ЭлементПодборки) Тогда
				СтруктураПоиска.Вставить("ЭлементПодборки", ЭлементПодборки);
			КонецЕсли;
			
			СтрокаСсылки = ТаблицаСсылокОбъектаСУЗ.НайтиСтроки(СтруктураПоиска);
			
			Если СтрокаСсылки.Количество() = 0 Тогда
				
				СсылкаОбъект = Справочники.СсылкиОбъектовСУЗ.СоздатьЭлемент();
				
				СсылкаОбъект.Владелец = Владелец;
				СсылкаОбъект.Поставщик = Поставщик;
				СсылкаОбъект.СсылкаНаОбъектСУЗ = СсылкаНаОбъектСУЗ;
				СсылкаОбъект.ЭлементПодборки = ЭлементПодборки;
				
				Попытка
					СсылкаОбъект.ЦелевоеОкно = Перечисления.ЦелевыеОкнаДляСсылокСУЗ[ЦелевоеОкно];
				Исключение
					СсылкаОбъект.ЦелевоеОкно = Неопределено;
				КонецПопытки;					
				
				СсылкаОбъект.Записать();
				
				НоваяСтрока = ТаблицаСсылокОбъектаСУЗ.Добавить();
				НоваяСтрока.Ссылка = СсылкаОбъект.Ссылка;
				НоваяСтрока.СсылкаНаОбъектСУЗ = СсылкаНаОбъектСУЗ;
				НоваяСтрока.ЭлементПодборки = ЭлементПодборки;
				НоваяСтрока.Актуально = Истина;
				
			Иначе
				
				СтрокаСсылки[0].Актуально = Истина; // Уже есть запись о гиперссылки
				
				Если СтрокаСсылки[0].ПометкаУдаления = Истина Тогда // BUG булево
				
					СсылкаОбъект = СтрокаСсылки[0].Ссылка.ПолучитьОбъект(); 
					СсылкаОбъект.УстановитьПометкуУдаления(Ложь);
					
				КонецЕсли;
					
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	// Удаляем не актуальные элементы справочника
	//
	
	Для каждого Строка Из ТаблицаСсылокОбъектаСУЗ Цикл
	
		Если Строка.Актуально Тогда
			Продолжить;
		КонецЕсли;
		
		СсылкаОбъект = Строка.Ссылка.ПолучитьОбъект(); 
		СсылкаОбъект.УстановитьПометкуУдаления(Истина);
		
	КонецЦикла;			
	
КонецПроцедуры

Процедура ОбновитьГиперссылкиРесурса(Ресурс = Неопределено) Экспорт
	
	// Вызывается в т.ч. и фоновым заданием
	// Может использоваться для обновления ссылок всех ресурсов
	
	ТаблицаГиперссылок = Новый ТаблицаЗначений;
	ТаблицаГиперссылок.Колонки.Добавить("Ресурс");
	ТаблицаГиперссылок.Колонки.Добавить("Гиперссылки");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ФайлыСУЗ.Ссылка,
	               |	ФайлыСУЗ.Владелец КАК Ресурс,
	               |	ФайлыСУЗ.Поставщик,
	               |	ФайлыСУЗ.ТипФайла
	               |ИЗ
	               |	Справочник.ФайлыСУЗ КАК ФайлыСУЗ
	               |ГДЕ
	               |	ФайлыСУЗ.ПометкаУдаления = ЛОЖЬ
	               |	И ФайлыСУЗ.ЭтоГруппа = ЛОЖЬ
	               |	И ФайлыСУЗ.ВнешнийФайл = ЛОЖЬ
	               |	И ((ФайлыСУЗ.ТипФайла = ЗНАЧЕНИЕ(Перечисление.ТипыФайловСУЗ.Default) И (ФайлыСУЗ.ИмяФайла ПОДОБНО ""%.html"" ИЛИ ФайлыСУЗ.ИмяФайла ПОДОБНО ""%.htm""))
	               |			ИЛИ ФайлыСУЗ.ТипФайла = ЗНАЧЕНИЕ(Перечисление.ТипыФайловСУЗ.Document))";	
				   
				   
				   
				   
	Если ЗначениеЗаполнено(Ресурс) Тогда
		
		Запрос.Текст = Запрос.Текст + " И ФайлыСУЗ.Владелец = &Ресурс";

		Запрос.Параметры.Вставить("Ресурс", Ресурс);
	   
	КонецЕсли;				   
				   
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ПутьКФайлуДляУдаления = "";
		ПутьКФайлуHTML = "";
		
		// Читаем файл HTML
		
		Если ВыборкаДетальныеЗаписи.ТипФайла = Перечисления.ТипыФайловСУЗ.Document Тогда
			
			ПутьКВременномуКаталогу = ПолучитьИмяВременногоФайла("");
			
			ПутьКФайлуДляУдаления = ПутьКВременномуКаталогу; 
			
			СоздатьКаталог(ПутьКВременномуКаталогу);
			
			ПутьКВременномуКаталогу = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКВременномуКаталогу);
			
			ПолноеИмяСохраняемогоФайла = ПутьКВременномуКаталогу + "document.zip";			
			
			ДвоичныеДанныеАрхива = ОбъектыСУЗ.ПолучитьДанные(ВыборкаДетальныеЗаписи.Ссылка, "HTML", Истина, "ДвоичныеДанные");
			
			ДвоичныеДанныеАрхива.Записать(ПолноеИмяСохраняемогоФайла);
			
			ФайлАрхива = Новый ЧтениеZIPФайла(ПолноеИмяСохраняемогоФайла);
			ФайлАрхива.ИзвлечьВсе(ПутьКВременномуКаталогу, РежимВосстановленияПутейФайловZIP.Восстанавливать); 
			ФайлАрхива.Закрыть(); 				

			ПутьКФайлуHTML = РазработкаСУЗКлиентСервер.ПутьКФайлуЗапускаДокумента(ПутьКВременномуКаталогу);
			
			
		Иначе
			
			ПутьКВременномуФайлу = ПолучитьИмяВременногоФайла("html");
			
			ПутьКФайлуДляУдаления = ПутьКВременномуФайлу;
			
			ПутьКФайлуHTML = ПутьКВременномуФайлу;
			
			ДвоичныеДанные = ОбъектыСУЗ.ПолучитьДанные(ВыборкаДетальныеЗаписи.Ссылка, "ДвоичныеДанные", Истина, "ДвоичныеДанные");
			
			ДвоичныеДанные.Записать(ПутьКВременномуФайлу);			
			
		КонецЕсли;
		
		
		ЧтениеHTML = Новый ЧтениеHTML;
		ЧтениеHTML.ОткрытьФайл(ПутьКФайлуHTML);
		
		ПостроительDOM = Новый ПостроительDOM;
		ДокументHTML = ПостроительDOM.Прочитать(ЧтениеHTML);
				
		Гиперссылки = ДокументHTML.ПолучитьЭлементыПоИмени("a");
			
		// Обрабатываем ссылки файла и записываем их в базу
		
		Для каждого ЭлементВебСсылки Из Гиперссылки Цикл
			
			СтрокаТаблица = ТаблицаГиперссылок.Найти(ВыборкаДетальныеЗаписи.Ресурс, "Ресурс");
			
			Если СтрокаТаблица = Неопределено Тогда
				
				СтрокаТаблица = ТаблицаГиперссылок.Добавить();
				СтрокаТаблица.Ресурс = ВыборкаДетальныеЗаписи.Ресурс;
				СтрокаТаблица.Гиперссылки = Новый Массив;
				
			КонецЕсли;
			
			Если СтрокаТаблица.Гиперссылки.Найти(ЭлементВебСсылки.Гиперссылка) = Неопределено Тогда
				СтрокаТаблица.Гиперссылки.Добавить(ЭлементВебСсылки.Гиперссылка);
			КонецЕсли;
			
		КонецЦикла;
		
		ЧтениеHTML.Закрыть();
		
		Попытка
			УдалитьФайлы(ПутьКФайлуДляУдаления);
		Исключение
		КонецПопытки;		
		
	КонецЦикла;		
	
	Для каждого Строка Из ТаблицаГиперссылок Цикл	
		РазработкаСУЗ.ОбновитьГиперссылкиОбъектаСУЗ(Строка.Ресурс, Строка.Гиперссылки);	
	КонецЦикла;
	
	
КонецПроцедуры

Процедура ОбновитьЗависимыеРесурсы(Ресурс, ЗависимыеРесурсы, ЗависимыеРесурсыДополняющиеAPI) Экспорт
	
	// Указываем зависимые ресурсы или удаляем лишние
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗависимыеРесурсыСУЗ.Ссылка,
		|	ЗависимыеРесурсыСУЗ.Ресурс КАК Ресурс
		|ИЗ
		|	Справочник.ЗависимыеРесурсыСУЗ КАК ЗависимыеРесурсыСУЗ
		|ГДЕ
		|	ЗависимыеРесурсыСУЗ.ПометкаУдаления = ЛОЖЬ
		|	И ЗависимыеРесурсыСУЗ.Владелец = &Ресурс";

	Запрос.УстановитьПараметр("Ресурс", Ресурс);

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();	
	
	Если ЗависимыеРесурсы <> Неопределено И ЗависимыеРесурсы.Количество() > 0 Тогда
		
		Для каждого ЗависимыйРесурс Из ЗависимыеРесурсы Цикл
			
			ВыборкаДетальныеЗаписи.Сбросить();
			
			Если ВыборкаДетальныеЗаписи.НайтиСледующий(ЗависимыйРесурс, "Ресурс") Тогда
				
				ЗависимыйРесурсОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
				
			Иначе
				
				ЗависимыйРесурсОбъект = Справочники.ЗависимыеРесурсыСУЗ.СоздатьЭлемент();
				
				ЗависимыйРесурсОбъект.Владелец     = Ресурс;
				ЗависимыйРесурсОбъект.Ресурс       = ЗависимыйРесурс;
				
				РазработкаСУЗ.УстановитьПредпочитаемогоПоставщика(ЗависимыйРесурсОбъект);
				
				
			КонецЕсли;
			
			ЗависимыйРесурсОбъект.Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗависимыйРесурс, "Наименование");
			
			Если ЗависимыеРесурсыДополняющиеAPI <> Неопределено
				И ЗависимыеРесурсыДополняющиеAPI.Найти(Строка(ЗависимыйРесурс.УникальныйИдентификатор())) <> Неопределено Тогда
				
				ЗависимыйРесурсОбъект.ДополняетAPI = Истина;
				
			Иначе
				
				ЗависимыйРесурсОбъект.ДополняетAPI = Ложь;
				
			КонецЕсли;
			
			ЗависимыйРесурсОбъект.Записать();
			
		КонецЦикла;
		
		
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи.Сбросить();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ЗависимыеРесурсы = Неопределено
			ИЛИ ЗависимыеРесурсы.Количество() = 0
			ИЛИ ЗависимыеРесурсы.Найти(ВыборкаДетальныеЗаписи.Ресурс) = Неопределено Тогда
			
			ЗависимыйРесурсОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();

			ЗависимыйРесурсОбъект.УстановитьПометкуУдаления(Истина);
			
			ЗависимыйРесурсОбъект.Записать();
			
		КонецЕсли;
		
	КонецЦикла;	
	
	
КонецПроцедуры

Функция ИспользоватьВстроенныйПлеерКурсовВебКабинета() Экспорт
	УстановитьПривилегированныйРежим(Истина);
	Возврат ВебКабинетСУ.Используется()
		И Константы.ИспользоватьВстроенныйПлеерКурсовВебКабинетаСУЗ.Получить();
КонецФункции

Процедура УбратьВидимостьНеподдерживаемыхПлееромВебКабинетаЭлементов(Знач ЭлектронныйРесурс, МассивЭлементов, ЭтоНовыйЭлемент = Ложь) Экспорт
	
	УбратьВидимость = Ложь;
	
	Если ЭтоНовыйЭлемент И ИспользоватьВстроенныйПлеерКурсовВебКабинета() Тогда
		УбратьВидимость = Истина;
	КонецЕсли;
	
	Если ТипЗнч(ЭлектронныйРесурс) = Тип("СправочникСсылка.СводыЗнанийСУЗ")
		И РегистрыСведений.ПлеерКурсовВебКабинетаСУЗ.ИспользоватьВстроенныйПлеер(ЭлектронныйРесурс) Тогда
		УбратьВидимость = Истина;
	КонецЕсли;
	
	Если УбратьВидимость Тогда
		Для каждого ЭлементФормы Из МассивЭлементов Цикл
			ЭлементФормы.Видимость = Ложь;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры


			<dataPath>ПрохождениеЗадания.ДатаПроверки</dataPath>
			<field>ДатаПроверки</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата проверки</v8:content>

КонецФункции

// Уведомления

Функция ПолучитьУведомленияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем уведомления
	//
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Права = ДанныеСессии.Права.Получить();
	
	Уведомления = Новый Структура("КоличествоНовыхЛичныхСообщений, КоличествоНовыхСообщенийФорума, КоличествоНовыхНовостей, КоличествоПользователейОнлайн, Пользователь", 0, 0, 0, 0, Неопределено);
	
	Если Права.Свойство("Сообщения") И Права.Сообщения Тогда
		Уведомления.КоличествоНовыхЛичныхСообщений = Документы.СообщениеСУО.КоличествоНовыхЛичныхСообщений(ДанныеСессии.Пользователь);
	КонецЕсли;
		
	Если Права.Свойство("Форум") И Права.Форум Тогда
		Уведомления.КоличествоНовыхСообщенийФорума = Документы.СообщениеСУО.КоличествоНовыхГрупповыхСообщений(ДанныеСессии.Пользователь);	
	КонецЕсли;
	
	Если Права.Свойство("Новости") И Права.Новости Тогда
		
		ДатаПросмотраЛентыНовостей = РегистрыСведений.ПросмотрыЛентыНовостейПользователямиСУО.ДатаПоследнегоПросмотра(ДанныеСессии.Пользователь);	
		
		Если ДатаПросмотраЛентыНовостей = Неопределено Тогда
			ДатаПросмотраЛентыНовостей = ДобавитьМесяц(ТекущаяДата, -1)
		КонецЕсли;
		
		Уведомления.КоличествоНовыхНовостей = РегистрыСведений.НовостиСУО.КоличествоНовостейЗаПериод(ДанныеСессии.Пользователь, ДатаПросмотраЛентыНовостей, ТекущаяДата);  
		
	КонецЕсли;
	
	Если Права.Свойство("Пользователи") И Права.Пользователи Тогда		
		
		// Получаем данные запроса
		
		Попытка
			СтруктураДанных = ОбщегоНазначенияСУ.JSONВДанные(Запрос.ПолучитьТелоКакСтроку());
		Исключение
		КонецПопытки;
		
		Если ТипЗнч(СтруктураДанных) = Тип("Структура") И СтруктураДанных.Свойство("getCountUsersOnline") И СтруктураДанных.getCountUsersOnline Тогда
			
			Если НЕ Права.Свойство("КаталогПользователей") ИЛИ НЕ Права.КаталогПользователей Тогда
				ПользователиКаталога = КаталогПользователей(ДанныеСессии, Истина);				
			Иначе				
				ПользователиКаталога = Неопределено; // Доступны все пользователи и явно их не получаем
			КонецЕсли;			
			
			МассивАктивныхПользователей = РегистрыСведений.СессииВебКабинетаСУ.АктивныеПользователи(ПользователиКаталога);		
			
			Уведомления.КоличествоПользователейОнлайн = МассивАктивныхПользователей.Количество();
			
		КонецЕсли;
			
	КонецЕсли;
	
	Уведомления.Пользователь = ВебКабинетСУО.ПользовательСтруктура(ДанныеСессии.Пользователь);
	
	// Возвращаем результат
	
	Возврат ОтветКлиентуJSON(,Уведомления);
	
КонецФункции

// Настройки пользователя

Функция ПолучитьНастройкиPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем настройки из регистра настроек
	//
	
	НастройкиПользователя = Новый Структура;
	
	РегистрыСведений.НастройкиПользователейСУО.ЗаполнитьСтруктуруНастроек(ДанныеСессии.Пользователь, НастройкиПользователя);
	
	// Получаем контактную информацию
	//
	
	ЗапросДанных = Новый Запрос;
	ЗапросДанных.Текст = 
		"ВЫБРАТЬ
		|	ПользователиКонтактнаяИнформация.Представление,
		|	ПользователиКонтактнаяИнформация.НомерСтроки,
		|	ВидыКонтактнойИнформации.Ссылка КАК Вид,
		|	ВидыКонтактнойИнформации.Наименование КАК НаименованиеВида,
		|	ВидыКонтактнойИнформации.ЗапретитьРедактированиеПользователем КАК ЗапретитьРедактированиеПользователем,
		|	ВидыКонтактнойИнформации.Тип КАК Тип,
		|	ВидыКонтактнойИнформации.ИмяПредопределенныхДанных
		|ИЗ
		|	Справочник.ВидыКонтактнойИнформации КАК ВидыКонтактнойИнформации
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
		|		ПО (ПользователиКонтактнаяИнформация.Вид = ВидыКонтактнойИнформации.Ссылка)
		|			И (ПользователиКонтактнаяИнформация.Ссылка = &Пользователь)
		|ГДЕ
		|	ВидыКонтактнойИнформации.Родитель = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.СправочникПользователи)
		|	И ВидыКонтактнойИнформации.ЭтоГруппа = ЛОЖЬ
		|	И ВидыКонтактнойИнформации.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВидыКонтактнойИнформации.РеквизитДопУпорядочивания";
	
	ЗапросДанных.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	
	НастройкиПользователя.Вставить("КонтактнаяИнформация", ЗапросДанных.Выполнить().Выгрузить());
	
	// Получаем дополнительные сведения
	//
	
	НастройкиПользователя.Вставить("ДополнительныеСведения", ВебКабинетСУО.ТаблицаДополнительныхРеквизитовОбъекта(ДанныеСессии.Пользователь));
	
	// Получаем фотографию и аватар
	//
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ФотографииПользователейСУО.Фотография,
		|	ФотографииПользователейСУО.Аватар
		|ИЗ
		|	РегистрСведений.ФотографииПользователейСУО КАК ФотографииПользователейСУО
		|ГДЕ
		|	ФотографииПользователейСУО.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
	
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		ВыборкаДетальныеЗаписи.Следующий();

		ДвоичныеДанныеФотографии = ВыборкаДетальныеЗаписи.Фотография.Получить(); 
		
		Если ДвоичныеДанныеФотографии <> Неопределено Тогда
			
			ИмяФайлаФотографии = РегистрыСведений.ФотографииПользователейСУО.ИмяФайлаФотографии(ДвоичныеДанныеФотографии);
		
			НастройкиПользователя.Вставить("Фотография", Строка(ДанныеСессии.Пользователь.УникальныйИдентификатор()) + "/" + ИмяФайлаФотографии);
			
		КонецЕсли;
		
		ДвоичныеДанныеАватара = ВыборкаДетальныеЗаписи.Аватар.Получить(); 
		
		Если ДвоичныеДанныеАватара <> Неопределено Тогда
			
			ИмяФайлаАватара = РегистрыСведений.ФотографииПользователейСУО.ИмяФайлаАватара();
		
			НастройкиПользователя.Вставить("Аватар", Строка(ДанныеСессии.Пользователь.УникальныйИдентификатор()) + "/" + ИмяФайлаАватара);
			
		КонецЕсли;		
		
	КонецЕсли;
	
	// Получаем пин-коды
	//
	
	ПинКоды = Новый Структура("Используется, Список", ПолучитьФункциональнуюОпцию("ИспользоватьПинКодыВПерсональныхНастройкахСУО"), Неопределено);
	
	Если ПинКоды.Используется Тогда		
		ПинКоды.Список = РегистрыСведений.ВыданныеПинКодыСУО.КодыПользователя(ДанныеСессии.Пользователь);
	КонецЕсли;	
	
	НастройкиПользователя.Вставить("ПинКоды", ПинКоды);
	
	// Получаем время доступа
	//
	
	НастройкиПользователя.Вставить("ВремяДоступа", РегистрыСведений.ВремяДоступаПользователейСУО.ДатыДоступа(ДанныеСессии.Пользователь));
	
	// Возвращаем результат
	//
	
	Возврат ОтветКлиентуJSON(,НастройкиПользователя);
	
КонецФункции

Функция ЗаписатьНастройкиPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Записываем настройки	
	//
	
	НастройкиДляЗаписиJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если НЕ ЗначениеЗаполнено(НастройкиДляЗаписиJSON) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Попытка
		НастройкиДляЗаписи = ОбщегоНазначенияСУ.JSONВДанные(НастройкиДляЗаписиJSON);
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;
	
	ПрохождениеОбученияДляОбновления = Неопределено;
	
	Для каждого Настройка Из НастройкиДляЗаписи Цикл
	
		Если Настройка.Ключ = "denyMailing" Тогда
			РегистрыСведений.НастройкиПользователейСУО.ЗаписатьНастройку(ДанныеСессии.Пользователь, "ЗапретитьРассылкуНаАдресЭлектроннойПочты", Настройка.Значение);	
		КонецЕсли;
		
		Если Настройка.Ключ = "denyNewMessagesMailing" Тогда
			РегистрыСведений.НастройкиПользователейСУО.ЗаписатьНастройку(ДанныеСессии.Пользователь, "ЗапретитьУведомленияОНовыхЛичныхСообщениях", Настройка.Значение);	
		КонецЕсли;
		
		Если Настройка.Ключ = "denyNewForumTopicsMailing" Тогда
			РегистрыСведений.НастройкиПользователейСУО.ЗаписатьНастройку(ДанныеСессии.Пользователь, "ЗапретитьУведомленияОНовыхСообщенияхФорума", Настройка.Значение);	
		КонецЕсли;		
		
		Если Настройка.Ключ = "hideContactInformation" Тогда
			РегистрыСведений.НастройкиПользователейСУО.ЗаписатьНастройку(ДанныеСессии.Пользователь, "СкрытьКонтактнуюИнформацию", Настройка.Значение);
		КонецЕсли;
		
		Если Настройка.Ключ = "hideAdditionalInformation" Тогда
			РегистрыСведений.НастройкиПользователейСУО.ЗаписатьНастройку(ДанныеСессии.Пользователь, "СкрытьДополнительныеСведения", Настройка.Значение);
		КонецЕсли;		
		
		Если Настройка.Ключ = "updateActivity" И ЗначениеЗаполнено(Настройка.Значение) Тогда
			ПрохождениеОбученияДляОбновления = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(Настройка.Значение));			
		КонецЕсли;
		
		Если Настройка.Ключ = "contacts" Тогда
			
			ДанныеЗаполнения = УправлениеКонтактнойИнформацией.НоваяКонтактнаяИнформация(Ложь);	
			
			Для каждого Элемент Из Настройка.Значение Цикл
				
				Если НЕ Элемент.Свойство("num") ИЛИ НЕ Элемент.Свойство("value") ИЛИ НЕ Элемент.Свойство("kind") ИЛИ НЕ Элемент.Свойство("type") Тогда
				    Возврат ОтветКлиентуJSON("errorData");
				КонецЕсли;				
				
				ТипКИ = Перечисления.ТипыКонтактнойИнформации[Элемент.type];
				
				СтрокаЗаполнения = ДанныеЗаполнения.Добавить();
				СтрокаЗаполнения.Вид = Справочники.ВидыКонтактнойИнформации.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.kind));
				СтрокаЗаполнения.Представление = Элемент.value;
				СтрокаЗаполнения.Тип = ТипКИ;
				Если ТипЗнч(Элемент.num) = Тип("Число") Тогда
					СтрокаЗаполнения.ИдентификаторСтрокиТабличнойЧасти = Элемент.num;
				КонецЕсли;
						
			КонецЦикла;			
						
			УправлениеКонтактнойИнформацией.УстановитьКонтактнуюИнформациюОбъекта(ДанныеСессии.Пользователь, ДанныеЗаполнения, Истина);
			
		КонецЕсли;
		
		Если Настройка.Ключ = "additionalInfo" Тогда
			
			УправлениеСвойствами.ЗаписатьСвойстваУОбъекта(ДанныеСессии.Пользователь, СформироватьТаблицуДополнительныхСвойств(Настройка.Значение));
			
		КонецЕсли;
		
		Если Настройка.Ключ = "avatar" Тогда

			Если ЗначениеЗаполнено(Настройка.Значение) Тогда
			
				Попытка
					ДвоичныеДанныеАватара = Base64Значение(Настройка.Значение);
				Исключение
					Возврат ОтветКлиентуJSON("errorData");
				КонецПопытки;	
				
				АдресХраненияАватара = ПоместитьВоВременноеХранилище(ДвоичныеДанныеАватара);
				
				РегистрыСведений.ФотографииПользователейСУО.СохранитьФотографиюПользователя(ДанныеСессии.Пользователь,,АдресХраненияАватара, Истина);
				
			Иначе
				
				РегистрыСведений.ФотографииПользователейСУО.УдалитьФотографиюПользователя(ДанныеСессии.Пользователь,,Истина, Истина);
				
			КонецЕсли;
			
			РегистрыСведений.ФотографииПользователейСУО.ОбновитьДанныеВебКабинета(ДанныеСессии.Пользователь);
			
			ВебКабинетСУ.ВыполнитьОбновлениеЗависимостей(ДанныеСессии.Пользователь);
			
		КонецЕсли;	
		
		Если Настройка.Ключ = "photo" Тогда
			
			Если ЗначениеЗаполнено(Настройка.Значение) Тогда
				
				// Ничего не делаем, так как фотография записывается через загрузку файлов
				
			Иначе
				
				РегистрыСведений.ФотографииПользователейСУО.УдалитьФотографиюПользователя(ДанныеСессии.Пользователь, Истина, Ложь, Истина);
				
			КонецЕсли;
			
			РегистрыСведений.ФотографииПользователейСУО.ОбновитьДанныеВебКабинета(ДанныеСессии.Пользователь);
			
		КонецЕсли;		
		
	КонецЦикла;	
	
	Если ЗначениеЗаполнено(ПрохождениеОбученияДляОбновления) Тогда
		ВебКабинетСУ.ОбновитьДанныеОбъекта(Документы.ПрохождениеОбученияСУО, ПрохождениеОбученияДляОбновления);
	КонецЕсли;
	
	ВебКабинетСУО.ОбновитьДанныеПользователяВебКабинета(ДанныеСессии.Пользователь);
	
	// Возвращаем результат
	//
	
	Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена", Истина));		
	
КонецФункции

Функция АктивироватьПинКодPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;	
	
	// Записываем настройки	
	//
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьПинКодыВПерсональныхНастройкахСУО") Тогда
		Возврат ОтветКлиентуJSON("noFunctionality");
	КонецЕсли;
	
	НастройкиДляЗаписиJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если НЕ ЗначениеЗаполнено(НастройкиДляЗаписиJSON) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Попытка
		НастройкиДляЗаписи = ОбщегоНазначенияСУ.JSONВДанные(НастройкиДляЗаписиJSON);
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;
	
	Если НЕ НастройкиДляЗаписи.Свойство("pinCode") Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	ДанныеПинКода = РегистрыСведений.ВыданныеПинКодыСУО.КодДоступенДляАктивации(
		НастройкиДляЗаписи.pinCode,
		?(НастройкиДляЗаписи.Свойство("pinCodeOption"), НастройкиДляЗаписи.pinCodeOption, Неопределено)
	);
	
	Если ДанныеПинКода.ТребуетсяОпция Тогда
		
		ДанныеПинКода.Вставить("ДоступныеОпции", Справочники.СерииПинКодовСУО.СтруктураОпцийДляВебКабинета(ДанныеПинКода.Серия));
		
		Возврат ОтветКлиентуJSON(, ДанныеПинКода);
			
	КонецЕсли;
	
	Если НЕ ДанныеПинКода.ДоступенДляАктивации Тогда
		
		Возврат ОтветКлиентуJSON(, ДанныеПинКода);
		
	КонецЕсли;
	
	РегистрыСведений.ВыданныеПинКодыСУО.АктивироватьКод(ДанныеПинКода.Серия, ДанныеПинКода.Код, ДанныеСессии.Пользователь,,ДанныеПинКода.Опция,Истина);
	
	ТекстУведомления = РегистрыСведений.ВыданныеПинКодыСУО.ПолучитьТекстУведомленияИЗапомнить(ДанныеСессии.Пользователь);
	
	ДанныеПинКода.Вставить("Уведомление", ТекстУведомления);
	
	Возврат ОтветКлиентуJSON(, ДанныеПинКода);
	
КонецФункции


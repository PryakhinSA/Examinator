#Если Сервер Тогда
	
Функция Значение(Элемент) Экспорт
	
	Если ТипЗнч(Элемент) = Тип("ПеречислениеСсылка.ТипыДанныхВебКабинетаСУО") Тогда
		Возврат Элемент;
	КонецЕсли;
	
	Если ТипЗнч(Элемент) = Тип("Строка") Тогда
		Возврат Перечисления.ТипыДанныхВебКабинетаСУО[ВебКабинетСУ.Перевод(Элемент, "ТипыДанныхВебКабинетаСУО")];
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции


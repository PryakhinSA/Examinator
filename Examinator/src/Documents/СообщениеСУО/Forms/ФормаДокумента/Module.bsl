	НоваяСтрока.ИмяРеквизита      = "Ссылка";
	НоваяСтрока.Доступность       = ?(УправлениеДоступом.ЕстьРоль("УправлениеПроведениемОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	
	// Преподавателю
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому                            = Перечисления.АдресатыСообщенийСУО.Преподавателю;
	НоваяСтрока.ОписаниеИсточника               = "учащемуся";
	НоваяСтрока.ФормаВыбора                     = "РегистрСведений.ПрохожденияОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ИмяРеквизита                    = "Ссылка";
	НоваяСтрока.ПромежуточнаяФормаВыбора        = "РегистрСведений.ПроведениеПреподавателямиОбученияСУО.Форма.ФормаВыбораПреподавателяМероприятия";
	НоваяСтрока.ИмяПараметраПромежуточнойФормы  = "ПроведениеОбучения";
	НоваяСтрока.ИмяПромежуточногоРеквизита      = "ПроведениеОбучения";
	НоваяСтрока.Доступность                     = ?(УправлениеДоступом.ЕстьРоль("ЛичныйКабинетПрохождениеОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому                           = Перечисления.АдресатыСообщенийСУО.Преподавателю;
	НоваяСтрока.ОписаниеИсточника              = "преподавателю";	
	НоваяСтрока.ФормаВыбора                    = "РегистрСведений.ПроведениеПреподавателямиОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ИмяРеквизита                   = "Ссылка";
	НоваяСтрока.ПромежуточнаяФормаВыбора       = "РегистрСведений.ПроведениеПреподавателямиОбученияСУО.Форма.ФормаВыбораПреподавателяМероприятия";
	НоваяСтрока.ИмяПараметраПромежуточнойФормы = "ПроведениеОбучения";
	НоваяСтрока.ИмяПромежуточногоРеквизита     = "ПроведениеОбучения";	
	НоваяСтрока.Доступность                    = ?(УправлениеОбучениемСУО.ЕстьРольПреподавателя(Объект.Пользователь), Истина, Ложь);
	
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому                           = Перечисления.АдресатыСообщенийСУО.Преподавателю;
	НоваяСтрока.ОписаниеИсточника              = "менеджеру";	
	НоваяСтрока.ФормаВыбора                    = "Документ.ПроведениеОбученияСУО.ФормаВыбора";
	НоваяСтрока.ИмяРеквизита                   = "Ссылка";
	НоваяСтрока.ПромежуточнаяФормаВыбора       = "РегистрСведений.ПроведениеПреподавателямиОбученияСУО.Форма.ФормаВыбораПреподавателяМероприятия";
	НоваяСтрока.ИмяПараметраПромежуточнойФормы = "ПроведениеОбучения";
	НоваяСтрока.ИмяПромежуточногоРеквизита     = "Ссылка";
	НоваяСтрока.Доступность                    = ?(УправлениеДоступом.ЕстьРоль("УправлениеПроведениемОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	// Пользователю
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому         = Перечисления.АдресатыСообщенийСУО.Пользователю;
	НоваяСтрока.ФормаВыбора  = "Справочник.Пользователи.ФормаВыбора";
	НоваяСтрока.ИмяРеквизита = "Ссылка";
	НоваяСтрока.Доступность  = ?(УправлениеДоступом.ЕстьРоль("УправлениеУчастникамиОбученияСУО",,Объект.Пользователь), Истина, Ложь);
								 
	// Администратору
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому         = Перечисления.АдресатыСообщенийСУО.Администратору;
	НоваяСтрока.Значение     = Константы.АвторАвтоматическихРассылокСУО.Получить();
	НоваяСтрока.ИмяРеквизита = "Ссылка";
	НоваяСтрока.Доступность  = ?(ЗначениеЗаполнено(НоваяСтрока.Значение), Истина, Ложь);
	
	// Организатору
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому         = Перечисления.АдресатыСообщенийСУО.Организатору;
	НоваяСтрока.ФормаВыбора  = "Справочник.ОрганизаторыСУО.ФормаВыбора";
	НоваяСтрока.ИмяРеквизита = "Ссылка";
	НоваяСтрока.Доступность  = ?(СписокАдресатов.Количество() > 0, Истина, Ложь);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	// Устанавливаем параметры выбора элемента формы "Кому"
	//
	
	МассивПараметров = Новый Массив();
	МассивПараметров.Добавить(Новый ПараметрВыбора("СформироватьДанныеВыбора", Истина));
	
	Если НЕ Пользователи.ЭтоПолноправныйПользователь(Пользователи.ТекущийПользователь()) Тогда
	
		МассивПараметров.Добавить(Новый ПараметрВыбора("УчитыватьНастройки", Истина));
		
		МассивДоступныхЗначений = Новый Массив();
		
		Для каждого СтрокаТДК Из ДанныеОКонтексте Цикл
		
			Если СтрокаТДК.Доступность
				И МассивДоступныхЗначений.Найти(СтрокаТДК.Кому) = Неопределено Тогда
				
				МассивДоступныхЗначений.Добавить(СтрокаТДК.Кому);
				
			КонецЕсли;
		
		КонецЦикла;
		
		МассивПараметров.Добавить(Новый ПараметрВыбора("ДоступныеЗначения", Новый ФиксированныйМассив(МассивДоступныхЗначений)));
		
	КонецЕсли;
	
	Элементы.Кому.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
	

	// Устанавливаем заголовок
	
	Если Кому = Перечисления.АдресатыСообщенийСУО.НаФоруме
		И Объект.Ссылка.Пустая() Тогда
		
		Заголовок = НСтр("ru = 'Тема и сообщение (создание)'");
		
	КонецЕсли;
	
	
	// Устанавливаем доступность элементов
	
	УправлениеДоступностьюЭлементовФормыНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УправлениеДоступностьюЭлементовФормы();
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	Если ЗначениеЗаполнено(ТекущийОбъект.Шаблон) И НЕ ТекущийОбъект.Ссылка.Пустая() Тогда
		Сообщение = Документы.СообщениеСУО.ФорматированныйДокументСообщения(ТекущийОбъект.Ссылка);
	Иначе
		Сообщение = ТекущийОбъект.ФорматированныйДокумент.Получить();
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ЗначениеЗаполнено(Объект.РодительскоеСообщение) Тогда
		ТекстРодительскогоСообщения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.РодительскоеСообщение, "ФорматированныйДокумент").Получить();
	КонецЕсли;
	
	// Дополнительные адреса
	
	ДополнительныеАдреса = "";
	Если Объект.ДополнительныеАдреса.Количество() > 0 Тогда
		Для каждого СтрокаДА Из Объект.ДополнительныеАдреса Цикл
			ДополнительныеАдреса = ДополнительныеАдреса + СтрокаДА.АдресЭлектроннойПочты + ", ";
		КонецЦикла;		
		ДополнительныеАдреса = Сред(ДополнительныеАдреса, 1, СтрДлина(ДополнительныеАдреса) - 2);
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(ДополнительныеАдреса) Тогда
		Элементы.ДополнительныеАдреса.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Объект.Ссылка.Пустая()	И (НЕ ЗначениеЗаполнено(Кому) ИЛИ НЕ ЗначениеЗаполнено(Контекст)) Тогда
		
		Текст = НСтр("ru = 'Заполните поле ""Кому"" полностью'");
		Поле = "Кому";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст,,Поле,,Отказ);
		
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая()	И НЕ ЗначениеЗаполнено(НоваяТема) И НЕ ЗначениеЗаполнено(Объект.Тема) Тогда
		
		Текст = НСтр("ru = 'Укажите тему сообщения'");
		Поле = "НоваяТема";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст,,Поле,,Отказ);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.ФорматированныйДокумент = Новый ХранилищеЗначения(Сообщение, Новый СжатиеДанных(9));
	
	Если Объект.Ссылка.Пустая()
		И НЕ ЗначениеЗаполнено(Объект.Тема) Тогда

		УстановитьПривилегированныйРежим(Истина);
		
		НоваяТемаОбъект = Справочники.ТемыСообщенийСУО.СоздатьЭлемент();
		НоваяТемаОбъект.Наименование = НоваяТема;
		НоваяТемаОбъект.Контекст     = Контекст;
		НоваяТемаОбъект.Автор        = Объект.Пользователь;
		НоваяТемаОбъект.Кому         = Кому;
		
		НоваяТемаОбъект.Записать();
		
		ТекущийОбъект.Тема                 = НоваяТемаОбъект.Ссылка;
		ТекущийОбъект.ПервоеСообщениеВТеме = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если ТипЗнч(ИнформацияОПрикрепленныхФайлах) = Тип("ФиксированныйМассив") Тогда
		
		Для каждого ИнформацияОПрикрепленномФайле Из ИнформацияОПрикрепленныхФайлах Цикл
			
			// Создадим карточку Файла в БД
			ПрисоединенныеФайлы.ДобавитьФайл(
				ТекущийОбъект.Ссылка,
				ИнформацияОПрикрепленномФайле.ИмяБезРасширения,
				ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(ИнформацияОПрикрепленномФайле.Расширение),
				,
				,
				ИнформацияОПрикрепленномФайле.Адрес);
				
			ЕстьФайлы = Истина;
				
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ИнформацияОПрикрепленныхФайлах = Неопределено;
	Элементы.ИнформацияОПрикрепленномФайле.Заголовок = "";	
	УправлениеДоступностьюЭлементовФормыНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Оповестить("ЗаписаноСообщениеОбсуждения", Контекст);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, СтандартнаяОбработка)
	
	Если НЕ Объект.Ссылка.Пустая() И НЕ Объект.Проведен И НЕ ПользовательСогласилсяЗакрытьНепроведенныйДокумент Тогда
		
		Отказ = Истина;
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПередЗакрытиемПродолжение", ЭтотОбъект);
		
		ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'Это сообщение не отправлено. Отправить сообщение?'"), РежимДиалогаВопрос.ДаНет);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда						
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение)); 
    КонецЕсли;

	Если Результат = КодВозвратаДиалога.Нет Тогда
		ПользовательСогласилсяЗакрытьНепроведенныйДокумент = Истина;
	КонецЕсли;
	
	Закрыть();
	
КонецПроцедуры


#КонецОбласти


#Область ОбработчикиСобытийЭлементовШапкиФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура КомуПриИзменении(Элемент)
	
	УправлениеДоступностьюЭлементовФормы();
	
	Контекст        = Неопределено;
	ПредставлениеКонтекста = "";
	
	НайденныеСтроки = ДанныеОКонтексте.НайтиСтроки(Новый Структура("Кому, Доступность", Кому, Истина));
	
	Если НайденныеСтроки.Количество() = 1 И ЗначениеЗаполнено(НайденныеСтроки[0].Значение) Тогда
		
		Контекст               = ПолучитьКонтекстСообщения(НайденныеСтроки[0].Значение, НайденныеСтроки[0].ИмяРеквизита);
		ПредставлениеКонтекста = ПредставлениеКонтекстаСообщения(Кому, Контекст, Объект.Тема, Объект.Пользователь);
		
		Элементы.ВыбратьКонтекст.Доступность = Ложь;
		
	Иначе
		
		Элементы.ВыбратьКонтекст.Доступность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти



#Область ОбработчикиКомандФормы

// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ВыбратьКонтекст(Команда)
	
	НайденныеСтроки = ДанныеОКонтексте.НайтиСтроки(Новый Структура("Кому, Доступность", Кому, Истина));
	
	Если НайденныеСтроки.Количество() = 0 Тогда
		
		ПоказатьПредупреждение(,НСтр("ru = 'Нарушение прав доступа'"));
		Возврат;
		
	ИначеЕсли НайденныеСтроки.Количество() = 1 Тогда
		
		ВыбратьКонтекстПослеВыбораИсточника(0, НайденныеСтроки); 
		
	Иначе
		
		ТекстВопроса = НСтр("ru = 'Выбрать из мероприятий, которые доступны мне как...'");
		
		Кнопки = Новый СписокЗначений;
		
		Индекс = 0;
		Для каждого Элемент Из НайденныеСтроки Цикл
		
			Кнопки.Добавить(Индекс, Элемент.ОписаниеИсточника);
			
			Индекс = Индекс + 1;
			
		КонецЦикла;
		
		Оповещение = Новый ОписаниеОповещения("ВыбратьКонтекстПослеВыбораИсточника", ЭтотОбъект, НайденныеСтроки);
		
		ПоказатьВопрос(Оповещение, ТекстВопроса, Кнопки,, 0, НСтр("ru = 'Выбор источника данных'"));

	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьКонтекстПослеВыбораИсточника(ВыбранныйИсточник, НайденныеСтроки) Экспорт
	
	Оповещение = Новый ОписаниеОповещения("ВыбратьКонтекстПослеВыбораПервогоЗначения", ЭтотОбъект, НайденныеСтроки[ВыбранныйИсточник]);	
	ОткрытьФорму(НайденныеСтроки[ВыбранныйИсточник].ФормаВыбора, Новый Структура("РежимВыбора, ПоказатьДоступныеДляОбщения", Истина, Истина),,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура ВыбратьКонтекстПослеВыбораПервогоЗначения(ВыбранноеЗначение, ПараметрыКонтекста) Экспорт
	
	Если ЗначениеЗаполнено(ПараметрыКонтекста.ПромежуточнаяФормаВыбора)
		И ВыбранноеЗначение <> Неопределено Тогда
		
		ПараметрыФормы = Новый Структура(ПараметрыКонтекста.ИмяПараметраПромежуточнойФормы, ПолучитьКонтекстСообщения(ВыбранноеЗначение, ПараметрыКонтекста.ИмяПромежуточногоРеквизита));
		
		Оповещение = Новый ОписаниеОповещения("ВыбратьКонтекстОкончениеВыбора", ЭтотОбъект, ПараметрыКонтекста.ИмяРеквизита);
		ОткрытьФорму(ПараметрыКонтекста.ПромежуточнаяФормаВыбора, ПараметрыФормы,,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
	Иначе
	
	    ВыбратьКонтекстОкончениеВыбора(ВыбранноеЗначение, ПараметрыКонтекста.ИмяРеквизита);
	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВыбратьКонтекстОкончениеВыбора(ВыбранноеЗначение, ИмяРеквизита) Экспорт
	
	Если ВыбранноеЗначение <> Неопределено Тогда
		Контекст               = ПолучитьКонтекстСообщения(ВыбранноеЗначение, ИмяРеквизита);
		ПредставлениеКонтекста = ПредставлениеКонтекстаСообщения(Кому, Контекст, Объект.Тема, Объект.Пользователь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьАдресатаИзСписка(Команда)
	
	Оповещение = Новый ОписаниеОповещения("ПослеВыбораАдресата", ЭтотОбъект);
	СписокАдресатов.ПоказатьВыборЭлемента(Оповещение, НСтр("ru = 'Выберите адресата'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораАдресата(ВыбранноеЗначение, Параметры) Экспорт
	Если ВыбранноеЗначение <> Неопределено Тогда
		Контекст               = ВыбранноеЗначение.Значение;
		ПредставлениеКонтекста = ПредставлениеКонтекстаСообщения(Кому, Контекст, Объект.Тема, Объект.Пользователь);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПрикрепитьФайл(Команда)
	ОписаниеОповещения = Новый ОписаниеОповещения("ПрикрепитьФайлПродолжение", ЭтотОбъект);	
	ОткрытьФорму("ОбщаяФорма.ЗагрузкаФайловСУ", Новый Структура("УникальныйИдентификаторФормыВладельца, ИнформацияОПрикрепленныхФайлах", УникальныйИдентификатор, ИнформацияОПрикрепленныхФайлах),,,,,ОписаниеОповещения);	
КонецПроцедуры

&НаКлиенте
Процедура ПрикрепитьФайлПродолжение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	МассивПрикрепленныхФайлов = Новый Массив;
	
	Для каждого Строка Из РезультатЗакрытия Цикл
		
		ОписаниеФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(Строка.ПолноеИмя);
		ОписаниеФайла.Вставить("Адрес", Строка.АдресВХранилище);
		
		МассивПрикрепленныхФайлов.Добавить(ОписаниеФайла);
	
	КонецЦикла;
	
	ИнформацияОПрикрепленныхФайлах = Новый ФиксированныйМассив(МассивПрикрепленныхФайлов); // Запоминаем в реквизите формы
	
	Элементы.ИнформацияОПрикрепленномФайле.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Прикреплено файлов: %1'"), ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(ИнформацияОПрикрепленныхФайлах.Количество()));
	
КонецПроцедуры

&НаКлиенте
Процедура ПрикрепленныеФайлы(Команда)
	ПараметрыФормы = Новый Структура("ВладелецФайла, ТолькоПросмотр", Объект.Ссылка, Истина);
	ОткрытьФорму("Обработка.РаботаСФайлами.Форма.ПрисоединенныеФайлы", ПараметрыФормы);
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаКлиенте
Процедура УправлениеДоступностьюЭлементовФормы()
	
	Если ЗначениеЗаполнено(Кому) Тогда
		Элементы.ВыбратьКонтекст.Доступность = Истина;
	Иначе
		Элементы.ВыбратьКонтекст.Доступность = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УправлениеДоступностьюЭлементовФормыНаСервере()
	
	ЭтоГрупповоеОбсуждение = Документы.СообщениеСУО.ЭтоГрупповоеОбсуждение(Кому);
	
	// Общее
	
	Элементы.ГруппаРодительскоеСообщение.Видимость = ЗначениеЗаполнено(Объект.РодительскоеСообщение);
	
	// Тема
	
	Элементы.Тема.Видимость = ЗначениеЗаполнено(Объект.Тема);
	Элементы.НоваяТема.Видимость = НЕ ЗначениеЗаполнено(Объект.Тема);
	
	// Адресаты
	
	Элементы.ГруппаКому.ТолькоПросмотр = ЗначениеЗаполнено(Контекст);
	
	Элементы.Кому.ТолькоПросмотр = ЗначениеЗаполнено(Параметры.Кому); // Жестко задано при открытии
	
	Если НЕ ЭтоГрупповоеОбсуждение
		И (Элементы.Кому.ТолькоПросмотр ИЛИ НЕ Объект.Ссылка.Пустая() ИЛИ ЗначениеЗаполнено(Объект.РодительскоеСообщение)) Тогда
		
		Элементы.Кому.Видимость = Ложь; // Для записанных писем или когда жестко задано при открытии
		Элементы.ПредставлениеКонтекста.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
		
	КонецЕсли;
	
	НастройкиАдресатаПользователю = ДанныеОКонтексте.НайтиСтроки(Новый Структура("Кому", Перечисления.АдресатыСообщенийСУО.Пользователю));
	
	ЕстьПравоВыборкаПользователей = Пользователи.РолиДоступны("ЛичныйКабинетКаталогПользователейСУО", Пользователи.ТекущийПользователь(), Ложь);
	
	// ВыбратьАдресатаИзСписка
	
	Если НастройкиАдресатаПользователю.Количество() = 1
		И Элементы.Кому.ТолькоПросмотр
		И Кому = Перечисления.АдресатыСообщенийСУО.Пользователю Тогда
		
		Элементы.ВыбратьАдресатаИзСписка.Видимость = Истина;	
		
	Иначе
		
		Элементы.ВыбратьАдресатаИзСписка.Видимость = Ложь;	
		
	КонецЕсли;
	
	// ВыбратьКонтекст
	
	Если ЗначениеЗаполнено(Контекст) Тогда
		
		Элементы.ВыбратьКонтекст.Видимость = Ложь;
		
	Иначе
	
		Если НастройкиАдресатаПользователю.Количество() = 1
			И Элементы.Кому.ТолькоПросмотр
			И Кому = Перечисления.АдресатыСообщенийСУО.Пользователю Тогда

			Если НастройкиАдресатаПользователю[0].Доступность Тогда
				Элементы.ВыбратьКонтекст.Видимость = ЕстьПравоВыборкаПользователей;
			Иначе
				Элементы.ВыбратьКонтекст.Видимость = Ложь;
			КонецЕсли;

		Иначе

			Элементы.ВыбратьКонтекст.Видимость = ЕстьПравоВыборкаПользователей;

		КонецЕсли;
		
	КонецЕсли;
	
	// Файлы
	
	Элементы.ПрикрепленныеФайлы.Видимость = ЕстьФайлы;
	Элементы.ГруппаНовыйФайл.Видимость = Объект.Ссылка.Пустая();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьКонтекстСообщения(ЗначениеВыбора, ИмяРеквизита) Экспорт
	
	Если ЗначениеВыбора = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ОбщегоНазначенияСУ.ЗначениеРеквизитаВПривилегированномРежиме(ЗначениеВыбора, ИмяРеквизита);
	
КонецФункции

&НаСервереБезКонтекста
Функция ПредставлениеКонтекстаСообщения(Кому, Контекст, Тема, Пользователь) Экспорт
	
	ЭтоГрупповоеОбсуждение = Документы.СообщениеСУО.ЭтоГрупповоеОбсуждение(Кому);
	
	Если ЭтоГрупповоеОбсуждение
		ИЛИ НЕ ЗначениеЗаполнено(Тема) Тогда
	
		Возврат Документы.СообщениеСУО.ПредставлениеКонтекстаСообщения(Кому, Контекст);
		
	Иначе
		
		АвторТемы = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Тема, "Автор");
		
		Если АвторТемы = Пользователь Тогда
			Возврат Документы.СообщениеСУО.ПредставлениеКонтекстаСообщения(Кому, Контекст);
		Иначе
			Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АвторТемы, "Наименование");
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции




#КонецОбласти


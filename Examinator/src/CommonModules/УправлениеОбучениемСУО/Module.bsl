#Область СлужебныеПроцедурыИФункции

Процедура УстановитьФункциональныйПрофиль(Знач ИмяПрофиля = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ИмяПрофиля = Неопределено Тогда
		ИмяПрофиля = Метаданные.Имя;
	КонецЕсли;
	
	ПолныйИнтерфейсСУО = Ложь;
	ОбразовательнаяОрганизацияОО = Ложь;
	ЭкзаменаторЭР = Ложь;
	
	ИспользоватьСотрудников = Константы.ИспользоватьСотрудниковСУО.Получить();
	ИспользоватьСтудентов = Константы.ИспользоватьСтудентовСУО.Получить();
	ИспользоватьТолькоПользователей = Константы.ИспользоватьТолькоПользователейСУ.Получить();
	ИспользоватьСлушателей = Константы.ИспользоватьСлушателейСУО.Получить();
	
	Если Найти(ИмяПрофиля, "КорпоративныйУниверситет") = 1 Тогда
		
		ПолныйИнтерфейсСУО = Истина;
		
		Константы.ИспользоватьУниверсальныйСервисОбщенияСУО.Установить(Ложь);
		Константы.ИспользоватьЛичныеСообщенияСУО.Установить(Истина);
		Константы.ИспользоватьФорумыСУО.Установить(Истина);
		
		Если НЕ ИспользоватьСотрудников 
			И НЕ ИспользоватьСтудентов 
			И НЕ ИспользоватьТолькоПользователей 
			И НЕ ИспользоватьСлушателей Тогда
			
			Константы.ИспользоватьСотрудниковСУО.Установить(Истина);
			
		КонецЕсли;
		
		Если ИспользоватьСлушателей Тогда
			Константы.ИспользоватьПрограммыОбученияСУО.Установить(Ложь);
			Константы.ИспользоватьЗаявкиНаОбучениеСУО.Установить(Ложь);
		Иначе
			Константы.ИспользоватьПрограммыОбученияСУО.Установить(Истина);
			Константы.ИспользоватьЗаявкиНаОбучениеСУО.Установить(Истина);
		КонецЕсли;
		
	КонецЕсли;
	
	Если Найти(ИмяПрофиля, "ОбразовательнаяОрганизация") = 1 Тогда
		
		ОбразовательнаяОрганизацияОО = Истина;
		
		Константы.ИспользоватьУниверсальныйСервисОбщенияСУО.Установить(Ложь);
		Константы.ИспользоватьЛичныеСообщенияСУО.Установить(Истина);
		Константы.ИспользоватьФорумыСУО.Установить(Истина);
		Константы.ИспользоватьАнкетирование.Установить(Ложь);
		
		Константы.ИспользоватьСтудентовСУО.Установить(Истина);
		Константы.ИспользоватьСотрудниковСУО.Установить(Ложь);
		Константы.ИспользоватьСлушателейСУО.Установить(Ложь);
		Константы.ИспользоватьТолькоПользователейСУ.Установить(Ложь);
		Константы.РасширеннаяФункциональностьСУО.Установить(Ложь);
		
		Константы.ИспользоватьПрограммыОбученияСУО.Установить(Ложь);
		Константы.ИспользоватьЗаявкиНаОбучениеСУО.Установить(Ложь);
		
	КонецЕсли;
	
	Если Найти(ИмяПрофиля, "Экзаменатор") = 1 Тогда
		
		ЭкзаменаторЭР = Истина;
		
		Константы.ИспользоватьУниверсальныйСервисОбщенияСУО.Установить(Ложь);
		Константы.ИспользоватьЛичныеСообщенияСУО.Установить(Истина);
		Константы.ИспользоватьФорумыСУО.Установить(Ложь);
		Константы.ИспользоватьАнкетирование.Установить(Ложь);
		Константы.ИспользоватьДополнительныеМатериалыСУЗ.Установить(Ложь);
		Константы.ПоказыватьОбщиеДополнительныеМатериалыПослеПроверкиСУЗ.Установить(Ложь);
		Константы.РасширеннаяФункциональностьСУО.Установить(Ложь);
		
		Если НЕ ИспользоватьСотрудников 
			И НЕ ИспользоватьСтудентов 
			И НЕ ИспользоватьТолькоПользователей
			И НЕ ИспользоватьСлушателей Тогда
			
			Константы.ИспользоватьСотрудниковСУО.Установить(Истина);
			
		КонецЕсли;
		
		Константы.ИспользоватьПрограммыОбученияСУО.Установить(Ложь);
		Константы.ИспользоватьЗаявкиНаОбучениеСУО.Установить(Ложь);
		
	КонецЕсли;
				
	Константы.ПолныйИнтерфейсСУО.Установить(ПолныйИнтерфейсСУО);
	Константы.ОбразовательнаяОрганизацияОО.Установить(ОбразовательнаяОрганизацияОО);
	Константы.ЭкзаменаторЭР.Установить(ЭкзаменаторЭР);	
	
	РегистрыСведений.НастройкиУчебныхМатериаловСУО.УстановитьНастройки();
	
КонецПроцедуры

#Область Обучение 

Функция ЗачислитьУчастникаНаОбучение(Знач ПроведениеОбучения, Знач Сценарий = Неопределено, Знач Пользователь, Знач УчебнаяГруппа = Неопределено, Знач РодительскоеПрохождение = Неопределено, Знач Заявка = Неопределено, Знач ДелатьПроверки = Истина, Знач ОбновлятьСуществующее = Ложь, Знач ОбновитьДанныеВебКабинета = Ложь, Знач ЭтоИнтерактивноеЗачисление = Ложь, Знач ЭтоАвтозачисление = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем переменные
	//
	
	ДанныеОПроведении = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПроведениеОбучения, "ПроведениеПрограммыОбучения, ДатаНачалаПроведения, ОткрытоеМероприятие, ДатаОткрытияЗаписи, ДатаЗакрытияЗаписи, МаксимальноеКоличествоУчастников, Мероприятие, ЭлектронныйРесурс, НаОсновеЭлектронногоРесурса, НаОсновеМероприятия, БезСценария, ПрименениеУсловийЗачисления, ДатаКонтроля, СхемаПроведения, ВидОбучения, Проведен, ФильтрПоДатеПриемаНаРаботу");
	
	Если НЕ ЗначениеЗаполнено(Сценарий) Тогда
		Сценарий = Документы.ПроведениеОбученияСУО.СценарийОбучения(ПроведениеОбучения);
	КонецЕсли;
	
	ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(ДанныеОПроведении, Сценарий);
	
	СуществующееПрохождение = Документы.ПроведениеОбученияСУО.ПрохождениеОбучения(ПроведениеОбучения, Сценарий, Пользователь);
	
	// Делаем проверки возможности записи
	//
	
	Если ЭтоАвтозачисление
		И НЕ ЗначениеЗаполнено(СуществующееПрохождение)
		И Документы.ПроведениеОбученияСУО.ЕстьОтмененныеПрохожденияОбучения(ПроведениеОбучения, Пользователь, Сценарий) Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	Если ДелатьПроверки И (ДанныеОПроведении.Мероприятие = Сценарий  
		ИЛИ ДанныеОПроведении.НаОсновеЭлектронногоРесурса
		ИЛИ ДанныеОПроведении.БезСценария) Тогда
		
		РезультатБазовойПроверки = Документы.ПроведениеОбученияСУО.ПроверитьВозможностьЗачисленияНаОбучение(Пользователь, ПроведениеОбучения, ДанныеОПроведении, СуществующееПрохождение);
	
		Если РезультатБазовойПроверки.ЕстьОшибки Тогда
			Текст = НСтр("ru = 'Пользователь %1 не может быть зачислен. %2'");
			Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст, Пользователь, РезультатБазовойПроверки.ТекстОшибки);				
			Если ЭтоИнтерактивноеЗачисление Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
			Иначе
				ЗаписьЖурналаРегистрации(НСтр("ru = 'Зачисление участника на обучение'"),
					УровеньЖурналаРегистрации.Предупреждение,,ПроведениеОбучения,Текст);
			КонецЕсли;
			Возврат Неопределено;
		КонецЕсли;		
				
	КонецЕсли;
		
	// Создаем новое прохождение обучения или если оно есть возвращаем
	//
	
	Если НЕ ОбновлятьСуществующее И ЗначениеЗаполнено(СуществующееПрохождение) Тогда
		
		Если ЗначениеЗаполнено(ДанныеОПроведении.ПроведениеПрограммыОбучения)
			И НЕ ЗначениеЗаполнено(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СуществующееПрохождение, "ПрохождениеПрограммыОбучения")) Тогда
			
			ОбновлятьСуществующее = Истина; // Если зачислили не через программу, а потом к ней присоединили
			
		КонецЕсли;
		
		Если НЕ ОбновлятьСуществующее Тогда		
			Возврат СуществующееПрохождение;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СуществующееПрохождение) Тогда
				
		ПрохождениеОбъект = СуществующееПрохождение.ПолучитьОбъект();
		
	Иначе
		
		ПрохождениеОбъект = Документы.ПрохождениеОбученияСУО.СоздатьДокумент();
		
		ПрохождениеОбъект.Дата                        = ТекущаяДата();
		ПрохождениеОбъект.Пользователь                = Пользователь;
		ПрохождениеОбъект.ПроведениеОбучения          = ПроведениеОбучения;
		ПрохождениеОбъект.Сценарий                    = Сценарий;		
		ПрохождениеОбъект.Статус                      = Перечисления.СтатусыПрохожденияОбъектовСУО.Зачислен;
		
		Если ЗначениеЗаполнено(РодительскоеПрохождение) Тогда
			ПрохождениеОбъект.РодительскоеПрохождение = РодительскоеПрохождение;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(УчебнаяГруппа) Тогда
		ПрохождениеОбъект.УчебнаяГруппа = УчебнаяГруппа;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Заявка) Тогда
		ПрохождениеОбъект.Заявка = Заявка;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеОПроведении.ПроведениеПрограммыОбучения) Тогда
		ПрохождениеПрограммыОбучения = Документы.ПроведениеПрограммыОбученияСУО.ПрохождениеПрограммыОбучения(ДанныеОПроведении.ПроведениеПрограммыОбучения, Пользователь);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПрохождениеПрограммыОбучения) Тогда
		ПрохождениеОбъект.ПрохождениеПрограммыОбучения = ПрохождениеПрограммыОбучения;
	КонецЕсли;
	
	Если ВидОбучения.ТребуетсяПреподаватель
		И НЕ ВидОбучения.Общее Тогда
	
		Если ВидОбучения.Электронное
			И ВидОбучения.ВыставляетсяОценка Тогда
			
			// Если есть электронный ресурс, то считаем,
			// что проверка не требуется. В процессе прохождение
			// это может быть изменено, если в тестах есть открытые вопросы.
			
			// Преподаватель не требуется, если есть задания, так как
			// они тоже могут быть не требующие проверки. При прохождении
			// это может быть изменено. если окажется, что есть задания,
			// требующие проверки.
			
			// Если нет электронного ресурса и заданий и выставляется оценка
			// за электронное обучение, то проверка явно нужна, например,
			// чтобы проверить прикрепленный файл и выставить оценку.
			
			Если ЗначениеЗаполнено(Документы.ПроведениеОбученияСУО.ЭлектронныйРесурсОбучения(ДанныеОПроведении, Сценарий))
				ИЛИ Документы.ПроведениеОбученияСУО.ЗаданияОбучения(ПроведениеОбучения, Сценарий,,ВидОбучения).Количество() > 0 Тогда
				
				ПрохождениеОбъект.ПроверяетсяПреподавателем = Ложь;
				
			Иначе
				
				ПрохождениеОбъект.ПроверяетсяПреподавателем = Истина;
				
			КонецЕсли;
			
		Иначе
			
			// Не электронные обучения, например, вебинар не проверяются преподавателем,
			// даже если за них выставляется оценка.
			
			ПрохождениеОбъект.ПроверяетсяПреподавателем = Ложь;
			
		КонецЕсли;		
		
	Иначе
		
		ПрохождениеОбъект.ПроверяетсяПреподавателем = Ложь;
		
	КонецЕсли;	
	
	ЭтоНовоеИнтерактивноеЗачисление = ПрохождениеОбъект.ЭтоНовый() И ЭтоИнтерактивноеЗачисление;
	
	Если НЕ ЭтоНовоеИнтерактивноеЗачисление
		И ДанныеОПроведении.Проведен 
		И НЕ ПрохождениеОбъект.ПометкаУдаления Тогда
		ПрохождениеОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Иначе
		ПрохождениеОбъект.ДополнительныеСвойства.Вставить("НеОбновлятьДанныеВебКабинета", Истина);
		// Данные веб-кабинета не следует обновлять, так как документ новый и не проведенный.
		// Задание на обновление будет создано при проведении документа.
		ПрохождениеОбъект.Записать(РежимЗаписиДокумента.Запись);
	КонецЕсли;
	
	// Зачисляем на подчиненные мероприятия
	//	
	
	Если ТипЗнч(Сценарий) = Тип("СправочникСсылка.КаталогМероприятийСУО")
		И НЕ ЗначениеЗаполнено(РодительскоеПрохождение)
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сценарий, "Вид.Общее") Тогда
		
		ТаблицаПодчиненныхМероприятий = Документы.ПроведениеОбученияСУО.ПодчиненныеМероприятия(ПроведениеОбучения);
		
		Если ТаблицаПодчиненныхМероприятий.Количество() > 0 Тогда
		
			Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеОПроведении.СхемаПроведения, "ПоследовательноеПрохождение") Тогда
				
				// При последовательном прохождении зачисляем только на первое обучение.
				// На остальные будем зачислять в событии ПриПрохожденииМероприятия.
				// При этом, если родительское обучение не актуально, то зачисление не происходит.
				
				Если Документы.ПрохождениеОбученияСУО.Актуально(ПрохождениеОбъект.Ссылка) Тогда 				
					ЗачислитьУчастникаНаОбучение(ПроведениеОбучения, ТаблицаПодчиненныхМероприятий[0].Мероприятие, Пользователь, УчебнаяГруппа, ПрохождениеОбъект.Ссылка, Заявка,,,ОбновитьДанныеВебКабинета); // Рекурсия
				КонецЕсли;
				
			Иначе
				
				// Зачисляем на все подчиненные
				
				Для каждого Строка Из ТаблицаПодчиненныхМероприятий Цикл
					ЗачислитьУчастникаНаОбучение(ПроведениеОбучения, Строка.Мероприятие, Пользователь, УчебнаяГруппа, ПрохождениеОбъект.Ссылка, Заявка,,,ОбновитьДанныеВебКабинета); // Рекурсия
				КонецЦикла;				
				
			КонецЕсли;
			
		КонецЕсли;
			
	КонецЕсли;		
	
	// Создаем автоматическую рассылку
	//
	
	УправлениеОбучениемСУО.СоздатьАвтоматическуюРассылку(ПрохождениеОбъект);
	
	// Добавляем документ проведения обучения в документы, требующие перепроведения
	//
	
	Если ОбновитьДанныеВебКабинета Тогда		
		Документы.ПрохождениеОбученияСУО.ОбновитьДанныеВебКабинета(ПрохождениеОбъект.Ссылка);
	КонецЕсли;
	
	Если НЕ ЭтоИнтерактивноеЗачисление Тогда
		РегистрыСведений.ДокументыТребующиеПерепроведенияСУО.ДобавитьДокумент(ПроведениеОбучения);
	КонецЕсли;
	
	Возврат ПрохождениеОбъект.Ссылка;
	
КонецФункции

Функция НазначитьПреподавателяНаОбучение(Знач ПроведениеОбучения, Знач Сценарий = Неопределено, Знач Преподаватель, Знач Роль = Неопределено, Знач РекурсивныйВызов = Ложь, Знач РодительскоеПроведение = Неопределено, Знач ЭтоИнтерактивноеЗачисление = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем данные
	//
	
	ДанныеОПроведении  = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПроведениеОбучения, "Мероприятие, ЭлектронныйРесурс, НаОсновеЭлектронногоРесурса, Проведен, СхемаПроведения, НаОсновеМероприятия, БезСценария, ВидОбучения");
	
	Если НЕ ЗначениеЗаполнено(Сценарий) Тогда
		Сценарий = Документы.ПроведениеОбученияСУО.СценарийОбучения(ПроведениеОбучения);
	КонецЕсли;	
	
	// Зачисляем на общее мероприятие
	//
	
	Если ТипЗнч(Сценарий) = Тип("СправочникСсылка.КаталогМероприятийСУО")
		И ДанныеОПроведении.Мероприятие <> Сценарий
		И НЕ РекурсивныйВызов
		И РодительскоеПроведение = Неопределено Тогда 
		
		// Это подчиненное мероприятие
		
		// Создаем документ, фиксирующий проведение общего мероприятия, если его еще нет.

		РодительскоеПроведение = Документы.ПроведениеОбученияСУО.ПроведениеОбученияПреподавателем(ПроведениеОбучения, ДанныеОПроведении.Мероприятие, Преподаватель);
		
		Если НЕ ЗначениеЗаполнено(РодительскоеПроведение) Тогда
			
			РодительскоеПроведениеОбъект = Документы.ПроведениеПреподавателемОбученияСУО.СоздатьДокумент();
			РодительскоеПроведениеОбъект.Дата = ТекущаяДата();
			РодительскоеПроведениеОбъект.Пользователь         = Преподаватель;
			РодительскоеПроведениеОбъект.Сценарий             = ДанныеОПроведении.Мероприятие;
			РодительскоеПроведениеОбъект.ПроведениеОбучения   = ПроведениеОбучения;
			
			// Роль преподавателя не указывается, так как он может иметь разные роли в рамках одного общего курса.
			
			Если ДанныеОПроведении.Проведен Тогда
				РодительскоеПроведениеОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Иначе
				РодительскоеПроведениеОбъект.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
			
			РодительскоеПроведение = РодительскоеПроведениеОбъект.Ссылка;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Ищем существующее проведение
	//

	Проведение = Документы.ПроведениеОбученияСУО.ПроведениеОбученияПреподавателем(ПроведениеОбучения, Сценарий, Преподаватель);
	
	Если ЗначениеЗаполнено(Проведение) Тогда
		
		ПроведениеОбъект = Проведение.ПолучитьОбъект();
		
	Иначе
		
		ПроведениеОбъект = Документы.ПроведениеПреподавателемОбученияСУО.СоздатьДокумент();
		ПроведениеОбъект.Дата                        = ТекущаяДата();
		ПроведениеОбъект.Сценарий                    = Сценарий;
		ПроведениеОбъект.ПроведениеОбучения          = ПроведениеОбучения;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Роль) Тогда
		ПроведениеОбъект.Роль = Роль;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Роль) И ТипЗнч(Роль) = Тип("СправочникСсылка.КаталогМероприятийСУО") Тогда
		ПроведениеОбъект.Роль = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сценарий, "РольПреподавателя");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Роль) Тогда
		ПроведениеОбъект.Роль = Справочники.РолиПреподавателейСУО.Модератор;
	КонецЕсли;
	
	ПроведениеОбъект.Пользователь = Преподаватель;
	
	Если ЗначениеЗаполнено(РодительскоеПроведение) Тогда
		ПроведениеОбъект.РодительскоеПроведение = РодительскоеПроведение;
	КонецЕсли;
	
	ЭтоНовоеИнтерактивноеЗачисление = ПроведениеОбъект.ЭтоНовый() И ЭтоИнтерактивноеЗачисление;
	
	Если НЕ ЭтоНовоеИнтерактивноеЗачисление И ДанныеОПроведении.Проведен И НЕ ПроведениеОбъект.ПометкаУдаления Тогда
		ПроведениеОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Иначе
		ПроведениеОбъект.ДополнительныеСвойства.Вставить("НеОбновлятьДанныеВебКабинета", Истина);
		ПроведениеОбъект.Записать(РежимЗаписиДокумента.Запись);
	КонецЕсли;
	
	Если НЕ РекурсивныйВызов И НЕ УправлениеОбучениемСУО.ЕстьРольПреподавателя(Преподаватель) Тогда
		Текст = НСтр("ru = 'Предупреждение: %1 не имеет прав преподавателя'");
		Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст, Преподаватель);
		Если ЭтоИнтерактивноеЗачисление Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
		Иначе
			ЗаписьЖурналаРегистрации(НСтр("ru = 'Назначение преподавателя на обучение'"),
					УровеньЖурналаРегистрации.Предупреждение,,ПроведениеОбучения,Текст);
		КонецЕсли;
	КонецЕсли;			
	
	// Зачисляем на подчиненные мероприятия
	//
	
	Если ДанныеОПроведении.ВидОбучения.Общее И ДанныеОПроведении.Мероприятие = Сценарий Тогда
		
		ПодчиненныеМероприятия = Документы.ПроведениеОбученияСУО.ПодчиненныеМероприятия(
			ПроведениеОбучения, Истина, ДанныеОПроведении.СхемаПроведения);
		
		Для каждого Строка Из ПодчиненныеМероприятия Цикл
			НазначитьПреподавателяНаОбучение(
				ПроведениеОбучения, Строка.Мероприятие, Преподаватель, Роль, Истина, ПроведениеОбъект.Ссылка); // Рекурсия		
		КонецЦикла;
		
	КонецЕсли;
	
	// Создаем рассылку
	//
	
	УправлениеОбучениемСУО.СоздатьАвтоматическуюРассылку(ПроведениеОбъект);
	
	// Добавляем документ проведения обучения в документы, требующие перепроведения
	//
	
	Если НЕ ЭтоИнтерактивноеЗачисление Тогда
		РегистрыСведений.ДокументыТребующиеПерепроведенияСУО.ДобавитьДокумент(ПроведениеОбучения);
	КонецЕсли;
	
	Возврат ПроведениеОбъект.Ссылка;
	
КонецФункции

Функция ЗачислитьУчастникаНаПрограммуОбучения(ПроведениеПрограммыОбучения, Пользователь, УчебнаяГруппа = Неопределено, Заявка = Неопределено, ОбновлятьСуществующее = Ложь, ОбновитьДанныеВебКабинета = Ложь, Знач ЭтоИнтерактивноеЗачисление = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеОПроведении = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПроведениеПрограммыОбучения,
		"ОткрытаяПрограмма, ДатаОткрытияЗаписи, ДатаЗакрытияЗаписи, МаксимальноеКоличествоУчастников, БезСценария, ПрограммаОбучения, Ссылка, Проведен");
	
	МаксимальноеКоличествоУчастников = ДанныеОПроведении.МаксимальноеКоличествоУчастников;
	
	Если МаксимальноеКоличествоУчастников > 0 Тогда
	
		КоличествоЗачисленныхУчастников  = Документы.ПроведениеПрограммыОбученияСУО.КоличествоУчастниковПрограммыОбучения(ПроведениеПрограммыОбучения);
		
		Если КоличествоЗачисленныхУчастников >= МаксимальноеКоличествоУчастников Тогда			
			Текст = НСтр("ru = 'Пользователь %1 не может быть зачислен на программу обучения. Превышено допустимое количество участников'");
			Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст, Пользователь);
			Если ЭтоИнтерактивноеЗачисление Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);			
			Иначе
				ЗаписьЖурналаРегистрации(НСтр("ru = 'Зачисление участника на программу обучения'"),
					УровеньЖурналаРегистрации.Предупреждение,,ПроведениеПрограммыОбучения,Текст);
			КонецЕсли;
			Возврат Неопределено;			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ДанныеОПроведении.ОткрытаяПрограмма Тогда
		
		Если ЗначениеЗаполнено(ДанныеОПроведении.ДатаОткрытияЗаписи)
			И ТекущаяДата() < ДанныеОПроведении.ДатаОткрытияЗаписи Тогда		
			Текст = НСтр("ru = 'Пользователь %1 не может быть зачислен на программу обучения. Запись будет открыта с %2'");
			Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст, Пользователь, ДанныеОПроведении.ДатаОткрытияЗаписи);
			Если ЭтоИнтерактивноеЗачисление Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);			
			Иначе
				ЗаписьЖурналаРегистрации(НСтр("ru = 'Зачисление участника на программу обучения'"),
					УровеньЖурналаРегистрации.Предупреждение,,ПроведениеПрограммыОбучения,Текст);
			КонецЕсли;
			Возврат Неопределено;			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеОПроведении.ДатаЗакрытияЗаписи)
			И ТекущаяДата() > ДанныеОПроведении.ДатаЗакрытияЗаписи Тогда		
			Текст = НСтр("ru = 'Пользователь %1 не может быть зачислен на программу обучения. Запись была доступна до %2'");
			Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст, Пользователь, ДанныеОПроведении.ДатаЗакрытияЗаписи);
			Если ЭтоИнтерактивноеЗачисление Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);			
			Иначе
				ЗаписьЖурналаРегистрации(НСтр("ru = 'Зачисление участника на программу обучения'"),
					УровеньЖурналаРегистрации.Предупреждение,,ПроведениеПрограммыОбучения,Текст);
			КонецЕсли;
			Возврат Неопределено;			
		КонецЕсли;
		
	КонецЕсли;
	
	СуществующееПрохождение = Документы.ПроведениеПрограммыОбученияСУО.ПрохождениеПрограммыОбучения(ПроведениеПрограммыОбучения, Пользователь);
	
	Если НЕ ЭтоИнтерактивноеЗачисление
		И НЕ ЗначениеЗаполнено(СуществующееПрохождение)
		И Документы.ПроведениеПрограммыОбученияСУО.ЕстьОтмененныеПрохождения(ПроведениеПрограммыОбучения, Пользователь) Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	Если НЕ ОбновлятьСуществующее
		И ЗначениеЗаполнено(СуществующееПрохождение) Тогда
		
		Возврат СуществующееПрохождение;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СуществующееПрохождение) Тогда
		
		ПрохождениеОбъект = СуществующееПрохождение.ПолучитьОбъект();
		
	Иначе
		
		ПрохождениеОбъект = Документы.ПрохождениеПрограммыОбученияСУО.СоздатьДокумент();
		
		ПрохождениеОбъект.Дата                        = ТекущаяДата();
		ПрохождениеОбъект.Пользователь                = Пользователь;
		ПрохождениеОбъект.Сценарий                    = Документы.ПроведениеПрограммыОбученияСУО.СценарийОбучения(ДанныеОПроведении);
		ПрохождениеОбъект.ПроведениеПрограммыОбучения = ПроведениеПрограммыОбучения;
		ПрохождениеОбъект.Статус                      = Перечисления.СтатусыПрохожденияОбъектовСУО.Зачислен;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(УчебнаяГруппа) Тогда
		ПрохождениеОбъект.УчебнаяГруппа = УчебнаяГруппа;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Заявка) Тогда
		ПрохождениеОбъект.Заявка = Заявка;
	КонецЕсли;
	
	ЭтоНовоеИнтерактивноеЗачисление = ПрохождениеОбъект.ЭтоНовый() И ЭтоИнтерактивноеЗачисление;
	
	Если НЕ ЭтоНовоеИнтерактивноеЗачисление И ДанныеОПроведении.Проведен И НЕ ПрохождениеОбъект.ПометкаУдаления Тогда
		
		ПрохождениеОбъект.Записать(РежимЗаписиДокумента.Проведение);
				
		ТаблицаМероприятий = Документы.ПроведениеПрограммыОбученияСУО.ПроведенияОбучения(ПроведениеПрограммыОбучения);
			
		Для каждого Строка Из ТаблицаМероприятий Цикл		
			ЗачислитьУчастникаНаОбучение(Строка.ПроведениеОбучения, Строка.Мероприятие, Пользователь, УчебнаяГруппа,,,Ложь,, ОбновитьДанныеВебКабинета, ЭтоИнтерактивноеЗачисление, Истина);
		КонецЦикла;

		УправлениеОбучениемСУО.СоздатьАвтоматическуюРассылку(ПрохождениеОбъект);
		
		РегистрыСведений.ДокументыТребующиеПерепроведенияСУО.ДобавитьДокумент(ПроведениеПрограммыОбучения);		
		
	Иначе
		
		ПрохождениеОбъект.ДополнительныеСвойства.Вставить("НеОбновлятьДанныеВебКабинета", Истина);
		ПрохождениеОбъект.Записать(РежимЗаписиДокумента.Запись);
		
	КонецЕсли;	
	
	Возврат ПрохождениеОбъект.Ссылка;
	
КонецФункции

#КонецОбласти

#Область Пользователи

Функция ВходВПрограммуРазрешен(Пользователь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВходВПрограммуРазрешен = Ложь;
	
	ВходВПрограммуРазрешен = Пользователи.ВходВПрограммуРазрешен(Пользователь);
	
	Если НЕ ВходВПрограммуРазрешен
		И ВебКабинетСУ.Используется() Тогда
		
		ВходВПрограммуРазрешен = РегистрыСведений.ПользователиВебКабинетаСУ.ПользовательСуществует(,Пользователь); 
		
	КонецЕсли;
	
	Возврат ВходВПрограммуРазрешен;
	
КонецФункции

Процедура УстановитьКонстантуИспользоватьТолькоПользователейСУ() Экспорт
	УстановитьПривилегированныйРежим(Истина);	
	ИспользоватьСотрудников = Константы.ИспользоватьСотрудниковСУО.Получить();
	ИспользоватьСтудентов = Константы.ИспользоватьСтудентовСУО.Получить();
	ИспользоватьСлушателей = Константы.ИспользоватьСлушателейСУО.Получить();	
	ИспользоватьТолькоПользователей = НЕ ИспользоватьСотрудников И НЕ ИспользоватьСтудентов И НЕ ИспользоватьСлушателей; 
	Константы.ИспользоватьТолькоПользователейСУ.Установить(ИспользоватьТолькоПользователей);
КонецПроцедуры

Функция ОбязательныеРеквизитыСлушателяУЦ() Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДополнительныеРеквизитыИСведения.Ссылка,
		|	ДополнительныеРеквизитыИСведения.Заголовок
		|ИЗ
		|	ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
		|ГДЕ
		|	ДополнительныеРеквизитыИСведения.НаборСвойств = &НаборСвойствПользователи
		|	И ДополнительныеРеквизитыИСведения.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("НаборСвойствПользователи", УправлениеСвойствами.НаборСвойствПоИмени("Справочник_Пользователи"));
	
	ТаблицаРеквизитовВБазе = Запрос.Выполнить().Выгрузить();
		
	ТаблицаРеквизитов = Новый ТаблицаЗначений;
	ТаблицаРеквизитов.Колонки.Добавить("Наименование");
	ТаблицаРеквизитов.Колонки.Добавить("НаименованиеАнгл");
	ТаблицаРеквизитов.Колонки.Добавить("ИмяРеквизита");
	ТаблицаРеквизитов.Колонки.Добавить("АвтоСсылка");
	ТаблицаРеквизитов.Колонки.Добавить("Ссылка");
	ТаблицаРеквизитов.Колонки.Добавить("Существует");
	ТаблицаРеквизитов.Колонки.Добавить("ТипЗначения");
	ТаблицаРеквизитов.Колонки.Добавить("Варианты");
	ТаблицаРеквизитов.Колонки.Добавить("КвалификаторыДаты");	
	ТаблицаРеквизитов.Колонки.Добавить("ИмяПоляФормы");
	
	// Поля: СНИЛС, Дата рождения, Пол (выбор из списка Муж/Жен)
		
	ТаблицаВариантов = Новый ТаблицаЗначений;
	ТаблицаВариантов.Колонки.Добавить("Наименование");
	ТаблицаВариантов.Колонки.Добавить("Идентификатор");
	НоваяСтрокаТВ = ТаблицаВариантов.Добавить();
	НоваяСтрокаТВ.Идентификатор = "2b7b803e-d429-4c63-ac0d-3cf608304738";
	НоваяСтрокаТВ.Наименование = "Мужской";
	НоваяСтрокаТВ = ТаблицаВариантов.Добавить();
	НоваяСтрокаТВ.Идентификатор = "b9a8d565-750e-42de-bc0a-eb0ccd7f4519";
	НоваяСтрокаТВ.Наименование = "Женский";
	ЗаполнитьТаблицуОбязательныхРеквизитовСлушателяУЦ(ТаблицаРеквизитов, ТаблицаРеквизитовВБазе, "Пол", "Sex", "Пол", "Gender", "e004ecbc-060b-4e57-ba2a-e7369a44509e", "СправочникСсылка.ЗначенияСвойствОбъектов", ТаблицаВариантов);

	ЗаполнитьТаблицуОбязательныхРеквизитовСлушателяУЦ(ТаблицаРеквизитов, ТаблицаРеквизитовВБазе, "Дата рождения", "Birthday", "ДатаРождения", "Birthday" , "57333403-c823-4ae8-a922-7d215f565ec9", "Дата",, Новый КвалификаторыДаты(ЧастиДаты.Дата));
	
	ЗаполнитьТаблицуОбязательныхРеквизитовСлушателяУЦ(ТаблицаРеквизитов, ТаблицаРеквизитовВБазе, "СНИЛС", "PFR number", "СтраховойНомерПФР", "PFRNumber", "bf6339f3-3dea-459e-a959-c66557d97061", "Строка");
	
	Возврат ТаблицаРеквизитов;
	
КонецФункции

Процедура ЗаполнитьТаблицуОбязательныхРеквизитовСлушателяУЦ(ТаблицаРеквизитов, ТаблицаРеквизитовВБазе, Наименование, НаименованиеАнгл, ИмяРеквизита, ИмяПоляФормы, АвтоИдентификатор, ТипЗначения, Варианты = Неопределено, КвалификаторыДаты = Неопределено)
	
	НоваяСтрока = ТаблицаРеквизитов.Добавить();
	НоваяСтрока.Наименование = Наименование;	
	НоваяСтрока.АвтоСсылка = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.ПолучитьСсылку(
		Новый УникальныйИдентификатор(АвтоИдентификатор)); 
	НоваяСтрока.ТипЗначения = ТипЗначения;
	НоваяСтрока.Варианты = Варианты;
	НоваяСтрока.Существует = Ложь;
	НоваяСтрока.КвалификаторыДаты = КвалификаторыДаты;
	НоваяСтрока.ИмяРеквизита = ИмяРеквизита;
	НоваяСтрока.ИмяПоляФормы = ИмяПоляФормы;
	НоваяСтрока.НаименованиеАнгл = НаименованиеАнгл;

	Если НЕ НоваяСтрока.Существует Тогда
		НайденнаяСтрока = ТаблицаРеквизитовВБазе.Найти(НоваяСтрока.АвтоСсылка, "Ссылка");	
		Если НайденнаяСтрока <> Неопределено Тогда
			НоваяСтрока.Ссылка = НоваяСтрока.АвтоСсылка;
			НоваяСтрока.Существует = Истина;
		КонецЕсли;	
	КонецЕсли;
	
	Если НЕ НоваяСтрока.Существует Тогда
		НайденнаяСтрока = ТаблицаРеквизитовВБазе.Найти(НоваяСтрока.Наименование, "Заголовок");
		Если НайденнаяСтрока <> Неопределено Тогда
			НоваяСтрока.Ссылка = НайденнаяСтрока.Ссылка;
			НоваяСтрока.Существует = Истина;
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

Процедура УстановитьОбязательныеРеквизитыСлушателяУЦ() Экспорт
		
	ТаблицаРеквизитов = ОбязательныеРеквизитыСлушателяУЦ();
	
	НачатьТранзакцию();
	
	Попытка
		
		Для каждого Строка Из ТаблицаРеквизитов Цикл
			
			Если Строка.Существует Тогда
				НовыйРеквизитОбъект = Строка.Ссылка.ПолучитьОбъект();
			Иначе
				НовыйРеквизитОбъект = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.СоздатьЭлемент();
				НовыйРеквизитОбъект.УстановитьСсылкуНового(Строка.АвтоСсылка);
			КонецЕсли;						
			
			НовыйРеквизитОбъект.Наименование = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = '%1 (Пользователь)'"), Строка.Наименование);
			
			Если Строка.ТипЗначения = "СправочникСсылка.ЗначенияСвойствОбъектов" Тогда			
				НовыйРеквизитОбъект.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.ЗначенияСвойствОбъектов");
				НовыйРеквизитОбъект.ДополнительныеЗначенияИспользуются = Истина;
			ИначеЕсли Строка.ТипЗначения = "Дата" Тогда
				НовыйРеквизитОбъект.ТипЗначения = Новый ОписаниеТипов(Строка.ТипЗначения,,,,, Строка.КвалификаторыДаты);
			Иначе			
				НовыйРеквизитОбъект.ТипЗначения = Новый ОписаниеТипов(Строка.ТипЗначения);			
			КонецЕсли;
			
			НовыйРеквизитОбъект.Заголовок = Строка.Наименование;
			НовыйРеквизитОбъект.НаборСвойств = УправлениеСвойствами.НаборСвойствПоИмени("Справочник_Пользователи");
			НовыйРеквизитОбъект.Записать();
			
			НовыйРеквизит = НовыйРеквизитОбъект.Ссылка;
									
			НаборСвойствОбъект = НовыйРеквизитОбъект.НаборСвойств.ПолучитьОбъект();
			ТабличнаяЧасть = НаборСвойствОбъект.ДополнительныеРеквизиты;
			НайденнаяСтрока = ТабличнаяЧасть.Найти(НовыйРеквизит, "Свойство");
			Если НайденнаяСтрока = Неопределено Тогда
				НоваяСтрока = ТабличнаяЧасть.Добавить();
				НоваяСтрока.Свойство = НовыйРеквизит;
				НаборСвойствОбъект.Записать();
			Иначе
				НаборСвойствОбъект = Неопределено;
			КонецЕсли;
			
			Если Строка.ТипЗначения = "СправочникСсылка.ЗначенияСвойствОбъектов" Тогда			
				Для каждого СтрокаТВ Из Строка.Варианты Цикл
					СуществующийВариантСсылка = Справочники.ЗначенияСвойствОбъектов.ПолучитьСсылку(
						Новый УникальныйИдентификатор(СтрокаТВ.Идентификатор));
					Если НЕ ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(СуществующийВариантСсылка) Тогда
							СуществующийВариантСсылка = Неопределено;
					КонецЕсли;
					Если СуществующийВариантСсылка = Неопределено Тогда
						СуществующийВариантСсылка = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию(СтрокаТВ.Наименование,,,НовыйРеквизит);
					КонецЕсли;
					Если ЗначениеЗаполнено(СуществующийВариантСсылка) Тогда
						ЗначенияСвойстваОбъект = СуществующийВариантСсылка.ПолучитьОбъект();
					Иначе
						ЗначенияСвойстваОбъект = Справочники.ЗначенияСвойствОбъектов.СоздатьЭлемент();
						ЗначенияСвойстваОбъект.Владелец = НовыйРеквизит;
					КонецЕсли;												
					ЗначенияСвойстваОбъект.Наименование = СтрокаТВ.Наименование;
					ЗначенияСвойстваОбъект.Записать();					
				КонецЦикла;			
			КонецЕсли;
			
		КонецЦикла;	
		
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗагрузитьПользователей(ДанныеСтрока) Экспорт
	
	ТелоХранилище = XMLЗначение(Тип("ХранилищеЗначения"), ДанныеСтрока);	
	СтруктураДанных = ТелоХранилище.Получить();
	
	Если ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		ВызватьИсключение НСтр("ru = 'Неверный формат структуры данных'");													
	КонецЕсли;
	
	// Загружаем данные
	
	НачатьТранзакцию();
	
	Попытка
		
		УстановитьПривилегированныйРежим(Истина);
		
		// Формируем группы пользователей на основе групп физических лиц
		
		Если СтруктураДанных.Свойство("ГруппыФизическихЛиц") Тогда
			УправлениеОбучениемСУО.ЗагрузитьГруппыПользователейИзГруппФизическихЛиц(СтруктураДанных.ГруппыФизическихЛиц);
		КонецЕсли;
		
		// Формируем должности
		
		Если СтруктураДанных.Свойство("Должности") Тогда
			УправлениеОбучениемСУО.ЗагрузитьДолжности(СтруктураДанных.Должности);
		КонецЕсли;		
		
		// Формируем структуру предприятия
		
		Если СтруктураДанных.Свойство("СтруктураПредприятия") Тогда
			УправлениеОбучениемСУО.ЗагрузитьСтруктуруПредприятия(СтруктураДанных.СтруктураПредприятия);
		КонецЕсли;				
		
		// Формируем организации
		
		Если СтруктураДанных.Свойство("Организации") Тогда
			УправлениеОбучениемСУО.ЗагрузитьОрганизации(СтруктураДанных.Организации);
		КонецЕсли;			
		
		// Формируем подразделения организаций
		
		Если СтруктураДанных.Свойство("ПодразделенияОрганизаций") Тогда
			УправлениеОбучениемСУО.ЗагрузитьПодразделенияОрганизаций(СтруктураДанных.ПодразделенияОрганизаций);
		КонецЕсли;			
		
		// Формируем пользователей из физических лиц
		
		Если СтруктураДанных.Свойство("ФизическиеЛицаСотрудников") Тогда
			УправлениеОбучениемСУО.ЗагрузитьПользователейИзФизическихЛицСотрудников(СтруктураДанных.ФизическиеЛицаСотрудников);
		КонецЕсли;			
		
		Если СтруктураДанных.Свойство("ФизическиеЛицаУУЦ") Тогда
			УправлениеОбучениемСУО.ЗагрузитьФизическиеЛицаУУЦ(СтруктураДанных.ФизическиеЛицаУУЦ);
		КонецЕсли;

		// Формируем сотрудников и их кадровые данные
		
		Если СтруктураДанных.Свойство("КадровыеДанныеСотрудников") Тогда
			УправлениеОбучениемСУО.ЗагрузитьСотрудниковПоКадровымДанным(СтруктураДанных.КадровыеДанныеСотрудников);
		КонецЕсли;
		
		// Указываем состояния сотрудников		
		
		Если СтруктураДанных.Свойство("СостоянияСотрудников") Тогда
			УправлениеОбучениемСУО.ЗагрузитьВозможностьУчиться(СтруктураДанных.СостоянияСотрудников);
		КонецЕсли;
		
		// Завершаем
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецПроцедуры

Функция ЕстьРольПреподавателя(Пользователь = Неопределено) Экспорт
	
	Возврат УправлениеДоступом.ЕстьРоль("ЛичныйКабинетПреподавательОбученияСУО",,Пользователь);
	
КонецФункции

#КонецОбласти

#Область ЗагрузкаДанных

// Кадры

Процедура ЗагрузитьВозможностьУчиться(СостоянияСотрудников) Экспорт
	
	// Колонки таблицы: Начало, Окончание, ОкончаниеПредположительно, Состояние, Сотрудник, ФизическоеЛицо
	
	ТаблицаСсылочныхЗначений = ПустаяТаблицаСсылочныхЗначений();
	
	НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();
	НоваяСтрока.ИмяКолонки = "ФизическоеЛицо";
	НоваяСтрока.Тип = "Справочник.Пользователи";
		
	ПодготовитьТаблицуКЗагрузке(СостоянияСотрудников, ТаблицаСсылочныхЗначений);	
	
	НачатьТранзакцию();
	
	Попытка
		
		Для каждого Строка Из СостоянияСотрудников Цикл
			
			Если НЕ ЗначениеЗаполнено(Строка.Начало) Тогда
				Продолжить;
			КонецЕсли;
			
			МожетУчиться = (Строка.Состояние.Идентификатор = "Работа");
			
			Если ЗначениеЗаполнено(Строка.Окончание) Тогда
				
				ТекущийПериод = Строка.Начало;
				Пока ТекущийПериод <= Строка.Окончание Цикл
					РегистрыСведений.ВозможностиУчитьсяСУО.УстановитьЗагруженноеЗначение(
						Строка.ФизическоеЛицо, ТекущийПериод, Ложь, МожетУчиться);
					ТекущийПериод = КонецДня(ТекущийПериод) + 1;						
				КонецЦикла;					
				
			Иначе
				РегистрыСведений.ВозможностиУчитьсяСУО.УстановитьЗагруженноеЗначение(
					Строка.ФизическоеЛицо, Строка.Начало, Истина, МожетУчиться);
			КонецЕсли;
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;	
	
КонецПроцедуры

Процедура ЗагрузитьСотрудниковПоКадровымДанным(КадровыеДанные) Экспорт
	
	// Колонки таблицы КадровыеДанные: ВидЗанятости, ДатаЗавершенияРаботы, ДатаПриема, Должность,
	// ДолжностьПоШтатномуРасписанию, МестоВСтруктуреПредприятия, Организация, Период, Подразделение, Состояние,
	// СостояниеПериодРегистрации, Сотрудник, ФизическоеЛицо.
	
	ТаблицаСсылочныхЗначений = ПустаяТаблицаСсылочныхЗначений();
	
	НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();
	НоваяСтрока.ИмяКолонки = "Должность";
	НоваяСтрока.Тип = "Справочник.ДолжностиСУО";
	
	НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();
	НоваяСтрока.ИмяКолонки = "МестоВСтруктуреПредприятия";
	НоваяСтрока.Тип = "Справочник.ПодразделенияПредприятияСУО";	
	
	НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();
	НоваяСтрока.ИмяКолонки = "Организация";
	НоваяСтрока.Тип = "Справочник.Организации";
	
	НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();
	НоваяСтрока.ИмяКолонки = "Подразделение";
	НоваяСтрока.Тип = "Справочник.ПодразделенияОрганизацииСУО";
	
	НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();
	НоваяСтрока.ИмяКолонки = "ФизическоеЛицо";
	НоваяСтрока.Тип = "Справочник.Пользователи";	
	
	ПодготовитьТаблицуКЗагрузке(КадровыеДанные, ТаблицаСсылочныхЗначений);	
	
	НачатьТранзакцию();
	
	Попытка
		
		Для каждого Строка Из КадровыеДанные Цикл
			
			Если НЕ ЗначениеЗаполнено(Строка.СостояниеПериодРегистрации) Тогда
				Продолжить;
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(Строка.ФизическоеЛицо) Тогда
				Продолжить;
			КонецЕсли;			
			
			МенеджерЗаписи = РегистрыСведений.СотрудникиСУО.СоздатьМенеджерЗаписи();
			МенеджерЗаписи.Период       = Строка.СостояниеПериодРегистрации;
			МенеджерЗаписи.Пользователь = Строка.ФизическоеЛицо;
			МенеджерЗаписи.Уволен = Значениезаполнено(Строка.ДатаЗавершенияРаботы);
			МенеджерЗаписи.Организация = Строка.Организация;
			МенеджерЗаписи.ТабельныйНомер = Строка.ТабельныйНомер;			
			МенеджерЗаписи.ПодразделениеОрганизации = Строка.Подразделение;
			МенеджерЗаписи.ПодразделениеПредприятия = Строка.МестоВСтруктуреПредприятия;
			МенеджерЗаписи.Должность = Строка.Должность;
			
			МенеджерЗаписи.Записать();
			
			ОбновитьДанныеСотрудников(МенеджерЗаписи.Пользователь);
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;		
	
КонецПроцедуры

Процедура ЗагрузитьПользователейИзФизическихЛицСотрудников(ТаблицаДанных) Экспорт
	
	ИспользуетсяВебКабинет = ВебКабинетСУ.Используется();
	
	// Колонки таблицы:	Ссылка, ФИО, Код, ДатаИзменения, Родитель, ЭлектроннаяПочта
	
	ИмяСправочника = "Пользователи";
	
	ТаблицаСсылочныхЗначений = ПустаяТаблицаСсылочныхЗначений();
	
	НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();
	НоваяСтрока.ИмяКолонки = "Ссылка";
	НоваяСтрока.Тип = "Справочник." + ИмяСправочника;

	Если ТаблицаДанных.Колонки.Найти("Родитель") <> Неопределено Тогда
		
		НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();
		НоваяСтрока.ИмяКолонки = "Родитель";
		НоваяСтрока.Тип = "Справочник.ГруппыПользователей";
		
	КонецЕсли;
		
	ПодготовитьТаблицуКЗагрузке(ТаблицаДанных, ТаблицаСсылочныхЗначений);
	
	НачатьТранзакцию();
	
	Попытка
		
		МассивГруппПользователей = Новый Массив;
		МассивГруппПользователей.Добавить(Справочники.ГруппыПользователей.ВсеПользователи);
		
		Для каждого Строка Из ТаблицаДанных Цикл
			
			// Обновляем пользователя
			
			Если ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(Строка.Ссылка) Тогда
				ЭлементОбъект = Строка.Ссылка.ПолучитьОбъект();
			Иначе
				ЭлементОбъект = Справочники[ИмяСправочника].СоздатьЭлемент();
				ЭлементОбъект.УстановитьСсылкуНового(Строка.Ссылка);
			КонецЕсли;
			
			ЭлементОбъект.Наименование = Строка.ФИО;		
			
			Если ТаблицаДанных.Колонки.Найти("Код") <> Неопределено Тогда
				ЭлементОбъект.Код = Строка.Код;
			КонецЕсли;				
			
			// Обновляем контактную информацию
			
			КонтактнаяИнформацияДляЗаполнения = УправлениеКонтактнойИнформацией.НоваяКонтактнаяИнформация(Ложь);
						
			Если ТаблицаДанных.Колонки.Найти("ЭлектроннаяПочта") <> Неопределено
				И ЗначениеЗаполнено(Строка.ЭлектроннаяПочта) Тогда
				
				СтрокаЗаполнения = КонтактнаяИнформацияДляЗаполнения.Добавить();
				СтрокаЗаполнения.Вид = Справочники.ВидыКонтактнойИнформации.EmailПользователя;
				СтрокаЗаполнения.Представление = СокрЛП(Строка.ЭлектроннаяПочта);
				
			КонецЕсли;		
			
			Если ТаблицаДанных.Колонки.Найти("МобильныйТелефон") <> Неопределено
				И ЗначениеЗаполнено(Строка.МобильныйТелефон) Тогда
				
				СтрокаЗаполнения = КонтактнаяИнформацияДляЗаполнения.Добавить();
				СтрокаЗаполнения.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонПользователя;
				СтрокаЗаполнения.Представление = СокрЛП(Строка.МобильныйТелефон);
			
			КонецЕсли;
			
			Если КонтактнаяИнформацияДляЗаполнения.Количество() > 0 Тогда			
				УправлениеКонтактнойИнформацией.УстановитьКонтактнуюИнформациюОбъекта(ЭлементОбъект, КонтактнаяИнформацияДляЗаполнения, Истина);
			КонецЕсли;
						
			// Устанавливаем свойства пользователя ИБ, если он еще не является пользователем базы
			
			Если ТаблицаДанных.Колонки.Найти("ОписаниеПользователяИБ") <> Неопределено
				И ТипЗнч(Строка.ОписаниеПользователяИБ) = Тип("Структура") Тогда
				
				ОписаниеПользователяИБ = Новый Структура;				
				ОписаниеПользователяИБ.Вставить("Действие", "Записать");
				ОписаниеПользователяИБ.Вставить("Имя", Строка.ОписаниеПользователяИБ.Имя);
				ОписаниеПользователяИБ.Вставить("СохраняемоеЗначениеПароля", Строка.ОписаниеПользователяИБ.СохраняемоеЗначениеПароля);
				ОписаниеПользователяИБ.Вставить("ПользовательОС", Строка.ОписаниеПользователяИБ.ПользовательОС);
				ОписаниеПользователяИБ.Вставить("АутентификацияOpenID", Строка.ОписаниеПользователяИБ.АутентификацияOpenID);
				ОписаниеПользователяИБ.Вставить("АутентификацияСтандартная", Строка.ОписаниеПользователяИБ.АутентификацияСтандартная);
				ОписаниеПользователяИБ.Вставить("АутентификацияОС", Строка.ОписаниеПользователяИБ.АутентификацияОС);
				ОписаниеПользователяИБ.Вставить("ЗапрещеноИзменятьПароль", Строка.ОписаниеПользователяИБ.ЗапрещеноИзменятьПароль);
				ОписаниеПользователяИБ.Вставить("ПоказыватьВСпискеВыбора", Строка.ОписаниеПользователяИБ.ПоказыватьВСпискеВыбора);								
				ОписаниеПользователяИБ.Вставить("РежимЗапуска", Строка.ОписаниеПользователяИБ.РежимЗапуска);				
				
				Если НЕ ЗначениеЗаполнено(ЭлементОбъект.ИдентификаторПользователяИБ)
					И ИспользуетсяВебКабинет Тогда

					ЭлементОбъект.ДополнительныеСвойства.Вставить("АутентификацияВебКабинета", Истина);
					
				ИначеЕсли ЗначениеЗаполнено(ЭлементОбъект.Ссылка) Тогда
					
					ЭлементОбъект.ДополнительныеСвойства.Вставить("АутентификацияВебКабинета",
						РегистрыСведений.ПользователиВебКабинетаСУ.ПользовательСуществует(, ЭлементОбъект.Ссылка));
					
				КонецЕсли;
				
				ЭлементОбъект.ДополнительныеСвойства.Вставить("ОписаниеПользователяИБ", ОписаниеПользователяИБ);
				
			КонецЕсли;
			
			Если ТаблицаДанных.Колонки.Найти("НедействительныйПользователь") <> Неопределено 
				И ТипЗнч(Строка.НедействительныйПользователь) = Тип("Булево") Тогда
				ЭлементОбъект.Недействителен = Строка.НедействительныйПользователь;				
			КонецЕсли;
			
			ЭлементОбъект.Записать(); // Обязательно записывать объект, чтобы отработали все подписки
			
			// Обновляем дополнительные реквизиты
			
			Если ПолучитьФункциональнуюОпцию("ИспользоватьСлушателейСУО") Тогда
				
				ТаблицаРеквизитовУЦ = ОбязательныеРеквизитыСлушателяУЦ();
				
				ТаблицаСвойств = Новый ТаблицаЗначений;
				ТаблицаСвойств.Колонки.Добавить("Свойство");
				ТаблицаСвойств.Колонки.Добавить("Значение");
				
				Для каждого СтрокаТР Из ТаблицаРеквизитовУЦ Цикл
					
					Если СтрокаТР.Существует
						И ТаблицаДанных.Колонки.Найти(СтрокаТР.ИмяРеквизита) <> Неопределено
						И ЗначениеЗаполнено(Строка[СтрокаТР.ИмяРеквизита]) Тогда
						
						НоваяСтрокаТС = ТаблицаСвойств.Добавить();
						НоваяСтрокаТС.Свойство = СтрокаТР.Ссылка;
						
						Если СтрокаТР.ТипЗначения = "СправочникСсылка.ЗначенияСвойствОбъектов" Тогда
							НоваяСтрокаТС.Значение = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию(Строка[СтрокаТР.ИмяРеквизита].Идентификатор,,, СтрокаТР.Ссылка);
						Иначе
							НоваяСтрокаТС.Значение = Строка[СтрокаТР.ИмяРеквизита];
						КонецЕсли;
											
					КонецЕсли;
					
				КонецЦикла;
				
				Если ТаблицаСвойств.Количество() > 0 Тогда				
					УправлениеСвойствами.ЗаписатьСвойстваУОбъекта(ЭлементОбъект.Ссылка, ТаблицаСвойств); 
				КонецЕсли;
				
			КонецЕсли;
			
			Если ТаблицаДанных.Колонки.Найти("Родитель") <> Неопределено Тогда
					
				// Добавляем пользователя в группу
				
				Если ЗначениеЗаполнено(Строка.Родитель) Тогда
					ГруппаДляДобавления = РодительскийЭлементСправочника(Строка.Родитель, Ложь);
					ГруппаДляДобавленияОбъект = ГруппаДляДобавления.ПолучитьОбъект();
					СтрокаСостава = ГруппаДляДобавленияОбъект.Состав.Добавить();
					СтрокаСостава.Пользователь = ЭлементОбъект.Ссылка;
					ОбновлениеИнформационнойБазы.ЗаписатьДанные(ГруппаДляДобавленияОбъект);
					Если МассивГруппПользователей.Найти(ГруппаДляДобавления) = Неопределено Тогда
						МассивГруппПользователей.Добавить(ГруппаДляДобавления);
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
				
		КонецЦикла;	
		
		// Обновляем группы пользователей
		Для каждого ГруппаДляДобавления Из МассивГруппПользователей Цикл
			ПользователиСлужебный.ОбновитьСоставыГруппПользователей(ГруппаДляДобавления);
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;		
		
КонецПроцедуры

Процедура ЗагрузитьПодразделенияОрганизаций(ТаблицаДанных) Экспорт
	
	// Колонки таблицы:	Код, Наименование, ПометкаУдаления, Родитель, Ссылка, ДатаИзменения, Владелец
	
	ИмяСправочника = "ПодразделенияОрганизацииСУО";
	
	ТаблицаСсылочныхЗначений = ПустаяТаблицаСсылочныхЗначений();
	
	НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();
	НоваяСтрока.ИмяКолонки = "Ссылка";
	НоваяСтрока.Тип = "Справочник." + ИмяСправочника;
	
	НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();
	НоваяСтрока.ИмяКолонки = "Родитель";
	НоваяСтрока.Тип = "Справочник." + ИмяСправочника;
	
	НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();
	НоваяСтрока.ИмяКолонки = "Владелец";
	НоваяСтрока.Тип = "Справочник.Организации";	
	
	ПодготовитьТаблицуКЗагрузке(ТаблицаДанных, ТаблицаСсылочныхЗначений);
	
	НачатьТранзакцию();
	
	Попытка
		
		Для каждого Строка Из ТаблицаДанных Цикл
			
			Если ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(Строка.Ссылка) Тогда
				ЭлементОбъект = Строка.Ссылка.ПолучитьОбъект();
			Иначе
				ЭлементОбъект = Справочники[ИмяСправочника].СоздатьЭлемент();
				ЭлементОбъект.УстановитьСсылкуНового(Строка.Ссылка);
			КонецЕсли;
			
			ЭлементОбъект.ПометкаУдаления = Строка.ПометкаУдаления;
			ЭлементОбъект.Наименование = Строка.Наименование;
			ЭлементОбъект.Родитель = РодительскийЭлементСправочника(Строка.Родитель, Ложь);
			ЭлементОбъект.Владелец = Строка.Владелец;
			
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ЭлементОбъект);
			
		КонецЦикла;	
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;	
	
КонецПроцедуры


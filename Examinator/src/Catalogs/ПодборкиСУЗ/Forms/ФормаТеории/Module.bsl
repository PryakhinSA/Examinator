КонецПроцедуры

// Загрузка

&НаКлиенте
Процедура ЗагрузитьФайлы(Команда)
	РазработкаСУЗКлиент.ЗагрузитьЭлементыВТаблицуСУЗ(ЭтотОбъект, Элементы.ЭлементыПодборки, ЭлектронныйРесурс, Объект.Ссылка);
КонецПроцедуры

// Зависимые

&НаКлиенте
Процедура СкрытыеРесурсыОткрыть(Команда)
	
	ТекущиеДанные = Элементы.СкрытыеРесурсы.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ТекущиеДанные.Ресурс) = Тип("СправочникСсылка.РесурсыСУЗ") Тогда
		
		ПараметрыФормы = Новый Структура();
		ПараметрыФормы.Вставить("ОткрытьФормуФайла", Истина);
		
		ОбщегоНазначенияСУКлиент.ОткрытьЗначениеВФорме(ТекущиеДанные.Ресурс, ПараметрыФормы, Элементы.СкрытыеРесурсы);
		
	Иначе
		
		ПоказатьЗначение(,ТекущиеДанные.Ресурс);
		
	КонецЕсли;
	
	
КонецПроцедуры


// Дополнительно

&НаКлиенте
Процедура КлассификаторЭлементовПодборок(Команда)
	ОткрытьФорму("Справочник.КлассификаторОбъектовСУЗ.ФормаСписка");
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Процедура УстановитьДоступностьЭлементовФормы()
	
	Если Элементы.Найти("ЭлементыПодборкиКласс") <> Неопределено Тогда
		Элементы.ЭлементыПодборкиКласс.Видимость = Объект.ПоказыватьКлассификатор;
	КонецЕсли;
	
	Если Объект.ПредставлениеЭлементов = ПредопределенноеЗначение("Перечисление.ВариантыПредставленияЭлементовПодборкиСУЗ.КлассификационнаяТаблица") Тогда
		Элементы.ПоказыватьКлассификатор.ТолькоПросмотр = Истина;
		Элементы.СвернутьРазделы.ТолькоПросмотр         = Истина;
	Иначе
		Элементы.ПоказыватьКлассификатор.ТолькоПросмотр = Ложь;
		Элементы.СвернутьРазделы.ТолькоПросмотр         = Ложь;
	КонецЕсли;
	
	Если НЕ Объект.ПоказыватьСтартовуюСтраницу Тогда
		Элементы.ВыравниваниеСтартовогоРесурса.ТолькоПросмотр = Ложь;
		Элементы.СтартовыйРесурс.ТолькоПросмотр               = Ложь;
	Иначе
		Элементы.ВыравниваниеСтартовогоРесурса.ТолькоПросмотр = Истина;
		Элементы.СтартовыйРесурс.ТолькоПросмотр               = Истина;
	КонецЕсли;
	
	// Тип навигации
	
	Если ПоказыватьДополнительныеТипыНавигации Тогда
		
		Элементы.ТипНавигации.ПараметрыВыбора = Новый ФиксированныйМассив(Новый Массив());
		
	Иначе		

		МассивТиповНавигации = Новый Массив();
		МассивТиповНавигации.Добавить(Перечисления.ТипыНавигацииПодборкиСУЗ.ВыпадающимСписком);
		МассивТиповНавигации.Добавить(Перечисления.ТипыНавигацииПодборкиСУЗ.НаОднойСтранице);
		
		МассивПараметровВыбора = Новый Массив();
		
		МассивПараметровВыбора.Добавить(Новый ПараметрВыбора("ИсключитьЗначения", Новый ФиксированныйМассив(МассивТиповНавигации)));
		Элементы.ТипНавигации.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметровВыбора);
		
	КонецЕсли;	
	
	// Для веб-кабинета
	
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета = Новый Массив;
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.СтраницаНастройки);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ПоказыватьДополнительныеТипыНавигации);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.Шаблон);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ЭлементыПодборкиСоздатьВопрос);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ЭлементыПодборкиДобавитьВопрос);
	
	РазработкаСУЗ.УбратьВидимостьНеподдерживаемыхПлееромВебКабинетаЭлементов(ЭлектронныйРесурс, МассивЭлементовНеподдерживаемыхПлееромВебКабинета);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборы()

	// Отборы
	
	ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(ЭлементыПодборки, Объект.Ссылка);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьРеквизиты()

	// Реквизиты
	
	Справочники.ПодборкиСУЗ.УстановитьОбязательныеРеквизиты(Объект);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовок()
	
	Если Объект.Ссылка.Пустая() Тогда
		Заголовок = НСтр("ru = 'Теория (создание)'");
	Иначе
		Заголовок = НСтр("ru = 'Теория ""%1""'");
		Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Заголовок, Объект.Наименование);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПоместитьЭлементВПодборку(Подборка, Элемент, ГруппаЭлементов)
	
	Если НЕ ЗначениеЗаполнено(Элемент) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Элемент) = Тип("СправочникСсылка.ФайлыСУЗ") Тогда
		Элемент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Элемент, "Владелец"); // Прикрепляем ресурс, а не файл
	КонецЕсли;
	
	Справочники.ПодборкиСУЗ.ДобавитьЭлементВПодборку(Подборка, Элемент, ГруппаЭлементов);
	
КонецПроцедуры


#КонецОбласти

////////////////////////////////////////////////////////////////////////////////
// ОПЕРАТОРЫ ОСНОВНОЙ ПРОГРАММЫ

ОписаниеДопустимыхТиповПеретаскивания = Новый ОписаниеТипов("Файл");


<package xmlns="http://v8.1c.ru/8.1/xdto" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://v8.1c.ru/kms/1/ImportCoursesSettings">
	<import namespace="http://v8.1c.ru/8.1/data/enterprise/current-config"/>
	<import namespace="http://v8.1c.ru/8.1/data/core"/>
	<objectType name="Настройки">
		<property xmlns:d3p1="http://v8.1c.ru/8.1/data/enterprise/current-config" name="ЭлектронныйРесурс" type="d3p1:CatalogRef.СводыЗнанийСУЗ"/>
		<property name="Наименование" type="xs:string" lowerBound="0"/>
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/ImportCoursesSettings" name="ЭлементыЗагрузки" type="d3p1:ЭлементыЗагрузки"/>
	</objectType>
	<objectType name="ЭлементыЗагрузки">
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/ImportCoursesSettings" name="Теория" type="d3p1:Теория" lowerBound="0" upperBound="-1"/>
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/ImportCoursesSettings" name="Тест" type="d3p1:Тест" lowerBound="0" upperBound="-1"/>
		<property xmlns:d3p1="http://v8.1c.ru/kms/1/ImportCoursesSettings" name="Глоссарий" type="d3p1:Глоссарий" lowerBound="0" upperBound="-1"/>
	</objectType>
	<objectType name="Теория">
		<property name="Каталог" type="xs:string"/>
	</objectType>
	<objectType name="Тест">
		<property name="ФайлВопросов" type="xs:string"/>
		<property name="ФайлРесурсов" type="xs:string"/>
	</objectType>
	<objectType name="Глоссарий">
		<property name="Файл" type="xs:string"/>
		<property name="СоздаватьСсылки" type="xs:boolean" lowerBound="0"/>
	</objectType>
</package>
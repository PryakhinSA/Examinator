			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВыполнениеЗадания.Год</dataPath>
			<field>ПериодГод</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Год периода проверки задания</v8:content>
				</v8:item>
			</title>
			<presentationExpression>Формат(ВыполнениеЗадания.Год, "ДФ=yyyy") + " год"</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВыполнениеЗадания.Месяц</dataPath>
			<field>ПериодМесяц</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Месяц проверки задания</v8:content>
				</v8:item>
			</title>
			<presentationExpression>Выбор 
    Когда Месяц(ВыполнениеЗадания.Месяц) = 1 Тогда "Январь"
    Когда Месяц(ВыполнениеЗадания.Месяц) = 2 Тогда "Февраль"
    Когда Месяц(ВыполнениеЗадания.Месяц) = 3 Тогда "Март"
    Когда Месяц(ВыполнениеЗадания.Месяц) = 4 Тогда "Апрель"
    Когда Месяц(ВыполнениеЗадания.Месяц) = 5 Тогда "Май"
    Когда Месяц(ВыполнениеЗадания.Месяц) = 6 Тогда "Июнь"
    Когда Месяц(ВыполнениеЗадания.Месяц) = 7 Тогда "Июль"
    Когда Месяц(ВыполнениеЗадания.Месяц) = 8 Тогда "Август"
    Когда Месяц(ВыполнениеЗадания.Месяц) = 9 Тогда "Сентябрь"
    Когда Месяц(ВыполнениеЗадания.Месяц) = 10 Тогда "Октябрь"
    Когда Месяц(ВыполнениеЗадания.Месяц) = 11 Тогда "Ноябрь"
    Когда Месяц(ВыполнениеЗадания.Месяц) = 12 Тогда "Декабрь"
Конец</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВыполнениеЗадания.МесяцГода</dataPath>
			<field>ПериодМесяцГода</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Месяц года проверки задания</v8:content>
				</v8:item>
			</title>
			<presentationExpression>Выбор 
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 1 Тогда "Январь " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 2 Тогда "Февраль " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 3 Тогда "Март " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 4 Тогда "Апрель " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 5 Тогда "Май " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 6 Тогда "Июнь " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 7 Тогда "Июль " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 8 Тогда "Август " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 9 Тогда "Сентябрь " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 10 Тогда "Октябрь " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 11 Тогда "Ноябрь " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
    Когда Месяц(ВыполнениеЗадания.МесяцГода) = 12 Тогда "Декабрь " + Формат(ВыполнениеЗадания.Год, "ДФ=yyyy")
Конец</presentationExpression>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ПопыткиПрохожденияЗаданийСУО.Задание КАК Задание,
	ПопыткиПрохожденияЗаданийСУО.ПрохождениеОбучения КАК ПрохождениеОбучения,
	ПопыткиПрохожденияЗаданийСУО.ПроведениеОбучения КАК ПроведениеОбучения,
	ПопыткиПрохожденияЗаданийСУО.Пользователь КАК Участник,
	ПопыткиПрохожденияЗаданийСУО.ПроверяетсяПреподавателем КАК ПроверяетсяПреподавателем,
	ПопыткиПрохожденияЗаданийСУО.ПроверенПреподавателем КАК ПроверенПреподавателем,
	ПопыткиПрохожденияЗаданийСУО.ДатаОтправкиНаПроверку КАК ДатаОтправкиНаПроверку,
	ПопыткиПрохожденияЗаданийСУО.КомментарийПреподавателя КАК КомментарийПреподавателя,
	ПопыткиПрохожденияЗаданийСУО.ВозвращеноНаДоработку КАК ВозвращеноНаДоработку,
	ПопыткиПрохожденияЗаданийСУО.ПричинаВозвратаНаДоработку КАК ПричинаВозвратаНаДоработку,
	ПопыткиПрохожденияЗаданийСУО.ДатаВозвратаНаДоработку КАК ДатаВозвратаНаДоработку,
	ПопыткиПрохожденияЗаданийСУО.Наименование КАК НаименованиеЗадания,
	ПопыткиПрохожденияЗаданийСУО.Значимость КАК ЗначимостьЗадания,
	ПопыткиПрохожденияЗаданийСУО.НеЖдатьПроверки КАК НеЖдатьПроверки,
	ПопыткиПрохожденияЗаданийСУО.ПроверившийПреподаватель КАК Преподаватель,
	ПопыткиПрохожденияЗаданийСУО.Регистратор КАК ПрохождениеЗадания,
	ПопыткиПрохожденияЗаданийСУО.ДатаПроверки КАК ДатаПроверкиЗадания,
	ПопыткиПрохожденияЗаданийСУО.ПопыткаЗавершена КАК ЗаданиеВыполнено,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ПопыткиПрохожденияЗаданийСУО.Задание) = ТИП(Справочник.ЗаданияСУО)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЭтоЗаданиеНаПроверку,
	НАЧАЛОПЕРИОДА(ПопыткиПрохожденияЗаданийСУО.ДатаПроверки, ГОД) КАК ПериодГод,
	НАЧАЛОПЕРИОДА(ПопыткиПрохожденияЗаданийСУО.ДатаПроверки, МЕСЯЦ) КАК ПериодМесяц,
	НАЧАЛОПЕРИОДА(ПопыткиПрохожденияЗаданийСУО.ДатаПроверки, МЕСЯЦ) КАК ПериодМесяцГода
ИЗ
	РегистрСведений.ПопыткиПрохожденияЗаданийСУО КАК ПопыткиПрохожденияЗаданийСУО
{ГДЕ
	(ПопыткиПрохожденияЗаданийСУО.ДатаПроверки МЕЖДУ &amp;НачалоПериодаПроверкиЗадания И &amp;КонецПериодаПроверкиЗадания)}</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>ПроведенияОбучения</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Обучение.СтатусПроведенияОбучения</dataPath>
			<field>Статус</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Статус проведения обучения</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Обучение.ПроведениеОбучения</dataPath>
			<field>ПроведениеОбучения</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Проведение обучения</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Обучение.ДатаОбучения</dataPath>
			<field>ДатаПроведенияОбучения</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата проведения обучения</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Обучение.ДатаНачалаОбучения</dataPath>
			<field>ДатаНачалаОбучения</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата начала обучения</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Обучение.ДатаОкончанияОбучения</dataPath>
			<field>ДатаОкончанияОбучения</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата окончания обучения</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Обучение.Месяц</dataPath>
			<field>ПериодМесяц</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Месяц</v8:content>
				</v8:item>
			</title>
			<presentationExpression>Выбор 
    Когда Месяц(Обучение.Месяц) = 1 Тогда "Январь"
    Когда Месяц(Обучение.Месяц) = 2 Тогда "Февраль"
    Когда Месяц(Обучение.Месяц) = 3 Тогда "Март"
    Когда Месяц(Обучение.Месяц) = 4 Тогда "Апрель"
    Когда Месяц(Обучение.Месяц) = 5 Тогда "Май"
    Когда Месяц(Обучение.Месяц) = 6 Тогда "Июнь"
    Когда Месяц(Обучение.Месяц) = 7 Тогда "Июль"
    Когда Месяц(Обучение.Месяц) = 8 Тогда "Август"
    Когда Месяц(Обучение.Месяц) = 9 Тогда "Сентябрь"
    Когда Месяц(Обучение.Месяц) = 10 Тогда "Октябрь"
    Когда Месяц(Обучение.Месяц) = 11 Тогда "Ноябрь"
    Когда Месяц(Обучение.Месяц) = 12 Тогда "Декабрь"
Конец</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Обучение.МесяцГода</dataPath>
			<field>ПериодМесяцГода</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Месяц года</v8:content>
				</v8:item>
			</title>
			<presentationExpression>
Выбор 
    Когда Месяц(Обучение.МесяцГода) = 1 Тогда "Январь " + Формат(Обучение.Год, "ДФ=yyyy")
    Когда Месяц(Обучение.МесяцГода) = 2 Тогда "Февраль " + Формат(Обучение.Год, "ДФ=yyyy")
    Когда Месяц(Обучение.МесяцГода) = 3 Тогда "Март " + Формат(Обучение.Год, "ДФ=yyyy")
    Когда Месяц(Обучение.МесяцГода) = 4 Тогда "Апрель " + Формат(Обучение.Год, "ДФ=yyyy")
    Когда Месяц(Обучение.МесяцГода) = 5 Тогда "Май " + Формат(Обучение.Год, "ДФ=yyyy")
    Когда Месяц(Обучение.МесяцГода) = 6 Тогда "Июнь " + Формат(Обучение.Год, "ДФ=yyyy")
    Когда Месяц(Обучение.МесяцГода) = 7 Тогда "Июль " + Формат(Обучение.Год, "ДФ=yyyy")
    Когда Месяц(Обучение.МесяцГода) = 8 Тогда "Август " + Формат(Обучение.Год, "ДФ=yyyy")
    Когда Месяц(Обучение.МесяцГода) = 9 Тогда "Сентябрь " + Формат(Обучение.Год, "ДФ=yyyy")
    Когда Месяц(Обучение.МесяцГода) = 10 Тогда "Октябрь " + Формат(Обучение.Год, "ДФ=yyyy")
    Когда Месяц(Обучение.МесяцГода) = 11 Тогда "Ноябрь " + Формат(Обучение.Год, "ДФ=yyyy")
    Когда Месяц(Обучение.МесяцГода) = 12 Тогда "Декабрь " + Формат(Обучение.Год, "ДФ=yyyy")
Конец</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Обучение.Год</dataPath>
			<field>ПериодГод</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Год</v8:content>
				</v8:item>
			</title>
			<presentationExpression>Формат(Обучение.Год, "ДФ=yyyy") + " год"</presentationExpression>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ПроведениеОбученияСУО.Ссылка КАК ПроведениеОбучения,
	ПроведениеОбученияСУО.Статус КАК Статус,
	ПроведениеОбученияСУО.Дата КАК ДатаПроведенияОбучения,
	ВЫБОР
		КОГДА ПроведениеОбученияСУО.ДатаНачалаПроведения &lt;&gt; ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
			ТОГДА ПроведениеОбученияСУО.ДатаНачалаПроведения
		КОГДА ПроведениеОбученияСУО.ДатаНачалаДоступа &lt;&gt; ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
			ТОГДА ПроведениеОбученияСУО.ДатаНачалаДоступа
		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	КОНЕЦ КАК ДатаНачалаОбучения,
	ВЫБОР
		КОГДА ПроведениеОбученияСУО.ДатаОкончанияПроведения &lt;&gt; ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
			ТОГДА ПроведениеОбученияСУО.ДатаОкончанияПроведения
		КОГДА ПроведениеОбученияСУО.ДатаКонтроля &lt;&gt; ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
			ТОГДА ПроведениеОбученияСУО.ДатаКонтроля
		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	КОНЕЦ КАК ДатаОкончанияОбучения,
	НАЧАЛОПЕРИОДА(ПроведениеОбученияСУО.Дата, ГОД) КАК ПериодГод,
	НАЧАЛОПЕРИОДА(ПроведениеОбученияСУО.Дата, МЕСЯЦ) КАК ПериодМесяц,
	НАЧАЛОПЕРИОДА(ПроведениеОбученияСУО.Дата, МЕСЯЦ) КАК ПериодМесяцГода
ИЗ
	Документ.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО</query>
	</dataSet>

Функция ПолучитьРазделыФорумаPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Форум");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем разделы форума
	
	ЗапросДанных = Новый Запрос;
	ЗапросДанных.Текст = 
		"ВЫБРАТЬ
		|	ДанныеВебКабинетаСУО_ОН.Данные КАК object,
		|	ДанныеВебКабинетаСУО_ОН_Описание.Данные КАК description,
		|	ДанныеВебКабинетаСУО_ПН_Описание.Данные КАК userDescription
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ДанныеВебКабинетаСУО_ОН
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ДанныеВебКабинетаСУО_ОН_Описание
		|		ПО ДанныеВебКабинетаСУО_ОН.Объект = ДанныеВебКабинетаСУО_ОН_Описание.Объект
		|			И (ДанныеВебКабинетаСУО_ОН_Описание.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.РазделФорумаОписание))
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО_ПН_Описание
		|		ПО ДанныеВебКабинетаСУО_ОН.Объект = ДанныеВебКабинетаСУО_ПН_Описание.Объект
		|			И (ДанныеВебКабинетаСУО_ПН_Описание.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.РазделФорумаОписание))
		|			И (ДанныеВебКабинетаСУО_ПН_Описание.Пользователь = &Пользователь)
		|ГДЕ
		|	ДанныеВебКабинетаСУО_ОН.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.РазделФорума)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ДанныеВебКабинетаСУО_ПН.Данные,
		|	ДанныеВебКабинетаСУО_ОН_Описание.Данные,
		|	ДанныеВебКабинетаСУО_ПН_Описание.Данные
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО_ПН
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ДанныеВебКабинетаСУО_ОН_Описание
		|		ПО ДанныеВебКабинетаСУО_ПН.Объект = ДанныеВебКабинетаСУО_ОН_Описание.Объект
		|			И (ДанныеВебКабинетаСУО_ОН_Описание.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.РазделФорумаОписание))
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО_ПН_Описание
		|		ПО ДанныеВебКабинетаСУО_ПН.Объект = ДанныеВебКабинетаСУО_ПН_Описание.Объект
		|			И (ДанныеВебКабинетаСУО_ПН_Описание.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.РазделФорумаОписание))
		|			И (ДанныеВебКабинетаСУО_ПН_Описание.Пользователь = &Пользователь)
		|ГДЕ
		|	ДанныеВебКабинетаСУО_ПН.Пользователь = &Пользователь
		|	И ДанныеВебКабинетаСУО_ПН.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.РазделФорума)";
	
	ЗапросДанных.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	
	РезультатЗапроса = ЗапросДанных.Выполнить();
	
	// ЗаполнитьЗначенияСвойств
	
	Возврат ОтветКлиентуJSON(,РезультатЗапроса.Выгрузить());
	
КонецФункции

Функция ПолучитьТемыРазделаФорумаPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Форум");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем переменные
	//
		
	МассивИдентификаторов = Новый Массив;
	
	ИдентификаторРазделаЗначениеПараметра = Запрос.ПараметрыURL.Получить("РазделФорума");
	
	Если СтрДлина(ИдентификаторРазделаЗначениеПараметра) > 1 Тогда
	
		ИдентификаторРазделаМассивСтрок = ОбщегоНазначенияСУКлиентСервер.РасщепитьСтроку(ИдентификаторРазделаЗначениеПараметра, ";");
			
		Для каждого ИдентификаторРазделаСтрока Из ИдентификаторРазделаМассивСтрок Цикл
		
			Попытка
				ИдентификаторРаздела = Новый УникальныйИдентификатор(ИдентификаторРазделаСтрока);
			Исключение
			КонецПопытки;
			
			Если НЕ ЗначениеЗаполнено(ИдентификаторРаздела) Тогда
				Возврат ОтветКлиентуJSON("errorData");
			КонецЕсли;	
			
			МассивИдентификаторов.Добавить(ИдентификаторРаздела);
		
		КонецЦикла;
		
	КонецЕсли;
		
	ДанныеДляЗаписиJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если ЗначениеЗаполнено(ДанныеДляЗаписиJSON) Тогда
		
		Попытка
			ДанныеДляЗаписиСтруктура = ОбщегоНазначенияСУ.JSONВДанные(ДанныеДляЗаписиJSON);
		Исключение
			Возврат ОтветКлиентуJSON("errorData");
		КонецПопытки;
		
		Если ДанныеДляЗаписиСтруктура.Свойство("categories") 
			И ТипЗнч(ДанныеДляЗаписиСтруктура.categories) = Тип("Массив") Тогда
			Для каждого ИдентификаторРазделаСтрока Из ДанныеДляЗаписиСтруктура.categories Цикл
				Попытка
					ИдентификаторРаздела = Новый УникальныйИдентификатор(ИдентификаторРазделаСтрока);
				Исключение
				КонецПопытки;
				Если НЕ ЗначениеЗаполнено(ИдентификаторРаздела) Тогда
					Возврат ОтветКлиентуJSON("errorData");
				КонецЕсли;
				МассивИдентификаторов.Добавить(ИдентификаторРаздела);
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
		
	// Темы раздела
	//
	
	Запрос = Новый Запрос;
		
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СписокТем.Данные КАК object,
		|	ОписаниеТем.Данные КАК description,
		|	ОписаниеТемПользовательское.Данные КАК userDescription
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК СписокТем
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборДанных
		|		ПО СписокТем.Объект = ОтборДанных.Объект
		|			И (СписокТем.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.ТемаОбщения))
		|			И (ОтборДанных.Отбор В (&МассивИдентификаторов))
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборДанныхПоПользователям
		|		ПО СписокТем.Объект = ОтборДанныхПоПользователям.Объект
		|			И (СписокТем.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.ТемаОбщения))
		|			И (ОтборДанныхПоПользователям.Отбор = &ИдентификаторПользователя)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ОписаниеТем
		|		ПО СписокТем.Объект = ОписаниеТем.Объект
		|			И (СписокТем.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.ТемаОбщения))
		|			И (ОписаниеТем.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.ТемаОбщенияОписание))
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ОписаниеТемПользовательское
		|		ПО СписокТем.Объект = ОписаниеТемПользовательское.Объект
		|			И (СписокТем.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.ТемаОбщения))
		|			И (ОписаниеТемПользовательское.Пользователь = &Пользователь)
		|			И (ОписаниеТемПользовательское.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.ТемаОбщенияОписание))";
		
	Запрос.УстановитьПараметр("МассивИдентификаторов", МассивИдентификаторов);
	Запрос.УстановитьПараметр("ИдентификаторПользователя", ДанныеСессии.Пользователь.УникальныйИдентификатор());
	Запрос.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат ОтветКлиентуJSON(,РезультатЗапроса.Выгрузить());
	
КонецФункции


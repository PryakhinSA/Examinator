&НаСервереБезКонтекста
Функция ЕстьВерныйВариант(СсылкаНаВопрос)
	Возврат Справочники.ВопросыСУЗ.ЕстьВерныйВариант(СсылкаНаВопрос);
КонецФункции

&НаСервере
Процедура УстановитьДоступностьЭлементовФормыПриЗагрузке()
	
	//////////////////////////////////////////////////////////////////
	
	// Устанавливаем доступность данных от поставщика
	
	ТаблицаДоступностиДанныхПоставщика = РазработкаСУЗ.ПолучитьТаблицуДоступностиДанныхПоставщика();

	Строка = ТаблицаДоступностиДанныхПоставщика.Добавить();
	Строка.ЭлементФормы = Элементы.ТекстовыйДокумент;
	Строка.Свойство = "ТолькоПросмотр";
	Строка.Значение = Ложь;
	
	Строка = ТаблицаДоступностиДанныхПоставщика.Добавить();
	Строка.ЭлементФормы = Элементы.ГруппаФорматированныйДокумент;
	Строка.Свойство = "ТолькоПросмотр";
	Строка.Значение = Ложь;
	
	Строка = ТаблицаДоступностиДанныхПоставщика.Добавить();
	Строка.ЭлементФормы = Элементы.ВариантыОтветов;
	Строка.Свойство = "ТолькоПросмотр";
	Строка.Значение = Ложь;
	
	Строка = ТаблицаДоступностиДанныхПоставщика.Добавить();
	Строка.ЭлементФормы = Элементы.КатегорииОтветов;
	Строка.Свойство = "ТолькоПросмотр";
	Строка.Значение = Ложь;
	
	Строка = ТаблицаДоступностиДанныхПоставщика.Добавить();
	Строка.ЭлементФормы = Элементы.Фасеты;
	Строка.Свойство = "ТолькоПросмотр";
	Строка.Значение = Ложь;
	
	Строка = ТаблицаДоступностиДанныхПоставщика.Добавить();
	Строка.ЭлементФормы = Элементы.Ссылки;
	Строка.Свойство = "ТолькоПросмотр";
	Строка.Значение = Ложь;
	
	РазработкаСУЗ.УстановитьДоступностьДанныхОтПоставщика(ЭтотОбъект, ТаблицаДоступностиДанныхПоставщика);
	
	//////////////////////////////////////////////////////////////////
	
	РазработкаСУЗ.УстановитьДоступностьРедактора(ЭтотОбъект);
	        
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьЭлементовФормы()
	
	// Вкладка "Фасеты"
	
	Если Объект.ФасетныйВопрос Тогда
		Элементы.СтраницаФасеты.Видимость = Истина;
	Иначе
		Элементы.СтраницаФасеты.Видимость = Ложь;
	КонецЕсли;
	
	// Вкладка "Варианты ответов"
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ЭлементActiveX")
	 ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Открытый")
	 ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.РаботаВПрограмме") Тогда
		Элементы.СтраницаВариантыОтветов.Видимость = Ложь;
	Иначе
		Элементы.СтраницаВариантыОтветов.Видимость = Истина;
	КонецЕсли;
	
	// Вкладка "Категории"
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Таблица") Тогда
		Элементы.СтраницаКатегорииОтветов.Видимость = Истина;
		Элементы.ВариантыОтветовКатегория.Видимость = Истина;
	Иначе
		Элементы.СтраницаКатегорииОтветов.Видимость = Ложь;
		Элементы.ВариантыОтветовКатегория.Видимость = Ложь;
	КонецЕсли;

	// Конфигурация
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.РаботаВПрограмме") Тогда
	
		Элементы.ПрограммныйПродукт.Видимость = Истина;
		Элементы.СтраницаЭтапыРаботыВПрограмме.Видимость = Истина;
		Элементы.СтраницаПараметры.Видимость = Истина;
		Элементы.СтраницаКомментарии.Видимость = Истина;
		
	Иначе
		
		Элементы.ПрограммныйПродукт.Видимость = Ложь;
		Элементы.СтраницаЭтапыРаботыВПрограмме.Видимость = Ложь;
		Элементы.СтраницаПараметры.Видимость = Ложь;
		Элементы.СтраницаКомментарии.Видимость = Ложь;
		
	КонецЕсли;
		
	// Метод расчета результата
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.МногиеИзМногих")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Последовательность")
		ИЛИ	Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Соответствие")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Таблица") Тогда
		Элементы.МетодРасчетаРезультата.Доступность = Истина;
	Иначе
		Элементы.МетодРасчетаРезультата.Доступность = Ложь;
	КонецЕсли;
	
	// Флажок "Фасетный вопрос"
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ОдинИзМногих")
	 ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.МногиеИзМногих")
	 ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ПоШаблону") Тогда
		Элементы.ФасетныйВопрос.Доступность = Истина;
	Иначе
		Элементы.ФасетныйВопрос.Доступность = Ложь;
	КонецЕсли;
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ЭлементActiveX")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Открытый") Тогда	
		Элементы.РазрешенРазвернутыйОтвет.Доступность = Ложь;
	Иначе
		Элементы.РазрешенРазвернутыйОтвет.Доступность = Истина;
	КонецЕсли;
	
	// Реквизит "ПеремешиватьВарианты"
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ЭлементActiveX")
	 ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Открытый")
	 ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.РаботаВПрограмме") Тогда
		Элементы.ПеремешиватьВарианты.Доступность = Ложь;
	Иначе
		Элементы.ПеремешиватьВарианты.Доступность = Истина;
	КонецЕсли;
	
	// Последовательный вывод результата	
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Соответствие")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Таблица") Тогда
		Элементы.ПоследовательныйВыводВариантов.Доступность = Истина;
	Иначе
		Элементы.ПоследовательныйВыводВариантов.Доступность = Ложь;
	КонецЕсли;
	
	// Отображать наименование
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ЭлементActiveX") Тогда
		Элементы.ОтображатьНаименование.Доступность = Ложь;
	Иначе
		Элементы.ОтображатьНаименование.Доступность = Истина;
	КонецЕсли;
	
	// Отображать имена полей
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ЭлементActiveX") Тогда
		Элементы.ОтображатьИменаПолей.Доступность = Ложь;
	Иначе
		Элементы.ОтображатьИменаПолей.Доступность = Истина;
	КонецЕсли;
	
	// Штраф за подсказку
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ЭлементActiveX")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ОдинИзМногихПсихологический")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.МногиеИзМногихПсихологический") Тогда
		
		Элементы.ШтрафЗаПодсказку.Доступность = Ложь;
		
	Иначе
		
		Элементы.ШтрафЗаПодсказку.Доступность = Истина;
		
	КонецЕсли;
	
	// Представление полей

	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Соответствие")
	 ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Таблица") Тогда
		Элементы.ПредставлениеГрупп.Доступность = Истина;
	Иначе
		Элементы.ПредставлениеГрупп.Доступность = Ложь;
	КонецЕсли;
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Таблица") Тогда
		Элементы.ПредставлениеКатегорий.Доступность = Истина;
	Иначе
		Элементы.ПредставлениеКатегорий.Доступность = Ложь;
	КонецЕсли;
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ЭлементActiveX")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Открытый")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.РаботаВПрограмме") Тогда
		Элементы.ПредставлениеВариантовОтветов.Доступность = Ложь;
	Иначе
		Элементы.ПредставлениеВариантовОтветов.Доступность = Истина;
	КонецЕсли;
	
	// ГоризонтальноеРазмещениеВариантов и отображение вариантов
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ЭлементActiveX")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.РаботаВПрограмме")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.Открытый") 
		 ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ПоШаблону") Тогда
		Элементы.ГоризонтальноеРазмещениеВариантов.Доступность = Ложь;
		Элементы.ОтображениеВариантовГруппа.Доступность = Ложь;
	Иначе
		Элементы.ГоризонтальноеРазмещениеВариантов.Доступность = Истина;
		Элементы.ОтображениеВариантовГруппа.Доступность = Истина;
	КонецЕсли;
	
	// Разрешен развернутый ответ
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.ОдинИзМногихПсихологический")
		ИЛИ Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыВопросовСУЗ.МногиеИзМногихПсихологический") Тогда
		Элементы.РазрешенРазвернутыйОтвет.Доступность = Ложь;
		Объект.РазрешенРазвернутыйОтвет = Ложь;
	Иначе
		Элементы.РазрешенРазвернутыйОтвет.Доступность = Истина;
	КонецЕсли;
	
	// Тип вопроса
	
	МассивТиповВопросов = Новый Массив();
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	Если НЕ ПолучитьФункциональнуюОпцию("РасширеннаяФункциональностьСУО")
		ИЛИ НЕ ПоказатьДополнительныеТипыВопросов Тогда			
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.ЭлементActiveX);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.ОдинИзМногихПсихологический);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.МногиеИзМногихПсихологический);		
	КонецЕсли;
	//----------------------------------//
	
	Если НЕ ПоказатьДополнительныеТипыВопросов Тогда								
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.ПоШаблону);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.Таблица);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.Соответствие);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.Открытый);		
	КонецЕсли;
	
	Если РегистрыСведений.ПлеерКурсовВебКабинетаСУЗ.ИспользоватьВстроенныйПлеер(ЭлектронныйРесурс) Тогда
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.ПоШаблону);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.Таблица);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.Соответствие);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.Открытый);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.ЭлементActiveX);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.РаботаВПрограмме);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.ОдинИзМногихПсихологический);
		МассивТиповВопросов.Добавить(Перечисления.ТипыВопросовСУЗ.МногиеИзМногихПсихологический);
	КонецЕсли;
	
	МассивПараметровВыбора = Новый Массив();
	
	Если МассивТиповВопросов.Количество() > 0 Тогда
		МассивПараметровВыбора.Добавить(Новый ПараметрВыбора("ИсключитьЗначения", Новый ФиксированныйМассив(МассивТиповВопросов)));
	КонецЕсли;
	
	Элементы.ТипВопроса.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметровВыбора);
	
	// Вес вопроса
	
	Если ЗначениеЗаполнено(Подборка) ИЛИ ЗначениеЗаполнено(ЭлементРубрикатора) Тогда
		Элементы.ВесВопроса.Видимость = Истина;
	Иначе
		Элементы.ВесВопроса.Видимость = Ложь;
	КонецЕсли;
	
	// Связанные элементы
	
	Элементы.СтраницаСвязанныеЭлементы.Видимость = ЗначениеЗаполнено(ЭлектронныйРесурс) 
		И ТипЭлектронногоРесурса = Перечисления.ТипыЭлектронныхРесурсовСУЗ.ЭлектронныйКурс;
	
	// Для веб-кабинета
	
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета = Новый Массив;
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ВесВопроса);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.СтраницаВид);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ПоказатьДополнительныеТипыВопросов);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.СтраницаНастройки);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.СтраницаСвязанныеЭлементы);
	
	РазработкаСУЗ.УбратьВидимостьНеподдерживаемыхПлееромВебКабинетаЭлементов(ЭлектронныйРесурс, МассивЭлементовНеподдерживаемыхПлееромВебКабинета);
	
	// Отборы
	
	ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(КатегорииОтветов, Объект.Ссылка);
	ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(Фасеты, Объект.Ссылка);
	ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(ВариантыОтветов, Объект.Ссылка);
	ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(Ссылки, Объект.Ссылка);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьВерсиюНаСервере(ПерваяЗагрузка = Ложь)
	
	// Загружаем текст вопроса (задание)
	
	ИмяРедактируемыхДанных = "Вопрос";
	РазработкаСУЗ.УстановитьДанныеВерсииОбъекта(ЭтотОбъект, Объект, ТипОбъектаНаСервере, ПерваяЗагрузка);
	
	// Загружаем таблицу с данными вариантов ответов
	
	Если НЕ Объект.Ссылка.Пустая() Тогда 
		
		ТекстЗапроса = "ВЫБРАТЬ
		|	ВариантыОтветовНаВопросСУЗ.Ссылка
		|ИЗ
		|	Справочник.ВариантыОтветовНаВопросСУЗ КАК ВариантыОтветовНаВопросСУЗ
		|ГДЕ
		|	ВариантыОтветовНаВопросСУЗ.Владелец = &Владелец";
		
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.УстановитьПараметр("Владелец", Объект.Ссылка); 
		
		ВыборкаВариантыОтветов = Запрос.Выполнить().Выбрать();
		
		Пока ВыборкаВариантыОтветов.Следующий() Цикл
			
			МассивПолучаемыхРеквизитов = Новый Массив();
			МассивПолучаемыхРеквизитов.Добавить("ТекстовыеДанные");
			МассивПолучаемыхРеквизитов.Добавить("ВерныйКомментарий");
			МассивПолучаемыхРеквизитов.Добавить("ОшибочныйКомментарий");
			
			ДанныеВарианта = ОбъектыСУЗ.ПолучитьДанные(Объект.Ссылка, ВыборкаВариантыОтветов.Ссылка, Ложь, МассивПолучаемыхРеквизитов);
			
			НоваяСтрока = ДанныеВариантовОтветов.Добавить();
			НоваяСтрока.ВариантОтвета = ВыборкаВариантыОтветов.Ссылка;
			НоваяСтрока.Текст = ДанныеВарианта.ТекстовыеДанные;
			НоваяСтрока.ВерныйКомментарий = ДанныеВарианта.ВерныйКомментарий;
			НоваяСтрока.ОшибочныйКомментарий = ДанныеВарианта.ОшибочныйКомментарий;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ВывестиТекстыВариантов();
	
	УстановитьДоступностьЭлементовФормыПриЗагрузке();
	
КонецПроцедуры

// Загружает данные текущей версии объекта для редактирования.
// Вызывается из общей формы "ВерсииОбъектаСУЗ" и после инициализации редактора.
//
&НаКлиенте
Процедура ЗагрузитьВерсию() Экспорт
	
	ЗагрузитьВерсиюНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ВывестиТекстыВариантов() Экспорт
	
	ВариантыОтветов.УсловноеОформление.Элементы.Очистить();
	
	Для каждого Строка Из ДанныеВариантовОтветов Цикл
		
		НовоеОформление = ВариантыОтветов.УсловноеОформление.Элементы.Добавить();
		НовоеОформление.Использование = Истина;
		НовоеОформление.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный; 
		НовоеОформление.ПредставлениеПользовательскойНастройки = "Служебное"; 
		
		Отбор = НовоеОформление.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		Отбор.ЛевоеЗначение    = Новый ПолеКомпоновкиДанных("Ссылка");
		Отбор.ВидСравнения     = ВидСравненияКомпоновкиДанных.Равно;
		Отбор.Использование    = Истина;
		Отбор.Представление    = "Ссылка";
		Отбор.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
		Отбор.ПравоеЗначение   = Строка.ВариантОтвета;
		
		// Находим элемент оформления "Текст"
		ЭлементОформленияТекст = Неопределено;
		Для каждого ЭлементОформления Из НовоеОформление.Оформление.Элементы Цикл
		
			Если ЭлементОформления.Параметр = Новый ПараметрКомпоновкиДанных("Текст") Тогда
				ЭлементОформленияТекст = ЭлементОформления;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		ЭлементОформленияТекст.Значение = Строка.Текст;
		ЭлементОформленияТекст.Использование = Истина;
		
		// Устанавливаем поле для оформления
		
		ПолеОформления = НовоеОформление.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Текст"); 
		
	КонецЦикла;
	
КонецПроцедуры

// Связанные элементы

&НаСервере
Функция ПолучитьАвтоРубрикатор(СоздаватьПриОтсутствии)
	
	УникальныйИдентификаторЭР = ЭлектронныйРесурс.УникальныйИдентификатор();
	АвтоРубрикатор = Справочники.РубрикаторыСУЗ.ПолучитьСсылку(УникальныйИдентификаторЭР);
	НаименованиеЭлектронногоРесурса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлектронныйРесурс, "Наименование");
	
	Если СоздаватьПриОтсутствии Тогда
	
		Если ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(АвтоРубрикатор, Ложь) Тогда
			АвтоРубрикаторОбъект = АвтоРубрикатор.ПолучитьОбъект();		
		Иначе
			АвтоРубрикаторОбъект = Справочники.РубрикаторыСУЗ.СоздатьЭлемент();
			АвтоРубрикаторОбъект.УстановитьСсылкуНового(АвтоРубрикатор);		
			РазработкаСУЗ.УстановитьПредпочитаемогоПоставщика(АвтоРубрикаторОбъект);
		КонецЕсли;
		
		АвтоРубрикаторОбъект.Наименование = 
			СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = '%1 (заполняется автоматически)'"), НаименованиеЭлектронногоРесурса);
			
		АвтоРубрикаторОбъект.Записать();
		
		Возврат АвтоРубрикатор;	
		
	Иначе
		
		Если ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(АвтоРубрикатор, Ложь) Тогда
			Возврат АвтоРубрикатор;
		Иначе
			Возврат Неопределено;
		КонецЕсли;
		
	КонецЕсли;	
	
КонецФункции

&НаСервере
Процедура ЗаполнитьТаблицуСвязанныхЭлементов()
	
	// Очищаем таблицу
	
	СвязанныеЭлементы.Очистить();
	
	// Делаем проверки
	
	УстановитьДоступностьЭлементовФормы();
	
	Если НЕ ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
		Возврат;
	КонецЕсли;	
	
	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем все элементы рубрикатора данного вопроса и заполняем таблицу
	
	АвтоРубрикатор = ПолучитьАвтоРубрикатор(Ложь);
	
	Если НЕ ЗначениеЗаполнено(АвтоРубрикатор) Тогда
		Возврат;
	КонецЕсли;
	
	РубрикиВопроса = РегистрыСведений.РубрикиОбъектовСУЗ.РубрикиЭлемента(АвтоРубрикатор, Объект.Ссылка);
	
	Для каждого ТекущийЭлементРубрикатора Из РубрикиВопроса Цикл
		АвтоЭлементСодержания = Справочники.СодержаниеСУЗ.ПолучитьСсылку(ТекущийЭлементРубрикатора.УникальныйИдентификатор());
		НоваяСтрока = СвязанныеЭлементы.Добавить();
		НоваяСтрока.ЭлементСодержания = АвтоЭлементСодержания;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьТаблицуСвязанныхЭлементов()
	
	Если НЕ ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
		Возврат;
	КонецЕсли;
	
	АвтоРубрикатор = ПолучитьАвтоРубрикатор(Ложь);
	
	Если НЕ ЗначениеЗаполнено(АвтоРубрикатор)
		И СвязанныеЭлементы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		
		// Получаем авторубрикатор электронного ресурса
		
		АвтоРубрикатор = ПолучитьАвтоРубрикатор(Истина);
		
		// Получаем элементы рубрикатора для каждого элемента содержания
		
		ЭлементыРубрикатора = Новый Массив;
		
		Для каждого Строка Из СвязанныеЭлементы Цикл
		
			ТекущийЭлементРубрикатора = Справочники.ЭлементыРубрикатораСУЗ.ПолучитьСсылку(Строка.ЭлементСодержания.УникальныйИдентификатор());
			Если ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(ТекущийЭлементРубрикатора, Ложь) Тогда
				ЭлементРубрикатораОбъект = ТекущийЭлементРубрикатора.ПолучитьОбъект();
			Иначе			
				ЭлементРубрикатораОбъект = Справочники.ЭлементыРубрикатораСУЗ.СоздатьЭлемент();
				ЭлементРубрикатораОбъект.УстановитьСсылкуНового(ТекущийЭлементРубрикатора);
				ЭлементРубрикатораОбъект.Владелец = АвтоРубрикатор;				
				РазработкаСУЗ.УстановитьПредпочитаемогоПоставщика(ЭлементРубрикатораОбъект);
			КонецЕсли;
			
			ЭлементРубрикатораОбъект.Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Строка.ЭлементСодержания, "Наименование");		
			ЭлементРубрикатораОбъект.Записать();
			
			Если ЭлементыРубрикатора.Найти(ТекущийЭлементРубрикатора) = Неопределено Тогда
				ЭлементыРубрикатора.Добавить(ТекущийЭлементРубрикатора);
			КонецЕсли;
		
		КонецЦикла;
		
		// Удаляем вопрос из элементов рубрикатора, которых нет в таблице
		
		РубрикиВопроса = РегистрыСведений.РубрикиОбъектовСУЗ.РубрикиЭлемента(АвтоРубрикатор, Объект.Ссылка);
		
		Для каждого ТекущийЭлементРубрикатора Из РубрикиВопроса Цикл
		    Если ЭлементыРубрикатора.Найти(ТекущийЭлементРубрикатора) = Неопределено Тогда
				РегистрыСведений.РубрикиОбъектовСУЗ.УдалитьЭлемент(АвтоРубрикатор, ТекущийЭлементРубрикатора, Объект.Ссылка); 
			КонецЕсли;
		КонецЦикла;
		
		// Добавляем вопрос в элементы рубрикатора, которые есть в таблице		
		
		Для каждого ТекущийЭлементРубрикатора Из ЭлементыРубрикатора Цикл		
			РегистрыСведений.РубрикиОбъектовСУЗ.ДобавитьЭлемент(АвтоРубрикатор, ТекущийЭлементРубрикатора, Объект.Ссылка); 		
		КонецЦикла;
		
		// Завершаем
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецПроцедуры




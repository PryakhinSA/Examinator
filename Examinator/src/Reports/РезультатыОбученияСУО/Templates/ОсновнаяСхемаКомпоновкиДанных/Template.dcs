		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ВыданныеПинКодыСУО.Серия.Код + ВыданныеПинКодыСУО.Код КАК ПинКод,
	ВыданныеПинКодыСУО.Серия,
	ВыданныеПинКодыСУО.Код,
	ВыданныеПинКодыСУО.Пользователь,
	ВыданныеПинКодыСУО.Заблокирован,
	ВыданныеПинКодыСУО.Выдан,
	ВыданныеПинКодыСУО.УведомлениеПоказано,
	ВыданныеПинКодыСУО.ДатаСоздания,
	ВыданныеПинКодыСУО.ДатаВыдачи,
	ВыданныеПинКодыСУО.ДатаИспользования,
	ВыданныеПинКодыСУО.ДатаПоказаУведомления,
	ВыданныеПинКодыСУО.Ответственный,
	ВыданныеПинКодыСУО.Примечание,
	ВыданныеПинКодыСУО.Выдавший,
	ВыданныеПинКодыСУО.Заблокировал,
	ВыданныеПинКодыСУО.ДатаБлокировки,
	ВыданныеПинКодыСУО.Опция,
	СерииПинКодовСУООбучение.Проведение КАК ПроведениеОбучения
ИЗ
	РегистрСведений.ВыданныеПинКодыСУО КАК ВыданныеПинКодыСУО
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СерииПинКодовСУО.Обучение КАК СерииПинКодовСУООбучение
		ПО ВыданныеПинКодыСУО.Серия = СерииПинКодовСУООбучение.Ссылка</query>
	</dataSet>

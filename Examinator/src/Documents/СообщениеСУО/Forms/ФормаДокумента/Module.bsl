
#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтоОбразовательнаяОрганизация = ПолучитьФункциональнуюОпцию("ОбразовательнаяОрганизацияОО");
	
	// Примечание: если создается новый документ, то для него всегда
	// Создается новая тема, так как ответы на уже существующие
	// Темы записываются не интерактивно, а программно из формы
	// "ОбсуждениеТемы" справочника ТемыСообщенийСУО.
	
	// Выполняем установку реквизитов и доступность элементов
	//
	
	Если Объект.Ссылка.Пустая() Тогда
		
		Объект.Пользователь          = Пользователи.ТекущийПользователь();
		Объект.РодительскоеСообщение = Параметры.РодительскоеСообщение;
		
		УстановитьПривилегированныйРежим(Истина);
		
		Если ЗначениеЗаполнено(Объект.РодительскоеСообщение) Тогда
			
			ТекстРодительскогоСообщения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.РодительскоеСообщение, "ФорматированныйДокумент").Получить();
			
			Если НЕ ЗначениеЗаполнено(Параметры.Тема) Тогда
				Параметры.Тема = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.РодительскоеСообщение, "Тема");
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(Параметры.Контекст)
				И ЗначениеЗаполнено(Параметры.Тема) Тогда
				
				Параметры.Контекст = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.Тема, "Контекст");
				
			КонецЕсли;
			
		КонецЕсли;
		
		УстановитьПривилегированныйРежим(Ложь);
		
		Если ЗначениеЗаполнено(Параметры.Тема) Тогда
			
			Объект.Тема = Параметры.Тема;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Параметры.Кому) Тогда
			
			Кому = Перечисления.АдресатыСообщенийСУО[Параметры.Кому];
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Параметры.Контекст) Тогда
			
			Контекст = Параметры.Контекст;
			
			Если НЕ ЗначениеЗаполнено(Кому) Тогда
				Кому = Справочники.ТемыСообщенийСУО.АдресатПоКонтексту(Контекст);
			КонецЕсли;
			
			ПредставлениеКонтекста = ПредставлениеКонтекстаСообщения(Кому, Контекст, Объект.Тема, Объект.Пользователь);
			
		КонецЕсли;
		
		
		Если ЗначениеЗаполнено(Объект.Шаблон) Тогда
			
			Если Объект.Шаблон.ЭтоГруппа Тогда
				Текст = НСтр("ru = 'Создание сообщения на основании группы шаблонов не поддерживается'");
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст,,,,Отказ);
			КонецЕсли;
			
			НоваяТема = Объект.Шаблон.Заголовок;
			
		КонецЕсли;
		
	Иначе
		
		Кому     = Объект.Тема.Кому;
		Контекст = Объект.Тема.Контекст;
		
		ПредставлениеКонтекста = ПредставлениеКонтекстаСообщения(Кому, Контекст, Объект.Тема, Объект.Пользователь);
		
		МассивФайлов = Новый Массив;
		ПрисоединенныеФайлы.ПолучитьПрикрепленныеФайлыКОбъекту(Объект.Ссылка, МассивФайлов);
		ЕстьФайлы = ?(МассивФайлов.Количество() > 0, Истина, Ложь); 
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Шаблон) Тогда
		
		Элементы.ГруппаСообщение.ТолькоПросмотр = Истина;
		
		Если ЗначениеЗаполнено(Объект.Рассылка) Тогда
			Элементы.ЗначенияПеременных.Видимость = Ложь;
		Иначе
			Элементы.ЗначенияПеременных.Видимость = Истина;
		КонецЕсли;
		
	Иначе
		
		Элементы.Шаблон.Видимость = Ложь; // Заполняется программно
		
		Элементы.ЗначенияПеременных.Видимость = Ложь; // Переменные задаются в рассылке.
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Рассылка) Тогда
		Элементы.Рассылка.Видимость = Ложь;  // Заполняется программно
	КонецЕсли;
	
	// Заполняем список адресатов

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ОрганизаторыСУО.Пользователь,
		|	ОрганизаторыСУО.Наименование
		|ИЗ
		|	Справочник.ОрганизаторыСУО КАК ОрганизаторыСУО
		|ГДЕ
		|	ОрганизаторыСУО.ПометкаУдаления = ЛОЖЬ";

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СписокАдресатов.Добавить(ВыборкаДетальныеЗаписи.Пользователь, ВыборкаДетальныеЗаписи.Наименование);
	КонецЦикла;
	
	ТаблицаПреподавателей = РегистрыСведений.ПреподавателиОбученияСУО.ВсеПреподавателиПользователя(Пользователи.ТекущийПользователь());
	
	Для каждого СтрокаТП Из ТаблицаПреподавателей Цикл
		СписокАдресатов.Добавить(СтрокаТП.Преподаватель, СтрокаТП.Наименование);
	КонецЦикла;
	
	
	// Заполняем таблицу, определяющую сценарий получения контекста сообщения для
	// Каждого адресата.
	//
	
	// Описание колонок
	
	// Кому                           - значение перечисления "АдресатыСообщенийСУО".
	//                                 По этому значению находится соответствующая строка таблицы.
	
	// ОписаниеИсточника              - строка подставляется в вопрос при необходимости выбрать несколько источников данных
	//                                 в рамках одного адресата (поля Кому).
	//                                 Каждый источник данных задается отдельной строкой таблицы.
	
	// ФормаВыбора                    - форма, которая позволяет выбрать контекст сообщения.
	
	// ИмяРеквизита                   - реквизит данных, переданных из формы выбора (основной или дополнительной
	//                                 при ее наличии), который содержит контекст сообщения      
	
	// ПромежуточнаяФормаВыбора       - форма из которой выбираются дополнительные данные для уточнения контекста.
	//                                 Вызывается при наличии после вывода первой формы выбора.
	
	// ИмяПараметраПромежуточнойФормы - имя параметра, который нужно передать в промежуточную форму,
	//                                 чтобы там отобразился нужный список выбора.
	
	// ИмяПромежуточногоРеквизита     - имя реквизита данных, полученный из основной формы, который
	//                                 нужно передать в промежуточную форму
	
	// Значение                       - предопределенное значение, которое будет подставлено в качестве контекста.
	//
	
	// УчастникамМероприятия
	
	УстановитьПривилегированныйРежим(Истина);
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому              = Перечисления.АдресатыСообщенийСУО.УчастникамМероприятия;
	НоваяСтрока.ФормаВыбора       = "РегистрСведений.ПрохожденияОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ОписаниеИсточника = "учащемуся";
	НоваяСтрока.ИмяРеквизита      = "ПроведениеОбучения";
	НоваяСтрока.Доступность       = ?(УправлениеДоступом.ЕстьРоль("ЛичныйКабинетПрохождениеОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому              = Перечисления.АдресатыСообщенийСУО.УчастникамМероприятия;
	НоваяСтрока.ФормаВыбора       = "РегистрСведений.ПроведениеПреподавателямиОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ОписаниеИсточника = "преподавателю";
	НоваяСтрока.ИмяРеквизита      = "ПроведениеОбучения";
	НоваяСтрока.Доступность       = ?(УправлениеДоступом.ЕстьРоль("УправлениеПроведениемОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому              = Перечисления.АдресатыСообщенийСУО.УчастникамМероприятия;
	НоваяСтрока.ФормаВыбора       = "Документ.ПроведениеОбученияСУО.ФормаВыбора";
	НоваяСтрока.ОписаниеИсточника = "менеджеру";
	НоваяСтрока.ИмяРеквизита      = "Ссылка";
	НоваяСтрока.Доступность       = ?(УправлениеДоступом.ЕстьРоль("УправлениеПроведениемОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	// УчастникамПрограммыОбучения
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому              = Перечисления.АдресатыСообщенийСУО.УчастникамПрограммыОбучения;
	НоваяСтрока.ФормаВыбора       = "РегистрСведений.ПрохожденияПрограммОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ОписаниеИсточника = "учащемуся";
	НоваяСтрока.ИмяРеквизита      = "ПроведениеПрограммыОбучения";
	НоваяСтрока.Доступность       = ?(УправлениеДоступом.ЕстьРоль("ЛичныйКабинетПрохождениеОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому              = Перечисления.АдресатыСообщенийСУО.УчастникамПрограммыОбучения;
	НоваяСтрока.ФормаВыбора       = "Документ.ПроведениеПрограммыОбученияСУО.ФормаВыбора";
	НоваяСтрока.ОписаниеИсточника = "менеджеру";
	НоваяСтрока.ИмяРеквизита      = "Ссылка";
	НоваяСтрока.Доступность       = ?(УправлениеДоступом.ЕстьРоль("УправлениеПроведениемОбученияСУО",,Объект.Пользователь), Истина, Ложь);

	// УчебнойГруппе
	
	Если ЭтоОбразовательнаяОрганизация Тогда
	
		НоваяСтрока = ДанныеОКонтексте.Добавить();
		НоваяСтрока.Кому         = Перечисления.АдресатыСообщенийСУО.УчебнойГруппе;
		НоваяСтрока.ФормаВыбора  = "Справочник.УчебныеГруппыОО.ФормаВыбора";
		НоваяСтрока.ИмяРеквизита = "Ссылка";
		НоваяСтрока.Доступность  = ?(УправлениеДоступом.ЕстьРоль("ЛичныйКабинетУчебныеГруппыСУО",,Объект.Пользователь), Истина, Ложь);
									 
	Иначе
		 
		НоваяСтрока = ДанныеОКонтексте.Добавить();
		НоваяСтрока.Кому         = Перечисления.АдресатыСообщенийСУО.УчебнойГруппе;
		НоваяСтрока.ФормаВыбора  = "Справочник.УчебныеГруппыСУО.ФормаВыбора";
		НоваяСтрока.ИмяРеквизита = "Ссылка";
		НоваяСтрока.Доступность  = ?(УправлениеДоступом.ЕстьРоль("ЛичныйКабинетУчебныеГруппыСУО",,Объект.Пользователь), Истина, Ложь);		 
		 
	 КонецЕсли;						 
									 
	// НаФорум
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому         = Перечисления.АдресатыСообщенийСУО.НаФоруме;
	НоваяСтрока.ФормаВыбора  = "Справочник.РазделыФорумаСУО.ФормаВыбора";
	НоваяСтрока.ИмяРеквизита = "Ссылка";
	НоваяСтрока.Доступность  = Истина;
								 
	// УчастникуМероприятия
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому                            = Перечисления.АдресатыСообщенийСУО.УчастникуМероприятия;
	НоваяСтрока.ОписаниеИсточника               = "учащемуся";
	НоваяСтрока.ФормаВыбора                     = "РегистрСведений.ПрохожденияОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ИмяРеквизита                    = "Ссылка";
	НоваяСтрока.ПромежуточнаяФормаВыбора        = "РегистрСведений.УчастникиОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ИмяПараметраПромежуточнойФормы  = "ПроведениеОбучения";
	НоваяСтрока.ИмяПромежуточногоРеквизита      = "ПроведениеОбучения";
	НоваяСтрока.Доступность                     = ?(УправлениеДоступом.ЕстьРоль("ЛичныйКабинетПрохождениеОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому                           = Перечисления.АдресатыСообщенийСУО.УчастникуМероприятия;
	НоваяСтрока.ОписаниеИсточника              = "преподавателю";	
	НоваяСтрока.ФормаВыбора                    = "РегистрСведений.ПроведениеПреподавателямиОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ИмяРеквизита                   = "Ссылка";
	НоваяСтрока.ПромежуточнаяФормаВыбора       = "РегистрСведений.УчастникиОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ИмяПараметраПромежуточнойФормы = "ПроведениеОбучения";
	НоваяСтрока.ИмяПромежуточногоРеквизита     = "ПроведениеОбучения";
	НоваяСтрока.Доступность                    = ?(УправлениеДоступом.ЕстьРоль("УправлениеПроведениемОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому                           = Перечисления.АдресатыСообщенийСУО.УчастникуМероприятия;
	НоваяСтрока.ОписаниеИсточника              = "менеджеру";	
	НоваяСтрока.ФормаВыбора                    = "Документ.ПроведениеОбученияСУО.ФормаВыбора";
	НоваяСтрока.ИмяРеквизита                   = "Ссылка";
	НоваяСтрока.ПромежуточнаяФормаВыбора       = "РегистрСведений.УчастникиОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ИмяПараметраПромежуточнойФормы = "ПроведениеОбучения";
	НоваяСтрока.ИмяПромежуточногоРеквизита     = "Ссылка";
	НоваяСтрока.Доступность                    = ?(УправлениеДоступом.ЕстьРоль("УправлениеПроведениемОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	// УчастникуПрограммыОбучения
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому                            = Перечисления.АдресатыСообщенийСУО.УчастникуПрограммыОбучения;
	НоваяСтрока.ОписаниеИсточника               = "учащемуся";
	НоваяСтрока.ФормаВыбора                     = "РегистрСведений.ПрохожденияПрограммОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ИмяРеквизита                    = "Ссылка";
	НоваяСтрока.ПромежуточнаяФормаВыбора        = "РегистрСведений.УчастникиПрограммОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ИмяПараметраПромежуточнойФормы  = "ПроведениеПрограммыОбучения";
	НоваяСтрока.ИмяПромежуточногоРеквизита      = "ПроведениеПрограммыОбучения";
	НоваяСтрока.Доступность                     = ?(УправлениеДоступом.ЕстьРоль("ЛичныйКабинетПрохождениеОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому                           = Перечисления.АдресатыСообщенийСУО.УчастникуПрограммыОбучения;
	НоваяСтрока.ОписаниеИсточника              = "менеджеру";	
	НоваяСтрока.ФормаВыбора                    = "Документ.ПроведениеПрограммыОбученияСУО.ФормаВыбора";
	НоваяСтрока.ИмяРеквизита                   = "Ссылка";
	НоваяСтрока.ПромежуточнаяФормаВыбора       = "РегистрСведений.УчастникиПрограммОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ИмяПараметраПромежуточнойФормы = "ПроведениеПрограммыОбучения";
	НоваяСтрока.ИмяПромежуточногоРеквизита     = "Ссылка";
	НоваяСтрока.Доступность                    = ?(УправлениеДоступом.ЕстьРоль("УправлениеПроведениемОбученияСУО",,Объект.Пользователь), Истина, Ложь);
												   
												   
	// Преподавателям
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому              = Перечисления.АдресатыСообщенийСУО.Преподавателям;
	НоваяСтрока.ФормаВыбора       = "РегистрСведений.ПрохожденияОбученияСУО.Форма.ФормаВыбора";
	НоваяСтрока.ОписаниеИсточника = "учащемуся";
	НоваяСтрока.ИмяРеквизита      = "ПроведениеОбучения";
	НоваяСтрока.Доступность       = ?(УправлениеДоступом.ЕстьРоль("ЛичныйКабинетПрохождениеОбученияСУО",,Объект.Пользователь), Истина, Ложь);
	
	НоваяСтрока = ДанныеОКонтексте.Добавить();
	НоваяСтрока.Кому              = Перечисления.АдресатыСообщенийСУО.Преподавателям;

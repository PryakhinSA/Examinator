// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

// Темы

&НаКлиенте
Процедура УстановитьПериодОбновленияСпискаТем()
	
	ОтключитьОбработчикОжидания("Подключаемый_ОбновитьСписокТем");
	
	Если ЧастотаОбновленияСпискаТем > 0 Тогда
		ПодключитьОбработчикОжидания("Подключаемый_ОбновитьСписокТем", ЧастотаОбновленияСпискаТем);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьСписокТем()
	
	Если Элементы.Новые.Пометка Тогда
		Возврат; // Отключаем обновление тем, чтобы они сами не пропадали
	КонецЕсли;
	
	Элементы.Темы.Обновить();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ИзменитьСтатусТемы(Тема, ИмяРеквизита=Неопределено, Значение=Неопределено)
	
	Справочники.ТемыСообщенийСУО.ЗаписатьПользовательскиеНастройкиТемы(Тема, ИмяРеквизита, Значение, Пользователи.ТекущийПользователь());
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьСтатусТемыНаКлиенте(ИмяРеквизита, Значение=Неопределено)
	
	ТекущиеДанные = Элементы.Темы.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Значение = Неопределено Тогда
		Значение = ?(ТекущиеДанные[ИмяРеквизита], Ложь, Истина); // Устанавливаем значение, противоположное текущему.
	КонецЕсли;
	
	ИзменитьСтатусТемы(ТекущиеДанные.Тема, ИмяРеквизита, Значение);
	
	Элементы.Темы.Обновить();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборТем(ИмяОтбора=Неопределено)
	
	ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(Темы.Отбор, "Архивирована");
	ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(Темы.Отбор, "Удалена");
	ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(Темы.Отбор, "Помечена");
	ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(Темы.Отбор, "ЭтоАвтор");
	ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(Темы.Отбор, "ЕстьНовыеСообщения");
	
	Если ИмяОтбора = Неопределено Тогда
		ИмяОтбора = "Входящие";
	КонецЕсли;
	
	Если ИмяОтбора = "Входящие" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Темы.Отбор, "Архивирована", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Темы.Отбор, "Удалена", Ложь);
		Элементы.Входящие.Пометка = Истина;
		Элементы.КомандаАрхивировать.Доступность = Истина;
		Элементы.КомандаУдалить.Доступность = Истина;
		Элементы.ТемыКонтекстноеМенюВосстановить.Доступность = Ложь;
	Иначе
		Элементы.Входящие.Пометка = Ложь;
	КонецЕсли;
	
	Если ИмяОтбора = "Новые" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Темы.Отбор, "ЕстьНовыеСообщения", Истина);
		Элементы.Новые.Пометка = Истина;
		Элементы.КомандаАрхивировать.Доступность = Истина;
		Элементы.КомандаУдалить.Доступность = Истина;
		Элементы.ТемыКонтекстноеМенюВосстановить.Доступность = Ложь;
	Иначе
		Элементы.Новые.Пометка = Ложь;
	КонецЕсли;
	
	Если ИмяОтбора = "Помеченные" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Темы.Отбор, "Помечена", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Темы.Отбор, "Удалена", Ложь);
		Элементы.Помеченные.Пометка = Истина;
		Элементы.КомандаАрхивировать.Доступность = Истина;
		Элементы.КомандаУдалить.Доступность = Истина;
		Элементы.ТемыКонтекстноеМенюВосстановить.Доступность = Ложь;
	Иначе
		Элементы.Помеченные.Пометка = Ложь;
	КонецЕсли;
	
	Если ИмяОтбора = "Отправленные" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Темы.Отбор, "ЭтоАвтор", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Темы.Отбор, "Удалена", Ложь);
		Элементы.Отправленные.Пометка = Истина;
		Элементы.КомандаАрхивировать.Доступность = Истина;
		Элементы.КомандаУдалить.Доступность = Истина;
		Элементы.ТемыКонтекстноеМенюВосстановить.Доступность = Ложь;
	Иначе
		Элементы.Отправленные.Пометка = Ложь;
	КонецЕсли;
	
	Если ИмяОтбора = "Все" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Темы.Отбор, "Удалена", Ложь);
		Элементы.ВсеТемы.Пометка = Истина;
		Элементы.КомандаАрхивировать.Доступность = Ложь;
		Элементы.КомандаУдалить.Доступность = Истина;
		Элементы.ТемыКонтекстноеМенюВосстановить.Доступность = Истина;
	Иначе
		Элементы.ВсеТемы.Пометка = Ложь;
	КонецЕсли;
	
	Если ИмяОтбора = "Корзина" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Темы.Отбор, "Удалена", Истина);
		Элементы.Корзина.Пометка = Истина;
		Элементы.КомандаАрхивировать.Доступность = Истина;
		Элементы.КомандаУдалить.Доступность = Ложь;
		Элементы.ТемыКонтекстноеМенюВосстановить.Доступность = Истина;
	Иначе
		Элементы.Корзина.Пометка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

// Обсуждение темы

&НаСервереБезКонтекста
Функция ПолучитьДокументСообщения(НомерСообщения, УникальныйИдентификатор=Неопределено)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Сообщение = Документы.СообщениеСУО.НайтиПоНомеру(НомерСообщения);
	
	Если УникальныйИдентификатор = Неопределено Тогда
		Возврат Сообщение;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СообщениеСУОПрисоединенныеФайлы.Ссылка
		|ИЗ
		|	Справочник.СообщениеСУОПрисоединенныеФайлы КАК СообщениеСУОПрисоединенныеФайлы
		|ГДЕ
		|	СообщениеСУОПрисоединенныеФайлы.ВладелецФайла = &Сообщение";

	Запрос.УстановитьПараметр("Сообщение", Сообщение);

	Результат = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Если ВыборкаДетальныеЗаписи.Количество() = 1 Тогда
		
		ВыборкаДетальныеЗаписи.Следующий();
		
		Возврат ПрисоединенныеФайлы.ПолучитьДанныеФайла(ВыборкаДетальныеЗаписи.Ссылка, УникальныйИдентификатор);
		
	Иначе
		
		Возврат Сообщение;
		
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьАвтораСообщения(УникальныйИдентификатор)
	Возврат Справочники.Пользователи.ПолучитьСсылку(УникальныйИдентификатор);
КонецФункции

&НаСервереБезКонтекста
Процедура СохранитьСообщение(Знач Тема, Знач Сообщение, Знач ИнформацияОПрикрепленныхФайлах, Отказ)
	
	НачатьТранзакцию();
	
	СообщениеОбъект = Документы.СообщениеСУО.СоздатьДокумент();
	СообщениеОбъект.Дата         = ТекущаяДатаСеанса();
	СообщениеОбъект.Пользователь = Пользователи.ТекущийПользователь();
	СообщениеОбъект.Тема         = Тема;
	
	ХранилищеСообщения = Новый ХранилищеЗначения(Сообщение, Новый СжатиеДанных(9));  
	СообщениеОбъект.ФорматированныйДокумент = ХранилищеСообщения;
	
	СообщениеОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	// Прикрепляем файл
	
	Если ТипЗнч(ИнформацияОПрикрепленныхФайлах) = Тип("ФиксированныйМассив") Тогда
		
		Для каждого ИнформацияОПрикрепленномФайле Из ИнформацияОПрикрепленныхФайлах Цикл
		
		// Создадим карточку Файла в БД
		ПрисоединенныйФайл = ПрисоединенныеФайлы.ДобавитьФайл(
									СообщениеОбъект.Ссылка,
									ИнформацияОПрикрепленномФайле.ИмяБезРасширения,
									ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(ИнформацияОПрикрепленномФайле.Расширение),
									,
									,
									ИнформацияОПрикрепленномФайле.Адрес);
									
			
		
		КонецЦикла;
		
	КонецЕсли;
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

&НаСервере
Процедура СохранитьСообщениеНаСервере(Тема)
	
	// Примечание: сохранение сообщения происходит в настоящее время при помощи обычной серверной
	// Процедуры, так как при передачи сообщения с клиента на сервер при использовании
	// Внеконтекстного вызова серверной процедуры возникают ошибки.
	
	Отказ = Ложь;
	СохранитьСообщение(Тема, Сообщение, ИнформацияОПрикрепленныхФайлах, Отказ);
	
	Если НЕ Отказ Тогда
		
		Сообщение.Удалить(); // Очищаем поле форматированного документа
		
		ИнформацияОПрикрепленныхФайлах = Неопределено;
		Элементы.ИнформацияОПрикрепленномФайле.Заголовок = "";
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьXDTOСообщений(ТаблицаСообщений, НомерРодительскогоСообщения, ДатаПросмотра, СообщенияXDTO, СообщениеXDTOТип, ПользовательXDTOТип, Знач Уровень, ДеревоСообщений)
	
	Если ДеревоСообщений Тогда
	
		Уровень = Уровень + 1;
		
		СтрокиДляОбхода = ТаблицаСообщений.НайтиСтроки(Новый Структура("НомерРодительскогоСообщения", НомерРодительскогоСообщения));
		
	Иначе
		
		СтрокиДляОбхода = ТаблицаСообщений;
		
	КонецЕсли;
		
	Для каждого Строка Из СтрокиДляОбхода Цикл
			
		СообщениеXDTO = Документы.СообщениеСУО.СообщениеXDTO(Строка.Сообщение, Строка, СообщениеXDTOТип, ПользовательXDTOТип);
		
		Если ЗначениеЗаполнено(ДатаПросмотра) И Строка.Дата > ДатаПросмотра Тогда
			СообщениеXDTO.Новое = Истина;
		Иначе
			СообщениеXDTO.Новое = Ложь;
		КонецЕсли;
		
		СообщениеXDTO.Уровень = Уровень;
		
		СообщенияXDTO.Сообщение.Добавить(СообщениеXDTO);
		
		Если ДеревоСообщений Тогда
			
			ДобавитьXDTOСообщений(ТаблицаСообщений, Строка.Номер, ДатаПросмотра, СообщенияXDTO, СообщениеXDTOТип, ПользовательXDTOТип, Уровень, ДеревоСообщений); // Рекурсия
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьДанныеОбсуждения(Тема, НовыеВверху, ДеревоСообщений, ДатаПросмотра, Пользователь, ЭтоФорум, ПервыйПоказ, ИдентификаторФормы)
	
	УстановитьПривилегированныйРежим(Истина); 
	
	ДанныеТемы = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Тема, "Кому, Контекст, Закрыта");
	
	Если ДатаПросмотра = Неопределено Тогда
		
		Запрос = Новый Запрос;
		
		Если ЭтоФорум Тогда
			
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	НастройкиТемФорумаСУО.ДатаПросмотра
			|ИЗ
			|	РегистрСведений.НастройкиТемФорумаСУО КАК НастройкиТемФорумаСУО
			|ГДЕ
			|	НастройкиТемФорумаСУО.Пользователь = &Пользователь
			|	И НастройкиТемФорумаСУО.Тема = &Тема";
			
		Иначе
		
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	НастройкиТемОбщенияСУО.ДатаПросмотра
			|ИЗ
			|	РегистрСведений.НастройкиТемОбщенияСУО КАК НастройкиТемОбщенияСУО
			|ГДЕ
			|	НастройкиТемОбщенияСУО.Пользователь = &Пользователь
			|	И НастройкиТемОбщенияСУО.Тема = &Тема";
			
		КонецЕсли;
		
		Запрос.УстановитьПараметр("Пользователь", Пользователь);
		Запрос.УстановитьПараметр("Тема", Тема);

		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			
			ДатаПросмотра = Дата("00010101");
			
		Иначе
			
			ВыборкаДетальныеЗаписи = Результат.Выбрать();

			ВыборкаДетальныеЗаписи.Следующий();

			ДатаПросмотра = ВыборкаДетальныеЗаписи.ДатаПросмотра;
			
		КонецЕсли;
			
	КонецЕсли;
	
	
	// Выбираем все сообщения
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СообщенияТемСУО.ФорматированныйДокумент КАК ФорматированныйДокумент,
		|	СообщенияТемСУО.Регистратор КАК Документ,
		|	СообщенияТемСУО.Номер КАК Номер,
		|	СообщенияТемСУО.Период КАК Дата,
		|	СообщенияТемСУО.Пользователь КАК Пользователь,
		|	СообщенияТемСУО.Пользователь.Наименование КАК ИмяПользователя,
		|	СообщенияТемСУО.Шаблон,
		|	СообщенияТемСУО.РодительскоеСообщение
		|ИЗ
		|	РегистрСведений.СообщенияТемСУО КАК СообщенияТемСУО
		|ГДЕ
		|	СообщенияТемСУО.Тема = &Тема
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата";

		
	Если НовыеВверху Тогда
		Запрос.Текст = Запрос.Текст + " УБЫВ";
	КонецЕсли;
		
	Запрос.УстановитьПараметр("Тема", Тема);

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	// Формируем массив документов СообщениеСУО
	
	МассивДокументов = Новый Массив();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивДокументов.Добавить(ВыборкаДетальныеЗаписи.Документ);
	КонецЦикла;

	ЗапросФайлов = Новый Запрос;
	ЗапросФайлов.Текст = 
		"ВЫБРАТЬ
		|	СообщениеСУОПрисоединенныеФайлы.Ссылка КАК Файл,
		|	СообщениеСУОПрисоединенныеФайлы.ВладелецФайла КАК Сообщение
		|ИЗ
		|	Справочник.СообщениеСУОПрисоединенныеФайлы КАК СообщениеСУОПрисоединенныеФайлы
		|ГДЕ
		|	СообщениеСУОПрисоединенныеФайлы.ВладелецФайла В(&МассивСообщений)";

	ЗапросФайлов.УстановитьПараметр("МассивСообщений", МассивДокументов);

	ТаблицаФайловСообщений = ЗапросФайлов.Выполнить().Выгрузить();
	
	// Формируем таблицу сообщений
	
	ТаблицаСообщений = Новый ТаблицаЗначений();
	ТаблицаСообщений.Колонки.Добавить("ТекстHTML");
	ТаблицаСообщений.Колонки.Добавить("Пользователь");
	ТаблицаСообщений.Колонки.Добавить("ИмяПользователя");
	ТаблицаСообщений.Колонки.Добавить("Номер");
	ТаблицаСообщений.Колонки.Добавить("Дата");
	ТаблицаСообщений.Колонки.Добавить("ЕстьПрикрепленныеФайлы");
	ТаблицаСообщений.Колонки.Добавить("Сообщение");
	ТаблицаСообщений.Колонки.Добавить("РодительскоеСообщение");
	ТаблицаСообщений.Колонки.Добавить("НомерРодительскогоСообщения");
	ТаблицаСообщений.Колонки.Добавить("Уровень");
	
	МассивРесурсовДляКэширования = Новый Массив();
	
	ВыборкаДетальныеЗаписи.Сбросить();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Сообщение  = ВыборкаДетальныеЗаписи.ФорматированныйДокумент.Получить();
		
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Шаблон) Тогда
			ИдентификаторСообщения  = Строка(ВыборкаДетальныеЗаписи.Шаблон.УникальныйИдентификатор());
			Ресурс                  = ВыборкаДетальныеЗаписи.Шаблон;
		Иначе
			ИдентификаторСообщения  = Строка(ВыборкаДетальныеЗаписи.Документ.УникальныйИдентификатор());
			Ресурс                  = ВыборкаДетальныеЗаписи.Документ;
		КонецЕсли;
		
		НоваяСтрокаТС = ТаблицаСообщений.Добавить();
		
		НоваяСтрокаТС.ТекстHTML             = ОбщегоНазначенияСУ.ПредставлениеФорматированныйДокументДляПоляHTML(Сообщение, ИдентификаторФормы);
		НоваяСтрокаТС.Пользователь          = ВыборкаДетальныеЗаписи.Пользователь;
		НоваяСтрокаТС.ИмяПользователя       = ВыборкаДетальныеЗаписи.ИмяПользователя;
		НоваяСтрокаТС.Номер                 = ВыборкаДетальныеЗаписи.Номер;
		НоваяСтрокаТС.Дата                  = ВыборкаДетальныеЗаписи.Дата;
		НоваяСтрокаТС.РодительскоеСообщение = ВыборкаДетальныеЗаписи.РодительскоеСообщение;
		НоваяСтрокаТС.Сообщение             = ВыборкаДетальныеЗаписи.Документ;
	
		Если ТаблицаФайловСообщений.Найти(ВыборкаДетальныеЗаписи.Документ, "Сообщение") = Неопределено Тогда
			НоваяСтрокаТС.ЕстьПрикрепленныеФайлы = Ложь;
		Иначе
			НоваяСтрокаТС.ЕстьПрикрепленныеФайлы = Истина;
		КонецЕсли;
		
		НоваяСтрокаТС.НомерРодительскогоСообщения = "";
		
	КонецЦикла;

	ЭтоДерево = Ложь;
	
	Если ДеревоСообщений Тогда
		
		Для каждого Строка Из ТаблицаСообщений Цикл
			
			// Указываем номер родительского сообщения
			
			Если ЗначениеЗаполнено(Строка.РодительскоеСообщение) Тогда
				
				СтрокаРодительская = ТаблицаСообщений.Найти(Строка.РодительскоеСообщение, "Сообщение");
				
				Если СтрокаРодительская <> Неопределено Тогда
					
					Строка.НомерРодительскогоСообщения = СтрокаРодительская.Номер;
					
					ЭтоДерево = Истина;
					
				КонецЕсли;
				
			Иначе
				
				Строка.НомерРодительскогоСообщения = "";
				
			КонецЕсли;
		
		КонецЦикла;
		
	КонецЕсли;
	
	// Формируем модель XML обсуждения через механизм XDTO.
	
	ОбсуждениеXDTOТип   = ФабрикаXDTO.Тип("http://v8.1c.ru/lms/1/Forum","Обсуждение");
	ОбсуждениеXDTO      = ФабрикаXDTO.Создать(ОбсуждениеXDTOТип);
	
	СообщенияXDTOТип    = ФабрикаXDTO.Тип("http://v8.1c.ru/lms/1/Forum","Сообщения");
	СообщенияXDTO       = ФабрикаXDTO.Создать(СообщенияXDTOТип);
	
	СообщениеXDTOТип    = ФабрикаXDTO.Тип("http://v8.1c.ru/lms/1/Forum","Сообщение");
	ПользовательXDTOТип = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/User","Пользователь");
	
	
	ДобавитьXDTOСообщений(ТаблицаСообщений, "", ДатаПросмотра, СообщенияXDTO, СообщениеXDTOТип, ПользовательXDTOТип, 0, ДеревоСообщений);
	
	ОбсуждениеXDTO.Сообщения = СообщенияXDTO;
	
	ОбсуждениеXDTO.ЭтоДерево = ЭтоДерево;
	ОбсуждениеXDTO.Закрыто   = ДанныеТемы.Закрыта;
	ОбсуждениеXDTO.ДоступноМодерирование = ?(ТипЗнч(ДанныеТемы.Контекст) = Тип("СправочникСсылка.Пользователи"), Ложь, Истина);
	
	// Получаем XML.
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();
	ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, ОбсуждениеXDTO);
	
	XMLДанныеОбсуждения = ЗаписьXML.Закрыть();
	
	// Получаем представление HTML.
	
	Преобразование = Новый ПреобразованиеXSL;
	ШаблонXSL = Справочники.ТемыСообщенийСУО.ПолучитьМакет("ШаблонОбсуждения").ПолучитьТекст();
	
	Преобразование.ЗагрузитьИзСтроки(ШаблонXSL);
	ИтоговыйHTML = Преобразование.ПреобразоватьИзСтроки(XMLДанныеОбсуждения);
	
	// Формируем структуру данных сообщения для возврата на клиент.
	
	ДанныеОбсуждения = Новый Структура("Представление, ПредставлениеКонтекстаТемы, ЭтоДерево", ИтоговыйHTML, Документы.СообщениеСУО.ПредставлениеКонтекстаСообщения(ДанныеТемы.Кому, ДанныеТемы.Контекст), ЭтоДерево);
		
	// Запоминаем последнюю дату просмотра темы
	
	ИзменитьСтатусТемы(Тема);
				
	Возврат ДанныеОбсуждения;
	
КонецФункции

&НаКлиенте
Процедура ЗагрузитьОбсуждение(ПервыйПоказ=Ложь)
	
	Если НЕ ЗначениеЗаполнено(Параметры.Тема) Тогда // Много тем
		
		ДатаПросмотра      = Неопределено;
		ТекущаяТема        = Неопределено;
		ТекущаяТемаЗакрыта = Истина;		
		ТекущийКонтекст    = Неопределено;
		ТекущийАдресат     = Неопределено;
		
		ТекущиеДанные = Элементы.Темы.ТекущиеДанные;
		
		Если ТекущиеДанные <> Неопределено Тогда
			
			ТекущаяТема        = ТекущиеДанные.Тема;
			ДатаПросмотра      = ТекущиеДанные.ДатаПросмотра;
			ТекущаяТемаЗакрыта = ТекущиеДанные.Закрыта;
			ТекущийКонтекст    = ТекущиеДанные.Контекст;
			ТекущийАдресат     = ТекущиеДанные.Кому;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущаяТема) Тогда
		
		Если Элементы.КомандаПоказатьСкрытьУчастников.Пометка Тогда
			Участники.Параметры.УстановитьЗначениеПараметра("Тема", ТекущаяТема);
		КонецЕсли;
		
		ДанныеОбсуждения = ПолучитьДанныеОбсуждения(ТекущаяТема, НовыеСообщениеРазмещатьВверху, ДеревоСообщений, ДатаПросмотра, ТекущийПользователь, ЭтоФорум, ПервыйПоказ, УникальныйИдентификатор); // Внеконтекстный вызов сервера
		
		// Запоминаем текущие данные открытой темы
		
		Обсуждение                 = ДанныеОбсуждения.Представление; // Реквизит формы
		ПредставлениеКонтекстаТемы = ДанныеОбсуждения.ПредставлениеКонтекстаТемы;  // Реквизит формы
		ЭтоДерево                  = ДанныеОбсуждения.ЭтоДерево; // Реквизит формы
		
	Иначе
		
		ПредставлениеКонтекстаТемы = ""; // Реквизит формы
		Обсуждение                 = ""; // Реквизит формы

		Участники.Параметры.УстановитьЗначениеПараметра("Тема", Неопределено);
		
	КонецЕсли;
	
	// Управляем видимостью элементов
	
	Если ЭтоФорум Тогда
		
		Элементы.ВашОтвет.Видимость = НЕ ТекущаяТемаЗакрыта;
		Элементы.ГруппаОтправкаСообщения.Видимость = НЕ ТекущаяТемаЗакрыта;
		
	Иначе
		
		Элементы.ВашОтвет.Доступность = НЕ ТекущаяТемаЗакрыта;
		Элементы.ГруппаОтправкаСообщения.Доступность = НЕ ТекущаяТемаЗакрыта;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ЗагрузитьОбсуждение()
	
	ЗагрузитьОбсуждение();
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьСтатусыПользователей()
	
	Если Элементы.Участники.Видимость Тогда
		Участники.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДата());
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПериодОбновленияИнформацииОбАктивностиУчастников()
	
	ОтключитьОбработчикОжидания("Подключаемый_ОбновитьСтатусыПользователей");
	ОтключитьОбработчикОжидания("Подключаемый_УстановитьАктивностьПользователя");
	
	Если ЧастотаПроверкиСтатусаУчастников > 0 Тогда
		ПодключитьОбработчикОжидания("Подключаемый_ОбновитьСтатусыПользователей", ЧастотаПроверкиСтатусаУчастников);
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_УстановитьАктивностьПользователя()
	УстановитьАктивностьПользователя(ТекущийПользователь);
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьАктивностьПользователя(ТекущийПользователь)
	
	УстановитьПривилегированныйРежим(Истина);
	
	НаборЗаписей = РегистрыСведений.АктивностьУчастниковОбщенияСУО.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Пользователь.Установить(ТекущийПользователь);
	
	НоваяЗапись = НаборЗаписей.Добавить();
	НоваяЗапись.Пользователь            = ТекущийПользователь;
	НоваяЗапись.ДатаПоследнейАктивности = ТекущаяДата();
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПериодОбновленияСообщений()
	
	ОтключитьОбработчикОжидания("Подключаемый_ЗагрузитьОбсуждение");
	
	Если ЧастотаОбновленияСообщений > 0 Тогда
		ПодключитьОбработчикОжидания("Подключаемый_ЗагрузитьОбсуждение", ЧастотаОбновленияСообщений);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьИлиИсключитьУчастникаОбсуждения(Тема, Участник, Действие)
	
	Если НЕ УправлениеДоступом.ЕстьРоль("УправлениеКоммуникациямиСУО") Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	НачатьТранзакцию();
	
	Если Действие = "Добавить" Тогда
		ИмяТЧДляДобавления = "ДополнительныеПолучатели";
		ИмяТЧДляИсключения = "ИсключенныеПолучатели";
		ИмяОперации = "добавить"
	Иначе
		ИмяТЧДляДобавления = "ИсключенныеПолучатели";
		ИмяТЧДляИсключения = "ДополнительныеПолучатели";
		ИмяОперации = "исключить"
	КонецЕсли;		
	
	// Добавляем участника
	
	Если Участник = Пользователи.ТекущийПользователь() Тогда
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Запрещено %1 себя'"), ИмяОперации);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ТемаОбъект = Тема.ПолучитьОбъект();
	
	Если ТемаОбъект.Автор = Участник Тогда
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Запрещено %1 автора темы'"), ИмяОперации);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Если ТемаОбъект.Контекст = Участник Тогда
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Вы не можете %1 адресата темы. Действие отменено'"), ИмяОперации);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Если ТемаОбъект[ИмяТЧДляДобавления].Найти(Участник, "Пользователь") = Неопределено Тогда
		
		НоваяСтрокаТЧ = ТемаОбъект[ИмяТЧДляДобавления].Добавить();
		НоваяСтрокаТЧ.Пользователь = Участник;
		НоваяСтрокаТЧ.ДатаДобавления = ТекущаяДата();
		НоваяСтрокаТЧ.Ответственный = Пользователи.ТекущийПользователь();
		
	КонецЕсли;
	
	СтрокаТЧДляУдаления = ТемаОбъект[ИмяТЧДляИсключения].Найти(Участник, "Пользователь");
	
	Если СтрокаТЧДляУдаления <> Неопределено Тогда
		ТемаОбъект[ИмяТЧДляИсключения].Удалить(СтрокаТЧДляУдаления);	
	КонецЕсли;
	
	ТемаОбъект.Записать();
	
	// Перепроводим сообщения

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СообщениеСУО.Ссылка
		|ИЗ
		|	Документ.СообщениеСУО КАК СообщениеСУО
		|ГДЕ
		|	СообщениеСУО.Проведен = ИСТИНА
		|	И СообщениеСУО.Тема = &Тема";

	Запрос.УстановитьПараметр("Тема", Тема);

	Результат = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	ОбщегоНазначенияСУ.ПерепровестиВыборкуДокументов(ВыборкаДетальныеЗаписи); 

	// Делаем проверки
	
	СписокУчастников = ПолучитьУчастниковОбсуждения(Тема);
	
	Если СписокУчастников.Количество() < 2 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Количество участников обсуждения должно быть не менее двух. Действие отменено'"));
		ОтменитьТранзакцию();
		Возврат;
	КонецЕсли;
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьУчастниковОбсуждения(Тема)
	
	ДанныеОТеме = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Тема, "Контекст, Кому, Автор, ДатаСоздания, ДополнительныеПолучатели, ИсключенныеПолучатели");

	МассивУчастников = Документы.СообщениеСУО.ПолучателиСообщения(ДанныеОТеме);
	
	СписокУчастников = Новый СписокЗначений;
	
	СписокУчастников.ЗагрузитьЗначения(МассивУчастников);	
	
	Возврат СписокУчастников; 
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Устанавливаем настройки по умолчанию
	
	ДанныеНастроек = ХранилищеСистемныхНастроек.Загрузить(ЭтотОбъект.ИмяФормы+"/ТекущиеДанные");
	
	Если ДанныеНастроек = Неопределено Тогда
		
		ЧастотаПроверкиСтатусаУчастников = 30;
		ЧастотаОбновленияСпискаТем       = 60;
		ЧастотаОбновленияСообщений       = 120;
		
		НовыеСообщениеРазмещатьВверху    = Ложь;
		ДеревоСообщений                  = Истина;
		
	КонецЕсли;
	
	// Устанавливаем переменные
	
	ТекущийПользователь = Пользователи.ТекущийПользователь();
	
	Если ЗначениеЗаполнено(Параметры.Контекст) Тогда
		
		Заголовок = Заголовок + НСтр("ru = ' (установлен дополнительный отбор)'");
		
		Если ЗначениеЗаполнено(Параметры.ДополнительныйКонтекст) Тогда
			
			ГруппаОтбора = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(Темы.Отбор.Элементы, "Контексты", ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли);
			
			ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаОтбора, "Контекст", ВидСравненияКомпоновкиДанных.Равно, Параметры.Контекст, "Контекст", Истина);
			ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаОтбора, "Контекст", ВидСравненияКомпоновкиДанных.Равно, Параметры.ДополнительныйКонтекст, "ДополнительныйКонтекст", Истина);
			
		Иначе
			
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Темы.Отбор, "Контекст", Параметры.Контекст);
		
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.Рассылка) Тогда
		
		Заголовок = Заголовок + НСтр("ru = ' (установлен отбор тем рассылки)'");
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Темы.Отбор, "Рассылка", Параметры.Рассылка);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.Тема) Тогда
		
		ДанныеТемы         = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Параметры.Тема, "Наименование, Кому, Контекст, Закрыта");
		Заголовок          = ДанныеТемы.Наименование;
		ЭтоФорум           = Параметры.ЭтоФорум;
		ТекущийКонтекст    = ДанныеТемы.Контекст;
		ТекущийАдресат     = ДанныеТемы.Кому;
		ТекущаяТема        = Параметры.Тема;
		ТекущаяТемаЗакрыта = ДанныеТемы.Закрыта;
		
	КонецЕсли;
		
	// Управляем видимостью элементов
		
	Темы.Параметры.УстановитьЗначениеПараметра("Пользователь", ТекущийПользователь);
	Участники.Параметры.УстановитьЗначениеПараметра("ТекущийПользователь", ТекущийПользователь);
	Участники.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДата());
	
	УстановитьАктивностьПользователя(ТекущийПользователь);
	
	Элементы.Участники.Видимость       = Ложь;
	Элементы.ГруппаНастройки.Видимость = Ложь;
	Элементы.КомандаИнформация.Пометка = Истина;
	
	Элементы.ГруппаКомандыУправленияУчастниками.Видимость = УправлениеДоступом.ЕстьРоль("УправлениеКоммуникациямиСУО");
	
	Если ЗначениеЗаполнено(Параметры.Тема) Тогда
		
		ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиФормы.Нет;	
		
		Элементы.ГруппаТемы.Видимость = Ложь;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.Тема) Тогда

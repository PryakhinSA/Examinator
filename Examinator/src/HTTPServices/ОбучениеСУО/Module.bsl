				ДанныеФайлаТом = Выборка.Том;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ДанныеФайлаПутьКФайлу) Тогда 			
				ПолныйПуть = РаботаСФайламиСлужебный.ПолныйПутьТома(ДанныеФайлаТом) + ДанныеФайлаПутьКФайлу; 
				ДвоичныеДанные = Новый ДвоичныеДанные(ПолныйПуть);
			КонецЕсли;
				
		Иначе
			
			ДвоичныеДанные = РаботаСФайлами.ХранилищеФайлаИзИнформационнойБазы(ДанныеФайла.ТекущаяВерсия).Получить();
					
		КонецЕсли;		
		
	Иначе
		
		ВладелецФайла = Неопределено;
		
		Если ТипВладельца = "userActivity" Тогда
			ВладелецФайла = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));

		|	ИмпортированныеЭлементыПакетаSCORM.ИмяЭлемента = &ИмяЭлементаЭР";
	
	Запрос.УстановитьПараметр("ИмяЭлементаЭР", "organization");
	
	ТаблицаЭР = Запрос.Выполнить().Выгрузить(); // Идентификаторы пакетов электронных ресурсов
		

#Если Сервер ИЛИ ТолстыйКлиентОбычноеПриложение ИЛИ ВнешнееСоединение Тогда
	
Функция ТипОбъектаСУЗ() Экспорт
	
	Возврат Перечисления.ТипыОбъектовСУЗ.knowledgeBase;
	
КонецФункции

Функция ПолучитьXMLПредставление(Ссылка, ПараметрыСсылки, КонтекстВыполнения) Экспорт
	
	СводЗнанийXDTOТип  = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/KnowledgeBase", "СводЗнаний");
	СводЗнанийXDTO     = ФабрикаXDTO.Создать(СводЗнанийXDTOТип);
	
    СводЗнанийXDTO.id  = Ссылка.УникальныйИдентификатор();
	
	ИмяОбъектаСУЗ         = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ТипОбъектаСУЗ());
	СводЗнанийXDTO.object = ИмяОбъектаСУЗ;
    СводЗнанийXDTO.Наименование = Ссылка.Наименование;
	
	// ПоследняяВерсия = ПолучитьПоследнююВерсиюОбъектаСУЗ(ЭтотОбъект);
	
	// СводЗнанийXDTO.Версия   = Строка(ПоследняяВерсия.Версия);
	// СводЗнанийXDTO.Редакция = Строка(Редакция);
	СводЗнанийXDTO.Версия   = Ссылка.Версия;
	СводЗнанийXDTO.Редакция = Ссылка.Редакция;
	
	СводЗнанийXDTO.ЭтоБазоваяКонфигурация = ОбщегоНазначенияСУ.ЭтоБазоваяВерсияКонфигурации();
	
	ОбъектСУЗXDTOТип  = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/KnowledgeSources", "ОбъектСУЗ");
	
	Если ЗначениеЗаполнено(Ссылка.Карта) Тогда
		
		КартаXDTO = ФабрикаXDTO.Создать(ОбъектСУЗXDTOТип);
		КартаXDTO.object = "map";
		КартаXDTO.id = Ссылка.Карта.УникальныйИдентификатор();;
		
		СводЗнанийXDTO.Карта = КартаXDTO;
			
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ссылка.СтартоваяСтраница) Тогда
		
		Если ТипЗнч(Ссылка.СтартоваяСтраница) = Тип("СправочникСсылка.КартыСУЗ") Тогда
			
			ПараметрыСсылки.Вставить("idTargetMap", Строка(Ссылка.УникальныйИдентификатор()));
			ПараметрыСсылки.Вставить("targetMap", "KnowledgeBase");
			ПараметрыСсылки.Вставить("view", "children");
			
		КонецЕсли;
		
		
		СтруктураДанныхСтраницы = ОбъектыСУЗ.ПолучитьПредставление(Ссылка.СтартоваяСтраница, ПараметрыСсылки, КонтекстВыполнения);
		
		СтартоваяСтраницаXDTO = ФабрикаXDTO.Создать(ОбъектСУЗXDTOТип);
		СтартоваяСтраницаXDTO.Представление = СтруктураДанныхСтраницы.Представление;
		СтартоваяСтраницаXDTO.Скрипт = СтруктураДанныхСтраницы.Скрипт;
		
		СводЗнанийXDTO.СтартоваяСтраница = СтартоваяСтраницаXDTO;
	
	КонецЕсли;
	
	ШаблонОбъекта = ОбъектыСУЗ.ПолучитьСсылкуНаXSLШаблонОбъекта(Ссылка);
	ОбъектыСУЗ.ДобавитьШаблонВСписокОбъекта(ШаблонОбъекта, КонтекстВыполнения.СписокШаблонов);
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();
	ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, СводЗнанийXDTO);
	XMLДанные = ЗаписьXML.Закрыть();
	
	ОбъектыСУЗ.ДобавитьСсылкиОбъектаВМассив(Ссылка, КонтекстВыполнения);
	
	Возврат XMLДанные;
	
КонецФункции

// Функция служит для определения идентификатора свода знаний,
// который используется для формирования каталога хранения ресурсов свода знаний.
//
// Параметры:
//  ЭлементСодержания - ссылка на элемент справочника СводыЗнанийСУЗ или СодержаниеСУЗ.
//
// Возвращаемое значение:
//  Строка.
//
Функция ИдентификаторКаталога(ЭлементСодержания) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ЭлементСодержания) Тогда
		
		Возврат "common";
		
	Иначе
		
		Если ТипЗнч(ЭлементСодержания) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда
			СводЗнаний = ЭлементСодержания;
		Иначе
			СводЗнаний = ЭлементСодержания.Владелец;
		КонецЕсли;
		
		ДанныеСводаЗнаний = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СводЗнаний, "Идентификатор, ПоказыватьПоследнююВерсию");
		
		Если НЕ ДанныеСводаЗнаний.ПоказыватьПоследнююВерсию Тогда
			Возврат "common";	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеСводаЗнаний.Идентификатор) Тогда
			
			Возврат СокрЛП(ДанныеСводаЗнаний.Идентификатор);
			
		Иначе
			
			Возврат Строка(СводЗнаний.УникальныйИдентификатор());
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции

// Функция служит для определения поставщика свода знаний,
// в контексте которого воспроизводится объект.
//
// Параметры:
//  ЭлементСодержания - ссылка на элемент справочника СводыЗнанийСУЗ или СодержаниеСУЗ.
//
// Возвращаемое значение:
//  Ссылка на элемент справочника ПоставщикиСУЗ
//
Функция Поставщик(ЭлементСодержания) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ЭлементСодержания) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТипЗнч(ЭлементСодержания) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда
		СводЗнаний = ЭлементСодержания;
	Иначе
		СводЗнаний = ЭлементСодержания.Владелец;
	КонецЕсли;
	
	Если НЕ СводЗнаний.ПоказыватьПоследнююВерсию Тогда
		Возврат Неопределено;
	Иначе
		Возврат СводЗнаний.ПредпочитатьПоставщика;
	КонецЕсли;
	
КонецФункции

// Возвращает группу нужного типа, в которую будут помещаться элементы электронного ресурса.
//
Функция ГруппаДляХраненияПодчиненныхЭлементов(Знач ЭлектронныйРесурс, Знач ТипПодчиненногоЭлемента) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ЭлектронныйРесурс)
		ИЛИ НЕ ЗначениеЗаполнено(ТипПодчиненногоЭлемента) Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	ГруппаПодчиненныхЭлементов = РегистрыСведений.ГруппыОбъектовСУЗ.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйРесурс, ТипПодчиненногоЭлемента);
	
	Если ГруппаПодчиненныхЭлементов = Неопределено Тогда
		
		ИмяСправочника = Метаданные.НайтиПоТипу(ТипПодчиненногоЭлемента).Имя;
		
		НоваяГруппаОбъект =  Справочники[ИмяСправочника].СоздатьГруппу();
		НоваяГруппаОбъект.Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлектронныйРесурс, "Наименование");
		
		РазработкаСУЗ.УстановитьПредпочитаемогоПоставщика(НоваяГруппаОбъект);

		НоваяГруппаОбъект.Записать();
		
		ГруппаПодчиненныхЭлементов = НоваяГруппаОбъект.Ссылка;
		
		РегистрыСведений.ГруппыОбъектовСУЗ.СохранитьГруппуДляХраненияПодчиненныхЭлементов(ЭлектронныйРесурс, ГруппаПодчиненныхЭлементов);
		
	КонецЕсли;
	
	Возврат ГруппаПодчиненныхЭлементов;
	
КонецФункции

// Возвращает элемент справочника "ПодборкиСУЗ",
// который прикреплен к электронному ресурсу, как единственный тест.
//
Функция Тест(ЭлектронныйРесурс) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
		Возврат Неопределено;	
	КонецЕсли;
	
	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлектронныйРесурс, "Тип") <> Перечисления.ТипыЭлектронныхРесурсовСУЗ.Тест Тогда
		Возврат Неопределено;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СодержаниеСУЗ.СсылкаНаЭлемент
		|ИЗ
		|	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
		|ГДЕ
		|	СодержаниеСУЗ.Владелец = &ЭлектронныйРесурс
		|	И СодержаниеСУЗ.ЭтоГруппа = ЛОЖЬ
		|	И СодержаниеСУЗ.ПометкаУдаления = ЛОЖЬ
		|	И ТИПЗНАЧЕНИЯ(СодержаниеСУЗ.СсылкаНаЭлемент) = ТИП(Справочник.ПодборкиСУЗ)";

	Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);

	Результат = Запрос.Выполнить();

	Если НЕ Результат.Пустой() Тогда
		
		ВыборкаДетальныеЗаписи = Результат.Выбрать();

		Если ВыборкаДетальныеЗаписи.Количество() = 1 Тогда
			
			ВыборкаДетальныеЗаписи.Следующий();
			
			Возврат ВыборкаДетальныеЗаписи.СсылкаНаЭлемент;
			
		КонецЕсли;

	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Добавляет элемент в содержание электронного ресурса
//
Функция ДобавитьЭлементСодержания(ЭлектронныйРесурс, СсылкаНаЭлемент, Группа, ЭтоГруппа = Ложь, Наименование = Неопределено) Экспорт
	
	Если ЭтоГруппа Тогда
		ЭлементСодержанияОбъект = Справочники.СодержаниеСУЗ.СоздатьГруппу();
	Иначе
		ЭлементСодержанияОбъект = Справочники.СодержаниеСУЗ.СоздатьЭлемент();
    КонецЕсли;
	
	Если Наименование = Неопределено И ЗначениеЗаполнено(СсылкаНаЭлемент) Тогда
		
		ЭлементСодержанияОбъект.Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаЭлемент, "Наименование");
		
	Иначе
		
		ЭлементСодержанияОбъект.Наименование = Наименование;
		
		Если НЕ ЭтоГруппа Тогда
			ЭлементСодержанияОбъект.РазрешитьРедактироватьНаименование = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	ЭлементСодержанияОбъект.Владелец        = ЭлектронныйРесурс;
	
	Если ЗначениеЗаполнено(СсылкаНаЭлемент)
		И НЕ ЭтоГруппа Тогда
		
		ЭлементСодержанияОбъект.СсылкаНаЭлемент = СсылкаНаЭлемент;
		
	КонецЕсли;

	ЭлементСодержанияОбъект.Родитель        = Группа;
	
	РазработкаСУЗ.УстановитьПредпочитаемогоПоставщика(ЭлементСодержанияОбъект);
	
	
	ЭлементСодержанияОбъект.ДополнительныеСвойства.Вставить("ПроверитьНаДубликат", Истина);
	ЭлементСодержанияОбъект.Записать();
	
	Возврат ЭлементСодержанияОбъект.Ссылка;
	
КонецФункции

// Возвращает элемент содержания электронного ресурса,
// если он единственный. Иначе возвращает Неопределено.
//
Функция ЕдинственныйЭлементСодержания(ЭлектронныйРесурс) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СодержаниеСУЗ.Ссылка
		|ИЗ
		|	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
		|ГДЕ
		|	СодержаниеСУЗ.ЭтоГруппа = ЛОЖЬ
		|	И СодержаниеСУЗ.ПометкаУдаления = ЛОЖЬ
		|	И СодержаниеСУЗ.Владелец = &ЭлектронныйРесурс";

	Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);

	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		
		Возврат Неопределено;
		
	Иначе
		
		ВыборкаДетальныеЗаписи = Результат.Выбрать();

		Если ВыборкаДетальныеЗаписи.Количество() = 1 Тогда
			
			ВыборкаДетальныеЗаписи.Следующий();
			
			Возврат ВыборкаДетальныеЗаписи.Ссылка;
			
		Иначе
			
			Возврат Неопределено;
			
		КонецЕсли;
			
	КонецЕсли;
	
КонецФункции

// Возвращает ресурс из списка СкрытыеРесурсы, форма которого следует открывать для реадактирования.
//
// Примечание: получение ресурсов необходимо, так как в скрытых ресурсах могут хранится
// ссылки на общие объекты, например, подборки, которые содержат по одному элементу
// или вообще только скрытые ресурсы. Поэтому редактирование самих ресурсов неудобно -
// следует заглянуть внутрь его и открывать конечный ресурс пользователю.
// Такая ситуация связана с тем, что загрузка файлов через форму "ФормаИмпортаФайлов"
// выполняется единообразно, как для обычных, так и для скрытых, из-за этого
// скрытый ресурс может оказаться обернутым в несколько объектов.
//
Функция СкрытыйРесурсДляРедактирования(Ресурс) Экспорт
	
	Если ТипЗнч(Ресурс) = Тип("СправочникСсылка.РесурсыСУЗ") Тогда
		
		ЕдинственныйЭлемент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ресурс, "ЕдинственныйФайл");
		
		Если ЗначениеЗаполнено(ЕдинственныйЭлемент) Тогда
			Возврат СкрытыйРесурсДляРедактирования(ЕдинственныйЭлемент); // Рекурсия
		Иначе
			Возврат Ресурс;
		КонецЕсли;		
		
	ИначеЕсли ТипЗнч(Ресурс) = Тип("СправочникСсылка.ПодборкиСУЗ") Тогда
		
		ЕдинственныйЭлемент = Справочники.ПодборкиСУЗ.ЕдинственныйЭлементПодборки(Ресурс, Истина);
		
		Если ЗначениеЗаполнено(ЕдинственныйЭлемент) Тогда
			Возврат СкрытыйРесурсДляРедактирования(ЕдинственныйЭлемент);  // Рекурсия
		Иначе
			Возврат Ресурс;
		КонецЕсли;
		
	Иначе		
		
		Возврат Ресурс;
		
	КонецЕсли;	
	
КонецФункции

Функция ТипСкрытогоРесурсаДляРедактирования(РесурсДляРедактирования) Экспорт
	
	Если ТипЗнч(РесурсДляРедактирования) = Тип("СправочникСсылка.ФайлыСУЗ") Тогда
		
		ТипФайла = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РесурсДляРедактирования, "ТипФайла");
		
		Если ТипФайла = Перечисления.ТипыФайловСУЗ.Default Тогда
			Возврат НСТр("ru = 'Файл'");
		Иначе
			Возврат Строка(ТипФайла);
		КонецЕсли;		
		
	ИначеЕсли ТипЗнч(РесурсДляРедактирования) = Тип("СправочникСсылка.ПодборкиСУЗ") Тогда
		
		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РесурсДляРедактирования, "ЭтоТест") Тогда
			Возврат НСтр("ru = 'Тест'");
		Иначе
			Возврат НСтр("ru = 'Теория'");
		КонецЕсли;			
		
	Иначе
		
		Возврат Строка(ТипЗнч(РесурсДляРедактирования));
		
	КонецЕсли;
	
	
КонецФункции

Функция СкрытыйРесурсДляПросмотра(Ресурс) Экспорт
	
	Если ТипЗнч(Ресурс) = Тип("СправочникСсылка.ПодборкиСУЗ") Тогда
		
		// Примечание: это работает, пока в скрытые ресурсы нельзя добавлять
		// теорию вручную, а только через форму загрузки файлов. Так как
		// если добавлять теорию с одним элементом, то она может иметь свои настройки,
		// который будет ожидать увидеть пользователь.		
		
		ЕдинственныйЭлемент = Справочники.ПодборкиСУЗ.ЕдинственныйЭлементПодборки(Ресурс, Истина);
		
		Если ЗначениеЗаполнено(ЕдинственныйЭлемент) Тогда
			Возврат СкрытыйРесурсДляПросмотра(ЕдинственныйЭлемент);  // Рекурсия
		Иначе
			Возврат Ресурс;
		КонецЕсли;		
		
	Иначе
		
		Возврат Ресурс;
		
	КонецЕсли;
	
КонецФункции

Функция ВыставляетсяОценка(Знач ЭлектронныйРесурс) Экспорт
	
	МассивЭлектронныхРесурсов = Новый Массив;
	МассивЭлектронныхРесурсов.Добавить(ЭлектронныйРесурс);
	
	ТаблицаЭлектронныхРесурсов = ТаблицаВыставляетсяОценка(МассивЭлектронныхРесурсов);
	
	Возврат ТаблицаЭлектронныхРесурсов[0].ВыставляетсяОценка;
	
КонецФункции

Функция ТаблицаВыставляетсяОценка(МассивЭлектронныхРесурсов) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА СодержаниеСУЗ.СсылкаНаЭлемент ССЫЛКА Справочник.ПодборкиСУЗ
		|			ТОГДА ВЫРАЗИТЬ(СодержаниеСУЗ.СсылкаНаЭлемент КАК Справочник.ПодборкиСУЗ).НазначениеТестирования
		|	КОНЕЦ КАК НазначениеТестирования,
		|	ВЫБОР
		|		КОГДА СодержаниеСУЗ.СсылкаНаЭлемент ССЫЛКА Справочник.ПодборкиСУЗ
		|			ТОГДА ВЫРАЗИТЬ(СодержаниеСУЗ.СсылкаНаЭлемент КАК Справочник.ПодборкиСУЗ).ЭтоТест
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЭтоТест,
		|	ВЫБОР
		|		КОГДА СодержаниеСУЗ.СсылкаНаЭлемент ССЫЛКА Справочник.РесурсыСУЗ
		|			ТОГДА ВЫРАЗИТЬ(СодержаниеСУЗ.СсылкаНаЭлемент КАК Справочник.РесурсыСУЗ).SCO
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЭтоSCO,
		|	СодержаниеСУЗ.Владелец КАК ЭлектронныйРесурс,
		|	СодержаниеСУЗ.Ссылка КАК ЭлементСодержания
		|ПОМЕСТИТЬ ВыборкаЭлементовСодержания
		|ИЗ
		|	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
		|ГДЕ
		|	СодержаниеСУЗ.ЭтоГруппа = ЛОЖЬ
		|	И СодержаниеСУЗ.ПометкаУдаления = ЛОЖЬ
		|	И СодержаниеСУЗ.Владелец В(&МассивЭлектронныхРесурсов)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВыборкаЭлементовСодержания.ЭлектронныйРесурс КАК ЭлектронныйРесурс,
		|   ИСТИНА КАК ВыставляетсяОценка
		|ИЗ
		|	ВыборкаЭлементовСодержания КАК ВыборкаЭлементовСодержания
		|ГДЕ
		|	((ВыборкаЭлементовСодержания.ЭтоТест = ИСТИНА
		|				И ВыборкаЭлементовСодержания.НазначениеТестирования = &НазначениеТестированияАттестация)
		|			ИЛИ ВыборкаЭлементовСодержания.ЭтоSCO = ИСТИНА)";

	Запрос.УстановитьПараметр("МассивЭлектронныхРесурсов", МассивЭлектронныхРесурсов);
	Запрос.УстановитьПараметр("НазначениеТестированияАттестация", Перечисления.НазначенияТестированийСУЗ.Аттестация);
	
	Результат = Запрос.Выполнить();
	
	ТаблицаЭлектронныхРесурсов = Результат.Выгрузить();
	
	Для каждого ЭлектронныйРесурс Из МассивЭлектронныхРесурсов Цикл
	
		Если ТаблицаЭлектронныхРесурсов.Найти(ЭлектронныйРесурс, "ЭлектронныйРесурс") = Неопределено Тогда
			НоваяСтрока = ТаблицаЭлектронныхРесурсов.Добавить();
			НоваяСтрока.ЭлектронныйРесурс = ЭлектронныйРесурс;
			НоваяСтрока.ВыставляетсяОценка = Ложь;
		КонецЕсли;
	
	КонецЦикла;
	
	Возврат ТаблицаЭлектронныхРесурсов;
	
КонецФункции

//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//

// ВЕБ-КАБИНЕТ

Функция ТаблицаЭлектронныхРесурсовДляДанныхВебКабинета() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СводыЗнанийСУЗ.Ссылка,
		|	СводыЗнанийСУЗ.Родитель,
		|	СводыЗнанийСУЗ.ЭтоГруппа КАК ЭтоГруппа,
		|	СводыЗнанийСУЗ.Наименование КАК Наименование,
		|	СводыЗнанийСУЗ.ДатаИзменения,
		|	СводыЗнанийСУЗ.Тип
		|ИЗ
		|	Справочник.СводыЗнанийСУЗ КАК СводыЗнанийСУЗ
		|ГДЕ
		|	СводыЗнанийСУЗ.ПометкаУдаления = ЛОЖЬ
		|	И СводыЗнанийСУЗ.Предопределенный = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	СводыЗнанийСУЗ.ЭтоГруппа УБЫВ,
		|	СводыЗнанийСУЗ.Наименование";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

// Обновляет данные веб-кабинета пользователя, которые не обновляются "пообъектно"
//
Процедура ОбновитьДанныеВебКабинета(Пользователь, ТаблицаЭлектронныхРесурсов = Неопределено) Экспорт

	УстановитьПривилегированныйРежим(Истина);		
	
	// Удаляем старые данные
	
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(
		ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Пользователь, "ИдентификаторПользователяИБ")
	);
	
	Если ПравоДоступа("Просмотр", Метаданные.Справочники.СводыЗнанийСУЗ, ПользовательИБ) Тогда
		
		// Получаем данные
		//
		
		Если ТаблицаЭлектронныхРесурсов = Неопределено Тогда
			ТаблицаЭР = ТаблицаЭлектронныхРесурсовДляДанныхВебКабинета();
		Иначе
			ТаблицаЭР = ТаблицаЭлектронныхРесурсов.Скопировать();
		КонецЕсли;
		
		Если ОбъектыСУЗПовтИсп.ИспользуютсяОграниченияНаДоступКЭлектроннымКурсам() Тогда
		
			// Удаляем недоступные электронные ресурсы
				
			Сч = ТаблицаЭР.Количество();

			Пока Сч > 0 Цикл			
				
				ТекСтрока = ТаблицаЭР[Сч - 1];

				Если НЕ УправлениеДоступом.ЕстьРоль("ЭлектронныеРесурсыПросмотрКаталогаСУО", ТекСтрока.Ссылка, Пользователь) Тогда //--# КК: ЗАМЕНИТЬ РОЛЬ НА "УченикКК"
					ТаблицаЭР.Удалить(Сч - 1);		
				КонецЕсли;
				
				Сч = Сч - 1;
				
			КонецЦикла;
			
		КонецЕсли;		
		
		// Записываем данные
		//
		
		РегистрыСведений.ДанныеВебКабинетаСУЗ_ПН.ДобавитьДанные(
			Пользователь,
			Перечисления.ТипыДанныхВебКабинетаСУЗ.КаталогЭлектронныхРесурсов,
			Пользователь,
			ОбщегоНазначенияСУ.ДанныеВJSON(ТаблицаЭР),
			Перечисления.ФорматыВебДанныхСУ.json);	
			
		// Записываем зависимости	
		//
		
		МассивЭлектронныхРесурсов = ТаблицаЭР.ВыгрузитьКолонку("Ссылка");	
		
		РегистрыСведений.ЗависимостиДанныхВебКабинетаСУ.ДобавитьДанные(Пользователь, "Справочник.СводыЗнанийСУЗ", МассивЭлектронныхРесурсов);	
		
	Иначе
		
		РегистрыСведений.ЗависимостиДанныхВебКабинетаСУ.УдалитьДанные(Пользователь, "Справочник.СводыЗнанийСУЗ");
		РегистрыСведений.ДанныеВебКабинетаСУЗ_ПН.УдалитьДанные(Пользователь, Перечисления.ТипыДанныхВебКабинетаСУЗ.КаталогЭлектронныхРесурсов, Пользователь);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьДанныеВебКабинетаДляВсехПользователей(ТаблицаЭлектронныхРесурсов = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если НЕ ВебКабинетСУ.Используется() Тогда
		Возврат;
	КонецЕсли;	
	
	Если ТаблицаЭлектронныхРесурсов = Неопределено Тогда
		ТаблицаЭлектронныхРесурсов = Справочники.СводыЗнанийСУЗ.ТаблицаЭлектронныхРесурсовДляДанныхВебКабинета();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПользователиВебКабинетаСУ.Пользователь,
		|	ПользователиВебКабинетаСУ.Пользователь.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ
		|ИЗ
		|	РегистрСведений.ПользователиВебКабинетаСУ КАК ПользователиВебКабинетаСУ";
			
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	МассивПользователей = Новый Массив;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(
			ВыборкаДетальныеЗаписи.ИдентификаторПользователяИБ
		);
		
		Если НЕ ПравоДоступа("Просмотр", Метаданные.Справочники.СводыЗнанийСУЗ, ПользовательИБ) Тогда
			Продолжить; // Нельзя смотреть каталог, поэтому данные не нужны
		КонецЕсли;
		
		МассивПользователей.Добавить(ВыборкаДетальныеЗаписи.Пользователь);
		
	КонецЦикла;		
	
	ПараметрыФЗ = Новый Массив;
	ПараметрыФЗ.Добавить(МассивПользователей);
	ПараметрыФЗ.Добавить(ТаблицаЭлектронныхРесурсов);
	
	ВебКабинетСУ.ДобавитьЗаданиеНаОбновлениеДанных(ОбщегоНазначения.ИмяТаблицыПоСсылке(Справочники.СводыЗнанийСУЗ.ПустаяСсылка()), "ВебКабинетСУ.ОбновитьДанныеОбъекта", ПараметрыФЗ, "СводыЗнанийСУЗ.ОбновитьДанныеВебКабинетаДляВсехПользователей");
	
КонецПроцедуры


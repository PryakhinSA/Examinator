	КонецЕсли;

	// Получаем данные
	//	
	
	Попытка
		ИдентификаторПроведенияОбучения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ПроведениеОбучения"));
	Исключение

Функция ПоляРегистрацииПоУмолчанию(Знач ЯзыкВебКабинета) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ЯзыкВебКабинета)
		ИЛИ ЯзыкВебКабинета = Перечисления.ЯзыкиВебКабинетаСУ.Авто Тогда
		
		ЯзыкВебКабинета = Перечисления.ЯзыкиВебКабинетаСУ.ruRU;
		
	КонецЕсли;
	
	ПоляРегистрации = Новый ТаблицаЗначений;
	
	РеквизитыПолей = Метаданные.Справочники.ПубликацииВебКабинетаСУ.ТабличныеЧасти.ПоляРегистрации.Реквизиты;
	
	Для каждого РеквизитТЧ Из РеквизитыПолей Цикл	
		ПоляРегистрации.Колонки.Добавить(РеквизитТЧ.Имя, РеквизитТЧ.Тип, РеквизитТЧ.Синоним);	
	КонецЦикла;
	
	НовыйРаздел = ПоляРегистрации.Добавить();
	НовыйРаздел.Имя = Перечисления.ВидыПолейРегистрацииВебКабинетаСУО.LastName; 
	НовыйРаздел.Наименование = НаименованиеРазделаРегистрации("Last Name", ЯзыкВебКабинета);
	НовыйРаздел.Обязательное = Истина;
	НовыйРаздел.ТипПоля = Перечисления.ТипыПолейРегистрацииВебКабинетаСУО.ПолеВвода;
	
	НовыйРаздел = ПоляРегистрации.Добавить();
	НовыйРаздел.Имя = Перечисления.ВидыПолейРегистрацииВебКабинетаСУО.FirstName; 
	НовыйРаздел.Наименование = НаименованиеРазделаРегистрации("First Name", ЯзыкВебКабинета);
	НовыйРаздел.Обязательное = Истина;	
	НовыйРаздел.ТипПоля = Перечисления.ТипыПолейРегистрацииВебКабинетаСУО.ПолеВвода;
	
	НовыйРаздел = ПоляРегистрации.Добавить();
	НовыйРаздел.Имя = Перечисления.ВидыПолейРегистрацииВебКабинетаСУО.Patronymic; 
	НовыйРаздел.Наименование = НаименованиеРазделаРегистрации("Patronymic", ЯзыкВебКабинета);
	НовыйРаздел.ТипПоля = Перечисления.ТипыПолейРегистрацииВебКабинетаСУО.ПолеВвода;
	
	НовыйРаздел = ПоляРегистрации.Добавить();
	НовыйРаздел.Имя = "Email"; 
	НовыйРаздел.Наименование = НаименованиеРазделаРегистрации("Email", ЯзыкВебКабинета);
	НовыйРаздел.КонтактнаяИнформация = Справочники.ВидыКонтактнойИнформации.EmailПользователя;
	НовыйРаздел.Обязательное = Истина;
	НовыйРаздел.ТипПоля = Перечисления.ТипыПолейРегистрацииВебКабинетаСУО.ЭлектроннаяПочта;
	НовыйРаздел.ИспользоватьКакЛогин = Истина;
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьСлушателейСУО") Тогда
		
		НовыйРаздел = ПоляРегистрации.Добавить();
		НовыйРаздел.Имя = "MobilePhone"; 
		НовыйРаздел.Наименование = НаименованиеРазделаРегистрации("Mobile phone", ЯзыкВебКабинета);
		НовыйРаздел.КонтактнаяИнформация = Справочники.ВидыКонтактнойИнформации.ТелефонПользователя;
		НовыйРаздел.Обязательное = Истина;
		НовыйРаздел.ТипПоля = Перечисления.ТипыПолейРегистрацииВебКабинетаСУО.ПолеВвода;
		
		ОбязательныеРеквизитыУЦ = УправлениеОбучениемСУО.ОбязательныеРеквизитыСлушателяУЦ();
		
		Для каждого СтрокаТОР Из ОбязательныеРеквизитыУЦ Цикл
		
			Если НЕ СтрокаТОР.Существует Тогда
				Продолжить;
			КонецЕсли;
			
			НовыйРаздел = ПоляРегистрации.Добавить();
			НовыйРаздел.Имя = СтрокаТОР.ИмяПоляФормы; 
			НовыйРаздел.Наименование = НаименованиеРазделаРегистрации(СтрокаТОР.НаименованиеАнгл, ЯзыкВебКабинета);
			НовыйРаздел.Реквизит = СтрокаТОР.Ссылка;
			НовыйРаздел.Обязательное = Истина;
			НовыйРаздел.ТипПоля = Перечисления.ТипыПолейРегистрацииВебКабинетаСУО.ПолеВвода;
			
		КонецЦикла;

		
	КонецЕсли;
	
	//----------------------------------//
	
	НовыйРаздел = ПоляРегистрации.Добавить();
	НовыйРаздел.Имя = Перечисления.ВидыПолейРегистрацииВебКабинетаСУО.Password; 
	НовыйРаздел.Наименование = НаименованиеРазделаРегистрации("Password", ЯзыкВебКабинета);
	НовыйРаздел.ДобавлятьПолеПодтверждения = Истина;
	НовыйРаздел.Обязательное = Истина;
	НовыйРаздел.ТипПоля = Перечисления.ТипыПолейРегистрацииВебКабинетаСУО.Пароль;
	НовыйРаздел.НаименованиеПодтверждения = НаименованиеРазделаРегистрации("Confirm Password", ЯзыкВебКабинета);
			
	Возврат ПоляРегистрации;
	
КонецФункции

Процедура ЗаполнитьПоляРегистрацииПоУмолчанию(Объект) Экспорт
	
	ТаблицаПолей = ПоляРегистрацииПоУмолчанию(Объект.Язык);
	
	Объект.ПоляРегистрации.Загрузить(ТаблицаПолей);	
	
КонецПроцедуры

Функция ИмяРаздела(ИмяАнгл, ЯзыкКабинета)
	
	Если ЯзыкКабинета = Перечисления.ЯзыкиВебКабинетаСУ.enEN Тогда
		Возврат ИмяАнгл;
	Иначе
		Возврат ВебКабинетСУ.Перевод(ИмяАнгл, "РазделыВебКабинета", "EN", Перечисления.ЯзыкиВебКабинетаСУ.ПростойКодИзСоставного(ЯзыкКабинета));
	КонецЕсли;		
	
КонецФункции		

Функция НаименованиеРазделаРегистрации(НаименованиеАнгл, ЯзыкКабинета)
	
	Если ЯзыкКабинета = Перечисления.ЯзыкиВебКабинетаСУ.enEN Тогда
		Возврат НаименованиеАнгл;
	Иначе
		Возврат ВебКабинетСУ.Перевод(НаименованиеАнгл, "ПоляРегистрацииВебКабинета", "EN", Перечисления.ЯзыкиВебКабинетаСУ.ПростойКодИзСоставного(ЯзыкКабинета));
	КонецЕсли;		
	
КонецФункции


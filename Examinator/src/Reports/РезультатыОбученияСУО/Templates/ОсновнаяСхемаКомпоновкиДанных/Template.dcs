		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СотрудникиСУОСрезПоследних.Пользователь,
	СотрудникиСУОСрезПоследних.Организация,

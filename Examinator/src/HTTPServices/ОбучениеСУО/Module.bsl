Функция ВерсияANY(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);	
	НастройкиAPI = Новый Структура("Версия, База", ВебКабинетСУ.ВерсияAPI(), СтандартныеПодсистемыСервер.ИдентификаторИнформационнойБазы());	
	Возврат ОтветКлиентуJSON(,НастройкиAPI);

КонецФункции

// Обучение

Функция ПолучитьАктивностиУчастникаОбученияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Обучение");
	ПраваДляПроверки.Добавить("Преподавание");
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	Права = ДанныеСессии.Права.Получить();
	
	// Получаем данные запроса
	//	
	
	ТипОбучения   = Запрос.ПараметрыURL.Получить("ТипОбучения");
	ОтборДанных   = Запрос.ПараметрыURL.Получить("Отбор");
	ДатаНачала    = Запрос.ПараметрыURL.Получить("ДатаНачала");
	ДатаОкончания = Запрос.ПараметрыURL.Получить("ДатаОкончания");
	
	Попытка
		ДатаНачала = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(Число(ДатаНачала));
		ДатаОкончания = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(Число(ДатаОкончания));
	Исключение
		ДатаНачала = Дата("00010101");
		ДатаОкончания = Дата("00010101");
	КонецПопытки;	
	
	// Ждем окончания заданий
	
	ОжидатьЗавершенияЗаданияОбновленияЭлектронногоРесурса(ДанныеСессии, НСтр("ru = 'Список обучений'"));		
	
	// Делаем запрос к базе данных
	//
	
	ЗапросДанных = Новый Запрос;
	
	КоличествоСекцийЗапроса = 0;
	
	Если ОтборДанных = "All" Тогда
		
		Если ТипОбучения = "all" ИЛИ ТипОбучения = "periodic" Тогда
			
			ЗапросДанных.Текст = ЗапросДанных.Текст + 
				"ВЫБРАТЬ
				|	ДанныеВебКабинетаСУО_ПП.Данные КАК object
				|ИЗ
				|	РегистрСведений.ДанныеВебКабинетаСУО_ПП КАК ДанныеВебКабинетаСУО_ПП
				|ГДЕ
				|	ДанныеВебКабинетаСУО_ПП.Пользователь = &Пользователь
				|	И ДанныеВебКабинетаСУО_ПП.Тип В (&Тип)
				|   И ДанныеВебКабинетаСУО_ПП.Период МЕЖДУ &ДатаНачала И &ДатаОкончания";
				
			КоличествоСекцийЗапроса = КоличествоСекцийЗапроса + 1;
				
		КонецЕсли;
		
		Если ТипОбучения = "all" ИЛИ ТипОбучения = "distant" Тогда
			
			Если КоличествоСекцийЗапроса > 0 Тогда
				ЗапросДанных.Текст = ЗапросДанных.Текст + " ОБЪЕДИНИТЬ ВСЕ ";
			КонецЕсли;
				
			ЗапросДанных.Текст = ЗапросДанных.Текст + "
				|ВЫБРАТЬ
				|	ДанныеВебКабинетаСУО_ПН.Данные КАК object
				|ИЗ
				|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО_ПН
				|ГДЕ
				|	ДанныеВебКабинетаСУО_ПН.Пользователь = &Пользователь
				|	И ДанныеВебКабинетаСУО_ПН.Тип В (&Тип)";
				
			КоличествоСекцийЗапроса = КоличествоСекцийЗапроса + 1;
				
		КонецЕсли;
		
		// Выбираем общие активности, которые образуют виды обучения с группировкой	
		
		Если КоличествоСекцийЗапроса > 0 Тогда
			ЗапросДанных.Текст = ЗапросДанных.Текст + " ОБЪЕДИНИТЬ ВСЕ ";
		КонецЕсли;

		ЗапросДанных.Текст = ЗапросДанных.Текст + "
		|ВЫБРАТЬ
		|	ДанныеВебКабинетаСУО_ОН.Данные КАК object
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ДанныеВебКабинетаСУО_ОН
		|ГДЕ
		|	ДанныеВебКабинетаСУО_ОН.Тип В(&Тип)";	
			
		КоличествоСекцийЗапроса = КоличествоСекцийЗапроса + 1;
		
		
	Иначе
		
		МассивОтборов = Новый Массив;
		
		Если СтрДлина(ОтборДанных) = 36 Тогда
			
			Попытка
				МассивОтборов.Добавить(Новый УникальныйИдентификатор(ОтборДанных));
			Исключение
			КонецПопытки;				
			
		Иначе
			
			Если Найти(ОтборДанных, "_") = 0 Тогда
				МассивСтрокОтборов = Новый Массив;
				МассивСтрокОтборов.Добавить(ОтборДанных);
			Иначе
				МассивСтрокОтборов = ОбщегоНазначенияСУКлиентСервер.РасщепитьСтроку(ОтборДанных, "_");	
			КонецЕсли;
			
			Для каждого ОтборСтрока Из МассивСтрокОтборов Цикл			
				Попытка
					МассивОтборов.Добавить(Перечисления.ОтборыДанныхВебКабинетаСУО.Идентификатор(Перечисления.ОтборыДанныхВебКабинетаСУО[ВебКабинетСУ.Перевод(ОтборСтрока, "ОтборыДанныхВебКабинетаСУО")]));
				Исключение
				КонецПопытки;				
			КонецЦикла;
			
		КонецЕсли;
			
		Если МассивОтборов.Количество() = 0 Тогда
			Возврат ОтветКлиентуJSON("noFilter");
		КонецЕсли;
		
		Если ТипОбучения = "all" ИЛИ ТипОбучения = "periodic" Тогда
			
			ЗапросДанных.Текст = ЗапросДанных.Текст + 
				"ВЫБРАТЬ
				|	ДанныеВебКабинетаСУО_ПП.Данные КАК object
				|ИЗ
				|	РегистрСведений.ДанныеВебКабинетаСУО_ПП КАК ДанныеВебКабинетаСУО_ПП
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборыДанныхВебКабинетаСУО_О
				|		ПО ДанныеВебКабинетаСУО_ПП.Объект = ОтборыДанныхВебКабинетаСУО_О.Объект
				|ГДЕ
				|	ДанныеВебКабинетаСУО_ПП.Пользователь = &Пользователь
				|	И ДанныеВебКабинетаСУО_ПП.Тип В (&Тип)
				|	И ОтборыДанныхВебКабинетаСУО_О.Отбор = &Отбор
				|	И ДанныеВебКабинетаСУО_ПП.Период МЕЖДУ &ДатаНачала И &ДатаОкончания";
				
			КоличествоСекцийЗапроса = КоличествоСекцийЗапроса + 1;
				
		КонецЕсли;
		
		Если ТипОбучения = "all" ИЛИ ТипОбучения = "distant" Тогда
			
			Если КоличествоСекцийЗапроса > 0 Тогда
				ЗапросДанных.Текст = ЗапросДанных.Текст + " ОБЪЕДИНИТЬ ВСЕ ";
			КонецЕсли;
		
			ЗапросДанных.Текст = ЗапросДанных.Текст + "
				|ВЫБРАТЬ
				|	ДанныеВебКабинетаСУО_ПН.Данные КАК object
				|ИЗ
				|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО_ПН
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборыДанныхВебКабинетаСУО_О
				|		ПО ДанныеВебКабинетаСУО_ПН.Объект = ОтборыДанныхВебКабинетаСУО_О.Объект
				|ГДЕ
				|	ДанныеВебКабинетаСУО_ПН.Пользователь = &Пользователь
				|	И ДанныеВебКабинетаСУО_ПН.Тип В (&Тип)
				|	И ОтборыДанныхВебКабинетаСУО_О.Отбор = &Отбор";
			
				
			КоличествоСекцийЗапроса = КоличествоСекцийЗапроса + 1;
				
		КонецЕсли;
		
		// Выбираем общие активности, которые образуют виды обучения с группировкой	
		
		Если КоличествоСекцийЗапроса > 0 Тогда
			ЗапросДанных.Текст = ЗапросДанных.Текст + " ОБЪЕДИНИТЬ ВСЕ ";
		КонецЕсли;

		ЗапросДанных.Текст = ЗапросДанных.Текст + "
		|ВЫБРАТЬ
		|	ДанныеВебКабинетаСУО_ОН.Данные КАК object
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ДанныеВебКабинетаСУО_ОН
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборыДанныхВебКабинетаСУО_О
		|		ПО ДанныеВебКабинетаСУО_ОН.Объект = ОтборыДанныхВебКабинетаСУО_О.Объект
		|ГДЕ
		|	ДанныеВебКабинетаСУО_ОН.Тип В(&Тип)
		|	И ОтборыДанныхВебКабинетаСУО_О.Отбор = &Отбор";	
			
		КоличествоСекцийЗапроса = КоличествоСекцийЗапроса + 1;		
		
		
		Если МассивОтборов.Количество() = 1 Тогда
			
			ЗапросДанных.УстановитьПараметр("Отбор", МассивОтборов[0]);
			
		Иначе
			
			УсловиеОтбора = " (";
			НомерОтбора = 1;
			Для каждого Отбор Из МассивОтборов Цикл
			
				УсловиеОтбора = УсловиеОтбора + " ОтборыДанныхВебКабинетаСУО_О.Отбор = &Отбор" + ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(НомерОтбора) + " ИЛИ";
				
				ЗапросДанных.УстановитьПараметр("Отбор"+ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(НомерОтбора), Отбор);
				
				НомерОтбора = НомерОтбора + 1;
				
			КонецЦикла;
			
			УсловиеОтбора = Сред(УсловиеОтбора, 1, СтрДлина(УсловиеОтбора) - 3); // Убираем последнее ИЛИ
			
			УсловиеОтбора = УсловиеОтбора + ") ";
			
			ЗапросДанных.Текст = СтрЗаменить(ЗапросДанных.Текст, "ОтборыДанныхВебКабинетаСУО_О.Отбор = &Отбор", УсловиеОтбора);
			
		КонецЕсли;
	
		
	КонецЕсли;
	
	Если КоличествоСекцийЗапроса = 0 Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаНачала) И ЗначениеЗаполнено(ДатаОкончания) Тогда
		
		ЗапросДанных.УстановитьПараметр("ДатаНачала", ДатаНачала);
		ЗапросДанных.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		
	Иначе
		
		ЗапросДанных.Текст = СтрЗаменить(ЗапросДанных.Текст, "И ДанныеВебКабинетаСУО_ПП.Период МЕЖДУ &ДатаНачала И &ДатаОкончания", "");
		
	КонецЕсли;		
	
	
	// Устанавливаем параметры запроса и выполняем его	
	
	МассивТиповАктивностей = Новый Массив;
	
	Если (Права.Свойство("Обучение") И Права.Обучение) Тогда
		МассивТиповАктивностей.Добавить(Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивность);
	КонецЕсли;
	
	Если Права.Свойство("Преподавание") И Права.Преподавание Тогда
		МассивТиповАктивностей.Добавить(Перечисления.ТипыДанныхВебКабинетаСУО.ПреподавательскаяАктивность);
	КонецЕсли;
	
	ЗапросДанных.УстановитьПараметр("Тип", МассивТиповАктивностей);
	
	ЗапросДанных.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	
	РезультатЗапроса = ЗапросДанных.Выполнить();
	
	// Возвращаем результат
	
	Возврат ОтветКлиентуJSON(,РезультатЗапроса.Выгрузить());		
	
КонецФункции

Функция ПолучитьОписаниеАктивностиУчастникаОбученияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем тип активности
	
	Попытка
		ТипАктивности = Запрос.ПараметрыURL.Получить("ТипАктивности");
	Исключение
	КонецПопытки;
	
	Если ТипАктивности <> "education" И ТипАктивности <> "teaching" И ТипАктивности <> "check" Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	Если ТипАктивности = "education" Тогда
		ПравоДляПроверки = "Обучение";
	КонецЕсли;
	
	Если ТипАктивности = "teaching" Тогда
		ПравоДляПроверки = "Преподавание";
	КонецЕсли;	
	
	Если ТипАктивности = "check" Тогда
		ПравоДляПроверки = "Преподавание";
	КонецЕсли;	
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПравоДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные
	//	
	
	Попытка
		Идентификатор = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ИдентификаторАктивности"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(Идентификатор) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Если ТипАктивности = "education" Тогда
		ДокументАктивности = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(Идентификатор);
	КонецЕсли;
	
	Если ТипАктивности = "check" Тогда
		ДокументАктивности = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(Идентификатор);
	КонецЕсли;	
	
	Если ТипАктивности = "teaching" Тогда
		ДокументАктивности = Документы.ПроведениеПреподавателемОбученияСУО.ПолучитьСсылку(Идентификатор);
	КонецЕсли;		
	
	// Ждем окончания заданий
	
	ОжидатьЗавершенияЗаданияОбновленияЭлектронногоРесурса(ДанныеСессии, ДокументАктивности);		
	
	// Делаем запрос к БД
	
	ЗапросДанных = Новый Запрос;
	ЗапросДанных.Текст = 
		"ВЫБРАТЬ
		|	ДанныеВебКабинетаСУО.Данные КАК data
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО
		|ГДЕ
		|	ДанныеВебКабинетаСУО.Пользователь = &Пользователь
		|	И ДанныеВебКабинетаСУО.Тип = &Тип
		|	И ДанныеВебКабинетаСУО.Объект = &Объект";
	
	ЗапросДанных.УстановитьПараметр("Объект", ДокументАктивности);
	
	Если ТипАктивности = "check" Тогда
		ЗапросДанных.УстановитьПараметр("Пользователь", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументАктивности, "Пользователь"));
	Иначе		
		ЗапросДанных.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	КонецЕсли;	
	
	Если ТипАктивности = "education" Тогда
		ЗапросДанных.УстановитьПараметр("Тип", Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивностьОписание);
	КонецЕсли;
	
	Если ТипАктивности = "check" Тогда
		ЗапросДанных.УстановитьПараметр("Тип", Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивностьОписание);
	КонецЕсли;	
	
	Если ТипАктивности = "teaching" Тогда
		ЗапросДанных.УстановитьПараметр("Тип", Перечисления.ТипыДанныхВебКабинетаСУО.ПреподавательскаяАктивностьОписание);
	КонецЕсли;	
	
	РезультатЗапроса = ЗапросДанных.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		Возврат ОтветКлиентуJSON("errorData");
		
	Иначе
	
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		ВыборкаДетальныеЗаписи.Следующий();
		
		Возврат ОтветКлиентуXML(ВыборкаДетальныеЗаписи.data.Получить());
		
	КонецЕсли;
	
КонецФункции

Функция ПолучитьВедомостьУчастниковОбученияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Преподавание");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные
	//	
	
	Попытка
		ИдентификаторПроведенияОбучения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ПроведениеОбучения"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторПроведенияОбучения) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	

	Попытка
		ИдентификаторСценария =  Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("Сценарий"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторСценария) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	
	Возврат ПолучитьВедомостьУчастниковОбучения(ИдентификаторПроведенияОбучения, ИдентификаторСценария);

КонецФункции

Функция ПолучитьВедомостьУчастниковОбучения(ИдентификаторПроведенияОбучения, ИдентификаторСценария)
	
	// Выбираем данные из базы
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ОписаниеПрохожденияОбучения.Данные КАК data
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ОписаниеПрохожденияОбучения
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборПоПроведениюОбучения
		|		ПО ОписаниеПрохожденияОбучения.Объект = ОтборПоПроведениюОбучения.Объект
		|			И (ОтборПоПроведениюОбучения.Отбор = &ИдентификаторПроведенияОбучения)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборПоСценарию
		|		ПО ОписаниеПрохожденияОбучения.Объект = ОтборПоСценарию.Объект
		|			И (ОтборПоСценарию.Отбор = &ИдентификаторСценария)
		|ГДЕ
		|	ОписаниеПрохожденияОбучения.Тип = &Тип";
	
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивностьОписание);
	Запрос.УстановитьПараметр("ИдентификаторПроведенияОбучения", ИдентификаторПроведенияОбучения);
	Запрос.УстановитьПараметр("ИдентификаторСценария", ИдентификаторСценария);
		
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	РезультатТекстXML = "";
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РезультатТекстXML = РезультатТекстXML + ВыборкаДетальныеЗаписи.data.Получить();
	КонецЦикла;	
	
	Возврат ОтветКлиентуXML(РезультатТекстXML);	
	
КонецФункции

Функция ЗаписатьВедомостьУчастниковОбученияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Преподавание");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные
	//	
	
	Попытка
		ИдентификаторПроведенияОбучения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ПроведениеОбучения"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторПроведенияОбучения) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	
	
	Попытка
		ИдентификаторСценария =  Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("Сценарий"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторСценария) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	
	
	// Получаем данные для записи
	//
	
	ДанныеДляЗаписиJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если НЕ ЗначениеЗаполнено(ДанныеДляЗаписиJSON) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Попытка
		ДанныеДляЗаписи = ОбщегоНазначенияСУ.JSONВДанные(ДанныеДляЗаписиJSON);
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;
	
	// Получаем текущие данные из БД
	//		
	
	МассивПрохожденийОбучения = Новый Массив;
	
	Для каждого Элемент Из ДанныеДляЗаписи Цикл
		
		Если НЕ ЗначениеЗаполнено(Элемент.id) Тогда
			Продолжить;
		КонецЕсли;
		
		МассивПрохожденийОбучения.Добавить(Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.id)));
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрохождениеОбученияСУО.Ссылка КАК ПрохождениеОбучения,
		|	ПрохождениеОбученияСУО.Статус,
		|	ПрохождениеОбученияСУО.Баллы,
		|	ПрохождениеОбученияСУО.КомментарийПреподавателя
		|ИЗ
		|	Документ.ПрохождениеОбученияСУО КАК ПрохождениеОбученияСУО
		|ГДЕ
		|	ПрохождениеОбученияСУО.Ссылка В(&МассивПрохожденийОбучения)";
	
	Запрос.УстановитьПараметр("МассивПрохожденийОбучения", МассивПрохожденийОбучения);
	
	ТаблицаТекущихДанных = Запрос.Выполнить().Выгрузить();
	
	ПроведениеОбучения = Документы.ПроведениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторПроведенияОбучения));
	ШкалаОценки = Документы.ПроведениеОбученияСУО.ШкалаОценки(ПроведениеОбучения);
	
	// Записываем данные
	//
	
	Для каждого Элемент Из ДанныеДляЗаписи Цикл
		
		Если НЕ ЗначениеЗаполнено(Элемент.id) Тогда
			Продолжить;
		КонецЕсли;
		
		ПрохождениеОбучения = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.id));
		
		ДанныеИзменились = Ложь;
		СтарыеДанные = ТаблицаТекущихДанных.Найти(ПрохождениеОбучения, "ПрохождениеОбучения");
		
		Если Элемент.Свойство("status") Тогда
			СтатусПрохождения = Перечисления.СтатусыПрохожденияОбъектовСУО.ЧислоВЗначение(Число(Элемент.status));
			Если СтатусПрохождения <> СтарыеДанные.Статус Тогда
				ДанныеИзменились = Истина;
			КонецЕсли;				
		КонецЕсли;
		
		Если Элемент.Свойство("mark") И ЗначениеЗаполнено(Элемент.mark) Тогда
			ОценкаПрохождения = Справочники.ЭлементыШкалыОценокСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.mark));
			Если ОценкаПрохождения <> УправлениеОбучениемСУОПовтИсп.ОценкаИзБаллов(СтарыеДанные.Баллы, ШкалаОценки) Тогда
				ДанныеИзменились = Истина;
			КонецЕсли;			
		КонецЕсли;		
		
		Если Элемент.Свойство("comment") Тогда
			КомментарийПреподавателя = Элемент.comment;
		Иначе
			КомментарийПреподавателя = "";
		КонецЕсли;		
		
		Если СтарыеДанные.КомментарийПреподавателя <> КомментарийПреподавателя Тогда			
			ДанныеИзменились = Истина;			
		КонецЕсли;
			
		Если ДанныеИзменились Тогда				
			ОписаниеПрохождения = ОбучениеСУО.ПриПрохожденииМероприятия(ПрохождениеОбучения, СтатусПрохождения, КомментарийПреподавателя,ОценкаПрохождения,,,Истина);			
			ВебКабинетСУО.ОбновитьДанныеПрохожденияОбученияВебКабинета(ПрохождениеОбучения, ОписаниеПрохождения);
		КонецЕсли;
			
	КонецЦикла;

	
	// Возвращаем результат
	//
	
	Возврат ПолучитьВедомостьУчастниковОбучения(ИдентификаторПроведенияОбучения, ИдентификаторСценария);
	
КонецФункции

Функция ПолучитьРезультатыТестированияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Обучение");
	ПраваДляПроверки.Добавить("Преподавание");	
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные
	//	
	
	Попытка
		ТипАктивности = Запрос.ПараметрыURL.Получить("ТипАктивности");
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;
	
	Если ТипАктивности <> "education" И ТипАктивности <> "check" Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;		
	
	Попытка
		ИдентификаторПрохожденияОбучения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ПрохождениеОбучения"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторПрохожденияОбучения) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;		
	
	Попытка
		ПрохождениеОбучения = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторПрохожденияОбучения));
	Исключение
	КонецПопытки;	
	
	// Ждем окончания заданий
	
	Отбор = Новый Структура;
   	Отбор.Вставить("ИмяМетода", "ОбучениеСУО.ПриПрохожденииЭлектронногоРесурса");
   	Отбор.Вставить("Состояние", СостояниеФоновогоЗадания.Активно);
	Отбор.Вставить("Ключ", Строка(ДанныеСессии.Пользователь.УникальныйИдентификатор()));
   	ФоновыеЗаданияОбновления = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
	Если ФоновыеЗаданияОбновления.Количество() > 0 Тогда
		Попытка
			ФоновыеЗадания.ОжидатьЗавершения(ФоновыеЗаданияОбновления, 10);
		Исключение
			ЗаписьЖурналаРегистрации(
				НСТр("ru = 'Веб-кабинет. Получение данных'"),
				УровеньЖурналаРегистрации.Ошибка,
				,
				ПрохождениеОбучения,
				НСТр("ru = 'Не дождались окончания выполнения фонового задания по обновлению данных при получении результатов тестирования. '") + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЕсли;			
	
	ЗапросДанных = Новый Запрос;
	ЗапросДанных.Текст = 
		"ВЫБРАТЬ
		|	ДанныеВебКабинетаСУО.Данные КАК data
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО
		|ГДЕ
		|	ДанныеВебКабинетаСУО.Пользователь = &Пользователь
		|	И ДанныеВебКабинетаСУО.Тип = &Тип
		|	И ДанныеВебКабинетаСУО.Объект = &Объект";
	
	ЗапросДанных.УстановитьПараметр("Объект", ПрохождениеОбучения);
	ЗапросДанных.УстановитьПараметр("Тип", Перечисления.ТипыДанныхВебКабинетаСУО.РезультатыТестирования);
	
	Если ТипАктивности = "check" Тогда
		ЗапросДанных.УстановитьПараметр("Пользователь", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПрохождениеОбучения, "Пользователь"));
	Иначе		
		ЗапросДанных.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	КонецЕсли;	
	
	РезультатЗапроса = ЗапросДанных.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		Возврат ОтветКлиентуJSON(,"");
		
	Иначе
	
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		ВыборкаДетальныеЗаписи.Следующий();
		
		Возврат ОтветКлиентуJSON(,ВыборкаДетальныеЗаписи.data);
		
	КонецЕсли;
	
КонецФункции

Функция УстановитьПроведениеПреподавателемОбученияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Преподавание");
	

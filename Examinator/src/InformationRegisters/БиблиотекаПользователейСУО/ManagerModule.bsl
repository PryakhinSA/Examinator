Процедура БиблиотекаПользователейЗаполнитьДвижения(Движения, Знач Пользователь, Знач Период, Знач ВыборкаРесурсов, Знач СтатусПроцессаОбучения, Знач СтатусПроведения, Знач ЭтоУченик) Экспорт
	
	ВыборкаРесурсов.Сбросить();
	
	Пока ВыборкаРесурсов.Следующий() Цикл
		
		Если НЕ ВыборкаРесурсов.ДобавитьВБиблиотеку Тогда
			Продолжить;	
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ВыборкаРесурсов.Ресурс) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЭтоУченик И ВыборкаРесурсов.ПоказатьПослеПрохождения 
			И СтатусПроцессаОбучения <> Перечисления.СтатусыПроцессаОбученияСУО.Окончено
			И СтатусПроцессаОбучения <> Перечисления.СтатусыПроцессаОбученияСУО.ОконченоАвтоматом Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ Документы.ПроведениеОбученияСУО.МожноПоказатьРесурсПроведения(
			СтатусПроведения,
			ВыборкаРесурсов.ПоказатьПриСтатусеЗапланировано,
            ВыборкаРесурсов.ПоказатьПриСтатусеАктивно,
		    ВыборкаРесурсов.ПоказатьПриСтатусеЗавершено) Тогда
			 
			Продолжить;
			 
		КонецЕсли;
		
		Если ЭтоУченик И ВыборкаРесурсов.СкрыватьОтУченика Тогда
			Продолжить;
		КонецЕсли;
		
		УжеЕстьДвижение = Ложь; 
		Для каждого СуществующееДвижение Из Движения.БиблиотекаПользователейСУО Цикл		
			Если СуществующееДвижение.Пользователь = Пользователь
				И СуществующееДвижение.Ресурс = ВыборкаРесурсов.Ресурс Тогда
				УжеЕстьДвижение = Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
		
		Если УжеЕстьДвижение Тогда
			Продолжить;
		КонецЕсли;
		
		Движение = Движения.БиблиотекаПользователейСУО.Добавить();
		
		Движение.Пользователь = Пользователь;
		Движение.Ресурс       = ВыборкаРесурсов.Ресурс;
		Движение.Фрагмент     = ВыборкаРесурсов.Фрагмент;		
		Движение.Метка        = ВыборкаРесурсов.МеткаВБиблиотеке;
		
		Если ЗначениеЗаполнено(ВыборкаРесурсов.ДатаИзменения)
			И ВыборкаРесурсов.ДатаИзменения > Период Тогда
			
			Движение.Период = ВыборкаРесурсов.ДатаИзменения;
			
		Иначе
			
			Движение.Период = Период;
			
		КонецЕсли;		
		
		Если ЗначениеЗаполнено(Движение.Метка) Тогда
			Движение.Библиотека = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Движение.Метка, "Владелец");
		Иначе
			Движение.Библиотека = Справочники.СхемыМероприятийСУО.Общая;
		КонецЕсли;					
	
	КонецЦикла;
	
КонецПроцедуры

Функция БиблиотекиПользователя(Пользователь)
	
	МассивБиблиотек = Новый Массив;
	
	МассивБиблиотек.Добавить(Справочники.СхемыМероприятийСУО.Общая);
	
	Если ДоступнаБиблиотекаПользователя(Пользователь) Тогда
		МассивБиблиотек.Добавить(Пользователь);	
	КонецЕсли;
	
	ВыборкаБиблиотек = РегистрыСведений.БиблиотекаПользователейСУО.ВыборкаБиблиотекПользователя(Пользователь);
	
	Пока ВыборкаБиблиотек.Следующий() Цикл
		
		Если ЗначениеЗаполнено(ВыборкаБиблиотек.ВладелецМетки)
			И МассивБиблиотек.Найти(ВыборкаБиблиотек.ВладелецМетки) = Неопределено Тогда
			
			МассивБиблиотек.Добавить(ВыборкаБиблиотек.ВладелецМетки);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивБиблиотек;
	
КонецФункции

Функция ДоступнаБиблиотекаПользователя(Пользователь) Экспорт
	
	ДоступнаМояБиблиотека = Ложь;
	
	// Определяем, доступна ли моя библиотека

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	СтруктураБиблиотекиПользователейСУО.Ссылка
		|ИЗ
		|	Справочник.СтруктураБиблиотекиПользователейСУО КАК СтруктураБиблиотекиПользователейСУО
		|ГДЕ
		|	СтруктураБиблиотекиПользователейСУО.Владелец = &Пользователь
		|	И СтруктураБиблиотекиПользователейСУО.ПометкаУдаления = ЛОЖЬ";

	Запрос.УстановитьПараметр("Пользователь", Пользователь);

	Результат = Запрос.Выполнить();

	Если НЕ Результат.Пустой() Тогда
		ДоступнаМояБиблиотека = Истина;	
	КонецЕсли;
	
	Если НЕ ДоступнаМояБиблиотека Тогда

		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	БиблиотекаПользователейМеткиРесурсовСУО.Метка
			|ИЗ
			|	РегистрСведений.БиблиотекаПользователейМеткиРесурсовСУО КАК БиблиотекаПользователейМеткиРесурсовСУО
			|ГДЕ
			|	БиблиотекаПользователейМеткиРесурсовСУО.Пользователь = &Пользователь";

		Запрос.УстановитьПараметр("Пользователь", Пользователь);

		Результат = Запрос.Выполнить();

		Если НЕ Результат.Пустой() Тогда
			ДоступнаМояБиблиотека = Истина;
		КонецЕсли;
	
	КонецЕсли;
	
	Если НЕ ДоступнаМояБиблиотека Тогда

		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	БиблиотекаПользователейСУО.Регистратор
			|ИЗ
			|	РегистрСведений.БиблиотекаПользователейСУО КАК БиблиотекаПользователейСУО
			|ГДЕ
			|	БиблиотекаПользователейСУО.Библиотека = &Пользователь";

		Запрос.УстановитьПараметр("Пользователь", Пользователь);

		Результат = Запрос.Выполнить();

		Если НЕ Результат.Пустой() Тогда
			ДоступнаМояБиблиотека = Истина;
		КонецЕсли;
	
	КонецЕсли;
	
	Возврат ДоступнаМояБиблиотека;
	
КонецФункции

Функция ПользователиРегистратора(Регистратор) Экспорт
	
	Возврат Документы.НаполнениеБиблиотекиПользователейСУО.ПользователиДокумента(Регистратор);
	

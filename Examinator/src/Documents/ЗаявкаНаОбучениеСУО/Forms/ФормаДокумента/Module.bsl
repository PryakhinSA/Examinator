
////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

&НаСервереБезКонтекста
Функция ЗачислитьУчастника(ПредметЗаявки, ОбъектЗаявки, Пользователь, Заявка)
	
	Если ТипЗнч(ПредметЗаявки) = Тип("ДокументСсылка.ПроведениеОбученияСУО") Тогда		
		Возврат УправлениеОбучениемСУО.ЗачислитьУчастникаНаОбучение(ПредметЗаявки, ОбъектЗаявки, Пользователь,,,Заявка);		
	КонецЕсли;
	
	Если ТипЗнч(ПредметЗаявки) = Тип("ДокументСсылка.ПроведениеПрограммыОбученияСУО") Тогда		
		Возврат УправлениеОбучениемСУО.ЗачислитьУчастникаНаПрограммуОбучения(ПредметЗаявки, Пользователь,,Заявка);		
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ЗачислитьУчастников()
	
	НачатьТранзакцию();
	
	Для каждого Строка Из Объект.Участники Цикл
	
		Если НЕ ЗначениеЗаполнено(Строка.Прохождение) Тогда
			Строка.Прохождение = ЗачислитьУчастника(Объект.ПредметЗаявки, Объект.ОбъектЗаявки, Строка.Пользователь, Объект.Ссылка);
		КонецЕсли;
	
	КонецЦикла;
	
	Объект.Статус           = Перечисления.СтатусыЗаявокНаОбучениеСУО.Утверждена;
	Объект.ДатаРассмотрения = ТекущаяДата();
	
	РежимЗаписи = Новый Структура();
	РежимЗаписи.Вставить("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	Записать(РежимЗаписи);
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьКоманд()
	
	Если Объект.Статус = Перечисления.СтатусыЗаявокНаОбучениеСУО.НаРассмотрении
		ИЛИ Объект.Статус = Перечисления.СтатусыЗаявокНаОбучениеСУО.Отклонена
		ИЛИ Объект.Статус = Перечисления.СтатусыЗаявокНаОбучениеСУО.Отменена Тогда
		
		Элементы.ГруппаУтверждение.Доступность = Истина;
		
	Иначе
		
		Элементы.ГруппаУтверждение.Доступность = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Объект.Ссылка.Пустая() Тогда
		Отказ = Истина; // Объект создается интерактивно только в форме "ФормаПодачиЗаявки"
	КонецЕсли;
	
	ТипОбъектаЗаявки = Документы.ЗаявкаНаОбучениеСУО.ТипОбъектаЗаявки(Объект.ОбъектЗаявки);
	
	Если НЕ ЗначениеЗаполнено(Объект.Анкета) Тогда
		Элементы.Анкета.Видимость = Ложь;
	КонецЕсли;
	
	ЕстьПравоУтвержденияЗаявки = УправлениеДоступом.ЕстьРоль("УправлениеПроведениемОбученияСУО");
	
	Если НЕ ЕстьПравоУтвержденияЗаявки Тогда
		Элементы.ГруппаУтверждение.Видимость = Ложь;
		Элементы.Комментарий.ТолькоПросмотр  = Истина;
	КонецЕсли;
	
	Если Объект.Пользователь = Пользователи.ТекущийПользователь() Тогда
		Элементы.Информация.ТолькоПросмотр = Ложь;
	Иначе
		Элементы.Информация.ТолькоПросмотр = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ПредметЗаявки)
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ПредметЗаявки, "ОткрытоДляРуководителей") Тогда
		
		Элементы.Участники.Видимость = Истина;
		
	Иначе
		
		Элементы.Участники.Видимость = Ложь;
		
	КонецЕсли;
	
	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства

	УстановитьДоступностьКоманд();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства

КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	УстановитьДоступностьКоманд();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)	
	// СтандартныеПодсистемы.Свойства 
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтотОбъект, ИмяСобытия, Параметр) Тогда
	    ОбновитьЭлементыДополнительныхРеквизитов();
	    УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты);
	// Конец СтандартныеПодсистемы.Свойства
КонецПроцедуры


// Общее

&НаСервере
Процедура УстановитьВидимостьЭлементовФормы()
	
	Если РежимЗагрузки = "Подключение" Тогда
		Элементы.ГруппаПодключение.Видимость = Истина;
	Иначе
		Элементы.ГруппаПодключение.Видимость = Ложь;
	КонецЕсли;
	
	Если РежимЗагрузки = "Таблица" Тогда
		Элементы.ГруппаТаблица.Видимость = Истина;
	Иначе
		Элементы.ГруппаТаблица.Видимость = Ложь;
	КонецЕсли;	
	
КонецПроцедуры



#КонецОбласти


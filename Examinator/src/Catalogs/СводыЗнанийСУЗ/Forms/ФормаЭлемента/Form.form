	ВЫБОР
		КОГДА СправочникСодержаниеСУЗ.ЭтоГруппа
			ТОГДА &quot;Группа&quot;
		ИНАЧЕ ВЫБОР
				КОГДА СправочникСодержаниеСУЗ.СсылкаНаЭлемент.ЭтоТест
					ТОГДА &quot;Тест&quot;
				ИНАЧЕ ВЫБОР
						КОГДА НЕ СправочникСодержаниеСУЗ.СсылкаНаЭлемент.ЭтоТест
							ТОГДА ВЫБОР
									КОГДА СправочникСодержаниеСУЗ.СсылкаНаЭлемент.ЭтоПрезентация
										ТОГДА &quot;Презентация&quot;
									ИНАЧЕ &quot;Теория&quot;
								КОНЕЦ
						ИНАЧЕ ПРЕДСТАВЛЕНИЕ(ТИПЗНАЧЕНИЯ(СправочникСодержаниеСУЗ.СсылкаНаЭлемент))
					КОНЕЦ
			КОНЕЦ
	КОНЕЦ КАК ТипЭлемента
ИЗ
	Справочник.СодержаниеСУЗ КАК СправочникСодержаниеСУЗ</queryText>
      <mainTable>Catalog.СодержаниеСУЗ</mainTable>

    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ВЫБОР
		КОГДА Пользователи.ПометкаУдаления
			ТОГДА 0
		КОГДА Пользователи.ИдентификаторПользователяИБ = &amp;ПустойУникальныйИдентификатор
			ТОГДА 4
		ИНАЧЕ 1
	КОНЕЦ КАК НомерКартинки,
	Пользователи.Ссылка КАК Пользователь
ИЗ
	РегистрСведений.РуководителиСУО КАК РуководителиСУО
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
		ПО РуководителиСУО.ОбъектРуководства = Пользователи.Ссылка
ГДЕ
	РуководителиСУО.Пользователь = &amp;Пользователь
	И ТИПЗНАЧЕНИЯ(РуководителиСУО.ОбъектРуководства) = ТИП(Справочник.Пользователи)</queryText>
      <mainTable>Catalog.Пользователи</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>

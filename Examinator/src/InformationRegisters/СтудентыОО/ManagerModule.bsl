Процедура ОбновитьДанныеВебКабинета(Отбор) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Отбор.Найти("Пользователь") <> Неопределено Тогда
		
		Пользователь = Отбор.Пользователь.Значение;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПрохождениеОбученияСУО.Ссылка КАК ПрохождениеОбучения
			|ИЗ
			|	Документ.ПрохождениеОбученияСУО КАК ПрохождениеОбученияСУО
			|ГДЕ
			|	ПрохождениеОбученияСУО.Пользователь = &Пользователь
			|	И ПрохождениеОбученияСУО.Проведен = ИСТИНА";
		
		Запрос.УстановитьПараметр("Пользователь", Пользователь);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		ИмяТаблицы = ОбщегоНазначения.ИмяТаблицыПоСсылке(Документы.ПрохождениеОбученияСУО.ПустаяСсылка());
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ПараметрыФЗ = Новый Массив;
			ПараметрыФЗ.Добавить(ВыборкаДетальныеЗаписи.ПрохождениеОбучения);
			ПараметрыФЗ.Добавить(Неопределено);			
			
			ВебКабинетСУ.ДобавитьЗаданиеНаОбновлениеДанных(ИмяТаблицы, "ВебКабинетСУ.ОбновитьДанныеОбъекта", ПараметрыФЗ, Строка(ВыборкаДетальныеЗаписи.ПрохождениеОбучения.УникальныйИдентификатор()), 1);

			ПараметрыФЗ = Новый Массив;
			ПараметрыФЗ.Добавить(Пользователь);
			ПараметрыФЗ.Добавить(Неопределено);		
		
			ВебКабинетСУ.ДобавитьЗаданиеНаОбновлениеДанных("Справочник.Пользователи", "ВебКабинетСУО.ОбновитьДанныеПользователяВебКабинета", ПараметрыФЗ, Строка(Пользователь.УникальныйИдентификатор()), 1);
			
		КонецЦикла;	
		
	КонецЕсли;	
	
КонецПроцедуры

Функция ВсеСтуденты() Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтудентыООСрезПоследних.Пользователь
		|ИЗ
		|	РегистрСведений.СтудентыОО.СрезПоследних КАК СтудентыООСрезПоследних";
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Пользователь");
	
КонецФункции


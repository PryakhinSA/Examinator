Функция ВозвратитьОтчет(ТекстовыйДокументОтчета, ТипФайла, ИмяФайлаБезРасширения)
	
	ПутьКВременномуФайлу = ПолучитьИмяВременногоФайла("tmp");
	ТекстовыйДокументОтчета.Записать(ПутьКВременномуФайлу, ТипФайла);
	
	ДвоичныеДанныеОтчета = Новый ДвоичныеДанные(ПутьКВременномуФайлу);
	
	Попытка
		УдалитьФайлы(ПутьКВременномуФайлу);
	Исключение
		// Не требуется
	КонецПопытки;
	
	Если ТипФайла = ТипФайлаТабличногоДокумента.HTML5
		ИЛИ ТипФайла = ТипФайлаТабличногоДокумента.HTML
		ИЛИ ТипФайла = ТипФайлаТабличногоДокумента.HTML3
		ИЛИ ТипФайла = ТипФайлаТабличногоДокумента.HTML4 Тогда
	
		Возврат ОтветКлиентуHTMLИзДвоичныхДанных(ДвоичныеДанныеОтчета);
		
	КонецЕсли;
	
	Если ТипФайла = ТипФайлаТабличногоДокумента.XLS
		ИЛИ ТипФайла = ТипФайлаТабличногоДокумента.XLS95
		ИЛИ ТипФайла = ТипФайлаТабличногоДокумента.XLS97 Тогда
		
		Возврат ОтветКлиентуДвоичныеДанные(0, ДвоичныеДанныеОтчета, "application/vnd.ms-excel", ИмяФайлаБезРасширения + ".xls");
		
	КонецЕсли;
	
	Если ТипФайла = ТипФайлаТабличногоДокумента.XLSX Тогда		
		
		Возврат ОтветКлиентуДвоичныеДанные(0, ДвоичныеДанныеОтчета, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", ИмяФайлаБезРасширения + ".xlsx");
		
	КонецЕсли;
	
	Если ТипФайла = ТипФайлаТабличногоДокумента.PDF
		ИЛИ ТипФайла = ТипФайлаТабличногоДокумента.PDF_A_1
		ИЛИ ТипФайла = ТипФайлаТабличногоДокумента.PDF_A_2
		ИЛИ ТипФайла = ТипФайлаТабличногоДокумента.PDF_A_3 Тогда
	
		Возврат ОтветКлиентуДвоичныеДанные(0, ДвоичныеДанныеОтчета, "application/pdf", ИмяФайлаБезРасширения + ".pdf", Истина); 
		
	КонецЕсли;
	
КонецФункции

// ОБЩИЕ (аналогичные процедуры есть в других HTTP-сервисах)
//

Функция ОтветКлиентуJSON(КодОшибки = "", Данные = NULL)
	
	ТекстСообщенияСтруктура = Новый Структура("error, data", КодОшибки, Данные);
	
	ТекстСообщения = ОбщегоНазначенияСУ.ДанныеВJSON(ТекстСообщенияСтруктура);

	Если ЗначениеЗаполнено(КодОшибки) Тогда
		Ответ = Новый HTTPСервисОтвет(400);
	Иначе
		Ответ = Новый HTTPСервисОтвет(200);
	КонецЕсли;
		
	Ответ.УстановитьТелоИзСтроки(ТекстСообщения);
	
	Ответ.Заголовки.Вставить("Content-Type", "application/json");
	ДобавитьЗаголовкиМежсайтовогоЗапроса(Ответ);
	
	Возврат Ответ;
	
КонецФункции

Функция ОтветКлиентуДвоичныеДанные(КодОшибки = 0, ДвоичныеДанные = Неопределено, MIMEТип = Неопределено, ИмяФайла = Неопределено, ПросмотретьВБраузере = Ложь)
	
	Если ЗначениеЗаполнено(КодОшибки) Тогда
				
		Ответ = Новый HTTPСервисОтвет(КодОшибки);
		
	Иначе
		
		Если ТипЗнч(ДвоичныеДанные) = Тип("ДвоичныеДанные") Тогда
			
			Ответ = Новый HTTPСервисОтвет(200);
			Ответ.УстановитьТелоИзДвоичныхДанных(ДвоичныеДанные);
			
			Ответ.Заголовки.Вставить("Accept-Ranges", "bytes");
			
			Если ЗначениеЗаполнено(ИмяФайла) Тогда
				ВариантОткрытия = ?(ПросмотретьВБраузере, "inline", "attachment");
				Ответ.Заголовки.Вставить("Content-Disposition", ""+ВариантОткрытия+"; filename="""+ СтроковыеФункцииКлиентСервер.СтрокаЛатиницей(ИмяФайла) +"""");
			КонецЕсли;			
			
			Если ЗначениеЗаполнено(MIMEТип) Тогда
				Ответ.Заголовки.Вставить("Content-Type", MIMEТип);
			КонецЕсли;
			
		Иначе
			
			Ответ = Новый HTTPСервисОтвет(404);
			
		КонецЕсли;			
		
	КонецЕсли;	
	
	ДобавитьЗаголовкиМежсайтовогоЗапроса(Ответ);
	
	Возврат Ответ;
	
КонецФункции

Функция ОтветКлиентуXML(ТекстXML)
	
	РезультатЗапроса = "<?xml version=""1.0"" encoding=""utf-8""?><response>";
	РезультатЗапроса = РезультатЗапроса + ТекстXML;
	РезультатЗапроса = РезультатЗапроса + "</response>";
	
	Ответ = Новый HTTPСервисОтвет(200);
		
	Ответ.УстановитьТелоИзСтроки(РезультатЗапроса);

	Ответ.Заголовки.Вставить("Content-Type", "application/xml");
	ДобавитьЗаголовкиМежсайтовогоЗапроса(Ответ);
	
	Возврат Ответ;
	
КонецФункции

Функция ОтветКлиентуHTMLИзДвоичныхДанных(ДвоичныеДанные)
		
	Ответ = Новый HTTPСервисОтвет(200);
		
	Ответ.УстановитьТелоИзДвоичныхДанных(ДвоичныеДанные);

	Ответ.Заголовки.Вставить("Data-type", "text/html");
	Ответ.Заголовки.Вставить("Content-Type", "text/html");
	
	ДобавитьЗаголовкиМежсайтовогоЗапроса(Ответ);
	
	Возврат Ответ;
	
КонецФункции

Процедура ВосстановитьСимволыСтрокиПараметров(Значение)
	
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
	
		Значение = СтрЗаменить(Значение, "%3A", ":");
		Значение = СтрЗаменить(Значение, "%3B", ";");		
		
	КонецЕсли;
		
КонецПроцедуры

Функция СформироватьТаблицуДополнительныхСвойств(МассивСвойств)

	ТаблицаСвойств = Новый ТаблицаЗначений;
	ТаблицаСвойств.Колонки.Добавить("Свойство");
	ТаблицаСвойств.Колонки.Добавить("Значение");

	Для каждого Элемент Из МассивСвойств Цикл
		
		Если НЕ Элемент.Свойство("propertyId") ИЛИ НЕ Элемент.Свойство("value") ИЛИ НЕ ЗначениеЗаполнено(Элемент.propertyId) ИЛИ НЕ Элемент.Свойство("typeValue") Тогда
			ОтменитьТранзакцию();
		    Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;				
		
		НоваяСтрока = ТаблицаСвойств.Добавить();
		НоваяСтрока.Свойство = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.propertyId));
		
		Если Элемент.typeValue = "date" Тогда
			НоваяСтрока.Значение = ОбщегоНазначенияСУКлиентСервер.СтрокаISO8601ВДату(Элемент.value);
		ИначеЕсли Элемент.typeValue = "properties" ИЛИ Элемент.typeValue = "values" Тогда
			НоваяСтрока.Значение = Справочники.ЗначенияСвойствОбъектов.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.value));
		Иначе
			НоваяСтрока.Значение = Элемент.value;
		КонецЕсли;

	КонецЦикла;
	
	Возврат ТаблицаСвойств;
	
КонецФункции

Функция КаталогПользователей(ДанныеСессии, ТолькоПользователи=Ложь)
	
	Если ТолькоПользователи Тогда
		МассивПользователей = Новый Массив;
	Иначе
		КаталогПользователей = Новый Структура("УчебныеГруппы, КаталогПользователей, Преподаватели, Организаторы", Новый Массив, Неопределено, Неопределено, Неопределено);
	КонецЕсли;
		
	Права = ДанныеСессии.Права.Получить();
	
	Если Права.Свойство("Пользователи") И Права.Пользователи Тогда
		
		Если Права.Свойство("СвоиУчебныеГруппы") И Права.СвоиУчебныеГруппы Тогда

			// Получаем учебные группы пользователя
			//			
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	ВыборкаУчебныхГрупп.Данные
				|ИЗ
				|	РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ВыборкаУчебныхГрупп
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборУчебныхГруппПользователя
				|		ПО ВыборкаУчебныхГрупп.Объект = ОтборУчебныхГруппПользователя.Объект
				|ГДЕ
				|	ОтборУчебныхГруппПользователя.Отбор = &ИдентификаторПользователя
				|	И ВыборкаУчебныхГрупп.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.УчебнаяГруппаОписание)";

			Запрос.УстановитьПараметр("ИдентификаторПользователя", ДанныеСессии.Пользователь.УникальныйИдентификатор());

			РезультатЗапроса = Запрос.Выполнить();

			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				
				Если ТолькоПользователи Тогда
					
					ДанныеГруппы = ОбщегоНазначенияСУ.JSONВДанные(ВыборкаДетальныеЗаписи.Данные.Получить());
					
					Для каждого Участник Из ДанныеГруппы.Участники Цикл
						
						Пользователь = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(Участник.Идентификатор));
						
						Если МассивПользователей.Найти(Пользователь) = Неопределено Тогда
							МассивПользователей.Добавить(Пользователь);
						КонецЕсли;
					
					КонецЦикла;
					
				Иначе
					
					КаталогПользователей.УчебныеГруппы.Добавить(ВыборкаДетальныеЗаписи.Данные);
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
		Если Права.Свойство("КаталогПользователей") И Права.КаталогПользователей Тогда
		
			// Получаем общий каталог, если есть соответствующее право
			//

			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	ДанныеВебКабинетаСУО_ОН.Данные
				|ИЗ
				|	РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ДанныеВебКабинетаСУО_ОН
				|ГДЕ
				|	ДанныеВебКабинетаСУО_ОН.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.КаталогПользователей)
				|	И ДанныеВебКабинетаСУО_ОН.Объект = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.КаталогПользователей)";
			
			РезультатЗапроса = Запрос.Выполнить();
			
			Если НЕ РезультатЗапроса.Пустой() Тогда
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				
				ВыборкаДетальныеЗаписи.Следующий();
				
				Если ТолькоПользователи Тогда

					ДанныеОбщегоКаталога = ОбщегоНазначенияСУ.JSONВДанные(ВыборкаДетальныеЗаписи.Данные.Получить());
					
					Для каждого ПользовательОбщегоКаталога Из ДанныеОбщегоКаталога.Пользователи Цикл
						
						Пользователь = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ПользовательОбщегоКаталога.Идентификатор));
						
						Если МассивПользователей.Найти(Пользователь) = Неопределено Тогда
							МассивПользователей.Добавить(Пользователь);
						КонецЕсли;
					
					КонецЦикла;
					
				Иначе
					
					КаталогПользователей.КаталогПользователей = ВыборкаДетальныеЗаписи.Данные;
					
				КонецЕсли;
					
			КонецЕсли;
			
		КонецЕсли;
		
		Если Права.Свойство("Обучение") И Права.Обучение Тогда
			
			// Получаем преподавателей учащегося
			//
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	ДанныеВебКабинетаСУО_ПН.Данные
				|ИЗ
				|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК ДанныеВебКабинетаСУО_ПН
				|ГДЕ
				|	ДанныеВебКабинетаСУО_ПН.Пользователь = &Пользователь
				|	И ДанныеВебКабинетаСУО_ПН.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.ПреподавателиПользователя)
				|	И ДанныеВебКабинетаСУО_ПН.Объект = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.ПреподавателиПользователя)";
				
			Запрос.Параметры.Вставить("Пользователь", ДанныеСессии.Пользователь);
				
			РезультатЗапроса = Запрос.Выполнить();
			
			Если НЕ РезультатЗапроса.Пустой() Тогда
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				
				ВыборкаДетальныеЗаписи.Следующий();
				
				Если ТолькоПользователи Тогда
					
					ДанныеПреподавателей = ОбщегоНазначенияСУ.JSONВДанные(ВыборкаДетальныеЗаписи.Данные.Получить());
					
					Для каждого Преподаватель Из ДанныеПреподавателей Цикл
						
						Пользователь = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(Преподаватель.Идентификатор));
						
						Если МассивПользователей.Найти(Пользователь) = Неопределено Тогда
							МассивПользователей.Добавить(Пользователь);
						КонецЕсли;
					
					КонецЦикла;
					
				Иначе
									
					КаталогПользователей.Преподаватели = ВыборкаДетальныеЗаписи.Данные;
					
				КонецЕсли;	
					
			КонецЕсли;
			
		КонецЕсли;
		
		// Организаторы
		//

		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СписокОбщихАдресатов.Данные КАК object
			|ИЗ
			|	РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК СписокОбщихАдресатов
			|ГДЕ
			|	СписокОбщихАдресатов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.Организатор)
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	СписокПользовательскихАдресатов.Данные
			|ИЗ
			|	РегистрСведений.ДанныеВебКабинетаСУО_ПН КАК СписокПользовательскихАдресатов
			|ГДЕ
			|	СписокПользовательскихАдресатов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.Организатор)
			|	И СписокПользовательскихАдресатов.Пользователь = &Пользователь";
		
		Запрос.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
	
		РезультатЗапроса = Запрос.Выполнить();
		
		Если НЕ РезультатЗапроса.Пустой() Тогда			
			
			Если ТолькоПользователи Тогда

				ТаблицаОрганизаторов = РезультатЗапроса.Выгрузить();

				Для каждого ДанныеОрганизатора Из ТаблицаОрганизаторов Цикл
				
					СвойстваОрганизатора = ОбщегоНазначенияСУ.JSONВДанные(ДанныеОрганизатора.object.Получить());
					
					Пользователь = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(СвойстваОрганизатора.Пользователь));
					
					Если МассивПользователей.Найти(Пользователь) = Неопределено Тогда
						МассивПользователей.Добавить(Пользователь);
					КонецЕсли;
					
				КонецЦикла;				
				
			Иначе
			
				КаталогПользователей.Организаторы = РезультатЗапроса.Выгрузить();
				
			КонецЕсли;		
				
		КонецЕсли;
		
	КонецЕсли;
	
	Если ТолькоПользователи Тогда
		
		Возврат МассивПользователей;
		
	Иначе
		
		Возврат КаталогПользователей;	
		
	КонецЕсли;	
	
КонецФункции

Функция ОжидатьЗавершенияЗаданияОбновленияЭлектронногоРесурса(ДанныеСессии, ДокументАктивности)
	
	Отбор = Новый Структура;
   	Отбор.Вставить("ИмяМетода", "ОбучениеСУО.ПриПрохожденииЭлектронногоРесурса");
   	Отбор.Вставить("Состояние", СостояниеФоновогоЗадания.Активно);
	Отбор.Вставить("Ключ", Строка(ДанныеСессии.Пользователь.УникальныйИдентификатор()));
   	ФоновыеЗаданияОбновления = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
	Если ФоновыеЗаданияОбновления.Количество() > 0 Тогда
		Попытка
			ФоновыеЗадания.ОжидатьЗавершения(ФоновыеЗаданияОбновления, 10);
		Исключение
			ЗаписьЖурналаРегистрации(
				НСТр("ru = 'Веб-кабинет. Получение данных'"),
				УровеньЖурналаРегистрации.Ошибка,
				,
				ДокументАктивности,
				НСТр("ru = 'Не дождались окончания выполнения фонового задания по обновлению данных. '") + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЕсли;	
	
КонецФункции

Функция РазрешитьМежсайтовыеЗапросыOPTIONS(Запрос)
	
	Ответ = Новый HTTPСервисОтвет(200);
	ДобавитьЗаголовкиМежсайтовогоЗапроса(Ответ, Истина);
	Возврат Ответ;
	
КонецФункции

Процедура ДобавитьЗаголовкиМежсайтовогоЗапроса(Ответ, ПроверитьРазрешение = Ложь)
	Если НЕ ПроверитьРазрешение ИЛИ Константы.РазрешитьЗапросыКСервисамСДругихДоменовСУ.Получить() = Истина Тогда
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	    Ответ.Заголовки.Вставить("Access-Control-Allow-Methods", "GET, PUT, POST, DELETE, HEAD, OPTIONS");
	    Ответ.Заголовки.Вставить("Access-Control-Allow-Credentials", "true");
	    Ответ.Заголовки.Вставить("Access-Control-Allow-Headers", "X-Requested-With, origin, content-type, accept");
	КонецЕсли;
КонецПроцедуры













    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДокументЗапросНаОбучениеСУО.Ссылка,
	ДокументЗапросНаОбучениеСУО.ПометкаУдаления,
	ДокументЗапросНаОбучениеСУО.Номер,
	ДокументЗапросНаОбучениеСУО.Дата,
	ДокументЗапросНаОбучениеСУО.Проведен,
	ДокументЗапросНаОбучениеСУО.ОбъектЗапроса,
	ДокументЗапросНаОбучениеСУО.Пользователь,
	ДокументЗапросНаОбучениеСУО.Информация,
	ДокументЗапросНаОбучениеСУО.ДатаПодачи,
	ДокументЗапросНаОбучениеСУО.ЗапросРассмотрен,
	ДокументЗапросНаОбучениеСУО.ОтветНаЗапрос,
	ДокументЗапросНаОбучениеСУО.Ответственный,
	ДокументЗапросНаОбучениеСУО.ДатаРассмотрения,
	ДокументЗапросНаОбучениеСУО.МоментВремени,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ДокументЗапросНаОбучениеСУО.ОбъектЗапроса) = ТИП(Справочник.КаталогПрограммОбученияСУО)
			ТОГДА &quot;Программа обучения&quot;
		ИНАЧЕ ДокументЗапросНаОбучениеСУО.ОбъектЗапроса.Вид
	КОНЕЦ КАК Тип,
	ВЫБОР
		КОГДА ДокументЗапросНаОбучениеСУО.ЗапросРассмотрен
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК Картинка
ИЗ
	Документ.ЗапросНаОбучениеСУО КАК ДокументЗапросНаОбучениеСУО
ГДЕ
	ДокументЗапросНаОбучениеСУО.Пользователь = &amp;Пользователь
	И ДокументЗапросНаОбучениеСУО.Проведен = ИСТИНА</queryText>
      <mainTable>Document.ЗапросНаОбучениеСУО</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>

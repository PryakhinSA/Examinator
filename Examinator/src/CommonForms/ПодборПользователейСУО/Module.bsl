&НаСервере
Процедура СформироватьПользователейНастроекДоступа()
	
	// Сбрасываем параметры
	
	УстановитьПараметрыНастроекДоступаПоУмолчанию();
	
	// Находим пользователей по свойствам пользователей ИБ
	
	ПользователиИБ = ПолучитьТаблицуПользователейИБ();
	
	СтрокиПоискаПользователейИБ = ТаблицаНастроекДоступа.НайтиСтроки(
		Новый Структура("ИспользоватьНастройку, ЭтоСвойствоПользователяИБ", Истина, Истина)); 
		
	ИдентификаторыПользователейИБ = Неопределено;
	
	Если СтрокиПоискаПользователейИБ.Количество() > 0 Тогда
		
		ИдентификаторыПользователейИБ = Новый Массив;
		
		СтруктураПоискаПользователейИБ = Новый Структура;	
		Для каждого СтрокиПоискаПользователяИБ Из СтрокиПоискаПользователейИБ Цикл
			СтруктураПоискаПользователейИБ.Вставить(СтрокиПоискаПользователяИБ.ИмяСвойства, СтрокиПоискаПользователяИБ.Значение); 
		КонецЦикла;
		
		СтрокиПользователейИБ = ПользователиИБ.НайтиСтроки(СтруктураПоискаПользователейИБ);
		
		Для каждого СтрокаПИБ Из СтрокиПользователейИБ Цикл
			ИдентификаторыПользователейИБ.Добавить(СтрокаПИБ.УникальныйИдентификатор);
		КонецЦикла;	
		
	КонецЕсли;
	
	Если ИдентификаторыПользователейИБ = Неопределено Тогда
		ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ИдентификаторыПользователейИБ", Новый Массив());
		ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ИдентификаторыПользователейИБЗаданы", Ложь);
	Иначе
		ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ИдентификаторыПользователейИБ", ИдентификаторыПользователейИБ);
		ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ИдентификаторыПользователейИБЗаданы", Истина);
	КонецЕсли;
	
	// Формируем параметры для поиска пользователей по данным ИБ
	
	СтрокиПоискаПользователейИБ = ТаблицаНастроекДоступа.НайтиСтроки(
		Новый Структура("ЭтоСвойствоПользователяИБ", Ложь)); 	
		
	Для каждого СтрокаПБД Из СтрокиПоискаПользователейИБ Цикл
		
		Если СтрокаПБД.ИмяСвойства = "ВходВПрограммуРазрешен" Тогда
			
			ИдентификаторыПользователейИБВходРазрешен = Новый Массив;
			ИдентификаторыПользователейИБ = Новый Массив;
			
			Если СтрокаПБД.ИспользоватьНастройку Тогда
				
				МассивАутентификаций = Новый Массив;
				МассивАутентификаций.Добавить("АутентификацияСтандартная");
				МассивАутентификаций.Добавить("АутентификацияОС");
				МассивАутентификаций.Добавить("АутентификацияOpenID");
				
				Для каждого Аутентификация Из МассивАутентификаций Цикл				
					НайденныеСтроки = ПользователиИБ.НайтиСтроки(Новый Структура(Аутентификация, Истина));
					Для каждого НайденнаяСтрока Из НайденныеСтроки Цикл
						Если ИдентификаторыПользователейИБВходРазрешен.Найти(НайденнаяСтрока.УникальныйИдентификатор) = Неопределено Тогда
							ИдентификаторыПользователейИБВходРазрешен.Добавить(НайденнаяСтрока.УникальныйИдентификатор);
						КонецЕсли;
					КонецЦикла;					
				КонецЦикла;
				
				Если СтрокаПБД.Значение Тогда				
					ИдентификаторыПользователейИБ = ИдентификаторыПользователейИБВходРазрешен;				
				Иначе				
					ИдентификаторыВсехПользователейИБ = ПользователиИБ.ВыгрузитьКолонку("УникальныйИдентификатор");				
					ИдентификаторыПользователейИБ = ОбщегоНазначенияКлиентСервер.СократитьМассив(ИдентификаторыВсехПользователейИБ, ИдентификаторыПользователейИБВходРазрешен);
				КонецЕсли;
				
			КонецЕсли;
			
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ВходВПрограммуРазрешенИдентификаторы", ИдентификаторыПользователейИБ);
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ВходВПрограммуРазрешенИдентификаторыЗаданы", СтрокаПБД.ИспользоватьНастройку);
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ОтобратьСПустымИдентификаторомИБ", НЕ СтрокаПБД.Значение);
			
		КонецЕсли;
		
		Если СтрокаПБД.ИмяСвойства = "ВходВВебКабинетРазрешен" Тогда
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ВходВВебКабинетРазрешенЗадано", СтрокаПБД.ИспользоватьНастройку);
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ВходВВебКабинетРазрешен", СтрокаПБД.Значение);
		КонецЕсли;
		
		Если СтрокаПБД.ИмяСвойства = "ЗакончилосьВремяДоступа" Тогда
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ЗакончилосьВремяДоступаЗадано", СтрокаПБД.ИспользоватьНастройку);
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ЗакончилосьВремяДоступа", СтрокаПБД.Значение);
		КонецЕсли;
		
		Если СтрокаПБД.ИмяСвойства = "ЗаполненаЭлектроннаяПочта" Тогда
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ЗаполненаЭлектроннаяПочтаЗадано", СтрокаПБД.ИспользоватьНастройку);
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ЗаполненаЭлектроннаяПочта", СтрокаПБД.Значение);
		КонецЕсли;
		
		Если СтрокаПБД.ИмяСвойства = "ЭлектроннаяПочта" Тогда
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ЭлектроннаяПочтаЗадано", СтрокаПБД.ИспользоватьНастройку);
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ЭлектроннаяПочта" , СтрокаПБД.Значение);
		КонецЕсли;
		
		Если СтрокаПБД.ИмяСвойства = "ГруппаДоступа" Тогда
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ГруппаДоступаЗадано", СтрокаПБД.ИспользоватьНастройку);
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ГруппаДоступа" , СтрокаПБД.Значение);
		КонецЕсли;

		Если СтрокаПБД.ИмяСвойства = "ГруппаПользователей" Тогда
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ГруппаПользователейЗадано", СтрокаПБД.ИспользоватьНастройку);
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ГруппаПользователей" , СтрокаПБД.Значение);
		КонецЕсли;

		Если СтрокаПБД.ИмяСвойства = "Недействителен" Тогда
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("НедействителенЗадано", СтрокаПБД.ИспользоватьНастройку);
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("Недействителен" , СтрокаПБД.Значение);
		КонецЕсли;

		Если СтрокаПБД.ИмяСвойства = "ПометкаУдаления" Тогда
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ПометкаУдаленияЗадано", СтрокаПБД.ИспользоватьНастройку);
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("ПометкаУдаления" , СтрокаПБД.Значение);
		КонецЕсли;
		
		Если СтрокаПБД.ИмяСвойства = "УстановленыНастройкиДоступа" Тогда
			ПользователиДоступ.Параметры.УстановитьЗначениеПараметра("УстановленыНастройкиДоступаЗадано", СтрокаПБД.ИспользоватьНастройку);

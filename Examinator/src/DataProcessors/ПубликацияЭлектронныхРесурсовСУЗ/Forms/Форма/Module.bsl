

#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Определяем тип публикации
	
	Если ТипЗнч(Параметры.ТипПубликации) = Тип("Строка") Тогда
		Параметры.ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ[Параметры.ТипПубликации];
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.ТипПубликации) Тогда
		
		Объект.ТипПубликации = Параметры.ТипПубликации;
		
		Если Объект.ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS Тогда
			
			ПутьКОбщемуКаталогу = ОбъектыСУЗПовтИсп.ПутьКОбщемуКаталогу();
			
			Если НЕ ЗначениеЗаполнено(ПутьКОбщемуКаталогу) Тогда
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОбщегоНазначенияСУПовтИсп.ТекстОНеобходимостиНастроитьОбщийКаталог(),,,,Отказ);
				
				Возврат;
				
			КонецЕсли;				
			
		КонецЕсли;		
		
	Иначе
		
		Объект.ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.HTML;
		
		ЭлектронныеРесурсыПереопределяемый.ПриОпределенииТипПубликацииПоУмолчанию(Объект.ТипПубликации);		
		
	КонецЕсли;	
	
	// Заполняем ТЧ ЭлектронныеРесурсы
	
	ТаблицаЗаполняемыхЭР = Новый ТаблицаЗначений;
	ТаблицаЗаполняемыхЭР.Колонки.Добавить("ЭлектронныйРесурс", Новый ОписаниеТипов("СправочникСсылка.СводыЗнанийСУЗ"));
	ТаблицаЗаполняемыхЭР.Колонки.Добавить("Тип", Новый ОписаниеТипов("ПеречислениеСсылка.ТипыЭлектронныхРесурсовСУЗ"));
	
	Если Параметры.ЭлектронныеРесурсы <> Неопределено
		И ТипЗнч(Параметры.ЭлектронныеРесурсы) = Тип("Массив") Тогда
		
		Для каждого Элемент Из Параметры.ЭлектронныеРесурсы Цикл
		
			СвойстваЭлемента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Элемент, "ЭтоГруппа, ПометкаУдаления, Тип");
			
			Если СвойстваЭлемента.ПометкаУдаления Тогда
				Продолжить;
			КонецЕсли;
			
			Если СвойстваЭлемента.ЭтоГруппа Тогда
		
				Запрос = Новый Запрос;
				Запрос.Текст = 
					"ВЫБРАТЬ РАЗЛИЧНЫЕ
					|	СводыЗнанийСУЗ.Ссылка КАК ЭлектронныйРесурс,
					|	СводыЗнанийСУЗ.Тип
					|ИЗ
					|	Справочник.СводыЗнанийСУЗ КАК СводыЗнанийСУЗ
					|ГДЕ
					|	СводыЗнанийСУЗ.ЭтоГруппа = ЛОЖЬ
					|	И СводыЗнанийСУЗ.ПометкаУдаления = ЛОЖЬ
					|	И СводыЗнанийСУЗ.Ссылка В ИЕРАРХИИ(&Группа)";
				
				Запрос.УстановитьПараметр("Группа", Элемент);
				
				РезультатЗапроса = Запрос.Выполнить();
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
					НоваяСтрокаТЭР = ТаблицаЗаполняемыхЭР.Добавить();
					НоваяСтрокаТЭР.ЭлектронныйРесурс = ВыборкаДетальныеЗаписи.ЭлектронныйРесурс;
					НоваяСтрокаТЭР.Тип = ВыборкаДетальныеЗаписи.Тип;
				КонецЦикла;
	
			Иначе
				
				Если ТипЗнч(Элемент) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда					
					НоваяСтрокаТЭР = ТаблицаЗаполняемыхЭР.Добавить();
					НоваяСтрокаТЭР.ЭлектронныйРесурс = Элемент;
					НоваяСтрокаТЭР.Тип = СвойстваЭлемента.Тип;
				КонецЕсли;
				
			КонецЕсли;
		
		КонецЦикла;
		
		
	Иначе
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	СводыЗнанийСУЗ.Ссылка,
			|	СводыЗнанийСУЗ.Тип
			|ИЗ
			|	Справочник.СводыЗнанийСУЗ КАК СводыЗнанийСУЗ
			|ГДЕ
			|	СводыЗнанийСУЗ.ЭтоГруппа = ЛОЖЬ
			|	И СводыЗнанийСУЗ.ПометкаУдаления = ЛОЖЬ";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НоваяСтрокаТЭР = ТаблицаЗаполняемыхЭР.Добавить();
			НоваяСтрокаТЭР.ЭлектронныйРесурс = ВыборкаДетальныеЗаписи.Ссылка;
			НоваяСтрокаТЭР.Тип = ВыборкаДетальныеЗаписи.Тип;
		КонецЦикла;
		
	КонецЕсли;
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(СодержаниеСУЗ.Ссылка) КАК КоличествоЭлементов,
		|	СодержаниеСУЗ.Владелец КАК ЭлектронныйРесурс
		|ИЗ
		|	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
		|ГДЕ
		|	СодержаниеСУЗ.Владелец В(&МассивЭлектронныхРесурсов)
		|	И СодержаниеСУЗ.ПометкаУдаления = ЛОЖЬ
		|	И СодержаниеСУЗ.ЭтоГруппа = ЛОЖЬ
		|
		|СГРУППИРОВАТЬ ПО
		|	СодержаниеСУЗ.Владелец";
	
	Запрос.УстановитьПараметр("МассивЭлектронныхРесурсов", ТаблицаЗаполняемыхЭР.ВыгрузитьКолонку("ЭлектронныйРесурс"));
	
	ТаблицаЭлементовСодержания = Запрос.Выполнить().Выгрузить();
	
	
	
	Запрос = Новый Запрос;
	
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("ВнешнийИсточник", ТаблицаЗаполняемыхЭР);
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ТаблицаЭР.ЭлектронныйРесурс,
		|	ТаблицаЭР.Тип
		|ПОМЕСТИТЬ ТаблицаЭР
		|ИЗ
		|	&ВнешнийИсточник КАК ТаблицаЭР
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ТаблицаЭР.ЭлектронныйРесурс";
	
	Запрос.Выполнить();
	
		
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаЭР.ЭлектронныйРесурс КАК ЭлектронныйРесурс,
		|	ТаблицаЭР.Тип КАК Тип,
		|	Публикации.РазмещениеКнопкиВыхода КАК РазмещениеКнопкиВыхода,
		|	Публикации.Период КАК ДатаПубликации
		|ИЗ
		|	ТаблицаЭР КАК ТаблицаЭР
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПубликацииЭлектронныхРесурсовСУЗ.СрезПоследних КАК Публикации
		|		ПО (Публикации.ЭлектронныйРесурс = ТаблицаЭР.ЭлектронныйРесурс)";
		
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		НоваяСтрока = Объект.ЭлектронныеРесурсы.Добавить();
		НоваяСтрока.ЭлектронныйРесурс = ВыборкаДетальныеЗаписи.ЭлектронныйРесурс;
		НоваяСтрока.ЭтоТест = ?(ВыборкаДетальныеЗаписи.Тип = Перечисления.ТипыЭлектронныхРесурсовСУЗ.Тест, Истина, Ложь);
		
		СтрокаТКЭ = ТаблицаЭлементовСодержания.Найти(ВыборкаДетальныеЗаписи.ЭлектронныйРесурс, "ЭлектронныйРесурс");
		
		НоваяСтрока.НесколькоЭлементов = ?(
			НЕ НоваяСтрока.ЭтоТест И СтрокаТКЭ <> Неопределено И СтрокаТКЭ.КоличествоЭлементов > 1, Истина, Ложь); 
			
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.РазмещениеКнопкиВыхода)
				И НЕ НоваяСтрока.НесколькоЭлементов Тогда
			НоваяСтрока.РазмещениеКнопкиВыхода = ВыборкаДетальныеЗаписи.РазмещениеКнопкиВыхода;
		Иначе
			НоваяСтрока.РазмещениеКнопкиВыхода = Перечисления.ВариантыРазмещенияКнопкиВыходаСУЗ.ПустаяСсылка();
		КонецЕсли;	
		
	КонецЦикла;
	
	// Устанавливаем видимость элементов
	
	Элементы.ТипПубликации.ТолькоПросмотр = ЗначениеЗаполнено(Параметры.ТипПубликации);
	
	УстановитьДоступностьЭлементовФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	#Если НЕ ВебКлиент Тогда
		
	Если СтандартныеПодсистемыКлиентПовтИсп.ПараметрыРаботыКлиента().ИнформационнаяБазаФайловая Тогда
		МожноПубликоватьВКаталогНаКлиенте = Истина;
	КонецЕсли;
		
	#КонецЕсли
	
	УстановитьДоступностьЭлементовФормы(); // Необходимо, так как есть сохраняемые реквизиты
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии()
	
	Если ЗначениеЗаполнено(ИдентификаторЗадания) Тогда
		ОтменитьПроцессПубликации();
	КонецЕсли;
	
	Оповестить("ЭлектронныйРесурсОпубликован");
	
КонецПроцедуры

#КонецОбласти



#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Устанавливаем реквизиты
	//
	
	ЭтоПолныйИнтерфейс = ПолучитьФункциональнуюОпцию("ПолныйИнтерфейсСУО");
	ЭтоОбразовательнаяОрганизация = ПолучитьФункциональнуюОпцию("ОбразовательнаяОрганизацияОО");
	ИспользуютсяСлушатели = ПолучитьФункциональнуюОпцию("ИспользоватьСлушателейСУО");
	
	// Список группировок
	//
	
	Элементы.ГруппировкаСписка.СписокВыбора.Добавить("", НСтр("ru = 'Без группировки'"));
	
	Если ЭтоПолныйИнтерфейс Тогда
		
		Элементы.ГруппировкаСписка.СписокВыбора.Добавить("ГодПроведения", НСтр("ru = 'Год'"));
		ЭлементГруппировки = Список.Группировка.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
		ЭлементГруппировки.Использование = Ложь;
		ЭлементГруппировки.Поле = Новый ПолеКомпоновкиДанных("ГодПроведения");
		
		Элементы.ГруппировкаСписка.СписокВыбора.Добавить("МесяцПроведения", НСтр("ru = 'Месяц'"));
		ЭлементГруппировки = Список.Группировка.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
		ЭлементГруппировки.Использование = Ложь;
		ЭлементГруппировки.Поле = Новый ПолеКомпоновкиДанных("МесяцПроведения");
		
		Элементы.ГруппировкаСписка.СписокВыбора.Добавить("Вид", НСтр("ru = 'Вид'"));
		ЭлементГруппировки = Список.Группировка.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
		ЭлементГруппировки.Использование = Ложь;
		ЭлементГруппировки.Поле = Новый ПолеКомпоновкиДанных("Вид");
		
		Если ПолучитьФункциональнуюОпцию("ИспользоватьКаталогОбученийСУО") Тогда
		
			Элементы.ГруппировкаСписка.СписокВыбора.Добавить("Сценарий", НСтр("ru = 'Обучение'"));
			ЭлементГруппировки = Список.Группировка.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
			ЭлементГруппировки.Использование = Ложь;
			ЭлементГруппировки.Поле = Новый ПолеКомпоновкиДанных("Сценарий");		
			
		КонецЕсли;
			
		Если НЕ ИспользуютсяСлушатели Тогда
		
			Элементы.ГруппировкаСписка.СписокВыбора.Добавить("ПроведениеПрограммыОбучения", НСтр("ru = 'Программа'"));
			ЭлементГруппировки = Список.Группировка.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
			ЭлементГруппировки.Использование = Ложь;
			ЭлементГруппировки.Поле = Новый ПолеКомпоновкиДанных("ПроведениеПрограммыОбучения");			
			
		КонецЕсли;
		
		Если ИспользуютсяСлушатели Тогда
		
			Элементы.ГруппировкаСписка.СписокВыбора.Добавить("ПрограммаОбучения", НСтр("ru = 'Программа обучения УУЦ'"));
			ЭлементГруппировки = Список.Группировка.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
			ЭлементГруппировки.Использование = Ложь;
			ЭлементГруппировки.Поле = Новый ПолеКомпоновкиДанных("ПрограммаОбучения");			
			
		КонецЕсли;
		
	Иначе		
		
		Элементы.ГруппировкаСписка.СписокВыбора.Добавить("Сценарий", НСтр("ru = 'Обучение'")); // Группировка по сценарию, но с другим названием.
		ЭлементГруппировки = Список.Группировка.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
		ЭлементГруппировки.Использование = Ложь;
		ЭлементГруппировки.Поле = Новый ПолеКомпоновкиДанных("Сценарий");		
		
	КонецЕсли;
	
	// Восстанавливаем настройки
	//
	
	ДанныеНастроек = ХранилищеСистемныхНастроек.Загрузить(ИмяФормы+"/ТекущиеДанные");
	
	Если ДанныеНастроек <> Неопределено Тогда
		
		ГруппировкаСписка = ДанныеНастроек.Получить("ГруппировкаСписка");
		
		УстановитьГруппировкуСписка();
		
		ОтборВид = ДанныеНастроек.Получить("ОтборВид");
		
		УстановитьБыстрыйОтборСписка("Вид", ОтборВид);
		
		ОтборПериод = ДанныеНастроек.Получить("ОтборПериод");
		
		УстановитьБыстрыйОтборСписка("Период", ОтборПериод);
		
		ОтборСтатус = ДанныеНастроек.Получить("ОтборСтатус");
		
		УстановитьБыстрыйОтборСписка("Статус", ОтборСтатус);
		
	КонецЕсли;
	
	// Начальные параметры списка
	
	Список.Параметры.УстановитьЗначениеПараметра("ГруппаПроведенийОбучения", Неопределено);
	Список.Параметры.УстановитьЗначениеПараметра("ПоказатьВсеПроведения", Истина);
	Список.Параметры.УстановитьЗначениеПараметра("ЭтотДень", ТекущаяДатаСеанса());
	
	УстановитьПараметрыГрупп();
	
	// Изменяем наименования элементов согласно функциональному профилю
	//
	
	Если ЭтоПолныйИнтерфейс Тогда
		
		Элементы.Дисциплина.Видимость = Ложь;
		Элементы.Вид.Видимость = Истина;
		
		Элементы.ГруппаСлушателей.Видимость = ИспользуютсяСлушатели;
		Элементы.ПрограммаОбучения.Видимость = ИспользуютсяСлушатели;
		
		Если ИспользуютсяСлушатели Тогда
			Элементы.ГруппаСлушателей.Заголовок = НСтр("ru = 'Группа слушателей УУЦ'");
			Элементы.ПрограммаОбучения.Заголовок = НСтр("ru = 'Программа обучения УУЦ'");
		КонецЕсли;
		
	Иначе
		
		Элементы.Дисциплина.Видимость = ЭтоОбразовательнаяОрганизация;				
		Элементы.ГруппаСлушателей.Видимость = Ложь;
		Элементы.ПрограммаОбучения.Видимость = Ложь;
		Элементы.Вид.Видимость = Ложь;
		Элементы.ГодПроведения.Видимость = Ложь;
		Элементы.МесяцПроведения.Видимость = Ложь;
		Элементы.ДоступноВнешнимПользователям.Видимость = Ложь;
		Элементы.Открытое.Видимость = Ложь;
        Элементы.Автозачисление.Видимость = Ложь;
		Элементы.ТребуетсяЗаявка.Видимость = Ложь;
		Элементы.ДатаОткрытияЗаписи.Видимость = Ложь;
		Элементы.ДатаЗакрытияЗаписи.Видимость = Ложь;
		Элементы.ПроведениеПрограммыОбучения.Видимость = Ложь;
		Элементы.Сценарий.Видимость = Ложь;
		Элементы.ОткрытоДляВсех.Видимость = Ложь;
		Элементы.СхемаПроведения.Видимость = Ложь;
		Элементы.НаОсновеМероприятия.Видимость = Ложь;
		Элементы.НаОсновеЭлектронногоРесурса.Видимость = Ложь;		
		Элементы.МаксимальноеКоличествоУчастников.Видимость = Ложь;		
		
		
	КонецЕсли;
			
	// Формируем команды
	
	СформироватьКомандыСозданияПроведенийПоВиду();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановитьПараметрыСписка();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОбновитьСписокМероприятий" Тогда
		ОбновитьСписокИГруппыНаКлиенте();
	КонецЕсли;
	
	Если ИмяСобытия = "ОбновленыВидыОбучения"
		ИЛИ ИмяСобытия = "ЗаписьМероприятия" Тогда
		
		СформироватьКомандыСозданияПроведенийПоВиду();
		
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийЭлементовШапкиФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура ОтборСтатусПриИзменении(Элемент)
	УстановитьБыстрыйОтборСписка("Статус", ОтборСтатус);
КонецПроцедуры

&НаКлиенте
Процедура ОтборПериодПриИзменении(Элемент)
	УстановитьБыстрыйОтборСписка("Период", ОтборПериод);
КонецПроцедуры

&НаКлиенте
Процедура ОтборВидМероприятияПриИзменении(Элемент)
	УстановитьБыстрыйОтборСписка("Вид", ОтборВид);
КонецПроцедуры

&НаКлиенте
Процедура ГруппировкаСпискаПриИзменении(Элемент)
	УстановитьГруппировкуСписка();
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиКомандФормы

// ОБРАБОТЧИКИ КОМАНД ФОРМЫ


#Область ОбработчикиСобытийЭлементовТаблицыФормыУчастники

&НаКлиенте
Процедура УчастникиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;		
	Если Элемент.ТекущиеДанные <> Неопределено Тогда
		Если Поле <> неопределено И (Поле.Имя = "УчастникиЗавершеноВПроцентах" ИЛИ Поле.Имя = "УчастникиОценка") Тогда
			
			УправлениеОбучениемСУОКлиент.РезультатыЗаданийУчастника(Элемент.ТекущиеДанные.Ссылка);
			
		ИначеЕсли Поле <> неопределено И Поле.Имя = "УчастникиМожетУчиться" Тогда
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ВозможностиУчитьсяПослеЗакрытия", ЭтотОбъект);
			ПараметрыФормыВУ = Новый Структура();
			ПараметрыФормыВУ.Вставить("Пользователь", Элемент.ТекущиеДанные.Пользователь);
			
			Если ЭлектронноДистанционное
				И ЗначениеЗаполнено(Объект.ДатаНачалаДоступа) Тогда
				ПараметрыФормыВУ.Вставить("НачалоПериода", Объект.ДатаНачалаДоступа);
			КонецЕсли;				
			
			Если ЭлектронноДистанционное
				И ЗначениеЗаполнено(Объект.ДатаКонтроля) Тогда
				ПараметрыФормыВУ.Вставить("КонецПериода", Объект.ДатаКонтроля);
			КонецЕсли;
			
			Если НЕ ЭлектронноДистанционное
				И ЗначениеЗаполнено(Объект.ДатаНачалаПроведения) Тогда
				ПараметрыФормыВУ.Вставить("НачалоПериода", Объект.ДатаНачалаПроведения);
			КонецЕсли;

			Если НЕ ЭлектронноДистанционное
				И ЗначениеЗаполнено(Объект.ДатаОкончанияПроведения) Тогда
				ПараметрыФормыВУ.Вставить("КонецПериода", Объект.ДатаОкончанияПроведения);
			КонецЕсли;
			
			ОткрытьФорму("РегистрСведений.ВозможностиУчитьсяСУО.Форма.НастройкаВозможностиУчиться",
				ПараметрыФормыВУ,,,,,ОписаниеОповещения);
				
								
		ИначеЕсли Поле <> неопределено И Поле.Имя = "УчастникиДобавленоВремениСтрока" Тогда
			
			НачатьДобавлениеВремениУчастнику();
			
		Иначе
			
			ПоказатьЗначение(,Элемент.ТекущиеДанные.Пользователь);			
			
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВозможностиУчитьсяПослеЗакрытия(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	УстановитьДатыВозможностиУчиться(ЭтотОбъект);

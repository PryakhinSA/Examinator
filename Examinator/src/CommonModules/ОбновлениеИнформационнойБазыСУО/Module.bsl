// Вызывается при первоначальном заполнении информационной базы.
//
Процедура ВыполнитьЗаполнениеПредопределеннымиДанными(Параметр1 = Неопределено, Параметр2 = Неопределено) Экспорт

	// Заполняем начальные данные СУО
	
	ДвоичныеДанные = ПолучитьОбщийМакет(Метаданные.ОбщиеМакеты.ДанныеНачальногоЗаполненияСУО);
	
	ПутьКВременномуФайлуXML = ПолучитьИмяВременногоФайла(".xml");
	
	ДвоичныеДанные.Записать(ПутьКВременномуФайлуXML);
	
	ЧтениеXML = Новый ЧтениеXML();
	ЧтениеXML.ОткрытьФайл(ПутьКВременномуФайлуXML);		
	
	Пока ЧтениеXML.Прочитать() Цикл
		
		Пока ВозможностьЧтенияXML(ЧтениеXML) Цикл 
			
			ТекущийОбъект = ПрочитатьXML(ЧтениеXML);
			ТекущийОбъект.ОбменДанными.Загрузка = Истина;
			ТекущийОбъект.Записать();
			
		КонецЦикла;	
		
	КонецЦикла;	
	
	ЧтениеXML.Закрыть();  		
	

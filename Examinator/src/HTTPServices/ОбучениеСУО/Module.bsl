		ИмяФайла =    ДанныеФайла.ПолноеНаименованиеВерсии + "." + ДанныеФайла.Расширение;				
		
	Иначе
		
		ВладелецФайла = Неопределено;
		
		Если ТипВладельца = "userActivity" Тогда
			ВладелецФайла = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));
		КонецЕсли;
		
		Если ТипВладельца = "userTask" Тогда
			ВладелецФайла = Документы.ПопыткаВыполненияЗаданияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));
		КонецЕсли;		
		
		Если ТипВладельца = "message" Тогда
			ВладелецФайла = Документы.СообщениеСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));
			ШаблонСообщения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВладелецФайла, "Шаблон");
			Если ЗначениеЗаполнено(ШаблонСообщения) И ТипЗнч(ШаблонСообщения) = Тип("СправочникСсылка.ШаблоныСообщенийСУО") Тогда
				ВладелецФайла = ШаблонСообщения; // Ищем файлы в шаблоне
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ВладелецФайла) Тогда
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;
		
		ИмяСправочникаХраненияФайлов = РаботаСФайламиСлужебный.ИмяСправочникаХраненияФайлов(ВладелецФайла);		
		Файл = Справочники[ИмяСправочникаХраненияФайлов].ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторФайла));
		ДанныеФайла = ПрисоединенныеФайлы.ПолучитьДанныеФайла(Файл,,Ложь,Ложь);
		ИмяФайла = ДанныеФайла.ИмяФайла;				
			
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ИмяФайла) Тогда
		Возврат ОтветКлиентуJSON("fileNotFound");
	Иначе
		Возврат ОтветКлиентуJSON(,ИмяФайла);
	КонецЕсли;
	
КонецФункции

Функция ПолучитьАдресФайлаPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем ссылку на файл
	//
	
	ТипВладельца           = Запрос.ПараметрыURL.Получить("ТипВладельца");
	ИдентификаторВладельца = Запрос.ПараметрыURL.Получить("ИдентификаторВладельца");
	ИдентификаторФайла     = Запрос.ПараметрыURL.Получить("ИдентификаторФайла");	
	Пользователь           = ДанныеСессии.Пользователь;
	НастройкиКлиента       = ОбщегоНазначенияСУ.JSONВДанные(Запрос.ПолучитьТелоКакСтроку());
	АдресФайла             = Неопределено;
	
	// Примечание: в УдалитьФайлPOST аналогичный алгоритм поиска файла
	
	Если ТипВладельца = "common" Тогда
		
		Файл = Справочники.Файлы.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторФайла));
		
		ДанныеФайла = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайла(Файл);
		
		Если РаботаСФайламиСлужебный.ХранениеФайловВТомахНаДиске() Тогда
			
			Запрос = Новый Запрос;
			
			Запрос.Текст =
			"ВЫБРАТЬ
			|	ВерсииФайлов.ПутьКФайлу КАК ПутьКФайлу,
			|	ВерсииФайлов.Том КАК Том
			|ИЗ
			|	Справочник.ВерсииФайлов КАК ВерсииФайлов
			|ГДЕ
			|	ВерсииФайлов.Ссылка = &Версия";
			
			Запрос.Параметры.Вставить("Версия", ДанныеФайла.Версия);
			
			ДанныеФайлаПутьКФайлу = "";
			
			Выборка = Запрос.Выполнить().Выбрать();
			
			Если Выборка.Следующий() Тогда
				ДанныеФайлаПутьКФайлу = Выборка.ПутьКФайлу;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ДанныеФайлаПутьКФайлу) Тогда 
			
				АдресФайла = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(НастройкиКлиента.baseFiles);
				АдресФайла = АдресФайла + ДанныеФайлаПутьКФайлу;
				
				АдресФайла = ОбщегоНазначенияСУКлиентСервер.ПривестиСлэши(АдресФайла); 
				
			КонецЕсли;
				
		Иначе
			
			АдресФайла = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(НастройкиКлиента.baseDesktop);			
			АдресФайла = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(АдресФайла + ИдентификаторФайла);
			АдресФайла = ВебКабинетСУО.ПолноеИмяОбщегоФайлаВебКабинета(Файл, АдресФайла, ДанныеФайла);
					
		КонецЕсли;		
		
	Иначе
		
		ВладелецФайла = Неопределено;
		
		Если ТипВладельца = "userActivity" Тогда
			ВладелецФайла = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));
		КонецЕсли;
		
		Если ТипВладельца = "userTask" Тогда
			ВладелецФайла = Документы.ПопыткаВыполненияЗаданияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));
		КонецЕсли;		
		
		Если ТипВладельца = "message" Тогда
			ВладелецФайла = Документы.СообщениеСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));
			ШаблонСообщения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВладелецФайла, "Шаблон");
			Если ЗначениеЗаполнено(ШаблонСообщения) И ТипЗнч(ШаблонСообщения) = Тип("СправочникСсылка.ШаблоныСообщенийСУО") Тогда
				ВладелецФайла = ШаблонСообщения; // Ищем файлы в шаблоне
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ВладелецФайла) Тогда
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;
		
		ИмяСправочникаХраненияФайлов = РаботаСФайламиСлужебный.ИмяСправочникаХраненияФайлов(ВладелецФайла);
		
		Файл = Справочники[ИмяСправочникаХраненияФайлов].ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторФайла));

		Если РаботаСФайламиСлужебный.ХранениеФайловВТомахНаДиске() Тогда

			ПутьКФайлуВТоме = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Файл, "ПутьКФайлу");
			
			Если ЗначениеЗаполнено(ПутьКФайлуВТоме) Тогда 
			
				АдресФайла = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(НастройкиКлиента.baseFiles);
				АдресФайла = АдресФайла + ПутьКФайлуВТоме;
				
				АдресФайла = ОбщегоНазначенияСУКлиентСервер.ПривестиСлэши(АдресФайла); 
				
			КонецЕсли;			
			
		Иначе
		
			ДанныеФайла = ПрисоединенныеФайлы.ПолучитьДанныеФайла(Файл,,Ложь,Ложь);
			
			АдресФайла = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(НастройкиКлиента.baseDesktop);			
			АдресФайла = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(АдресФайла + ИдентификаторВладельца);
			АдресФайла = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(АдресФайла + ИдентификаторФайла);
			АдресФайла = АдресФайла + ДанныеФайла.ИмяФайла;
			
		КонецЕсли;
			
			
	КонецЕсли;
	
	Если АдресФайла = Неопределено Тогда
		Возврат ОтветКлиентуJSON("fileNotFound");
	Иначе
		Возврат ОтветКлиентуJSON(,АдресФайла);
	КонецЕсли;
	
КонецФункции


#Если Сервер ИЛИ ТолстыйКлиентОбычноеПриложение ИЛИ ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции

// ОСНОВНОЕ	
	
Функция Отменено(Знач ПрохождениеОбучения) Экспорт
	
	// Получаем необходимые данные
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТребуемыеДанные = Новый Структура;
	ТребуемыеДанные.Вставить("ПроведениеОбучения", "ПроведениеОбучения");
	ТребуемыеДанные.Вставить("ПроведениеОбученияПроведено", "ПроведениеОбучения.Проведен");
	ТребуемыеДанные.Вставить("Отменено", "Отменено");
	ТребуемыеДанные.Вставить("РодительскоеПрохождение", "РодительскоеПрохождение");
	ТребуемыеДанные.Вставить("ПрохождениеПрограммыОбучения", "ПрохождениеПрограммыОбучения");
	ТребуемыеДанные.Вставить("Пользователь", "Пользователь");
	ТребуемыеДанные.Вставить("ПроведениеПрограммыОбучения", "ПроведениеОбучения.ПроведениеПрограммыОбучения");
	ТребуемыеДанные.Вставить("ПроведениеПрограммыОбученияПроведено", "ПроведениеОбучения.ПроведениеПрограммыОбучения.Проведен");
	ТребуемыеДанные.Вставить("СтатусПроведенияОбучения", "ПроведениеОбучения.Статус");
	ТребуемыеДанные.Вставить("ПрохождениеПрограммыОбученияПроведено", "ПрохождениеПрограммыОбучения.Проведен");
	ТребуемыеДанные.Вставить("СтатусПрохожденияПрограммыОбучения", "ПрохождениеПрограммыОбучения.Статус");
	
	Если ТипЗнч(ПрохождениеОбучения) = Тип("ДокументСсылка.ПрохождениеОбученияСУО") Тогда
		ДанныеОПрохождении = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, ТребуемыеДанные);
	Иначе
		ДанныеОПрохождении = Новый Структура();
		Для каждого ЭлементСтруктуры Из ТребуемыеДанные Цикл
			Если Найти(ЭлементСтруктуры.Значение, ".") > 0 Тогда
				МассивЗначений = ОбщегоНазначенияСУКлиентСервер.РасщепитьСтроку(ЭлементСтруктуры.Значение, ".");
				Если МассивЗначений.Количество() = 2 Тогда
					ПодчиненноеЗначение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
						ПрохождениеОбучения[МассивЗначений[0]], МассивЗначений[1]);					
				ИначеЕсли МассивЗначений.Количество() = 3 Тогда
					ПодчиненноеЗначение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
						ПрохождениеОбучения[МассивЗначений[0]], МассивЗначений[1]+"."+МассивЗначений[2]);						
				Иначе
					ВызватьИсключение НСтр("ru = 'Невозможно получить данные'");
				КонецЕсли;
				ДанныеОПрохождении.Вставить(ЭлементСтруктуры.Ключ, ПодчиненноеЗначение);
			Иначе
				ДанныеОПрохождении.Вставить(ЭлементСтруктуры.Ключ, ПрохождениеОбучения[ЭлементСтруктуры.Значение]); 
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	// Отменено
	
	Если ДанныеОПрохождении.Отменено Тогда		
		Возврат Истина;		
	КонецЕсли;
	
	// Родительское прохождение
	
	Если ЗначениеЗаполнено(ДанныеОПрохождении.РодительскоеПрохождение) Тогда
		
		РодительскоеПрохождениеОтменено = Документы.ПрохождениеОбученияСУО.Отменено(
			ДанныеОПрохождении.РодительскоеПрохождение);
			
		Если РодительскоеПрохождениеОтменено Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	// Прохождение программы обучения
	
	Если ЗначениеЗаполнено(ДанныеОПрохождении.ПрохождениеПрограммыОбучения) Тогда
		Если НЕ ДанныеОПрохождении.ПрохождениеПрограммыОбученияПроведено Тогда
			Возврат Истина;
		КонецЕсли;
		Если ДанныеОПрохождении.СтатусПрохожденияПрограммыОбучения = Перечисления.СтатусыПроведенияОбъектовСУО.Отменено Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;
	
	// Проведение обучения
	
	Если ДанныеОПрохождении.СтатусПроведенияОбучения = Перечисления.СтатусыПроведенияОбъектовСУО.Отменено Тогда
		Возврат Истина
	КонецЕсли;
	
	Если НЕ ДанныеОПрохождении.ПроведениеОбученияПроведено Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Проведение программы обучения
	
	Если ЗначениеЗаполнено(ДанныеОПрохождении.ПроведениеПрограммыОбучения)
		И НЕ ДанныеОПрохождении.ПроведениеПрограммыОбученияПроведено Тогда
		Возврат Истина;
	КонецЕсли;
		
	Возврат Ложь;	
	
КонецФункции

// Определяет, является ли обучение актуальным.
// Актуальное обучение - это такое, которое видно в активных.
// Если оно актуально, это не значит, что в нем доступны все
// ресурсы.
// 
Функция Актуально(Знач ПрохождениеОбучения, СтатусПроцессаОбучения = Неопределено) Экспорт
		
	Если СтатусПроцессаОбучения = Неопределено Тогда	
		СтатусПроцессаОбучения = СтатусПроцессаОбучения(ПрохождениеОбучения);
	КонецЕсли;
	
	МассивАктуальныхСтатусов = СтатусыАктуально();
	
	Если МассивАктуальныхСтатусов.Найти(СтатусПроцессаОбучения) = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция СтатусыАктуально()
	
	Статусы = Новый Массив;
	Статусы.Добавить(Перечисления.СтатусыПроцессаОбученияСУО.Запланировано);
	Статусы.Добавить(Перечисления.СтатусыПроцессаОбученияСУО.Новое);
	Статусы.Добавить(Перечисления.СтатусыПроцессаОбученияСУО.Активно);
	Статусы.Добавить(Перечисления.СтатусыПроцессаОбученияСУО.Проверяется);
	Статусы.Добавить(Перечисления.СтатусыПроцессаОбученияСУО.ВозвращеноНаДоработку);	
	
	Возврат Статусы;	
	
КонецФункции

Функция ЕстьАктуальныеУчастники(Знач ПроведениеОбучения) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	УчастникиОбученияСУО.Пользователь КАК Пользователь
		|ИЗ
		|	РегистрСведений.УчастникиОбученияСУО КАК УчастникиОбученияСУО
		|ГДЕ
		|	УчастникиОбученияСУО.ПроведениеОбучения = &ПроведениеОбучения
		|	И УчастникиОбученияСУО.СтатусПроцессаОбучения В(&АктуальныеСтатусы)";
	
	Запрос.УстановитьПараметр("АктуальныеСтатусы", СтатусыАктуально());
	Запрос.УстановитьПараметр("ПроведениеОбучения", ПроведениеОбучения);
	
	Возврат НЕ Запрос.Выполнить().Пустой();
	
КонецФункции
	
// Определяет, является ли обучение пройденным.
// Пройденное обучение - это такое обучение, которое
// реально проходилось. Например, Автомат или Не допуск
// не позволяют считать обучение пройденным.
//
Функция Пройдено(Знач СтатусПрохождения) Экспорт
	
	Если СтатусПрохождения = Перечисления.СтатусыПрохожденияОбъектовСУО.Завершил
		ИЛИ СтатусПрохождения = Перечисления.СтатусыПрохожденияОбъектовСУО.НеЗавершил Тогда
		
		Возврат Истина;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ЗаданияДоступны(ПрохождениеОбучения, ПроведениеОбучения = Неопределено,  Сценарий = Неопределено, ВидОбучения = Неопределено, СтатусПроцессаОбучения = Неопределено, ВариантПродолжительности = Неопределено, ДатаНачалаПрохождения = Неопределено) Экспорт
	
	Если СтатусПроцессаОбучения = Неопределено Тогда	
		СтатусПроцессаОбучения = СтатусПроцессаОбучения(ПрохождениеОбучения);
	КонецЕсли;	
	
	Если СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.Запланировано
		ИЛИ СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.НеДопущен Тогда				
		Возврат Ложь; // Запланированное обучение всегда не доступно для прохождения
	КонецЕсли;	
	
	Если ПроведениеОбучения = Неопределено Тогда
		ПроведениеОбучения = ПроведениеОбучения(ПрохождениеОбучения);
	КонецЕсли;		
	
	Если Сценарий = Неопределено Тогда
		Сценарий = Документы.ПроведениеОбученияСУО.СценарийОбучения(ПроведениеОбучения);
	КонецЕсли;	
	
	Если ВидОбучения = Неопределено Тогда
		ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(ПроведениеОбучения, Сценарий);
	КонецЕсли;
	
	Если ВидОбучения.ЗакрытьДоступКМатериаламПослеЗавершения Тогда
				
		Если СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.Окончено
			ИЛИ СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.НеОкончено
			ИЛИ СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.ОконченоБезПроверки
			ИЛИ СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.ОконченоАвтоматом Тогда			
			Возврат Ложь;				
		КонецЕсли;
		
		Если ВремяИстекло(ПрохождениеОбучения) Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ВариантПродолжительности = Неопределено Тогда
		ВариантПродолжительности = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПроведениеОбучения, "ВариантПродолжительности");
	КонецЕсли;
	
	Если ВариантПродолжительности = Перечисления.ПродолжительностьОбученияСУО.СНачалаОбучения
		И СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.Новое Тогда
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Если ДатаНачалаПрохождения = Неопределено Тогда		
		ДатаНачалаПрохождения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПрохождениеОбучения, "ДатаНачалаПрохождения");		
	КонецЕсли;
	
	Если НЕ ВремяНачалаОбученияНастало(ДатаНачалаПрохождения) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция ПоследовательноеПрохождениеЗаданий(ПрохождениеОбучения, ПроведениеОбучения = Неопределено, Сценарий = Неопределено) Экспорт
	
	Если ПроведениеОбучения = Неопределено Тогда
		ПроведениеОбучения = ПроведениеОбучения(ПрохождениеОбучения);
	КонецЕсли;		
	
	Если Сценарий = Неопределено Тогда
		Сценарий = Документы.ПроведениеОбученияСУО.СценарийОбучения(ПроведениеОбучения);		
	КонецЕсли; 
	
	Если ТипЗнч(Сценарий) = Тип("СправочникСсылка.КаталогМероприятийСУО")
		ИЛИ ТипЗнч(Сценарий) = Тип("ДокументСсылка.ПроведениеОбученияСУО") Тогда
		Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сценарий, "ПоследовательноеПрохождениеЗаданий");
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

Функция ПодчиненныеМероприятияДоступны(ПрохождениеОбучения, ПроведениеОбучения = Неопределено,  Сценарий = Неопределено, ВидОбучения = Неопределено, СтатусПроцессаОбучения = Неопределено, ДатаНачалаПрохождения = Неопределено) Экспорт	
	
	Если ПроведениеОбучения = Неопределено Тогда
		ПроведениеОбучения = ПроведениеОбучения(ПрохождениеОбучения);
	КонецЕсли;		
	
	Если Сценарий = Неопределено Тогда
		Сценарий = Документы.ПроведениеОбученияСУО.СценарийОбучения(ПроведениеОбучения);
	КонецЕсли;	
	
	Если ВидОбучения = Неопределено Тогда
		ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(ПроведениеОбучения, Сценарий);
	КонецЕсли;		
 	
	Если НЕ ВидОбучения.Общее Тогда
		Возврат Ложь; // Подчиненные есть только у общих
	КонецЕсли;
		
	Если СтатусПроцессаОбучения = Неопределено Тогда
		СтатусПроцессаОбучения = СтатусПроцессаОбучения(ПрохождениеОбучения);
	КонецЕсли;	
	
	// Подчиненные мероприятия общего обучения доступны в тех же случаях, что и задания.
	Возврат ЗаданияДоступны(ПрохождениеОбучения, ПроведениеОбучения, Сценарий, ВидОбучения, СтатусПроцессаОбучения,, ДатаНачалаПрохождения);
	
КонецФункции

Функция СтатусПроцессаОбучения(Знач ПрохождениеОбучения, Знач ПроведениеОбученияСтатус = Неопределено) Экспорт
	
	Если Документы.ПрохождениеОбученияСУО.Отменено(ПрохождениеОбучения) Тогда
		Возврат Перечисления.СтатусыПроцессаОбученияСУО.ПустаяСсылка(); // Нет статуса процесса обучения, так как обучения тоже нет
	КонецЕсли;
	
	Если ТипЗнч(ПрохождениеОбучения) = Тип("ДокументСсылка.ПрохождениеОбученияСУО") Тогда
		ДанныеПрохождения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, "Статус, РодительскоеПрохождение, ПроверяетсяПреподавателем, ПроверенПреподавателем, ВозвращеноНаДоработку, Сценарий, ПроведениеОбучения, ЗавершеноВПроцентах");
	Иначе
		ДанныеПрохождения = ПрохождениеОбучения;
	КонецЕсли;	
	
	Если ДанныеПрохождения.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.НеДопущен Тогда			
		Возврат Перечисления.СтатусыПроцессаОбученияСУО.НеДопущен;			
	КонецЕсли;
	
	Если ДанныеПрохождения.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Автомат Тогда
		Возврат Перечисления.СтатусыПроцессаОбученияСУО.ОконченоАвтоматом;	
	КонецЕсли;
	
	Если ПроведениеОбученияСтатус = Неопределено Тогда
		ПроведениеОбученияСтатус = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеПрохождения.ПроведениеОбучения, "Статус");
	КонецЕсли;
	
	Если ПроведениеОбученияСтатус = Перечисления.СтатусыПроведенияОбъектовСУО.Запланировано Тогда		
		Возврат Перечисления.СтатусыПроцессаОбученияСУО.Запланировано;				
	КонецЕсли;	
	
	Если ПроведениеОбученияСтатус = Перечисления.СтатусыПроведенияОбъектовСУО.Завершено Тогда
		
		Если ДанныеПрохождения.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Завершил Тогда
			Возврат Перечисления.СтатусыПроцессаОбученияСУО.Окончено;
		ИначеЕсли ДанныеПрохождения.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Автомат Тогда
			Возврат Перечисления.СтатусыПроцессаОбученияСУО.ОконченоАвтоматом;
		Иначе
			Возврат Перечисления.СтатусыПроцессаОбученияСУО.НеОкончено;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ПроведениеОбученияСтатус = Перечисления.СтатусыПроведенияОбъектовСУО.Активно Тогда

		Если ДанныеПрохождения.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Зачислен Тогда			
			Возврат Перечисления.СтатусыПроцессаОбученияСУО.Новое;			
		КонецЕсли;
		
		Если ДанныеПрохождения.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Проходит Тогда
			
			ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(ДанныеПрохождения.ПроведениеОбучения, ДанныеПрохождения.Сценарий);
			
			Если ДанныеПрохождения.ПроверяетсяПреподавателем И НЕ ДанныеПрохождения.ПроверенПреподавателем И НЕ Справочники.ВидыМероприятийСУО.ЗаданияПроверяютсяВыборочно(ВидОбучения) Тогда
				Возврат Перечисления.СтатусыПроцессаОбученияСУО.Проверяется;
			Иначе				
				Если ДанныеПрохождения.ВозвращеноНаДоработку Тогда
					Возврат Перечисления.СтатусыПроцессаОбученияСУО.ВозвращеноНаДоработку;
				Иначе
					Возврат Перечисления.СтатусыПроцессаОбученияСУО.Активно;
				КонецЕсли;			
			КонецЕсли;
			
		КонецЕсли;
		
		Если ДанныеПрохождения.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Завершил Тогда
			
			Если ДанныеПрохождения.ПроверяетсяПреподавателем И НЕ ДанныеПрохождения.ПроверенПреподавателем Тогда
				Возврат Перечисления.СтатусыПроцессаОбученияСУО.ОконченоБезПроверки;
			Иначе
				Возврат Перечисления.СтатусыПроцессаОбученияСУО.Окончено;								
			КонецЕсли;			
			
		КонецЕсли;
		
		Если ДанныеПрохождения.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Автомат Тогда
			Возврат Перечисления.СтатусыПроцессаОбученияСУО.ОконченоАвтоматом;
		КонецЕсли;
		
		Если ДанныеПрохождения.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.НеЗавершил Тогда			
			Возврат Перечисления.СтатусыПроцессаОбученияСУО.НеОкончено;			
		КонецЕсли;			
			
	КонецЕсли;
	
	Возврат Перечисления.СтатусыПроцессаОбученияСУО.ПустаяСсылка();

КонецФункции

Функция Представление(Знач ПрохождениеОбучения) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если НЕ ЗначениеЗаполнено(ПрохождениеОбучения) Тогда
		Возврат "<>";
	КонецЕсли;
	
	ТребуемыеДанные = Новый Структура("
	|Дата,
	|ДатаНачалаОбучения,
	|НаименованиеСценария,
	|НаименованиеПользователя",
	"Дата",		
	"ПроведениеОбучения.ДатаНачалаПроведения",
	"Сценарий.Наименование",
	"Пользователь.Наименование"
	);
	
	Данные = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, ТребуемыеДанные);
	
	ДатаОбучения = ?(ЗначениеЗаполнено(Данные.ДатаНачалаОбучения), Данные.ДатаНачалаОбучения, Данные.Дата);
	
	Возврат Строка(Данные.НаименованиеСценария) + " / " + Строка(Данные.НаименованиеПользователя) + ", " + Строка(Формат(ДатаОбучения, "ДЛФ=D")) + " /";
			
КонецФункции

Функция НаименованиеОбучения(ДанныеПрохождения) Экспорт
	
	Если ДанныеПрохождения.Свойство("РодительскоеПроведение")
		И ЗначениеЗаполнено(ДанныеПрохождения.РодительскоеПроведение) Тогда
		Возврат ДанныеПрохождения.НаименованиеСценария; // Подчиненное обучение преподавателя
	ИначеЕсли ДанныеПрохождения.Свойство("РодительскоеПрохождение") 
		И ЗначениеЗаполнено(ДанныеПрохождения.РодительскоеПрохождение) Тогда
		Возврат ДанныеПрохождения.НаименованиеСценария; // Подчиненное обучение обучающегося
	Иначе
		Возврат ?(ЗначениеЗаполнено(ДанныеПрохождения.НаименованиеПроведенияОбучения), ДанныеПрохождения.НаименованиеПроведенияОбучения, ДанныеПрохождения.НаименованиеСценария);
	КонецЕсли;		
	
КонецФункции

Функция ТипАктивности() Экспорт
	Возврат Перечисления.ТипыУчебныхАктивностейСУО.Обучение;
КонецФункции

Функция СценарийОбучения(Знач ПрохождениеОбучения) Экспорт
	
	Если ТипЗнч(ПрохождениеОбучения) = Тип("ДокументСсылка.ПрохождениеОбученияСУО") Тогда
		ПрохождениеОбученияСвойства = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, "Сценарий, ПроведениеОбучения");
	Иначе
		ПрохождениеОбученияСвойства = ПрохождениеОбучения;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПрохождениеОбученияСвойства.Сценарий) Тогда
		Возврат ПрохождениеОбученияСвойства.Сценарий;
	Иначе
		Возврат Документы.ПроведениеОбученияСУО.СценарийОбучения(ПрохождениеОбученияСвойства.ПроведениеОбучения);
	КонецЕсли;	
	
КонецФункции

Функция ПроведениеОбучения(Знач ПрохождениеОбучения) Экспорт
	
	Если ТипЗнч(ПрохождениеОбучения) = Тип("ДокументСсылка.ПрохождениеОбученияСУО") Тогда
		ПрохождениеОбученияСвойства = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, "ПроведениеОбучения");
	Иначе
		ПрохождениеОбученияСвойства = ПрохождениеОбучения;
	КонецЕсли;
	
	Возврат ПрохождениеОбученияСвойства.ПроведениеОбучения;
	
КонецФункции

Функция ДоступноОбщение(Знач ПрохождениеОбучения) Экспорт
	
	Если Актуально(ПрохождениеОбучения) Тогда
		Возврат Документы.ПроведениеОбученияСУО.ДоступноОбщение(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПрохождениеОбучения, "ПроведениеОбучения"));
	Иначе
		Возврат Ложь;
	КонецЕсли;	
		
КонецФункции

Функция ЕстьАвтоРазделыФорума(Знач ПрохождениеОбучения) Экспорт
	
	Если ТипЗнч(ПрохождениеОбучения) = Тип("ДокументСсылка.ПрохождениеОбученияСУО") Тогда
		ПрохождениеОбученияСвойства = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, "Пользователь, ПроведениеОбучения");
	Иначе
		ПрохождениеОбученияСвойства = ПрохождениеОбучения;
	КонецЕсли;
	
	Возврат РегистрыСведений.АвтоРазделыФорумаСУО.РазделыПользователя(ПрохождениеОбученияСвойства.Пользователь, ПрохождениеОбученияСвойства.ПроведениеОбучения, Истина); 
	
КонецФункции

Функция ДоступноПрикреплениеФайлов(Знач ПрохождениеОбучения, СтатусПроцессаОбучения = Неопределено, ПрохождениеАктуально = Неопределено) Экспорт
	
	Если СтатусПроцессаОбучения = Неопределено Тогда
		СтатусПроцессаОбучения = СтатусПроцессаОбучения(ПрохождениеОбучения);				
	КонецЕсли;	
	
	Если ПрохождениеАктуально = Неопределено Тогда
		ПрохождениеАктуально = Актуально(ПрохождениеОбучения, СтатусПроцессаОбучения);
	КонецЕсли;
	
	Если ПрохождениеАктуально Тогда		
		
		Если СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.Активно
			ИЛИ СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.ВозвращеноНаДоработку
			ИЛИ СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.Новое
			ИЛИ СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.Проверяется Тогда				
			
			ДанныеПрохожденияОбучения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, "ПроведениеОбучения, Сценарий");
			Возврат Документы.ПроведениеОбученияСУО.ДоступноПрикреплениеФайлов(ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.Сценарий);
			
		Иначе
			
			Возврат Ложь;
			
		КонецЕсли;
		
	Иначе
		
		Возврат Ложь;		
		
	КонецЕсли;
			
КонецФункции

Функция ДоступноЗавершениеУчащимся(Знач ПрохождениеОбучения, Знач ПроведениеОбучения = Неопределено, Знач Сценарий = Неопределено, Знач ВидОбучения = Неопределено) Экспорт	
	
	Если Актуально(ПрохождениеОбучения) Тогда
		
		Если Сценарий = Неопределено Тогда
			Сценарий = СценарийОбучения(ПрохождениеОбучения);
		КонецЕсли;
		
		Если ПроведениеОбучения = Неопределено Тогда
			ПроведениеОбучения = ПроведениеОбучения(ПрохождениеОбучения);
		КонецЕсли;
		
		Возврат Документы.ПроведениеОбученияСУО.ДоступноЗавершениеУчащимся(ПроведениеОбучения, Сценарий, ВидОбучения);
		
	Иначе
		
		Возврат Ложь;
		
	КонецЕсли;		
	
КонецФункции

Функция КоличествоПрикрепленныхФайлов(Знач ПрохождениеОбучения) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПрохождениеОбученияСУОПрисоединенныеФайлы.Ссылка) КАК Количество
		|ИЗ
		|	Справочник.ПрохождениеОбученияСУОПрисоединенныеФайлы КАК ПрохождениеОбученияСУОПрисоединенныеФайлы
		|ГДЕ
		|	ПрохождениеОбученияСУОПрисоединенныеФайлы.ВладелецФайла = &ПрохождениеОбучения
		|	И ПрохождениеОбученияСУОПрисоединенныеФайлы.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("ПрохождениеОбучения", ПрохождениеОбучения);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	Возврат ВыборкаДетальныеЗаписи.Количество;
	
КонецФункции	
	
Функция ОписаниеЕдинственногоЗаданияПрохождения(Знач ПрохождениеОбучения, ПроведениеОбучения = Неопределено, Сценарий = Неопределено) Экспорт
	
	Если ПроведениеОбучения = Неопределено Тогда
		ПроведениеОбучения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПрохождениеОбучения, "ПроведениеОбучения");
	КонецЕсли;
	
	Если Сценарий = Неопределено Тогда 
		Сценарий = СценарийОбучения(ПрохождениеОбучения);
	КонецЕсли;
	
	Возврат Документы.ПроведениеОбученияСУО.ОписаниеЕдинственногоЗаданияОбучения(ПроведениеОбучения, Сценарий);		
	
КонецФункции

Функция СвойстваЗаданияПрохождения(Знач ПрохождениеОбучения, Задание) Экспорт
	
	ВсеЗадания = ЗаданияПрохождения(ПрохождениеОбучения, Задание);
	СтрокаЗадания = ВсеЗадания.Найти(Задание, "Задание");
	
	Если СтрокаЗадания = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	НаборСвойств = Новый Структура;
	Для каждого КолонкаТЗ Из ВсеЗадания.Колонки Цикл
		НаборСвойств.Вставить(КолонкаТЗ.Имя, СтрокаЗадания[КолонкаТЗ.Имя]);
	КонецЦикла;
	
	Возврат НаборСвойств;
	
КонецФункции

Функция ЗаданияПрохождения(Знач ПрохождениеОбучения, Знач Задание = Неопределено) Экспорт
	
	Если ТипЗнч(ПрохождениеОбучения) = Тип("ДокументСсылка.ПрохождениеОбученияСУО") Тогда
		ПрохождениеОбученияСвойства = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, "Ссылка, Сценарий, ПроведениеОбучения, ДобавленоВремениВСекундах");
	Иначе
		ПрохождениеОбученияСвойства = ПрохождениеОбучения;
	КонецЕсли;
	
	МассивЗаданий = Новый Массив;
	МассивЭлектронныхРесурсов = Новый Массив;
	МассивЭлектронныхКурсов = Новый Массив;
	ТаблицаНаименований = Документы.ПроведениеОбученияСУО.ПустаяТаблицаНаименованийЗаданий();
	ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(ПрохождениеОбученияСвойства.ПроведениеОбучения, ПрохождениеОбученияСвойства.Сценарий);  
	
	Если ТипЗнч(ПрохождениеОбученияСвойства.Сценарий) = Тип("ДокументСсылка.ПроведениеОбученияСУО")
		ИЛИ ТипЗнч(ПрохождениеОбученияСвойства.Сценарий) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда
		Документы.ПроведениеОбученияСУО.ЗаполнитьМассивЗаданийИЭлектронныхРесурсов(ПрохождениеОбученияСвойства.ПроведениеОбучения, МассивЗаданий, МассивЭлектронныхРесурсов, МассивЭлектронныхКурсов, ТаблицаНаименований, ВидОбучения, Задание);
	КонецЕсли;
	
	ШкалаОценкиПроведения = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданияСУО.Ссылка КАК Задание,
		|	ЗаданияСУО.Описание КАК Описание,
		|	ЗаданияСУО.ЗначимостьОценки КАК Значимость,
		|	ЗаданияСУО.НаОсновеЭлектронногоРесурса КАК НаОсновеЭлектронногоРесурса,
		|	ЗаданияСУО.ЭлектронныйРесурс КАК ЭлектронныйРесурс,
		|	ЗаданияСУО.Фрагмент КАК Фрагмент,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.Регистратор КАК ПопыткаВыполнения,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.Баллы КАК Баллы,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.ШкалаОценки КАК ШкалаОценки,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.ЗавершеноВПроцентах КАК ЗавершеноВПроцентах,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.ПопыткаЗавершена КАК Завершено,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.ПроверяетсяПреподавателем КАК ПроверяетсяПреподавателем,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.ПроверенПреподавателем КАК ПроверенПреподавателем,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.Вариант КАК Вариант,
		|	ЗаданияСУО.Наименование КАК Наименование,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.КомментарийПреподавателя КАК КомментарийПреподавателя,
		|	ЗаданияСУО.ПреподавательВыставляетОценку КАК ПреподавательВыставляетОценку,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.ВозвращеноНаДоработку КАК ВозвращеноНаДоработку,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.ЗатраченоВремениВСекундах КАК ЗатраченоВремениВСекундах,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.НеЖдатьПроверки КАК НеЖдатьПроверки,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.ДатаОтправкиНаПроверку КАК ДатаОтправкиНаПроверку,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.ДатаВозвратаНаДоработку КАК ДатаВозвратаНаДоработку,
		|	ПопыткиПрохожденияЗаданийСУОСрезПоследних.ВыставляетсяОценка КАК ВыставляетсяОценка
		|ИЗ
		|	Справочник.ЗаданияСУО КАК ЗаданияСУО
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПопыткиПрохожденияЗаданийСУО.СрезПоследних(, ПрохождениеОбучения = &ПрохождениеОбучения) КАК ПопыткиПрохожденияЗаданийСУОСрезПоследних
		|		ПО (ПопыткиПрохожденияЗаданийСУОСрезПоследних.Задание = ЗаданияСУО.Ссылка)
		|ГДЕ
		|	(&ОтборПоСценарию
		|			ИЛИ ЗаданияСУО.Ссылка В (&МассивЗаданий))
		|	И ЗаданияСУО.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЗаданияСУО.РеквизитДопУпорядочивания";

	Если ТипЗнч(ПрохождениеОбученияСвойства.Сценарий) = Тип("СправочникСсылка.КаталогМероприятийСУО") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоСценарию", "ЗаданияСУО.Владелец = &Мероприятие");
		Запрос.УстановитьПараметр("Мероприятие", ПрохождениеОбученияСвойства.Сценарий);	
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоСценарию", "ЛОЖЬ");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("МассивЗаданий", МассивЗаданий);
	Запрос.УстановитьПараметр("ПрохождениеОбучения", ПрохождениеОбученияСвойства.Ссылка);

	Результат = Запрос.Выполнить();

	ТаблицаЗаданий = Результат.Выгрузить();
	
	Документы.ПроведениеОбученияСУО.ПривестиТипыТаблицыЗаданий(ТаблицаЗаданий);
	
	ТаблицаЗаданий.Колонки.Добавить("Номер");
	ТаблицаЗаданий.Колонки.Добавить("ПроходнойБалл", Новый ОписаниеТипов("Число"));
	ТаблицаЗаданий.Колонки.Добавить("ДатаНачалаДоступаКЗаданию", Новый ОписаниеТипов("Дата"));
	ТаблицаЗаданий.Колонки.Добавить("ДатаОкончанияДоступаКЗаданию", Новый ОписаниеТипов("Дата"));
	ТаблицаЗаданий.Колонки.Добавить("СкрытьВремяДоступаКЗаданию", Новый ОписаниеТипов("Булево"));
	
	НомерЗадания = 1;
	Для каждого СтрокаТЗ Из ТаблицаЗаданий Цикл
		СтрокаТЗ.Номер = НомерЗадания;
		СтрокаТЗ.ДатаНачалаДоступаКЗаданию = Дата("00010101");
		СтрокаТЗ.ДатаОкончанияДоступаКЗаданию = Дата("00010101");
		СтрокаТЗ.СкрытьВремяДоступаКЗаданию = Ложь;		
		
		СтрокаТН = ТаблицаНаименований.Найти(СтрокаТЗ.Задание, "Задание");		
		Если СтрокаТН <> Неопределено Тогда
			СтрокаТЗ.Номер = СтрокаТН.Номер;

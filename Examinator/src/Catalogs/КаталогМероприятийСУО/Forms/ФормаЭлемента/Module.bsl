// ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЦЫ ФОРМЫ  ЭлектронныеРесурсы

&НаКлиенте
Процедура ЭлектронныеРесурсыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	РесурсыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование);
КонецПроцедуры

&НаКлиенте
Процедура ЭлектронныеРесурсыПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Поле = Элемент.Имя;
	ТекстСообщения = "";
	ИмяРеквизита = "";
	
	Если НЕ Элемент.ТекущиеДанные.ПоказатьПриСтатусеЗапланировано
		И НЕ Элемент.ТекущиеДанные.ПоказатьПриСтатусеАктивно
		И НЕ Элемент.ТекущиеДанные.ПоказатьПриСтатусеЗавершено Тогда
				
		ТекстСообщения = НСтр("ru = 'Укажите, при каких статусах Проведения обучения показывать ресурс'");
		ИмяРеквизита = "ПоказатьПриСтатусеЗавершено";
		
	КонецЕсли;
	
	Если Элемент.ТекущиеДанные.ПоказатьПриСтатусеЗапланировано
		И НЕ Элемент.ТекущиеДанные.ПоказатьПриСтатусеАктивно
		И НЕ Элемент.ТекущиеДанные.ПоказатьПриСтатусеЗавершено
		И Элемент.ТекущиеДанные.ПоказатьПослеПрохождения Тогда
		
		ТекстСообщения = НСтр("ru = 'Флажок не может быть установлен, когда ресурс показывается только при статусе Запланировано'");
		ИмяРеквизита = "ПоказатьПослеПрохождения";
			
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстСообщения) И ЗначениеЗаполнено(ИмяРеквизита) Тогда
	
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			ТекстСообщения,
			,
			Поле + "["+ ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(Элемент.ТекущаяСтрока) +"]." + ИмяРеквизита,
			"Объект");
	
	КонецЕсли;

КонецПроцедуры

#КонецОбласти


#Область ОбработчикиКомандФормы


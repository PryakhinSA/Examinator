		Параметры.Свойство("ОткрытьФормуДокумента", ОткрытьФормуДокумента);
		Параметры.Свойство("ОткрытьФормуРесурса", ОткрытьФормуРесурса);
		
		Если ОткрытьФормуРесурса = ИСТИНА Тогда
			Возврат; // Открываем по умолчанию
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Ключ) Тогда
			
			ЭтоSCO = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ключ, "SCO");
			
			Если ЭтоSCO Тогда
				СтандартнаяОбработка = Ложь;
				ВыбраннаяФорма = "Справочник.РесурсыСУЗ.Форма.ФормаЭлементаSCORM";
				Возврат;
			КонецЕсли;
		
		КонецЕсли;
		
		Если ОткрытьФормуФайла = ИСТИНА ИЛИ ОткрытьФормуДокумента = ИСТИНА Тогда
		
			Если ЗначениеЗаполнено(Ключ) Тогда				
								
				ЕдинственныйФайл = ЕдинственныйФайлРесурса(Ключ);
				
				Если ЗначениеЗаполнено(ЕдинственныйФайл) Тогда
					
					ТипЕдинственногоФайла = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЕдинственныйФайл, "ТипФайла");
					
					СтандартнаяОбработка = Ложь;
					Параметры.Ключ = ЕдинственныйФайл;
					
					ВыбраннаяФорма = ?(ОткрытьФормуДокумента = ИСТИНА
						ИЛИ ТипЕдинственногоФайла = Перечисления.ТипыФайловСУЗ.Document,

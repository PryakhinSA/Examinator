#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаНастроек

// ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЦЫ ФОРМЫ ТаблицаНастроек

&НаКлиенте
Процедура ТаблицаНастроекПередНачаломИзменения(Элемент, Отказ)
	
	ТабличноеПоле = Элемент;
	
	Если ТабличноеПоле.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПолеВвода = ТабличноеПоле.ПодчиненныеЭлементы[ТабличноеПоле.Имя + "Значение"];
	ПолеВвода.ОграничениеТипа = ТабличноеПоле.ТекущиеДанные.ДопустимыеТипы;
	
	ВыборГруппИЭлементов = ТабличноеПоле.ТекущиеДанные.ВыборГруппИЭлементов;
	
	Если ЗначениеЗаполнено(ВыборГруппИЭлементов) Тогда
		ПолеВвода.ВыборГруппИЭлементов = ГруппыИЭлементы[ВыборГруппИЭлементов];
	Иначе
		ПолеВвода.ВыборГруппИЭлементов = ГруппыИЭлементы.Авто;
	КонецЕсли;	
	
	Если ТабличноеПоле.ТекущиеДанные.ИмяСвойства = "Пароль" Тогда
		ПолеВвода.РежимВыбораИзСписка = Истина;
		ПолеВвода.СписокВыбора.Очистить();
		ПолеВвода.СписокВыбора.Добавить("Сбросить", НСтр("ru = 'Сбросить на пустой'"));
		ПолеВвода.СписокВыбора.Добавить("УстановитьСлучайный", НСтр("ru = 'Установить случайный'"));
	ИначеЕсли ТабличноеПоле.ТекущиеДанные.ИмяСвойства = "Логин" Тогда
		ПолеВвода.РежимВыбораИзСписка = Истина;
		ПолеВвода.СписокВыбора.Очистить();
		ПолеВвода.СписокВыбора.Добавить("СформироватьИзПолногоИмени", НСтр("ru = 'Сформировать из полного имени'"));
		ПолеВвода.СписокВыбора.Добавить("УстановитьЭлектроннуюПочту", НСтр("ru = 'Установить электронную почту'"));
	Иначе
		ПолеВвода.РежимВыбораИзСписка = Ложь;
		ПолеВвода.СписокВыбора.Очистить();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиКомандФормы

// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ИзменитьНастройкиДоступа(Команда)
	
	ВыбранныеНастройки = Новый Структура("Настройки, Рассылка");
	ВыбранныеНастройки.Настройки = Новый Массив;
	
	Если РассылатьУведомлениеАвтоматически Тогда
		ВыбранныеНастройки.Рассылка = Новый Структура("Шаблон, ВидЭлектронногоАдреса, ТолькоЭлектроннаяПочта", ШаблонУведомления, ВидЭлектронногоАдреса, РассылатьТолькоНаЭлектроннуюПочту);
		Если НЕ ЗначениеЗаполнено(ВыбранныеНастройки.Рассылка.Шаблон) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Шаблон уведомления не заполнен'"),,"ШаблонУведомления");
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	УстанавливаетсяНстройкаНедействителен = Ложь;
	
	Для каждого СтрокаТЗ Из ТаблицаНастроек Цикл
	
		Если НЕ СтрокаТЗ.ИзменитьНастройку Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаТЗ.Значение = Неопределено Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не указано значение настройки'"),,"ТаблицаНастроек[" + Строка(СтрокаТЗ.ПолучитьИдентификатор()) + "].Значение");
			Возврат;			
		КонецЕсли;
		
		ОписаниеНастройки = Новый Структура("Имя, Значение, Действие");
		ОписаниеНастройки.Имя = СтрокаТЗ.ИмяСвойства;
		ОписаниеНастройки.Значение = СтрокаТЗ.Значение;
		ОписаниеНастройки.Действие = СтрокаТЗ.Действие;
		
		Если ОписаниеНастройки.Имя = "Пароль"
			И ОписаниеНастройки.Значение = "УстановитьСлучайный" Тогда
			
			Если РассылатьУведомлениеАвтоматически И ЗначениеЗаполнено(ШаблонУведомления) Тогда
				
				Если НЕ ШаблонПисьмаСодержитПеременнуюНовыйПароль(ШаблонУведомления) Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Выберите шаблон сообщения типа ""Сброс пароля""'"),,"ШаблонУведомления");
					Возврат;																					
				КонецЕсли;
				
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Пользователь не сможет узнать свой пароль без сообщения на электронную почту.
				|Укажите шаблон письма с переменной {{НовыйПароль}}.'"),,"РассылатьУведомлениеАвтоматически");
				Возврат;										
			КонецЕсли;
			
		КонецЕсли;
		
		Если ОписаниеНастройки.Имя = "Недействителен"
			И ОписаниеНастройки.Значение = Истина Тогда
			
			УстанавливаетсяНстройкаНедействителен = Истина;
			
		КонецЕсли;
		
		ВыбранныеНастройки.Настройки.Добавить(ОписаниеНастройки);		
		
	КонецЦикла;
	
	Если УстанавливаетсяНстройкаНедействителен
		И ВыбранныеНастройки.Настройки.Количество() > 1 Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Настройка ""Недействителен"" не может быть установлена совместно с другими настройками'"));
		Возврат;										
		
	КонецЕсли;
	
	Если ВыбранныеНастройки.Настройки.Количество() = 0 
		И ВыбранныеНастройки.Рассылка <> Неопределено Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Уведомление нельзя отправить без установки хотя бы одной настройки'"),,"РассылатьУведомлениеАвтоматически");
		Возврат;												
		
	КонецЕсли;
	
	Если ВыбранныеНастройки.Настройки.Количество() > 0 Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект, ВыбранныеНастройки);
		ТекстВопрос = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Настройки будут установлены для %1 пользователей. Продолжить?'"), ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(КоличествоПользователей));
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопрос, РежимДиалогаВопрос.ДаНет, 0);
	Иначе
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаКлиенте
Процедура ПослеЗакрытияВопроса(РезультатВопроса, ВыбранныеНастройки) Экспорт
    Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
        Закрыть(ВыбранныеНастройки);
    КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступностьЭлементовФормы()
	
	Если НЕ РассылатьУведомлениеАвтоматически Тогда
		ВидЭлектронногоАдреса = Неопределено;
		ШаблонУведомления = Неопределено;
		РассылатьТолькоНаЭлектроннуюПочту = Ложь;
	КонецЕсли;
	
	Элементы.ВидЭлектронногоАдреса.Доступность = РассылатьУведомлениеАвтоматически;
	Элементы.ШаблонУведомления.Доступность = РассылатьУведомлениеАвтоматически;
	Элементы.РассылатьТолькоНаЭлектроннуюПочту.Доступность = РассылатьУведомлениеАвтоматически;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ШаблонПисьмаСодержитПеременнуюНовыйПароль(Знач ШаблонПисьма)
	
	ТипШаблона = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ШаблонПисьма, "ТипШаблона");
	
	Если ТипШаблона = Перечисления.ТипыШаблоновСообщенийСУО.СбросПароля Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

#КонецОбласти


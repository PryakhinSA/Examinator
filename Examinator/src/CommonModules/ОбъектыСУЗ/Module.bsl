// РЕДАКТИРОВАНИЕ ОБЪЕКТОВ

// Позволяет определить, можно ли редактировать данные указанного поставщика.
//
Функция ИзменениеДанныхОтПоставщикаЗапрещено(Поставщик, Отказ = Ложь, ПоказыватьСообщение = Истина) Экспорт
	
	Если Отказ = Неопределено Тогда
		Отказ = Ложь;
	КонецЕсли;
	
	Если Константы.ПоказыватьПоследнююВерсиюСУЗ.Получить() И
		Константы.ИзменятьДанныеТолькоПредпочитаемогоПоставщикаСУЗ.Получить() И
		Поставщик <> Константы.ПредпочитатьПоставщикаСУЗ.Получить() Тогда
		
		Если ПоказыватьСообщение Тогда
			Текст = НСтр("ru = 'Редактирование данных поставщика """ + Строка(Поставщик) + """ запрещено'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст,,,,Отказ);
		Иначе
			Отказ = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Отказ;
	
КонецФункции


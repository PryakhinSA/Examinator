Функция КоличествоФайловРазмещенныхВБСП() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ДанныеФайлов.СсылкаНаОбъектСУЗ) КАК КоличествоЭлементов
		|ИЗ
		|	РегистрСведений.ДанныеФайлыСУЗ КАК ДанныеФайлов
		|ГДЕ
		|	ДанныеФайлов.ПрисоединенныйФайл <> &ПрисоединенныйФайлПустаяСсылка";
	
	Запрос.УстановитьПараметр("ПрисоединенныйФайлПустаяСсылка", Справочники.ФайлыСУЗПрисоединенныеФайлы.ПустаяСсылка());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ВыборкаДетальныеЗаписи.Следующий();
	
	Возврат ВыборкаДетальныеЗаписи.КоличествоЭлементов;	
	
КонецФункции


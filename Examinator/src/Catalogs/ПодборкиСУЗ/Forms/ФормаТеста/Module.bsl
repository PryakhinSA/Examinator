КонецПроцедуры

&НаКлиенте
Процедура СтартовыйРесурсСоздать(Команда)
	РазработкаСУЗКлиент.СоздатьЭлементРеквизитаСУЗ(ЭтотОбъект, "СтартовыйРесурс", "СтраницыСУЗ", НСтр("ru = 'Стартовая страница'"), ЭлектронныйРесурс, Объект.Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура СтартовыйРесурсУдалить(Команда)
	РазработкаСУЗКлиент.УдалитьЭлементРеквизитаСУЗ(ЭтотОбъект, "СтартовыйРесурс");
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Процедура УстановитьДоступностьЭлементовФормы()
	
	РазработкаСУЗ.УстановитьДоступностьКомандРеквизитаСУЗ(ЭтотОбъект, "СтартовыйРесурс");
	
	// Реквизиты
	
	Справочники.ПодборкиСУЗ.УстановитьОбязательныеРеквизиты(Объект);
	
	// Отборы
	
	ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(ЭлементыПодборки, Объект.Ссылка);
	ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(ЭлементыПодборкиИзРубрикатора, Объект.Ссылка);
	ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(Комментарии, Объект.Ссылка);
	ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(Сложности, Объект.Ссылка);
	ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(СхемаАнализаПсихологическогоТестирования, Объект.Ссылка);
	
	// Доступность и видимость элементов
	
	Элементы.СтраницаРубрики.Видимость = Объект.ВыбиратьЭлементыИзРубрикатора;
	Элементы.СтраницаВопросы.Видимость = НЕ Объект.ВыбиратьЭлементыИзРубрикатора;	
	Элементы.ПереходитьВпередАвтоматически.ТолькоПросмотр = НЕ Объект.ПоказыватьНавигацию;	
	Элементы.ДекорацияЭлектронныйРесурс.Видимость = ЗначениеЗаполнено(ЭлектронныйРесурс);
	Элементы.СтраницаСложностиТеста.Видимость = (Объект.НазначениеТестирования <> Перечисления.НазначенияТестированийСУЗ.Анкетирование);	
	Элементы.УчитыватьПредыдущиеПопытки.Видимость = (Объект.НазначениеТестирования <> Перечисления.НазначенияТестированийСУЗ.Анкетирование);
	Элементы.Комментарии.Видимость = (Объект.НазначениеТестирования <> Перечисления.НазначенияТестированийСУЗ.Анкетирование);
	Элементы.СтраницаСхемаАнализаПсихологическогоТестирования.Видимость = (Объект.НазначениеТестирования <> Перечисления.НазначенияТестированийСУЗ.Анкетирование);
	Элементы.КоличествоПопыток.Доступность = (Объект.НазначениеТестирования <> Перечисления.НазначенияТестированийСУЗ.Анкетирование);		
	Элементы.ПеремешиватьГруппыЭлементов.Доступность = НЕ Объект.ВыбиратьЭлементыИзРубрикатора;
	Элементы.ИсключитьОткрытыеВопросы.Доступность = (Объект.НазначениеТестирования <> Перечисления.НазначенияТестированийСУЗ.Упражнение);
	Элементы.ПоказыватьНавигацию.Доступность = (Объект.НазначениеТестирования <> Перечисления.НазначенияТестированийСУЗ.Упражнение);
	Элементы.ПереходитьВпередАвтоматически.Доступность = (Объект.НазначениеТестирования <> Перечисления.НазначенияТестированийСУЗ.Упражнение);	
	
	Если НЕ Объект.ПоказыватьНавигацию И НЕ Объект.ИсключитьОткрытыеВопросы Тогда
		Элементы.ДекорацияПредупреждениеОткрытыеВопросы.Видимость = Истина;
	Иначе
		Элементы.ДекорацияПредупреждениеОткрытыеВопросы.Видимость = Ложь;
	КонецЕсли;
	
	// Для веб-кабинета
	
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета = Новый Массив;
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ИсключитьОткрытыеВопросы);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.УчитыватьПредыдущиеПопытки);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.СтартовыйРесурс);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ВыравниваниеСтартовогоРесурса);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ПоказыватьСтоимостьВопроса);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.СкрытьКомментарииВопросов);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ПоказыватьТаймер);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ИнформацияНаФинальнойСтранице);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ФорматТаймера);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ТипНавигации);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ПереходитьВпередАвтоматически);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ПоказыватьНавигацию);
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.ДекорацияПредупреждениеОткрытыеВопросы);	
	МассивЭлементовНеподдерживаемыхПлееромВебКабинета.Добавить(Элементы.СтраницаКомментарииКРезультатуТеста);
	
	РазработкаСУЗ.УбратьВидимостьНеподдерживаемыхПлееромВебКабинетаЭлементов(ЭлектронныйРесурс, МассивЭлементовНеподдерживаемыхПлееромВебКабинета);
	
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовок()
	
	Если Объект.Ссылка.Пустая() Тогда
		Заголовок = НСтр("ru = 'Тест (создание)'");
	Иначе
		Заголовок = НСтр("ru = 'Тест ""%1""'");
		Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Заголовок, Объект.Наименование);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПоместитьВопросВТест(Вопрос, Подборка, ВесВопроса = 1, ВыделеннаяГруппа)
	
	Справочники.ПодборкиСУЗ.ДобавитьВопросВПодборку(Вопрос, Подборка, ВесВопроса, ВыделеннаяГруппа);	
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьВопрос()
	
	РазработкаСУЗКлиент.РедактироватьЭлементТаблицыСУЗ(Элементы.Вопросы, "СсылкаНаОбъектСУЗ", ЭлектронныйРесурс, Объект.Ссылка);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПоместитьЭлементВПодборку(Подборка, Элемент, ГруппаЭлементов)
	
	Если НЕ ЗначениеЗаполнено(Элемент) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Элемент) = Тип("СправочникСсылка.ФайлыСУЗ") Тогда
		Элемент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Элемент, "Владелец"); // Прикрепляем ресурс, а не файл
	КонецЕсли;
	
	Справочники.ПодборкиСУЗ.ДобавитьЭлементВПодборку(Подборка, Элемент, ГруппаЭлементов);
	
КонецПроцедуры

#КонецОбласти

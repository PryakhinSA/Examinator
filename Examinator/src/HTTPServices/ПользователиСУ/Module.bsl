Функция ЗакрытьСессиюPOST(ЗапросHTTP)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(ЗапросHTTP, ДанныеСессии, КодОшибки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;	
	
	// Получаем тело запроса

	ТелоЗапросаСтрока = СокрЛП(ЗапросHTTP.ПолучитьТелоКакСтроку());
	
	Если ЗначениеЗаполнено(ТелоЗапросаСтрока) Тогда
		
		Попытка
			ТелоЗапросаСтруктура = ОбщегоНазначенияСУ.JSONВДанные(ТелоЗапросаСтрока);
		Исключение
			ТелоЗапросаСтруктура = Новый Структура;
		КонецПопытки;
		
		ИмяСобытия = "END";	
		
		ИдентификаторВкладки = Неопределено;
		ТелоЗапросаСтруктура.Свойство("tabUUID", ИдентификаторВкладки);
		
		Если ЗначениеЗаполнено(ИдентификаторВкладки) Тогда
			Попытка
				ИдентификаторВкладки = Новый УникальныйИдентификатор(ИдентификаторВкладки);
			Исключение
				Возврат ОтветКлиентуJSON("errorData");
			КонецПопытки;
		КонецЕсли;
		
		ЗаписатьСтатистику(ДанныеСессии, ИдентификаторВкладки, ИмяСобытия);
		
	КонецЕсли;		
	
	// Отмечаем сессию, как завершенную
	
	РегистрыСведений.СессииВебКабинетаСУ.ЗакрытьСессию(ДанныеСессии.Идентификатор);
	
	// Возвращаем идентификатор закрытой сессии
	
	Возврат ОтветКлиентуJSON(,ДанныеСессии.Идентификатор);
	
КонецФункции

Функция УстановитьДатуАктивностиСессииPOST(ЗапросHTTP)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(ЗапросHTTP, ДанныеСессии, КодОшибки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;	
	
	// Получаем тело запроса
	
	ТелоЗапросаСтрока = СокрЛП(ЗапросHTTP.ПолучитьТелоКакСтроку());
	
	Попытка
		ТелоЗапросаСтруктура = ОбщегоНазначенияСУ.JSONВДанные(ТелоЗапросаСтрока);
	Исключение
		ТелоЗапросаСтруктура = Новый Структура;
	КонецПопытки;
			
	ИмяСобытия = Неопределено;	
	ТелоЗапросаСтруктура.Свойство("event", ИмяСобытия);
	
	Если НЕ ЗначениеЗаполнено(ИмяСобытия) Тогда
		ИмяСобытия = "ONLINE";
	КонецЕсли;

	ИдентификаторВкладки = Неопределено;
	ТелоЗапросаСтруктура.Свойство("tabUUID", ИдентификаторВкладки);
	
	Если ЗначениеЗаполнено(ИдентификаторВкладки) Тогда
		Попытка
			ИдентификаторВкладки = Новый УникальныйИдентификатор(ИдентификаторВкладки);
		Исключение
			Возврат ОтветКлиентуJSON("errorData");
		КонецПопытки;
	КонецЕсли;
	
	// Запоминаем событие
	
	ЗаписатьСтатистику(ДанныеСессии, ИдентификаторВкладки, ИмяСобытия);	
	
	// Устанавливаем дату активности
	
	Если ИмяСобытия = "START" ИЛИ ИмяСобытия = "ONLINE" Тогда
		РегистрыСведений.СессииВебКабинетаСУ.ОбновитьДатуАктивности(ДанныеСессии.Идентификатор);
	КонецЕсли;
	
	// Возвращаем идентификатор закрытой сессии
	
	Возврат ОтветКлиентуJSON(, Новый Структура);
	
КонецФункции

Процедура ЗаписатьСтатистику(ДанныеСессии, ИдентификаторВкладки, ИмяСобытия)
	
	Если ЗначениеЗаполнено(ИдентификаторВкладки) Тогда
		
		Если ИмяСобытия = "START" Тогда
			Документы.ИспользованиеВебКабинетаСУ.НачатьИспользование(
				ДанныеСессии.Пользователь, ДанныеСессии.Идентификатор, ИдентификаторВкладки);
		КонецЕсли;
		
		Если ИмяСобытия = "ONLINE" Тогда
			Документы.ИспользованиеВебКабинетаСУ.ЗаписатьДатуПоследнейАктивности(
				ДанныеСессии.Пользователь, ДанныеСессии.Идентификатор, ИдентификаторВкладки);
		КонецЕсли;
		
		Если ИмяСобытия = "END" Тогда
			Документы.ИспользованиеВебКабинетаСУ.ЗавершитьИспользование(
				ДанныеСессии.Пользователь, ДанныеСессии.Идентификатор, ИдентификаторВкладки);
		КонецЕсли;
		
	КонецЕсли;

	
КонецПроцедуры


	КонецЕсли;		
	
	// Возвращаем данные
		
	ТаблицаСсылочныхЗначений = УправлениеОбучениемСУО.ПустаяТаблицаСсылочныхЗначений();
	
	НоваяСтрока = ТаблицаСсылочныхЗначений.Добавить();

		Возврат ОтветКлиентуJSON("Sertificate not found");
	КонецЕсли;	
	
	Попытка
		Сертификат = Документы.СертификатСУО.ПолучитьСсылку(ИдентификаторСертификата);
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(Сертификат) Тогда
		Возврат ОтветКлиентуJSON("Sertificate not found");
	КонецЕсли;	
	
	Если НЕ Документы.СертификатСУО.СертификатАктивен(Сертификат) Тогда
		Возврат ОтветКлиентуJSON("Sertificate not found");
	КонецЕсли;
	
	ДвоичныеДанныеСертификата = Документы.СертификатСУО.ПредставлениеPDF(Сертификат);
	
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Data-type", "application/pdf"); // Обязательно
	Ответ.Заголовки.Вставить("Content-Type", "application/pdf");
	Ответ.УстановитьТелоИзДвоичныхДанных(ДвоичныеДанныеСертификата);
	ДобавитьЗаголовкиМежсайтовогоЗапроса(Ответ);
	Возврат Ответ;
	
КонецФункции

Функция ПолучитьФайлыУчастниковОбученияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Преподавание");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные
	//	
	
	Попытка
		ИдентификаторПроведенияОбучения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ПроведениеОбучения"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторПроведенияОбучения) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;		
	
	ДополнительныеОтборыJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	ИдентификаторМероприятия = Неопределено;
	ИдентификаторУчастника = Неопределено;
	
	Если ЗначениеЗаполнено(ДополнительныеОтборыJSON) Тогда
	
		Попытка
			ДополнительныеОтборы = ОбщегоНазначенияСУ.JSONВДанные(ДополнительныеОтборыJSON);
		Исключение
			Возврат ОтветКлиентуJSON("errorData");
		КонецПопытки;
		
		Если ДополнительныеОтборы.Свойство("eduTemplate")
			И ЗначениеЗаполнено(ДополнительныеОтборы.eduTemplate) Тогда
			
			ИдентификаторМероприятия = Новый УникальныйИдентификатор(ДополнительныеОтборы.eduTemplate);
			
		КонецЕсли;	
		
				
		Если ДополнительныеОтборы.Свойство("user")
			И ЗначениеЗаполнено(ДополнительныеОтборы.user) Тогда
			
			ИдентификаторУчастника = Новый УникальныйИдентификатор(ДополнительныеОтборы.user);
			
		КонецЕсли;

	КонецЕсли;
	
	// Выбираем данные из базы
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВыборкаФайлов.Данные КАК object,
		|	ВыборкаДанныхОПроверкеФайла.Данные КАК userDescription
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ВыборкаФайлов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборПроведенияОбучения
		|		ПО ВыборкаФайлов.Объект = ОтборПроведенияОбучения.Объект
		|			И (ОтборПроведенияОбучения.Отбор = &ИдентификаторПроведенияОбучения)
		|       %ОтборПоМероприятию%
		|       %ОтборПоУчастнику%
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборПоПреподавателю
		|		ПО ВыборкаФайлов.Объект = ОтборПоПреподавателю.Объект
		|			И (ОтборПоПреподавателю.Отбор = &ИдентификаторПреподавателя)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеВебКабинетаСУО_ПП.СрезПоследних(, Пользователь = &Пользователь) КАК ВыборкаДанныхОПроверкеФайла
		|		ПО ВыборкаФайлов.Объект = ВыборкаДанныхОПроверкеФайла.Объект
		|			И ВыборкаФайлов.Тип = ВыборкаДанныхОПроверкеФайла.Тип
		|ГДЕ
		|	ВыборкаФайлов.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.ФайлУчащегося)";
	
		
	Если ЗначениеЗаполнено(ИдентификаторМероприятия) Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ОтборПоМероприятию%", "
			|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборПоМероприятию
			|	ПО ВыборкаФайлов.Объект = ОтборПоМероприятию.Объект
			|		И (ОтборПоМероприятию.Отбор = &ИдентификаторМероприятия)");			
			
		Запрос.УстановитьПараметр("ИдентификаторМероприятия", ИдентификаторМероприятия);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ОтборПоМероприятию%", "");
		
	КонецЕсли;				
		
	Если ЗначениеЗаполнено(ИдентификаторУчастника) Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ОтборПоУчастнику%", "
			|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборПоУчастнику
			|	ПО ВыборкаФайлов.Объект = ОтборПоУчастнику.Объект
			|		И (ОтборПоУчастнику.Отбор = &ИдентификаторУчастника)");			
			
		Запрос.УстановитьПараметр("ИдентификаторУчастника", ИдентификаторУчастника);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ОтборПоУчастнику%", "");
		
	КонецЕсли;		
	
	
	Запрос.УстановитьПараметр("ИдентификаторПроведенияОбучения", ИдентификаторПроведенияОбучения);
	Запрос.УстановитьПараметр("ИдентификаторПреподавателя", ДанныеСессии.Пользователь.УникальныйИдентификатор());
	Запрос.УстановитьПараметр("Пользователь", ДанныеСессии.Пользователь);
		
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат ОтветКлиентуJSON(,РезультатЗапроса.Выгрузить());
	
КонецФункции

Функция ЗаписатьНастройкиФайлаУчастникаОбученияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Преподавание");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные
	//	
	
	Попытка
		ИдентификаторФайла = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ФайлУчастникаОбучения"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторФайла) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	

	Файл = Справочники.ПрохождениеОбученияСУОПрисоединенныеФайлы.ПолучитьСсылку(ИдентификаторФайла);
	
	НастройкиДляЗаписиJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если НЕ ЗначениеЗаполнено(НастройкиДляЗаписиJSON) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Попытка
		НастройкиДляЗаписи = ОбщегоНазначенияСУ.JSONВДанные(НастройкиДляЗаписиJSON);
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;
	
	ИмяНастройки      = Неопределено;
	ЗначениеНастройки = Неопределено;
	
	Если НастройкиДляЗаписи.Свойство("name") И НастройкиДляЗаписи.Свойство("value") Тогда
		Попытка
			ИмяНастройки      = НастройкиДляЗаписи.name;
			ЗначениеНастройки = НастройкиДляЗаписи.value; 
		Исключение
			Возврат ОтветКлиентуJSON("errorData");
		КонецПопытки;			
	КонецЕсли;
	
	ТекущаяДата = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(ЗначениеНастройки);
	
	Файлы = Новый Массив;
	Файлы.Добавить(Файл);	
	
	Если ИмяНастройки = "setChecked" Тогда
		РегистрыСведений.ФайлыПроверенныеПреподавателямиСУО.ЗапомнитьПроверенныеФайлы(Файлы, ДанныеСессии.Пользователь, ТекущаяДата, Истина);
	КонецЕсли;
	
	Если ИмяНастройки = "clearChecked" Тогда
		РегистрыСведений.ФайлыПроверенныеПреподавателямиСУО.ОчиститьПроверенныеФайлы(Файлы, ДанныеСессии.Пользователь, Истина);
	КонецЕсли;
	
	РегистрыСведений.ФайлыПроверенныеПреподавателямиСУО.ОбновитьДанныеВебКабинета(Файл);
	
	Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена, Дата", Истина, ТекущаяДата));	
	
КонецФункции

Функция ОтложитьЗаданияНаПроверкуPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, "Преподавание");
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем данные для записи
	//
	
	ПараметрыJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если НЕ ЗначениеЗаполнено(ПараметрыJSON) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Попытка
		ПараметрыСтруктура = ОбщегоНазначенияСУ.JSONВДанные(ПараметрыJSON);
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;	
	
	НачатьТранзакцию();
	
	Попытка
		
		Для каждого СвойствоЗадания Из ПараметрыСтруктура.taskAttempts Цикл	

			Попытка
				ИдентификаторПрохожденияОбучения = Новый УникальныйИдентификатор(СвойствоЗадания.userActivity);
			Исключение
			КонецПопытки;
			
			ПрохождениеОбучения = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(ИдентификаторПрохожденияОбучения);
			
			НаОсновеЭлектронногоРесурса = СвойствоЗадания.onElectronicResource;
			
			Попытка
				ИдентификаторПопыткиВыполнения = Новый УникальныйИдентификатор(СвойствоЗадания.taskAttempt);
			Исключение
			КонецПопытки;
			
			Если НаОсновеЭлектронногоРесурса Тогда
				ПопыткаВыполнения = Документы.СессияЭлектронногоРесурсаСУЗ.ПолучитьСсылку(ИдентификаторПопыткиВыполнения);
			Иначе
				ПопыткаВыполнения = Документы.ПопыткаВыполненияЗаданияСУО.ПолучитьСсылку(ИдентификаторПопыткиВыполнения);
			КонецЕсли;
			
			РегистрыСведений.ОтложенныеЗаданияНаПроверкуСУО.ОтложитьЗадание(ПопыткаВыполнения, ДанныеСессии.Пользователь, ПрохождениеОбучения);
		
		КонецЦикла;		
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
	// Возвращаем результат
	//
	
	Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена", Истина));
	
КонецФункции

// Файлы (пользовательские)

Функция ЗагрузитьФайлPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки   = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем переменные
	//
	
	ЗаголовкиЗапроса       = Запрос.Заголовки;
	ИдентификаторВладельца = Запрос.ПараметрыURL.Получить("ИдентификаторВладельца");
	ТипВладельца           = Запрос.ПараметрыURL.Получить("ТипВладельца");
	ПараметрыФайла         = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(Запрос.ПолучитьТелоКакСтроку(), "", ";", ":", Истина);
	
	ФайлыДляЗаписи = ФайлыДляЗаписи(ПараметрыФайла);
	
	Если ФайлыДляЗаписи = Неопределено Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	
	
	// Загружаем файлы в базу
	//	
	
	Если ТипВладельца = "userPhoto" Тогда
		
		Если ФайлыДляЗаписи.Количество() <> 1 Тогда
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;
		
		СвойстваФайла = ФайлыДляЗаписи[0];
		
		РегистрыСведений.ФотографииПользователейСУО.СохранитьФотографиюПользователя(ДанныеСессии.Пользователь, СвойстваФайла.АдресХраненияФайла,, Истина);
		
		РегистрыСведений.ФотографииПользователейСУО.ОбновитьДанныеВебКабинета(ДанныеСессии.Пользователь);
		
		ВебКабинетСУО.ОбновитьДанныеПользователяВебКабинета(ДанныеСессии.Пользователь);
		
		Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена", Истина));	
		
	Иначе
		
		ВладелецФайла = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ВебКабинетСУ.Перевод(ТипВладельца, "Метаданные")).ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));
		
		ЗагруженныеФайлы = Новый Массив;
		
		Для каждого ФайлДляЗаписи Из ФайлыДляЗаписи Цикл
		
			СсылкаНаФайл = ПрисоединенныеФайлы.ДобавитьФайл(ВладелецФайла, ФайлДляЗаписи.ИмяФайлаБезРасширения, ФайлДляЗаписи.РасширениеФайлаБезТочки, ТекущаяДатаСеанса(), ФайлДляЗаписи.ВремяИзмененияФайла, ФайлДляЗаписи.АдресХраненияФайла,, ФайлДляЗаписи.ОписаниеФайла);
			
			Если НЕ ЗначениеЗаполнено(СсылкаНаФайл) Тогда
				Возврат ОтветКлиентуJSON("saveFileError");
			КонецЕсли;
			
			// Меняем автора на текущего пользователя
			
			ФайлОбъект = СсылкаНаФайл.ПолучитьОбъект();
			ФайлОбъект.Автор = ДанныеСессии.Пользователь;
			ФайлОбъект.Записать();
			
			ЗагруженныеФайлы.Добавить(Новый Структура("name, ref, extension",
				ФайлДляЗаписи.ИмяФайлаБезРасширения, Строка(СсылкаНаФайл.УникальныйИдентификатор()), ФайлДляЗаписи.РасширениеФайла));
			
		КонецЦикла;
			
		// Перепроводим документ владельца
		//
		
		ДокументыДляПерепроведения = Новый Массив;
		ДокументыДляПерепроведения.Добавить(ВладелецФайла);
		
		ОбщегоНазначенияСУ.ПровестиДокументы(ДокументыДляПерепроведения,,Новый Структура("НеОбновлятьДанныеВебКабинета", Истина));		
	
		ВебКабинетСУ.ОбновитьДанныеОбъекта(ОбщегоНазначения.МенеджерОбъектаПоСсылке(ВладелецФайла), ВладелецФайла);
		
		Возврат ОтветКлиентуJSON(,ЗагруженныеФайлы);

	КонецЕсли;	
	
		
КонецФункции

Функция УдалитьФайлPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем ссылку на файл
	//
	
	ТипВладельца           = Запрос.ПараметрыURL.Получить("ТипВладельца");
	ИдентификаторВладельца = Запрос.ПараметрыURL.Получить("ИдентификаторВладельца");
	ИдентификаторФайла     = Запрос.ПараметрыURL.Получить("ИдентификаторФайла");	
	Пользователь           = ДанныеСессии.Пользователь;
	НастройкиКлиента       = ОбщегоНазначенияСУ.JSONВДанные(Запрос.ПолучитьТелоКакСтроку());
	АдресФайла             = Неопределено;
	Права                  = ДанныеСессии.Права.Получить();
	
	// Примечание: в ПолучитьАдресФайлаPOST аналогичный алгоритм поиска файла 
	
	Если ТипВладельца = "common" Тогда
		
		Возврат ОтветКлиентуJSON("noPermissions");
		
	Иначе
		
		ВладелецФайла = Неопределено;
		ПользовательВладельца = Неопределено;
		
		Если ТипВладельца = "userActivity" Тогда			
			ВладелецФайла = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));
			ПользовательВладельца = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВладелецФайла, "Пользователь");
		КонецЕсли;
		
		Если ТипВладельца = "userTask" Тогда			
			ВладелецФайла = Документы.ПопыткаВыполненияЗаданияСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));
			ПользовательВладельца = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВладелецФайла, "ПрохождениеОбучения.Пользователь");			
		КонецЕсли;			
		
		Если ТипВладельца = "message" Тогда
			ВладелецФайла = Документы.СообщениеСУО.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторВладельца));
			ПользовательВладельца = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВладелецФайла, "Пользователь");
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ВладелецФайла) Тогда
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;
		
		
		ИмяСправочникаХраненияФайлов = РаботаСФайламиСлужебный.ИмяСправочникаХраненияФайлов(ВладелецФайла);
		
		Файл = Справочники[ИмяСправочникаХраненияФайлов].ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторФайла));
		
		ЕстьПравоУдаления = Ложь;
		
		Если ТипЗнч(ВладелецФайла) = Тип("ДокументСсылка.ПопыткаВыполненияЗаданияСУО") Тогда
			
			// Проверям, что автор файла совпадает с текущим пользователем, так как
			// в заданиях реализована возможность прикреплять файлы преподавателем.
				
			Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Файл, "Автор") = Пользователь Тогда
				ЕстьПравоУдаления = Истина;
			КонецЕсли;
			
		Иначе
			
			// Проверяем, что пользователь владельца, к которому прикреплен файл
			// совпадает с текущим пользователем, т.е. он удаляет файл своего объекта.
			// Автор файла может быть любой.
			
			Если ПользовательВладельца = Пользователь Тогда
				ЕстьПравоУдаления = Истина;
			КонецЕсли;
						
		КонецЕсли;
			

		Если НЕ ЕстьПравоУдаления Тогда
			Возврат ОтветКлиентуJSON("noPermissions");
		КонецЕсли;
		
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Файл) Тогда
		
		ФайлОбъект = Файл.ПолучитьОбъект();
		
		ФайлОбъект.ДополнительныеСвойства.Вставить("ОбновитьДанныеВебКабинетаВТранзакции", Истина);
		
		// Примечание: важно учитывать, что обновление данных веб-кабинета зависимых от файла объектов
		// работает только при пометке на удаление, но не при ее снятии, так как при снятии
		// сам файл не отмечается, как зависмый элемент, будучи помеченным на удаление.
		// В этом случае срабатывает подписка ПрисоединенныйФайлПриЗаписиСУО и документ перепроводится
		// регламетным заданием ПерепроведениеДокументовСУО. 
		
		ФайлОбъект.УстановитьПометкуУдаления(Истина, Истина);
		
	Иначе
		
		Возврат ОтветКлиентуJSON("errorData");
		
	КонецЕсли;	
	
	Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена", Истина));
	
КонецФункции

Функция ПолучитьИмяФайлаGET(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	

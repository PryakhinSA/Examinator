// Общее

Функция Используется() Экспорт
	УстановитьПривилегированныйРежим(Истина);
	Возврат Константы.ИспользоватьВебКабинетСУ.Получить();	
КонецФункции

Функция ВерсияAPI() Экспорт
	Возврат ПолучитьОбщийМакет("ВерсияAPIВебКабинетаСУ").ПолучитьТекст();	
КонецФункции

Функция Редакция() Экспорт
	УстановитьПривилегированныйРежим(Истина);
	ЗначениеНастройки = Константы.РедакцияВебКабинетаСУ.Получить();
	Если НЕ ЗначениеЗаполнено(ЗначениеНастройки) Тогда
		ЗначениеНастройки = Перечисления.РедакцииВебКабинетаСУ.Редакция20;
	КонецЕсли;
	Возврат ЗначениеНастройки;
КонецФункции

Функция РедакцияСтрока() Экспорт
	
	НомерРедакции = Редакция();
	
	Если НомерРедакции = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
		Возврат "2.0";
	КонецЕсли;
	
	Если НомерРедакции = Перечисления.РедакцииВебКабинетаСУ.Редакция30 Тогда
		Возврат "3.0";
	КонецЕсли;
	
	ВызватьИсключение НСтр("ru = 'Неизвестная редакция веб-кабинета'");
	
КонецФункции

Функция НомерПакета() Экспорт
	
	НомерПакета = ВерсияAPI();
	НомерПакета	= СтрЗаменить(НомерПакета, ".", "");
	НомерПакета = СокрЛП(НомерПакета);
	
	Возврат НомерПакета;
	
КонецФункции

Функция Модификация() Экспорт
	Возврат "cu"; //--# ЗАМЕНИТЬ НА "cc"	
КонецФункции

Функция ПутьККаталогуКартинок(Знач Путь) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Путь) Тогда
		ВызватьИсключение НСтр("ru = 'Путь к каталогу веб-кабинета не задан'");	
	КонецЕСли;	
	
	ПутьКаталогуКабинета = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(Путь);
	
	Если ИспользуетсяАвтоматическаяНастройка() Тогда
		ЕдинственнаяПубликация = Справочники.ПубликацииВебКабинетаСУ.ЕдинственнаяПубликацияВОбщемКаталоге();
		ОтносительныйПуть = "cabinet\"; // По умолчанию
		Если ЗначениеЗаполнено(ЕдинственнаяПубликация) Тогда
			ДанныеПубликации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЕдинственнаяПубликация, "АдресКаталогаКартинок, АдресПубликации, Редакция");
			Если ДанныеПубликации.Редакция = Перечисления.РедакцииВебКабинетаСУ.Редакция30
				И ЗначениеЗаполнено(ДанныеПубликации.АдресКаталогаКартинок) Тогда
				ОтносительныйПуть = СтрЗаменить(ДанныеПубликации.АдресКаталогаКартинок, ДанныеПубликации.АдресПубликации + "/", ""); 
			КонецЕсли;
		КонецЕсли;		
		ПутьКаталогуКабинета = ПутьКаталогуКабинета + ОтносительныйПуть;
	Иначе
		ПутьКаталогуКабинета = ПутьКаталогуКабинета + "v8cabinet\" 
			+ СтандартныеПодсистемыСервер.ИдентификаторИнформационнойБазы() + "\" + НомерПакета();
	КонецЕсли;
	
	ПутьКаталогуКабинета = ОбщегоНазначенияСУКлиентСервер.ПривестиСлэши(ПутьКаталогуКабинета);	
	ПутьКаталогуКабинета = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКаталогуКабинета);
	
	Возврат ПутьКаталогуКабинета;
	
КонецФункции

Функция ПутьККаталогуУстановки(Знач Путь) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Путь) Тогда
		ВызватьИсключение НСтр("ru = 'Путь к каталогу веб-кабинета не задан'");	
	КонецЕСли;
	
	Если Редакция() = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда		
		
		Возврат ПутьККаталогуКартинок(Путь); // Картинки размещаются вместе с файлами кабинета
		
	Иначе
		
		ПутьКаталогуКабинета = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(Путь);
		ПутьКаталогуКабинета = ПутьКаталогуКабинета + "wc";		
		ПутьКаталогуКабинета = ОбщегоНазначенияСУКлиентСервер.ПривестиСлэши(ПутьКаталогуКабинета);	
		ПутьКаталогуКабинета = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКаталогуКабинета);
		
		Возврат ПутьКаталогуКабинета;
		
	КонецЕсли;
	
КонецФункции

Функция ИмяФайлаНастроек(Редакция = Неопределено) Экспорт
	
	Если Редакция = Неопределено Тогда
		НомерРедакции = Редакция();
	Иначе
		НомерРедакции = Редакция;
	КонецЕсли;
	
	Если НомерРедакции = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
		Возврат "v8-settings.js";
	КонецЕсли;
	
	Если НомерРедакции = Перечисления.РедакцииВебКабинетаСУ.Редакция30 Тогда
		Возврат "sdo-settings.js";
	КонецЕсли;
	
	ВызватьИсключение НСтр("ru = 'Неизвестная редакция веб-кабинета'");
	
КонецФункции


// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

// Ведомость

&НаСервере
Процедура ЗагрузитьВедомость()
	
	УстановитьПривилегированныйРежим(Истина);
	
	Ведомость.Очистить();	
	ВариантыЗаданий.Очистить();	
	
	ШкалаОценки = Документы.ПроведениеОбученияСУО.ШкалаОценки(ПроведениеОбучения);
			
	// Заполняем данные о прохождении пользователями мероприятия
	
	Запрос = Новый Запрос;

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УчастникиОбучения.Статус КАК Статус,
		|	УчастникиОбучения.Баллы КАК Баллы,
		|	ВЫБОР
		|		КОГДА УчастникиОбучения.СтатусПроцессаОбучения = ЗНАЧЕНИЕ(Перечисление.СтатусыПроцессаОбученияСУО.Окончено)
		|				ИЛИ УчастникиОбучения.СтатусПроцессаОбучения = ЗНАЧЕНИЕ(Перечисление.СтатусыПроцессаОбученияСУО.ОконченоАвтоматом)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК Пройдено,
		|	УчастникиОбучения.Пользователь КАК Пользователь,
		|	УчастникиОбучения.ШкалаОценки КАК ШкалаОценки,
		|	ВЫБОР
		|		КОГДА ИСТИНА
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.ЭлементыШкалыОценокСУО.ПустаяСсылка)
		|	КОНЕЦ КАК ИтоговаяОценка,
		|	ВЫБОР
		|		КОГДА ИСТИНА
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.ЭлементыШкалыОценокСУО.ПустаяСсылка)
		|	КОНЕЦ КАК ТекущаяОценка,
		|	УчастникиОбучения.Регистратор КАК Прохождение,
		|	УчастникиОбучения.КомментарийПреподавателя КАК КомментарийПреподавателя,
		|	ВЫБОР
		|		КОГДА УчастникиОбучения.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.Завершил)
		|			ТОГДА 1
		|		КОГДА УчастникиОбучения.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.Автомат)
		|			ТОГДА 1
		|		КОГДА УчастникиОбучения.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.НеЗавершил)
		|			ТОГДА 0
		|		КОГДА УчастникиОбучения.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.НеДопущен)
		|			ТОГДА 0
		|		КОГДА УчастникиОбучения.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПрохожденияОбъектовСУО.Проходит)
		|			ТОГДА 2
		|		ИНАЧЕ 3
		|	КОНЕЦ КАК Картинка,
		|	УчастникиОбучения.Пользователь.Наименование КАК ПолноеИмяПользователя,
		|	УчастникиОбучения.ПроверяетсяПреподавателем КАК ПроверяетсяПреподавателем,
		|	УчастникиОбучения.ПроверенПреподавателем КАК ПроверенПреподавателем,
		|	УчастникиОбучения.ВозвращеноНаДоработку КАК ВозвращеноНаДоработку,
		|	УчастникиОбучения.СтатусПроцессаОбучения КАК СтатусПроцессаОбучения,
		|	УчастникиОбучения.ТекущиеБаллы КАК ТекущиеБаллы,
		|	УчастникиОбучения.ВыставляетсяОценка КАК ВыставляетсяОценка
		|ИЗ
		|	РегистрСведений.УчастникиОбученияСУО КАК УчастникиОбучения
		|ГДЕ
		|	УчастникиОбучения.ПроведениеОбучения = &ПроведениеОбучения
		|	И УчастникиОбучения.Сценарий = &Сценарий
		|
		|УПОРЯДОЧИТЬ ПО
		|	Пользователь";
		
	Запрос.УстановитьПараметр("Сценарий", Сценарий);
	Запрос.УстановитьПараметр("ПроведениеОбучения", ПроведениеОбучения);

	Результат = Запрос.Выполнить();

	ТаблицаПрохождений = Результат.Выгрузить();

	Для каждого Строка Из ТаблицаПрохождений Цикл
		
		// Ведомость
		
		НоваяСтрокаВедомости = Ведомость.Добавить();
		НоваяСтрокаВедомости.Пользователь              = Строка.Пользователь;
		НоваяСтрокаВедомости.ПолноеИмяПользователя     = Строка.ПолноеИмяПользователя;
		НоваяСтрокаВедомости.Пройдено                  = Строка.Пройдено;
		НоваяСтрокаВедомости.Прохождение               = Строка.Прохождение;
		НоваяСтрокаВедомости.Статус                    = Строка.Статус;
		НоваяСтрокаВедомости.Картинка                  = Строка.Картинка;
		НоваяСтрокаВедомости.Баллы                     = Строка.Баллы;
		НоваяСтрокаВедомости.ИтоговаяОценка            = Строка.ИтоговаяОценка;
		НоваяСтрокаВедомости.ТекущиеБаллы              = Строка.ТекущиеБаллы;
		НоваяСтрокаВедомости.ТекущаяОценка             = Строка.ТекущаяОценка;
		НоваяСтрокаВедомости.ШкалаОценки               = Строка.ШкалаОценки;
		НоваяСтрокаВедомости.Комментарий               = Строка.КомментарийПреподавателя;
		НоваяСтрокаВедомости.ПроверяетсяПреподавателем = Строка.ПроверяетсяПреподавателем;
		НоваяСтрокаВедомости.ПроверенПреподавателем    = Строка.ПроверенПреподавателем;
		НоваяСтрокаВедомости.ВозвращеноНаДоработку     = Строка.ВозвращеноНаДоработку;
		НоваяСтрокаВедомости.СтатусПроцессаОбучения    = Строка.СтатусПроцессаОбучения;
		НоваяСтрокаВедомости.ВыставляетсяОценка        = Строка.ВыставляетсяОценка;
		// Варианты заданий
		
		НоваяСтрокаВарианты = ВариантыЗаданий.Добавить();
		НоваяСтрокаВарианты.Пользователь   = Строка.Пользователь;
		НоваяСтрокаВарианты.Прохождение    = Строка.Прохождение;
		
				
	КонецЦикла;
	
	///////////////////////////////////////////////////////////////////
	// Получаем оценки пользователей
	
	ПоказыватьТекущуюОценкуНастройкаВида = ВидОбучения.ПоказыватьТекущуюОценку;
	ЕстьТекущаяОценка = Ложь;
	
	Если ВидОбучения.ВыставляетсяОценка Тогда
	
		///////////////////////////////////////////////////////////////////
		// Получаем итоговую оценку для каждого пользователя
		
		Для каждого Строка Из Ведомость Цикл
			
			Если Строка.Пройдено И Строка.ВыставляетсяОценка Тогда
				Строка.ИтоговаяОценка = УправлениеОбучениемСУОПовтИсп.ОценкаИзБаллов(Строка.Баллы, Строка.ШкалаОценки);				
			КонецЕсли;
			
			Если ПоказыватьТекущуюОценкуНастройкаВида 
				И Строка.ВыставляетсяОценка
				И Строка.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Проходит Тогда
				Строка.ТекущаяОценка = УправлениеОбучениемСУОПовтИсп.ОценкаИзБаллов(Строка.ТекущиеБаллы, Строка.ШкалаОценки);
				Если Строка.ТекущиеБаллы > 0 Тогда
					ЕстьТекущаяОценка = Истина;
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
		
		// Устанавливаем параметры выбора для итоговой оценки.
		
		МассивПараметровВыбора = Новый Массив();
		МассивПараметровВыбора.Добавить(Новый ПараметрВыбора("Отбор.Владелец", ШкалаОценки));
		Элементы.ВедомостьИтоговаяОценка.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметровВыбора);		
		
	КонецЕсли;
	
	ПоказыватьТекущуюОценку = ЕстьТекущаяОценка;
	
	///////////////////////////////////////////////////////////////////
	// Размещаем задания
	
	ТаблицаВсехЗаданийПроведения = Документы.ПроведениеОбученияСУО.ЗаданияОбучения(ПроведениеОбучения, Сценарий);
	
	Если ТаблицаВсехЗаданийПроведения.Количество() > 0 Тогда
		
		// Добавляем колонки к ведомости (задания)
		
		Для каждого СтрокаТВЗ Из ТаблицаВсехЗаданийПроведения Цикл
			
			Если Задания.НайтиСтроки(Новый Структура("Задание", СтрокаТВЗ.Задание)).Количество() > 0 Тогда
				Продолжить;
			КонецЕсли;
			
			// Заполняем таблицу "Задания". 
			
			НовоеЗадание = Задания.Добавить();
			
			НовоеЗадание.Задание                     = СтрокаТВЗ.Задание;
			НовоеЗадание.Наименование                = СтрокаТВЗ.Наименование;
			НовоеЗадание.НесколькоВариантов          = СтрокаТВЗ.НесколькоВариантов;
			НовоеЗадание.Номер                       = Задания.Количество();
			НовоеЗадание.ТолькоПросмотр              = (СтрокаТВЗ.НаОсновеЭлектронногоРесурса И НЕ СтрокаТВЗ.ПреподавательВыставляетОценку);
			НовоеЗадание.НаОсновеЭлектронногоРесурса = СтрокаТВЗ.НаОсновеЭлектронногоРесурса;
			НовоеЗадание.РазмещеноВВедомости         = Ложь;
			
			Если СтрокаТВЗ.НесколькоВариантов Тогда
				ЕстьЗаданияСНесколькимиВариантами = Истина; // Реквизит формы	
			КонецЕсли;
			
		КонецЦикла;
		
		Для каждого Строка Из Задания Цикл
			
			Если Строка.РазмещеноВВедомости Тогда
				Продолжить;
			КонецЕсли;
			
			НомерЗаданияСтрока = ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(Строка.Номер);
			
			// 1. Создаем реквизиты формы для ведомости и вариантов заданий
			
			// Создаем реквизит, где будет хранится информация об оценке (колонка к таблице "Ведомость").
			
			МассивТиповРеквизитаЗадание = Новый Массив;
			МассивТиповРеквизитаЗадание.Добавить(Тип("СправочникСсылка.ЭлементыШкалыОценокСУО"));
			МассивТиповРеквизитаЗадание.Добавить(Тип("СправочникСсылка.ПричиныВозвратаЗаданияНаДоработкуСУО"));
			МассивТиповРеквизитаЗадание.Добавить(Тип("Строка"));
			
			Реквизит1 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока,
										   Новый ОписаниеТипов(МассивТиповРеквизитаЗадание),
										   "Ведомость",
										   Строка.Наименование,
										   Ложь); 
										   
			
			Реквизит2 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "ПроверяетсяПреподавателем",
										   Новый ОписаниеТипов("Булево"),
										   "Ведомость",
										   "Задание """ + Строка.Наименование + """ проверяется преподавателем",
										   Ложь); 
										   
										   
			Реквизит3 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "ПроверенПреподавателем",
										   Новый ОписаниеТипов("Булево"),
										   "Ведомость",
										   "Задание """ + Строка.Наименование + """ проверено преподавателем",
										   Ложь); 
										   
										   
			Реквизит4 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "КомментарийПреподавателя",
										   Новый ОписаниеТипов("Строка"),
										   "Ведомость",
										   "Комментарий к выполнению задания """ + Строка.Наименование + """",
										   Истина); 
										   
										   
			Реквизит5 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "Прохождение",
										   Новый ОписаниеТипов("ДокументСсылка.ПопыткаВыполненияЗаданияСУО"),
										   "Ведомость",
										   "Ссылка на попытку выполнения задания """ + Строка.Наименование + """",
										   Ложь); 
										   
										   
			Реквизит6 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "ЭлектронныйРесурс",
										   Новый ОписаниеТипов("СправочникСсылка.СводыЗнанийСУЗ"),
										   "Ведомость",
										   "Электронный ресурс задания """ + Строка.Наименование + """",
										   Ложь); 
										   
										   
			Реквизит7 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "ФрагментЭлектронногоРесурса",
										   Новый ОписаниеТипов("СправочникСсылка.СодержаниеСУЗ"),
										   "Ведомость",
										   "Фрагмент электронного ресурса задания """ + Строка.Наименование + """",
										   Ложь); 
										   
										   
			Реквизит8 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "Ссылка",
										    Метаданные.ОпределяемыеТипы.ЗаданиеЭлектронногоОбучения.Тип,
										   "Ведомость",
										   "Ссылка на задание """ + Строка.Наименование + """",
										   Ложь); 
										   
			Реквизит9 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "ПрохождениеОбучения",
										   Новый ОписаниеТипов("ДокументСсылка.ПрохождениеОбученияСУО"),
										   "Ведомость",
										   "Ссылка на прохождения мероприятия задания """ + Строка.Наименование + """",
										   Ложь); 
										   
			Реквизит10 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "НесколькоВариантов",
										   Новый ОписаниеТипов("Булево"),
										   "Ведомость",
										   "Несколько вариантов у задания """ + Строка.Наименование + """",
										   Ложь); 
										   
			Реквизит11 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "Вариант",
										   Новый ОписаниеТипов("СправочникСсылка.ВариантыЗаданийСУО"),
										   "Ведомость",
										   "Вариант задания """ + Строка.Наименование + """",
										   Ложь); 
										   
			Реквизит12 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "ВозвращеноНаДоработку",
										   Новый ОписаниеТипов("Булево"),
										   "Ведомость",
										   НСтр("ru = 'Возвращено на доработку'"),
										   Ложь); 
										   
			Реквизит13 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "ПричинаВозвратаНаДоработку",
										   Новый ОписаниеТипов("СправочникСсылка.ПричиныВозвратаЗаданияНаДоработкуСУО"),
										   "Ведомость",
										   НСтр("ru = 'Причина возврата на доработку'"),
										   Ложь); 
										   
			Реквизит14 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "Оценка",
										   Новый ОписаниеТипов("СправочникСсылка.ЭлементыШкалыОценокСУО"),
										   "Ведомость",
										   НСтр("ru = 'Оценка'"),
										   Ложь);										   
										   
			Реквизит15 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "ПопыткаЗавершена",
										   Новый ОписаниеТипов("Булево"),
										   "Ведомость",
										   НСтр("ru = 'Попытка завершена'"),
										   Ложь); 
										   
										   
										   
			Если Строка.НесколькоВариантов Тогда							   
										   
			    // Создаем реквизиты для таблицы "Варианты заданий"
				
				Реквизит16 = Новый РеквизитФормы("ВариантЗадания" + НомерЗаданияСтрока,
											   Новый ОписаниеТипов("СправочникСсылка.ВариантыЗаданийСУО"),
											   "ВариантыЗаданий",
											   Строка.Наименование,
											   Истина); 
				
											   
				Реквизит17 = Новый РеквизитФормы("ВариантЗадания" + НомерЗаданияСтрока + "Прохождение",
											   Новый ОписаниеТипов("ДокументСсылка.ПопыткаВыполненияЗаданияСУО"),
											   "ВариантыЗаданий",
											   "Ссылка на попытку выполнения задания """ + Строка.Наименование + """",
											   Ложь); 
											   
			КонецЕсли;
			
			Реквизит18 = Новый РеквизитФормы("Задание" + НомерЗаданияСтрока + "ВыставляетсяОценка",
										   Новый ОписаниеТипов("Булево"),
										   "Ведомость",
										   НСтр("ru = 'Выставляется оценка'"),
										   Ложь); 			
			
			ДобавляемыеРеквизиты = Новый Массив();										   
			ДобавляемыеРеквизиты.Добавить(Реквизит1);
			ДобавляемыеРеквизиты.Добавить(Реквизит2);
			ДобавляемыеРеквизиты.Добавить(Реквизит3);
			ДобавляемыеРеквизиты.Добавить(Реквизит4);
			ДобавляемыеРеквизиты.Добавить(Реквизит5);
			ДобавляемыеРеквизиты.Добавить(Реквизит6);
			ДобавляемыеРеквизиты.Добавить(Реквизит7);
			ДобавляемыеРеквизиты.Добавить(Реквизит8);
			ДобавляемыеРеквизиты.Добавить(Реквизит9);
			ДобавляемыеРеквизиты.Добавить(Реквизит10);
			ДобавляемыеРеквизиты.Добавить(Реквизит11);
			ДобавляемыеРеквизиты.Добавить(Реквизит12);
			ДобавляемыеРеквизиты.Добавить(Реквизит13);
			ДобавляемыеРеквизиты.Добавить(Реквизит14);
			ДобавляемыеРеквизиты.Добавить(Реквизит15);
			
			Если Строка.НесколькоВариантов Тогда				
				ДобавляемыеРеквизиты.Добавить(Реквизит16);

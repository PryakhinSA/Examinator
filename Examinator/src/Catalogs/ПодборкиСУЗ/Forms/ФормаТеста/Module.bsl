
#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Заполняем переменные
	
	ЭлектронныйРесурс        = Параметры.ЭлектронныйРесурс;
	СоздатьЭлектронныйРесурс = Параметры.СоздатьЭлектронныйРесурс;
	ЭлементСодержания        = Параметры.ЭлементСодержания;
	
	Если НЕ Объект.ЭтоТест Тогда
		Объект.ЭтоТест = Истина;
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.ПоказыватьНавигацию = Ложь;
	КонецЕсли;
	
	Если Параметры.Свойство("ЗначенияЗаполнения")
		И Параметры.ЗначенияЗаполнения.Свойство("Родитель") Тогда
		РодительЭлектронногоРесурса = Параметры.ЗначенияЗаполнения.Родитель;
	КонецЕсли;
	
	//////////////////////////////////////////////////////////////////
	
	РазработкаСУЗ.УстановитьПредпочитаемогоПоставщика(Объект);
	
	// Устанавливаем доступность данных от поставщика
	
	ТаблицаДоступностиДанныхПоставщика = РазработкаСУЗ.ПолучитьТаблицуДоступностиДанныхПоставщика();

	Строка = ТаблицаДоступностиДанныхПоставщика.Добавить();
	Строка.ЭлементФормы = Элементы.Вопросы;
	Строка.Свойство = "ТолькоПросмотр";
	Строка.Значение = Ложь;
	
	Строка = ТаблицаДоступностиДанныхПоставщика.Добавить();
	Строка.ЭлементФормы = Элементы.ЭлементыПодборкиИзРубрикатора;
	Строка.Свойство = "ТолькоПросмотр";
	Строка.Значение = Ложь;
	
	Строка = ТаблицаДоступностиДанныхПоставщика.Добавить();
	Строка.ЭлементФормы = Элементы.Комментарии;
	Строка.Свойство = "ТолькоПросмотр";
	Строка.Значение = Ложь;
	
	Строка = ТаблицаДоступностиДанныхПоставщика.Добавить();
	Строка.ЭлементФормы = Элементы.Сложности;
	Строка.Свойство = "ТолькоПросмотр";
	Строка.Значение = Ложь;
	
	Строка = ТаблицаДоступностиДанныхПоставщика.Добавить();
	Строка.ЭлементФормы = Элементы.СхемаАнализаПсихологическогоТестирования;
	Строка.Свойство = "ТолькоПросмотр";
	Строка.Значение = Ложь;
	
	РазработкаСУЗ.УстановитьДоступностьДанныхОтПоставщика(ЭтотОбъект, ТаблицаДоступностиДанныхПоставщика);
	
	//////////////////////////////////////////////////////////////////
	
	УстановитьЗаголовок();
	УстановитьДоступностьЭлементовФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	РазработкаСУЗКлиент.УстановитьКонтекстЭлектронногоРесурса(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	РазработкаСУЗКлиент.ОбработкаВыбораНовогоЭлементаСУЗ(ВыбранноеЗначение, ИсточникВыбора, ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаЗаписиНового(НовыйОбъект, Источник, СтандартнаяОбработка)
	РазработкаСУЗКлиент.ОбработкаЗаписиНовогоЭлементаСУЗ(НовыйОбъект, Источник, ЭтотОбъект, СтандартнаяОбработка);
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	УстановитьЗаголовок();
	УстановитьДоступностьЭлементовФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если СоздатьЭлектронныйРесурс И НЕ ЗначениеЗаполнено(ЭлектронныйРесурс) И Объект.Ссылка.Пустая() Тогда
		ПараметрыЗаписи.Вставить("СоздатьЭлектронныйРесурс", Истина);
		ПараметрыЗаписи.Вставить("РодительЭлектронногоРесурса", РодительЭлектронногоРесурса);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
		ПараметрыЗаписи.Вставить("ЭлектронныйРесурс", ЭлектронныйРесурс);		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если ЗначениеЗаполнено(ЭлементСодержания) Тогда
		Справочники.СодержаниеСУЗ.Перезаписать(ЭлементСодержания);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Для каждого Параметр Из ПараметрыЗаписи Цикл
		ТекущийОбъект.ДополнительныеСвойства.Вставить(Параметр.Ключ, Параметр.Значение);	
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	РазработкаСУЗ.УдалитьЭлементПослеЗаписи(ЭлементыДляУдаления);	
	
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ЭлектронныйРесурс") Тогда
		ЭлектронныйРесурс = ТекущийОбъект.ДополнительныеСвойства.ЭлектронныйРесурс;
	КонецЕсли;
	
	УстановитьЗаголовок();
	УстановитьДоступностьЭлементовФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("ОбъектСУЗЗаписан", Объект.Ссылка, ЭтотОбъект);
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
		Оповестить("ЭлектронныйРесурсОбновлен", ЭлектронныйРесурс, ЭтотОбъект);
		Оповестить("ЭлектронныйРесурсЗаписан", Объект.Ссылка, ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "ПодборкаОбновлена" И Источник <> ЭтотОбъект Тогда
		Элементы.Вопросы.Обновить();
	КонецЕсли;
КонецПроцедуры


#КонецОбласти


#Область ОбработчикиСобытийЭлементовШапкиФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура ПоказыватьНавигациюПриИзменении(Элемент)
	УстановитьДоступностьЭлементовФормы();
КонецПроцедуры

&НаКлиенте
Процедура ИсключитьОткрытыеВопросыПриИзменении(Элемент)
	УстановитьДоступностьЭлементовФормы();
КонецПроцедуры

&НаКлиенте
Процедура ВыбиратьЭлементыИзРубрикатораПриИзменении(Элемент)
	УстановитьДоступностьЭлементовФормы();
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияЭлектронныйРесурсНажатие(Элемент)
	Если ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
		ПоказатьЗначение(,ЭлектронныйРесурс);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбщийФинальныйРесурсОткрытие(Элемент, СтандартнаяОбработка)
	РазработкаСУЗКлиент.ОбработкаОткрытияРесурса(Элемент, СтандартнаяОбработка, Объект.ОбщийФинальныйРесурс);
КонецПроцедуры

&НаКлиенте
Процедура ОбщийФинальныйРесурсСоздание(Элемент, СтандартнаяОбработка)
	РазработкаСУЗКлиент.ОбработкаСозданияРесурса(ЭтотОбъект, Элемент, СтандартнаяОбработка, Объект.Ссылка); 
КонецПроцедуры

&НаКлиенте
Процедура ОбщийФинальныйРесурсОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	РазработкаСУЗКлиент.ОбработкаВыбораРесурса(ВыбранноеЗначение);
КонецПроцедуры

&НаКлиенте
Процедура НазначениеТестированияПриИзменении(Элемент)
	УстановитьДоступностьЭлементовФормы();
КонецПроцедуры


#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыВопросы

// ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЦЫ ФОРМЫ Вопросы

&НаКлиенте
Процедура ВопросыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ОбщегоНазначенияСУКлиент.ПередВыборомЭлементаПодчиненногоСправочника(ЭтотОбъект, СтандартнаяОбработка);
	
	Если СтандартнаяОбработка Тогда
		
		СтандартнаяОбработка = Ложь;

		ОткрытьВопрос();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	ОбщегоНазначенияСУКлиент.ПередДобавлениемЭлементаПодчиненногоСправочника(ЭтотОбъект, Отказ);
КонецПроцедуры

&НаКлиенте
Процедура ВопросыОбработкаЗаписиНового(НовыйОбъект, Источник, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(НовыйОбъект) И ТипЗнч(НовыйОбъект) <> Тип("СправочникСсылка.ЭлементыПодборкиСУЗ") Тогда
		
		СтандартнаяОбработка = Ложь;
		ВыделеннаяГруппа = ОбщегоНазначенияСУКлиент.ВыделеннаяГруппаТаблицы(Элементы.Вопросы);
		
		Если ТипЗнч(НовыйОбъект) = Тип("СправочникСсылка.ВопросыСУЗ") Тогда
			Если Источник.Элементы.Найти("ВесВопроса") = Неопределено Тогда 
				ВесВопроса = 1;
			Иначе
				ВесВопроса = Источник.ВесВопроса;
			КонецЕсли;
			ПоместитьВопросВТест(НовыйОбъект, Объект.Ссылка, ВесВопроса, ВыделеннаяГруппа);
		Иначе
			ПоместитьЭлементВПодборку(Объект.Ссылка, НовыйОбъект, ВыделеннаяГруппа);
		КонецЕсли;
		
		Элементы.Вопросы.Обновить();
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВопросыОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) И ТипЗнч(ВыбранноеЗначение) <> Тип("СправочникСсылка.ЭлементыПодборкиСУЗ") Тогда
		
		СтандартнаяОбработка = Ложь;
		
		ВыделеннаяГруппа = ОбщегоНазначенияСУКлиент.ВыделеннаяГруппаТаблицы(Элементы.Вопросы);
		
		Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.ВопросыСУЗ") Тогда
			ПоместитьВопросВТест(ВыбранноеЗначение, Объект.Ссылка,, ВыделеннаяГруппа);
		Иначе
			ПоместитьЭлементВПодборку(Объект.Ссылка, ВыбранноеЗначение, ВыделеннаяГруппа);
		КонецЕсли;
		
		Элементы.Вопросы.Обновить();
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти


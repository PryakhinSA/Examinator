  <attributes>
    <name>СтраницыЭлементов</name>
    <title>
      <key>ru</key>
      <value>Страницы элементов</value>
    </title>
    <id>68</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СтраницыЭлементов.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СтраницыЭлементов.СсылкаНаОбъектСУЗ</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СтраницыЭлементов.СсылкаНаЭлемент</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СтраницыЭлементов.ЕдинственныйФайл</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СтраницыЭлементов.Родитель</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СтраницыЭлементов.Ссылка</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СтраницыЭлементов.ЭлементСтраницы</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СтраницыЭлементов.ЭтоГруппа</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СтраницыЭлемента.Ссылка КАК Ссылка,
	СтраницыЭлемента.ПометкаУдаления КАК ПометкаУдаления,
	СтраницыЭлемента.Владелец КАК Владелец,
	СтраницыЭлемента.Родитель КАК Родитель,
	СтраницыЭлемента.ЭтоГруппа КАК ЭтоГруппа,
	СтраницыЭлемента.Код КАК Код,
	СтраницыЭлемента.Наименование КАК Наименование,
	СтраницыЭлемента.ДатаИзменения КАК ДатаИзменения,
	ВЫБОР
		КОГДА СтраницыЭлемента.ЭтоГруппа
			ТОГДА СтраницыЭлемента.Ссылка
		ИНАЧЕ СтраницыЭлемента.СсылкаНаЭлементКурса
	КОНЕЦ КАК ЭлементСтраницы,
	СтраницыЭлемента.Поставщик КАК Поставщик,
	СтраницыЭлемента.СсылкаНаЭлементКурса.ЕдинственныйЭлемент КАК ЕдинственныйФайл,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(СтраницыЭлемента.СсылкаНаЭлементКурса) = ТИП(Справочник.ЭлектронныеРесурсы)
			ТОГДА ВЫБОР
					КОГДА СтраницыЭлемента.СсылкаНаЭлементКурса.ЕдинственныйЭлемент = ЗНАЧЕНИЕ(Справочник.ЭлементыЭлектронныхРесурсов.ПустаяСсылка)
						ТОГДА ПРЕДСТАВЛЕНИЕ(ТИПЗНАЧЕНИЯ(СтраницыЭлемента.СсылкаНаЭлементКурса))
				КОНЕЦ
		КОГДА ТИПЗНАЧЕНИЯ(СтраницыЭлемента.СсылкаНаЭлементКурса) = ТИП(Справочник.ТестовыеВопросы)
			ТОГДА ПРЕДСТАВЛЕНИЕ(СтраницыЭлемента.СсылкаНаЭлементКурса.ТипВопроса)
		КОГДА СтраницыЭлемента.ЭтоГруппа = ИСТИНА
			ТОГДА &quot;Группа вопросов&quot;
		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(ТИПЗНАЧЕНИЯ(СтраницыЭлемента.СсылкаНаЭлементКурса))
	КОНЕЦ КАК Тип
ИЗ
	Справочник.СтраницыЭлементовЭлектронныхКурсов КАК СтраницыЭлемента</queryText>
      <mainTable>Catalog.СтраницыЭлементовЭлектронныхКурсов</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>

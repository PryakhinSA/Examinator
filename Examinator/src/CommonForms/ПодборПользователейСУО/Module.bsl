// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ОК(Команда)
		
	ВыбранныеПользователиСтроки = ВыбранныеПользователи.НайтиСтроки(Новый Структура("Исключен", Ложь));
	
	МассивПользователей = Новый Массив;
	
	Для каждого Строка Из ВыбранныеПользователиСтроки Цикл
		Если ЗначениеЗаполнено(Строка.Пользователь) Тогда
			МассивПользователей.Добавить(Строка.Пользователь);	
		КонецЕсли;
	КонецЦикла;
	
	ОповеститьОВыборе(МассивПользователей);
		
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПользователя(Команда)
	
	ИмяТаблицы = ПолучитьИмяТекущейТаблицыПользователей();
	
	Если Элементы[ИмяТаблицы].ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Пользователь = Элементы[ИмяТаблицы].ТекущиеДанные.Пользователь;
	
	ПоказатьЗначение(,Пользователь);

КонецПроцедуры


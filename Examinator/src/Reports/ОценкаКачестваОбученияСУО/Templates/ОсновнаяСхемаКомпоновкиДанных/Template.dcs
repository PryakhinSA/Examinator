	<settingsVariant>
		<dcsset:name>ДинамикаОценок</dcsset:name>
		<dcsset:presentation xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Динамика оценок</v8:content>

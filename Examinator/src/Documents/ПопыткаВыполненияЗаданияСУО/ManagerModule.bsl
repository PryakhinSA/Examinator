	Если ТипЗнч(ДанныеПопытки.Задание) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда
		ДанныеПопытки.НаОсновеЭлектронногоРесурса = Истина;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеПопытки.Задание) = Тип("СправочникСсылка.ЭлектронныеКурсы") Тогда
		ДанныеПопытки.НаОсновеЭлектронногоРесурса = Ложь;
	КонецЕсли;	
	
	Если ТипЗнч(ДанныеПопытки.НаОсновеЭлектронногоРесурса) <> Тип("Булево") Тогда
		ДанныеПопытки.НаОсновеЭлектронногоРесурса = Ложь;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеПопытки.ИспользуетсяФорматированныйДокумент) <> Тип("Булево") Тогда
		ДанныеПопытки.ИспользуетсяФорматированныйДокумент = Ложь;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеПопытки.КонтролироватьПрикреплениеФайлаКОтвету) <> Тип("Булево") Тогда
		ДанныеПопытки.КонтролироватьПрикреплениеФайлаКОтвету = Ложь;
	КонецЕсли;
		
	Если ТипЗнч(ДанныеПопытки.КонтролироватьПрикреплениеФайлаКОтвету) <> Тип("Булево") Тогда
		ДанныеПопытки.КонтролироватьПрикреплениеФайлаКОтвету = Ложь;
	КонецЕсли;	
	
	Если ТипЗнч(ДанныеПопытки.Проведен) <> Тип("Булево") Тогда
		ДанныеПопытки.Проведен = Ложь;
	КонецЕсли;		
	
	Если ТипЗнч(ДанныеПопытки.Задание) = Тип("СправочникСсылка.ЗаданияСУО")
		И ТипЗнч(ДанныеПопытки.ИспользуетсяФорматированныйДокумент) = Тип("Булево")
		И ДанныеПопытки.ИспользуетсяФорматированныйДокумент Тогда
		ОписаниеЗаданияСтруктура = ОбщегоНазначенияСУ.ПредставлениеФорматированногоДокументаДляВыгрузкиHTML(
			ДанныеПопытки.ОписаниеФорматированныйДокумент.Получить(), Строка(ДанныеПопытки.Задание.УникальныйИдентификатор()),,Ложь,Истина);
		ДанныеПопытки.ТекстОписанияЗадания = СокрЛП(ОписаниеЗаданияСтруктура.ПредставлениеHTML);
	КонецЕсли;
	
	ДанныеПопытки.ДатаНачалаДоступаКЗаданию = Документы.ПопыткаВыполненияЗаданияСУО.ДатаДоступаКЗаданию(ДанныеПопытки.ДатаНачалаДоступаКЗаданию, ДанныеПопытки.ДобавленоВремениВСекундах);
	ДанныеПопытки.ДатаОкончанияДоступаКЗаданию = Документы.ПопыткаВыполненияЗаданияСУО.ДатаДоступаКЗаданию(ДанныеПопытки.ДатаОкончанияДоступаКЗаданию, ДанныеПопытки.ДобавленоВремениВСекундах);	
	
	Возврат ДанныеПопытки;
	

    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДокументСообщениеСУО.Ссылка,
	ДокументСообщениеСУО.ПометкаУдаления,
	ДокументСообщениеСУО.Номер,
	ДокументСообщениеСУО.Дата,
	ДокументСообщениеСУО.Проведен,
	ДокументСообщениеСУО.Пользователь,
	ДокументСообщениеСУО.Тема,
	ДокументСообщениеСУО.ДатаИзменения,
	ДокументСообщениеСУО.Шаблон,
	ДокументСообщениеСУО.Рассылка,
	ДокументСообщениеСУО.ТолькоЭлектроннаяПочта,
	ДокументСообщениеСУО.РодительскоеСообщение,
	ДокументСообщениеСУО.Тема.Контекст КАК Адресат
ИЗ
	Документ.СообщениеСУО КАК ДокументСообщениеСУО
{ГДЕ
	(ДокументСообщениеСУО.Рассылка.Основание = &amp;ПроведениеОбучения
			ИЛИ ДокументСообщениеСУО.Рассылка.Основание.ПроведениеОбучения = &amp;ПроведениеОбучения),
	(ДокументСообщениеСУО.Рассылка.Основание = &amp;ПроведениеПрограммыОбучения
			ИЛИ ДокументСообщениеСУО.Рассылка.Основание.ПроведениеПрограммыОбучения = &amp;ПроведениеПрограммыОбучения)}</queryText>
      <mainTable>Document.СообщениеСУО</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <parameters>
    <name>ПроведениеОбучения</name>
    <valueType>
      <types>DocumentRef.ПроведениеОбученияСУО</types>

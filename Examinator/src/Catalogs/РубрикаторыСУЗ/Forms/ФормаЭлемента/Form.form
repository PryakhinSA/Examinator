  <attributes>
    <name>ЭлементыРубрикатора</name>
    <title>
      <key>ru</key>
      <value>Элементы рубрикатора</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЭлементыРубрикатора.Owner</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЭлементыРубрикатора.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СправочникЭлементыРубрикатораСУЗ.Ссылка,
	СправочникЭлементыРубрикатораСУЗ.ВерсияДанных,
	СправочникЭлементыРубрикатораСУЗ.ПометкаУдаления,
	СправочникЭлементыРубрикатораСУЗ.Предопределенный,
	СправочникЭлементыРубрикатораСУЗ.Владелец,
	СправочникЭлементыРубрикатораСУЗ.Родитель,
	СправочникЭлементыРубрикатораСУЗ.Код,
	СправочникЭлементыРубрикатораСУЗ.Наименование,
	СправочникЭлементыРубрикатораСУЗ.ДатаИзменения,
	СправочникЭлементыРубрикатораСУЗ.Поставщик,
	СправочникЭлементыРубрикатораСУЗ.РеквизитДопУпорядочивания,
	ЗапросКоличестваЭлементов.КоличествоЭлементов
ИЗ
	Справочник.ЭлементыРубрикатораСУЗ КАК СправочникЭлементыРубрикатораСУЗ
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			КОЛИЧЕСТВО(РубрикиОбъектовСУЗ.СсылкаНаОбъектСУЗ) КАК КоличествоЭлементов,
			РубрикиОбъектовСУЗ.ЭлементРубрикатора КАК ЭлементРубрикатора
		ИЗ
			РегистрСведений.РубрикиОбъектовСУЗ КАК РубрикиОбъектовСУЗ
		
		СГРУППИРОВАТЬ ПО
			РубрикиОбъектовСУЗ.ЭлементРубрикатора) КАК ЗапросКоличестваЭлементов
		ПО СправочникЭлементыРубрикатораСУЗ.Ссылка = ЗапросКоличестваЭлементов.ЭлементРубрикатора</queryText>
      <mainTable>Catalog.ЭлементыРубрикатораСУЗ</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>

		<dcsset:settings xmlns:style="http://v8.1c.ru/8.1/data/ui/style" xmlns:sys="http://v8.1c.ru/8.1/data/ui/fonts/system" xmlns:web="http://v8.1c.ru/8.1/data/ui/colors/web" xmlns:win="http://v8.1c.ru/8.1/data/ui/colors/windows">
			<dcsset:userFields>
				<dcsset:item xsi:type="dcsset:UserFieldExpression">
					<dcsset:dataPath>ПользовательскиеПоля.Поле1</dcsset:dataPath>
					<dcsset:lwsTitle>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Процент выставленных</v8:content>
						</v8:item>
					</dcsset:lwsTitle>
					<dcsset:detailExpression>Строка(Выразить(КоличествоВыставленныхОценок / (КоличествоНеВыставленныхОценок + КоличествоВыставленныхОценок) * 100, "Число(15,0)")) + "%"</dcsset:detailExpression>
					<dcsset:detailExpressionPresentation>Строка(Выразить([Количество выставленных оценок] / ([Количество не выставленных оценок] + [Количество выставленных оценок]) * 100, "Число(15,0)")) + "%"</dcsset:detailExpressionPresentation>
					<dcsset:totalExpression>Строка(Выразить(КоличествоВыставленныхОценок / (КоличествоНеВыставленныхОценок + КоличествоВыставленныхОценок) * 100, "Число(15,0)")) + "%"</dcsset:totalExpression>
					<dcsset:totalExpressionPresentation>Строка(Выразить([Количество выставленных оценок] / ([Количество не выставленных оценок] + [Количество выставленных оценок]) * 100, "Число(15,0)")) + "%"</dcsset:totalExpressionPresentation>
				</dcsset:item>
			</dcsset:userFields>
			<dcsset:selection>

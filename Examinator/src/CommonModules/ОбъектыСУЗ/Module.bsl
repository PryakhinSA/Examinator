// Получает параметры главного узла плана обмена "ОбменМатериаламиСУЗ".
//
Функция ПолучитьПараметрыГлавногоУзла(ИмяПараметра = "Код") Экспорт
	
	Если ИмяПараметра = "Код" Тогда
		Возврат "f0e1f496-1ed3-4f47-b06e-46b9bd8da578";
	КонецЕсли;
	
	Если ИмяПараметра = "Наименование" Тогда
		Возврат "Информационная база";
	КонецЕсли;
	
КонецФункции

Функция ПолучитьМассивИменФайловИнформаторовПригодныхДляИмпорта(МассивИменФайловИнформаторов) Экспорт
	
	МассивИменПригодныхФайлов = Новый Массив();
	
	Для каждого ИмяФайла Из МассивИменФайловИнформаторов Цикл

		МассивПараметров = ОбщегоНазначенияСУКлиентСервер.РасщепитьСтроку(ИмяФайла, ".");
		Если МассивПараметров.Количество() < 3 Тогда
			Продолжить;
		КонецЕсли;
		
		КодПакетаДанных = МассивПараметров[1];
		НомерВерсииПакетаДанных = Число(МассивПараметров[2]);
		
		УзелПакетаДанных = ПланыОбмена.ОбменМатериаламиСУЗ.НайтиПоКоду(КодПакетаДанных);
		
		Если (УзелПакетаДанных = ПланыОбмена.ОбменМатериаламиСУЗ.ПустаяСсылка()
			ИЛИ УзелПакетаДанных.НомерПринятого < НомерВерсииПакетаДанных)
			И НЕ УзелПакетаДанных.ЗапретитьИмпортИзКаталогаШаблонов Тогда
			
			МассивИменПригодныхФайлов.Добавить(ИмяФайла);
				
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивИменПригодныхФайлов;
	
КонецФункции

Процедура ЗапретитьВДальнейшемАвтоматическийИмпорт(ОписаниеПакета) Экспорт
	
	УзелПакетаДанных = ПланыОбмена.ОбменМатериаламиСУЗ.НайтиПоКоду(ОписаниеПакета.Код);
	
	Если НЕ ЗначениеЗаполнено(УзелПакетаДанных)
		ИЛИ УзелПакетаДанных.ТипПакетаДанных <> Перечисления.ТипыПакетовДанныхСУЗ.XML_V8 Тогда
		УзелПакетаДанныхОбъект = ПланыОбмена.ОбменМатериаламиСУЗ.СоздатьУзел();
		УзелПакетаДанныхОбъект.ТипПакетаДанных = Перечисления.ТипыПакетовДанныхСУЗ.XML_V8;
	Иначе
		УзелПакетаДанныхОбъект = УзелПакетаДанных.ПолучитьОбъект();
	КонецЕсли;
	
	УзелПакетаДанныхОбъект.Код                               = ОписаниеПакета.Код;
	УзелПакетаДанныхОбъект.Наименование                      = ОписаниеПакета.Наименование;
	УзелПакетаДанныхОбъект.ЭтоИмпортированныйПакет           = Истина;
	УзелПакетаДанныхОбъект.ЗапретитьИмпортИзКаталогаШаблонов = Истина;
	
	УзелПакетаДанныхОбъект.Записать();
	
КонецПроцедуры

Функция ПолучитьОписаниеПакетаДанных(ПутьКПакетуДанныхНаСервере) Экспорт
	
	Возврат ПланыОбмена.ОбменМатериаламиСУЗ.ПолучитьИнформациюОПакетеДанных(ПутьКПакетуДанныхНаСервере, Истина);
	
КонецФункции

Функция ПолучитьПутьКПакетуДанных(АдресФайлаВоВременномХранилище, ИмяФайла) Экспорт 
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресФайлаВоВременномХранилище);
	
	Файл = Новый Файл(ИмяФайла);
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла(Файл.Расширение);
	
	ДвоичныеДанные.Записать(ИмяВременногоФайла);
	
	Возврат ИмяВременногоФайла;
	
КонецФункции


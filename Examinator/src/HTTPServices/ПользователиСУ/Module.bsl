// ОБЩЕЕ
//

Функция ВерсияANY(Запрос)
	УстановитьПривилегированныйРежим(Истина);	
	НастройкиAPI = Новый Структура("Версия, База", ВебКабинетСУ.ВерсияAPI(), СтандартныеПодсистемыСервер.ИдентификаторИнформационнойБазы());	
	Возврат ОтветКлиентуJSON(,НастройкиAPI);	
КонецФункции

// ПОЛЬЗОВАТЕЛИ
//

Функция СоздатьПользователяPOST(ЗапросHTTP)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем данные запроса
	//
	
	ТелоЗапроса = ЗапросHTTP.ПолучитьТелоКакСтроку();		
	
	ДанныеПользователя = Новый Структура;
	ДополнительныеСведения = Новый Структура;
	
	Формат = ЗапросHTTP.ПараметрыЗапроса.Получить("format");
	
	Если Формат = Неопределено Тогда
		Формат = "json";
	КонецЕсли;
	
	Если Формат = "json" Тогда
		
		Попытка
			СтруктураДанных = ОбщегоНазначенияСУ.JSONВДанные(ТелоЗапроса);
			ДанныеПользователяМассив = СтруктураДанных.userData;
			ДополнительныеСведенияМассив = СтруктураДанных.additionalInformation;
		Исключение
		КонецПопытки;
		
		Если СтруктураДанных = Неопределено
			ИЛИ ДанныеПользователяМассив = Неопределено Тогда
			
			Возврат ОтветКлиентуJSON("errorData");
			
		КонецЕсли;		
		
		Для каждого СвойствоСтруктура Из ДанныеПользователяМассив Цикл
			ИмяСвойства = Перевод(СвойствоСтруктура.name, "Пользователи");	
			ДанныеПользователя.Вставить(ИмяСвойства, СвойствоСтруктура.value);
		КонецЦикла;
		
		Если ДополнительныеСведенияМассив = Неопределено Тогда
			ДополнительныеСведенияМассив = Новый Массив;
		КонецЕсли;		
		
		Для каждого СвойствоСтруктура Из ДополнительныеСведенияМассив Цикл
			ИмяСвойства = Перевод(СвойствоСтруктура.name, "Пользователи");	
			ДополнительныеСведения.Вставить(ИмяСвойства, СвойствоСтруктура.value);
		КонецЦикла;		
		
	Иначе
		
		СтруктураДанных = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(ТелоЗапроса);
		
		Для каждого ЭлементСтруктуры Из СтруктураДанных Цикл
		
			ИмяСвойства = Перевод(ЭлементСтруктуры.Ключ, "Пользователи");	
			ДанныеПользователя.Вставить(ИмяСвойства, ЭлементСтруктуры.Значение);				
		
		КонецЦикла;
		
		ДополнительныеСведения = ДанныеПользователя; // Все параметры передаются одной строкой
		
	КонецЕсли;
	
	// Делаем проверки
	//	
	
	КодПубликации = Неопределено;
	
	Если СтруктураДанных.Свойство("publication") Тогда
		КодПубликации = СтруктураДанных.publication;
	ИначеЕсли ДанныеПользователя.Свойство("Публикация") Тогда
		КодПубликации = ДанныеПользователя.Публикация;
	КонецЕсли;
	
	Если КодПубликации = Неопределено Тогда
		КодПубликации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Справочники.ПубликацииВебКабинетаСУ.ОсновнаяПубликация(), "Код");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(КодПубликации) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПубликацииВебКабинетаСУ.ИспользоватьПинКодыДляРегистрации КАК ИспользоватьПинКоды,
		|	ПубликацииВебКабинетаСУ.ПоляРегистрации.(
		|		Имя,
		|		Реквизит,
		|		КонтактнаяИнформация,
		|		Обязательное,
		|		ИспользоватьКакЛогин
		|	),
		|	ПубликацииВебКабинетаСУ.ДоступнаСвободнаяРегистрация
		|ИЗ
		|	Справочник.ПубликацииВебКабинетаСУ КАК ПубликацииВебКабинетаСУ
		|ГДЕ
		|	ПубликацииВебКабинетаСУ.Код = &Код";
	
	Запрос.УстановитьПараметр("Код", КодПубликации);
	
	РезультатЗапроса = Запрос.Выполнить();		
		
	Если РезультатЗапроса.Пустой() Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	НастройкиПубликации = РезультатЗапроса.Выбрать();		
	НастройкиПубликации.Следующий();
	
	Если НЕ НастройкиПубликации.ДоступнаСвободнаяРегистрация Тогда
		Возврат ОтветКлиентуJSON("noFunctionality");
	КонецЕсли;
	
	Если НастройкиПубликации.ИспользоватьПинКоды Тогда
		
		//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
		
		Если НЕ ДанныеПользователя.Свойство("ПинКод") Тогда
			Возврат ОтветКлиентуJSON("noPinCode");
		КонецЕсли;
		
		ДанныеПинКода = РегистрыСведений.ВыданныеПинКодыСУО.КодДоступенДляАктивации(
			ДанныеПользователя.ПинКод,
			?(ДополнительныеСведения.Свойство("ОпцияПинКода"), ДополнительныеСведения.ОпцияПинКода, Неопределено)
		);
		
		Если ДанныеПинКода.ТребуетсяОпция Тогда
			
			// Наборы свойств соответствуют дополнительным свойствам настроек пользователя, например.				
			
			ДополнительныеСведения = Новый Массив();
			ДополнительныеСведения.Добавить(Справочники.СерииПинКодовСУО.СтруктураОпцийДляВебКабинета(ДанныеПинКода.Серия));
			
			Возврат ОтветКлиентуJSON(, Новый Структура("additionalInformation", ДополнительныеСведения));
			
		КонецЕсли;
		
		Если НЕ ДанныеПинКода.ДоступенДляАктивации Тогда
			Возврат ОтветКлиентуJSON(ДанныеПинКода.КодОшибки);
		КонецЕсли;
		
		//----------------------------------//
		
		//--# КОНСТРУКТОР КУРСОВ ДОБАВИТЬ #--//

		// Возврат ОтветКлиентуJSON("noFunctionality");
		
		//----------------------------------//				
		
	КонецЕсли;
	
	// Находим имя поля логина
	//
	
	ВыборкаПолейРегистрации = НастройкиПубликации.ПоляРегистрации.Выбрать();
	ВыборкаПолейРегистрации.Сбросить();
	ИмяПоляЛогина = Неопределено;
	
	Пока ВыборкаПолейРегистрации.Следующий() Цикл
		
		ИмяСвойства = Перевод(ВыборкаПолейРегистрации.Имя, "Пользователи");
		
		Если ДанныеПользователя.Свойство(ИмяСвойства)
			И ЗначениеЗаполнено(ДанныеПользователя[ИмяСвойства])
			И ВыборкаПолейРегистрации.ИспользоватьКакЛогин Тогда
			
			ИмяПоляЛогина = ИмяСвойства;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;		
	
	// Получаем данные пользователя
	//	
	
	Если НЕ ДанныеПользователя.Свойство("ПолноеИмя") Тогда
		
		ПолноеИмя = "";
		
		Если ДанныеПользователя.Свойство("Фамилия") Тогда
			ПолноеИмя = ПолноеИмя + СокрЛП(ДанныеПользователя.Фамилия) + " ";	
		КонецЕсли;
		
		Если ДанныеПользователя.Свойство("Имя") Тогда
			ПолноеИмя = ПолноеИмя + СокрЛП(ДанныеПользователя.Имя) + " ";
		КонецЕсли;
		
		Если ДанныеПользователя.Свойство("Отчество") Тогда
			ПолноеИмя = ПолноеИмя + СокрЛП(ДанныеПользователя.Отчество) + " ";
		КонецЕсли;
		
		ПолноеИмя = СокрЛП(ПолноеИмя);
		
		Если НЕ ЗначениеЗаполнено(ПолноеИмя)
			И ДанныеПользователя.Свойство("Логин") Тогда
			
			ПолноеИмя = ДанныеПользователя.Логин;
			
		КонецЕсли;		
		
		Если НЕ ЗначениеЗаполнено(ПолноеИмя)
			И ЗначениеЗаполнено(ИмяПоляЛогина)
			И ДанныеПользователя.Свойство(ИмяПоляЛогина) Тогда
			
			ПолноеИмя = ДанныеПользователя[ИмяПоляЛогина];
			
		КонецЕсли;
		
		ДанныеПользователя.Вставить("ПолноеИмя", ПолноеИмя);
		
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(ДанныеПользователя.ПолноеИмя) Тогда
		Возврат ОтветКлиентуJSON("emptyUserName");
	КонецЕсли;
	
	Если ДанныеПользователя.Свойство("Логин") Тогда
		
		ПользовательИБСуществующий = ПользователиИнформационнойБазы.НайтиПоИмени(ДанныеПользователя.Логин);
		
		Если ПользовательИБСуществующий <> Неопределено Тогда
			Возврат ОтветКлиентуJSON("userAlreadyExist");	
		КонецЕсли;
		
	ИначеЕсли ЗначениеЗаполнено(ИмяПоляЛогина) Тогда
		
		ПользовательИБСуществующий = ПользователиИнформационнойБазы.НайтиПоИмени(ДанныеПользователя[ИмяПоляЛогина]);
		
		ДанныеПользователя.Вставить("Логин", ДанныеПользователя[ИмяПоляЛогина]);
		
		Если ПользовательИБСуществующий <> Неопределено Тогда
			Возврат ОтветКлиентуJSON("userAlreadyExist");	
		КонецЕсли;		
		
	Иначе
		
		// Генерируем авто-логин (не учитываются пользователи ИБ)
		
		Логин                = ПользователиСлужебныйКлиентСервер.ПолучитьКраткоеИмяПользователяИБ(ДанныеПользователя.ПолноеИмя);
		СчетчикПользователей = 0;
		Постфикс             = "";
		
		Пока Истина Цикл
	
			ПользовательИБСуществующий = ПользователиИнформационнойБазы.НайтиПоИмени(Логин + Постфикс);
			
			Если ПользовательИБСуществующий = Неопределено Тогда
				Прервать;
			Иначе
				СчетчикПользователей = СчетчикПользователей + 1;
				Постфикс = ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(СчетчикПользователей);				
			КонецЕсли;
			
			Если СчетчикПользователей > 100 Тогда
				Возврат ОтветКлиентуJSON("tooManyUsers");
			КонецЕсли;
			
		КонецЦикла;
		
		ДанныеПользователя.Вставить("Логин", Логин + Постфикс);
		
		Если СчетчикПользователей > 0 Тогда // Проверяем, что это однофамилец, а не тот же пользователь
			
			Если ДанныеПользователя.Свойство("ЭлектроннаяПочта") Тогда
				ЭлектроннаяПочта = ДанныеПользователя.ЭлектроннаяПочта;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭлектроннаяПочта) Тогда
				
				Запрос = Новый Запрос;
				Запрос.Текст = 
					"ВЫБРАТЬ
					|	КонтактнаяИнформация.Ссылка КАК Пользователь
					|ИЗ
					|	Справочник.Пользователи.КонтактнаяИнформация КАК КонтактнаяИнформация
					|ГДЕ
					|	КонтактнаяИнформация.АдресЭП = &ЭлектроннаяПочта
					|	И КонтактнаяИнформация.Ссылка.Наименование = &ПолноеИмя";
				
				Запрос.УстановитьПараметр("ЭлектроннаяПочта", ЭлектроннаяПочта);
				Запрос.УстановитьПараметр("ПолноеИмя", ДанныеПользователя.ПолноеИмя);
				
				РезультатЗапроса = Запрос.Выполнить();
				
				Если НЕ РезультатЗапроса.Пустой() Тогда
					Возврат ОтветКлиентуJSON("userAlreadyExist");
				КонецЕсли;
				
			КонецЕсли;			
			
		КонецЕсли;

		
	КонецЕсли;	
	
	// Получаем дополнительные реквизиты и дополнительные поля контактной информации

	КонтактнаяИнформацияПользователя = Новый ТаблицаЗначений;
	КонтактнаяИнформацияПользователя.Колонки.Добавить("ВидКонтактнойИнформации");
	КонтактнаяИнформацияПользователя.Колонки.Добавить("Значение");
	
	ДополнительныеРеквизитыПользователя = Новый ТаблицаЗначений;
	ДополнительныеРеквизитыПользователя.Колонки.Добавить("Реквизит");
	ДополнительныеРеквизитыПользователя.Колонки.Добавить("Значение");	
	
	ВыборкаПолейРегистрации.Сбросить();
	
	Пока ВыборкаПолейРегистрации.Следующий() Цикл
		
		Если ДанныеПользователя.Свойство(ВыборкаПолейРегистрации.Имя)
			И ЗначениеЗаполнено(ДанныеПользователя[ВыборкаПолейРегистрации.Имя]) Тогда
			
			Если ЗначениеЗаполнено(ВыборкаПолейРегистрации.КонтактнаяИнформация) Тогда
				
				НоваяСтрока = КонтактнаяИнформацияПользователя.Добавить();
				НоваяСтрока.ВидКонтактнойИнформации = ВыборкаПолейРегистрации.КонтактнаяИнформация;
				НоваяСтрока.Значение = ДанныеПользователя[ВыборкаПолейРегистрации.Имя];
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ВыборкаПолейРегистрации.Реквизит) Тогда
				
				НоваяСтрока = ДополнительныеРеквизитыПользователя.Добавить();
				НоваяСтрока.Реквизит = ВыборкаПолейРегистрации.Реквизит;
				НоваяСтрока.Значение = ДанныеПользователя[ВыборкаПолейРегистрации.Имя];				
				
			КонецЕсли;			
			
		КонецЕсли;		
		
	КонецЦикла;	
	
	// Записываем данные
	//
	
	НачатьТранзакцию();
	
	// Создаем нового пользователя
		
	Пользователь = ЗаписатьНовогоПользователя(,ДанныеПользователя.Логин, ДанныеПользователя.Пароль, ДанныеПользователя.ПолноеИмя, ?(ДанныеПользователя.Свойство("ЭлектроннаяПочта"), ДанныеПользователя.ЭлектроннаяПочта, ""), Истина, "", КонтактнаяИнформацияПользователя, ДополнительныеРеквизитыПользователя);
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//	
	
	// Сохраняем факт использования пин-кода
	
	Если НастройкиПубликации.ИспользоватьПинКоды Тогда
		РегистрыСведений.ВыданныеПинКодыСУО.АктивироватьКод(ДанныеПинКода.Серия, ДанныеПинКода.Код, Пользователь,, ДанныеПинКода.Опция,Истина);
	КонецЕсли;
	
	// Зачисляем пользователя на мероприятия (через фоновое задание)
		
	МассивПроведенийОбучения = Документы.ПроведениеОбученияСУО.ПроведенияОбученияДляАвтоЗачисленияНовогоВнешнегоПользователя(Пользователь);
	
	Для каждого ПроведениеОбучения Из МассивПроведенийОбучения Цикл
		РегистрыСведений.НовыеЗачисленияНаОбучениеСУО.ДобавитьЗачисление(Пользователь, ПроведениеОбучения);	
	КонецЦикла;	
	
	// Зачисляем на указанный при регистрации курс
	
	Если ДанныеПользователя.Свойство("Курс") Тогда
		
		Попытка
			ЭлектронныйРесурс = Справочники.СводыЗнанийСУЗ.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеПользователя.Курс));
		Исключение
		КонецПопытки;
		
		Если НЕ ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("errorData", Новый Структура("electronicResource, description", ДанныеПользователя.Курс, "Electronic resource is not found"));
		КонецЕсли;
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ПроведениеОбученияСУО.Регистратор КАК ПроведениеОбучения
			|ИЗ
			|	РегистрСведений.ПроведениеОбученияСУО КАК ПроведениеОбученияСУО
			|ГДЕ
			|	ПроведениеОбученияСУО.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПроведенияОбъектовСУО.Активно)
			|	И ПроведениеОбученияСУО.ДоступноВсем = ЛОЖЬ
			|	И ПроведениеОбученияСУО.ДоступноВнешнимПользователям = ИСТИНА
			|	И ПроведениеОбученияСУО.НаОсновеЭлектронногоРесурса = ИСТИНА
			|	И ПроведениеОбученияСУО.Сценарий = &ЭлектронныйРесурс
			|	И ПроведениеОбученияСУО.АвтозачислениеНаОбучение = ИСТИНА
			|
			|УПОРЯДОЧИТЬ ПО
			|	ПроведениеОбученияСУО.Период УБЫВ";
			
		Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);
		
		// ПроведениеОбученияСУО.ДоступноВсем = ЛОЖЬ,
		// Так как на обучение доступное всем будут зачислены все (см. выше),
		// А здесь только те, у кого в запросе есть код курса.
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() Тогда
			ОтменитьТранзакцию();
			Возврат ОтветКлиентуJSON("noCourse");	
		КонецЕсли;
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			УправлениеОбучениемСУО.ЗачислитьУчастникаНаОбучение(ВыборкаДетальныеЗаписи.ПроведениеОбучения,,Пользователь,,,,,,Истина);
		КонецЦикла;
		
	КонецЕсли;
	
	// Устанавливаем ограничение по времени
	
	Если ДанныеПользователя.Свойство("ОграничениеПоВремени")
		И ЗначениеЗаполнено(ДанныеПользователя.ОграничениеПоВремени) Тогда
		
		ОграничениеПоВремениЧисло = Число(ДанныеПользователя.ОграничениеПоВремени); // В днях
		
		Если ОграничениеПоВремениЧисло > 0 Тогда
			
			ДатаНачалаДоступа = ТекущаяДатаСеанса();
			ДатаОкончанияДоступа = ДатаНачалаДоступа + ОграничениеПоВремениЧисло*24*60*60;
			
			РегистрыСведений.ВремяДоступаПользователейСУО.УстановитьВремяДоступа(Пользователь, ДатаНачалаДоступа, ДатаОкончанияДоступа);
			
		КонецЕсли;
		
	КонецЕсли;
	
	//----------------------------------//
	
	ЗафиксироватьТранзакцию();
	
	//--# КОНСТРУКТОР КУРСОВ ДОБАВИТЬ #--//

	// ВебКабинетСУ.ОбновитьДанныеОбъекта(Справочники.СводыЗнанийСУЗ, Пользователь);
	
	//----------------------------------//	
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	// Запускаем фоновое задание. Если оно не будет выполнено,
	// то попытка будет продолжена через регламентное задание.
	
	МассивПараметровФЗ = Новый Массив;
	МассивПараметровФЗ.Добавить(Пользователь);
	МассивПараметровФЗ.Добавить(Истина);
	
	ФоновыеЗадания.Выполнить("УправлениеОбучениемСУО.ЗачислениеПользователейНаОбучениеСУО", МассивПараметровФЗ);	
	
	//----------------------------------//
	
	//Попытка
	//	ВебКабинетСУ.ВыполнитьВсеЗадания();
	//Исключение
	//КонецПопытки;	
	
	// Возвращаем результат
	//
	
	Если Формат = "json" Тогда
		Возврат ОтветКлиентуJSON(,Новый Структура("login", ДанныеПользователя.Логин));
	Иначе
		Возврат ОтветКлиентуTEXT(,ДанныеПользователя.Логин);
	КонецЕсли;
	
КонецФункции

Функция ВосстановлениеПароляПользователяPOST(ЗапросHTTP)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем номер этапа
	//
	
	Попытка
		НомерЭтапа = Число(ЗапросHTTP.ПараметрыURL.Получить("НомерЭтапа"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(НомерЭтапа) ИЛИ НомерЭтапа > 3 Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	// Этап 1. Создание запроса на восстановление пароля
	//
	
	Если НомерЭтапа = 1 Тогда
	
		// Получаем данные запроса
		
		ТелоЗапроса = ЗапросHTTP.ПолучитьТелоКакСтроку();		
		ДанныеПользователя = Новый Структура;
			
		Попытка
			СтруктураДанных = ОбщегоНазначенияСУ.JSONВДанные(ТелоЗапроса);
			ДанныеПользователяМассив = СтруктураДанных.userData;
		Исключение
		КонецПопытки;
		
		Если СтруктураДанных = Неопределено
			ИЛИ ДанныеПользователяМассив = Неопределено Тогда
			
			Возврат ОтветКлиентуJSON("errorData");
			
		КонецЕсли;	
				
		Для каждого СвойствоСтруктура Из ДанныеПользователяМассив Цикл
			ИмяСвойства = Перевод(СвойствоСтруктура.name, "Пользователи");	
			ДанныеПользователя.Вставить(ИмяСвойства, СокрЛП(СвойствоСтруктура.value));
		КонецЦикла;
		
		// Ищем пользователя в базе
		
		Пользователь = Неопределено;
		АдресЭлектроннойПочтыПользователя = "";
		
		Если ДанныеПользователя.Свойство("Логин") И ЗначениеЗаполнено(ДанныеПользователя.Логин) Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	ПользователиВебКабинетаСУ.Пользователь КАК Пользователь
				|ИЗ
				|	РегистрСведений.ПользователиВебКабинетаСУ КАК ПользователиВебКабинетаСУ
				|ГДЕ
				|	ПользователиВебКабинетаСУ.Имя = &Логин";
			
			Запрос.УстановитьПараметр("Логин", ДанныеПользователя.Логин);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Если ВыборкаДетальныеЗаписи.Количество()  = 1 Тогда
				
				ВыборкаДетальныеЗаписи.Следующий();
				
				Пользователь = ВыборкаДетальныеЗаписи.Пользователь;
				
				МассивТиповКИ = Новый Массив;
				МассивТиповКИ.Добавить(Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
				
				МассивПользователей = Новый Массив;
				МассивПользователей.Добавить(Пользователь);
				
				АдресаЭлектроннойПочтыПользователя = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(МассивПользователей, МассивТиповКИ);
				
				Если АдресаЭлектроннойПочтыПользователя.Количество() = 0 Тогда
					Возврат ОтветКлиентуJSON("emptyMail");
				КонецЕсли;
				
				Для каждого Строка Из АдресаЭлектроннойПочтыПользователя Цикл				
					Строка.Представление = НРег(Строка.Представление);				
				КонецЦикла;
				
				Если ЗначениеЗаполнено(Пользователь) И ДанныеПользователя.Свойство("ЭлектроннаяПочта") И ЗначениеЗаполнено(ДанныеПользователя.ЭлектроннаяПочта) Тогда
					
					Если АдресаЭлектроннойПочтыПользователя.Найти(НРег(ДанныеПользователя.ЭлектроннаяПочта), "Представление") = Неопределено Тогда
						Возврат ОтветКлиентуJSON("notIdenticalUserMail");	
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если Пользователь = Неопределено И ДанныеПользователя.Свойство("ЭлектроннаяПочта") И ЗначениеЗаполнено(ДанныеПользователя.ЭлектроннаяПочта) Тогда
			
			АдресЭлектроннойПочтыПользователя = ДанныеПользователя.ЭлектроннаяПочта;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	ПользователиКонтактнаяИнформация.Ссылка КАК Пользователь
				|ИЗ
				|	Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
				|ГДЕ
				|	ПользователиКонтактнаяИнформация.АдресЭП = &ЭлектроннаяПочта";
			
			Запрос.УстановитьПараметр("ЭлектроннаяПочта", АдресЭлектроннойПочтыПользователя);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Если ВыборкаДетальныеЗаписи.Количество() = 1 Тогда
			
				ВыборкаДетальныеЗаписи.Следующий();
				
				Если РегистрыСведений.ПользователиВебКабинетаСУ.ПользовательСуществует(,ВыборкаДетальныеЗаписи.Пользователь) Тогда				
					Пользователь = ВыборкаДетальныеЗаписи.Пользователь;
				КонецЕсли;
				
			КонецЕсли;
			
			Если ВыборкаДетальныеЗаписи.Количество() > 1 Тогда
				Возврат ОтветКлиентуJSON("notUniqueMail");
			КонецЕсли;
			
		КонецЕсли;
		
		Если Пользователь = Неопределено Тогда
			Возврат ОтветКлиентуJSON("noUser");
		КонецЕсли;
		
		// Создаем новый запрос на восстановление
		
		АдресСтраницы = ЗапросHTTP.Заголовки.Получить("Referer");
		
		Если НЕ ЗначениеЗаполнено(АдресСтраницы) Тогда
			Возврат ОтветКлиентуJSON("error");
		КонецЕсли;
		
		ЗапросНаВосстановление = Документы.ВосстановлениеПароляСУ.СоздатьДокумент();
		ЗапросНаВосстановление.Дата = ТекущаяДатаСеанса();
		ЗапросНаВосстановление.Пользователь = Пользователь;
		ЗапросНаВосстановление.АдресСтраницыВосстановления = АдресСтраницы;
		ЗапросНаВосстановление.Записать(РежимЗаписиДокумента.Проведение);
		
		//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
		
		// Создаем автоматическую рассылку
		
		СозданныеРассылки = Новый Массив;
		
		УправлениеОбучениемСУО.СоздатьАвтоматическуюРассылку(ЗапросНаВосстановление,, СозданныеРассылки);
		
		ОбщегоНазначения.ПровестиДокументы(СозданныеРассылки);
		
		// Высылаем письмо фоновым заданием (в случае неудачи, оно будет выслано регламентным заданием)
		
		Для каждого СозданнаяРассылка Из СозданныеРассылки Цикл
			
			МассивПараметровФЗ = Новый Массив;
			МассивПараметровФЗ.Добавить(СозданнаяРассылка);
			
			ФоновыеЗадания.Выполнить("УправлениеОбучениемСУО.РазослатьСообщенияНаЭлектроннуюПочту", МассивПараметровФЗ);
			
		КонецЦикла;
		
		//----------------------------------//
		
		// Возвращаем ответ
		
		РезультатЗапроса = Новый Структура("Идентификатор", Строка(ЗапросНаВосстановление.Ссылка.УникальныйИдентификатор()));
		
	КонецЕсли;
	
	// Этап 2. Получание информации для страницы восстановления запроса
	//
	
	Если НомерЭтапа = 2 Тогда 
		
		// Получаем документ запроса
		
		ТелоЗапроса = ЗапросHTTP.ПолучитьТелоКакСтроку();
		
		Попытка
			СтруктураЗапроса = ОбщегоНазначенияСУ.JSONВДанные(ТелоЗапроса);
			ИдентификаторЗапроса = Новый УникальныйИдентификатор(СтруктураЗапроса.id);
			ДокументЗапроса = Документы.ВосстановлениеПароляСУ.ПолучитьСсылку(ИдентификаторЗапроса);
		Исключение
		КонецПопытки;
		
		Если НЕ ЗначениеЗаполнено(ДокументЗапроса) Тогда
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;
		
		ДанныеЗапроса = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументЗапроса, "Пользователь, ПарольВосстановлен, Дата, АдресСтраницыВосстановления");
		
		АдресСтраницы = ЗапросHTTP.Заголовки.Получить("Referer");
		
		Если НЕ ЗначениеЗаполнено(АдресСтраницы) Тогда
			Возврат ОтветКлиентуJSON("error");
		КонецЕсли;	
		
		// Проверяем корректность документа
		
		Если ДанныеЗапроса.ПарольВосстановлен Тогда
			Возврат ОтветКлиентуJSON("oldRequest");
		КонецЕсли;
		
		Если (ТекущаяДатаСеанса() - ДанныеЗапроса.Дата) > 86400 Тогда
			Возврат ОтветКлиентуJSON("overdueRequest");	
		КонецЕсли;	
		
		// Получаем данные пользователя
		
		ДанныеПользователяВК = РегистрыСведений.ПользователиВебКабинетаСУ.ДанныеПользователя(,ДанныеЗапроса.Пользователь);
		
		Если ДанныеПользователяВК = Неопределено Тогда
			Возврат ОтветКлиентуJSON("noUser");
		Иначе
			ЛогинПользователя = ДанныеПользователяВК.Имя;
		КонецЕсли;
		
		// Возвращаем ответ
		
		РезультатЗапроса = Новый Структура("Логин", ЛогинПользователя);
		
	КонецЕсли;
	
	// Этап 3. Изменение пароля
	//	
	
	Если НомерЭтапа = 3 Тогда 
		
		// Получаем данные запроса
		
		ТелоЗапроса = ЗапросHTTP.ПолучитьТелоКакСтроку();		
		ДанныеЗапроса = Новый Структура;
			
		Попытка
			СтруктураДанных = ОбщегоНазначенияСУ.JSONВДанные(ТелоЗапроса);
			ДанныеЗапросаМассив = СтруктураДанных.changePasswordData;
		Исключение
		КонецПопытки;
		
		Если СтруктураДанных = Неопределено
			ИЛИ ДанныеЗапросаМассив = Неопределено Тогда
			
			Возврат ОтветКлиентуJSON("errorData");
			
		КонецЕсли;	
				
		Для каждого СвойствоСтруктура Из ДанныеЗапросаМассив Цикл
			ИмяСвойства = Перевод(СвойствоСтруктура.name, "Пользователи");	
			ДанныеЗапроса.Вставить(ИмяСвойства, СокрЛП(СвойствоСтруктура.value));
		КонецЦикла;
		
		Если НЕ ДанныеЗапроса.Свойство("Пароль") ИЛИ НЕ ДанныеЗапроса.Свойство("Код") ИЛИ НЕ ДанныеЗапроса.Свойство("Идентификатор") Тогда
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;
		
		// Сохраняем изменение в документе "ВосстановлениеПароляСУ"
		
		НачатьТранзакцию();
		
		Попытка
			ВосстановлениеПароляОбъект = Документы.ВосстановлениеПароляСУ.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеЗапроса.Идентификатор)).ПолучитьОбъект();
			КодВосстановленияЧисло = Число(ДанныеЗапроса.Код);
		Исключение
		КонецПопытки;
		
		Если ВосстановлениеПароляОбъект = Неопределено ИЛИ НЕ ВосстановлениеПароляОбъект.Проведен ИЛИ НЕ ЗначениеЗаполнено(КодВосстановленияЧисло) Тогда
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;
		
		Если ВосстановлениеПароляОбъект.ПарольВосстановлен Тогда
			Возврат ОтветКлиентуJSON("oldRequest");
		КонецЕсли;
		
		ТекущаяДата = ТекущаяДатаСеанса();
		
		Если (ТекущаяДата - ВосстановлениеПароляОбъект.Дата) > 86400 Тогда
			Возврат ОтветКлиентуJSON("overdueRequest");	
		КонецЕсли;
		
		АдресСтраницы = ЗапросHTTP.Заголовки.Получить("Referer");
		
		Если НЕ ЗначениеЗаполнено(АдресСтраницы) Тогда
			Возврат ОтветКлиентуJSON("error");
		КонецЕсли;			
		
		Если ВосстановлениеПароляОбъект.КодВосстановления <> КодВосстановленияЧисло Тогда
			Возврат ОтветКлиентуJSON("errorAuthorization");
		КонецЕсли;
		
		ВосстановлениеПароляОбъект.ДатаВосстановления = ТекущаяДата;
		ВосстановлениеПароляОбъект.ПарольВосстановлен = Истина;
		
		ВосстановлениеПароляОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		// Изменяем пароль
		//
		
		ИзменитьПарольПользователя(ВосстановлениеПароляОбъект.Пользователь, ДанныеЗапроса.Пароль);
		
		ДанныеПользователяВК = РегистрыСведений.ПользователиВебКабинетаСУ.ДанныеПользователя(,ВосстановлениеПароляОбъект.Пользователь);
		
		Если ДанныеПользователяВК = Неопределено Тогда
			Возврат ОтветКлиентуJSON("noUser");
		Иначе
			ЛогинПользователя = ДанныеПользователяВК.Имя;
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
		
		РезультатЗапроса = Новый Структура("Логин", ЛогинПользователя);
		
	КонецЕсли;
	
	// Возвращаем ответ
	
	Возврат ОтветКлиентуJSON(,РезультатЗапроса);
	
КонецФункции

Функция ДанныеПользователяPOST(ЗапросHTTP)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(ЗапросHTTP, ДанныеСессии, КодОшибки, Ложь);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;	
	
	// Получаем идентификатор пользователя
	//
	
	Попытка
		ИдентификаторПользователя = Новый УникальныйИдентификатор(ЗапросHTTP.ПараметрыURL.Получить("ИдентификаторПользователя"));
		Пользователь = Справочники.Пользователи.ПолучитьСсылку(ИдентификаторПользователя);
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(Пользователь) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	// Возвращаем данные
	//
	
	ДанныеПользователя = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Пользователь, "Наименование");
	
	ОтветКлиенту = Новый Структура("name, recipient", ДанныеПользователя.Наименование, Строка(ДанныеСессии.Пользователь.УникальныйИдентификатор()));
	
	Возврат ОтветКлиентуJSON(,ОтветКлиенту);	
	
КонецФункции

Функция ИзменитьПарольPOST(ЗапросHTTP)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(ЗапросHTTP, ДанныеСессии, КодОшибки, Ложь);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;	
	
	// Изменяем пароль
	//
	
	ТелоЗапроса = ЗапросHTTP.ПолучитьТелоКакСтроку();
	
	Пароль = "";
		
	Попытка
		СтруктураДанных = ОбщегоНазначенияСУ.JSONВДанные(ТелоЗапроса);
		ДанныеМассив = СтруктураДанных.changePasswordData;
	Исключение
	КонецПопытки;
	
	Если СтруктураДанных = Неопределено
		ИЛИ ДанныеМассив = Неопределено Тогда
		
		Возврат ОтветКлиентуJSON("errorData");
		
	КонецЕсли;	
	
	// Проверяем, есть ли право на изменение пароля
	//
	
	ИдентификаторПользователяИБ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеСессии.Пользователь, "ИдентификаторПользователяИБ");
	СвойстваПользователяИБ = Новый Структура("ЗапрещеноИзменятьПароль", Ложь);
	ОписаниеОшибки = "";
	Если Пользователи.ПрочитатьПользователяИБ(ИдентификаторПользователяИБ, СвойстваПользователяИБ, ОписаниеОшибки) Тогда
		Если СвойстваПользователяИБ.ЗапрещеноИзменятьПароль Тогда
			Возврат ОтветКлиентуJSON("noFunctionality");
		КонецЕсли;
	Иначе
		Возврат ОтветКлиентуJSON("errorData", ОписаниеОшибки);		
	КонецЕсли;
	
	// Изменяем пароль
	//
	
	Для каждого СвойствоСтруктура Из ДанныеМассив Цикл
		Если СвойствоСтруктура.name = "password" Тогда
			Пароль = СвойствоСтруктура.value;
		КонецЕсли;
	КонецЦикла;		
	
	ИзменитьПарольПользователя(ДанныеСессии.Пользователь, Пароль);
	
	// Возвращаем результат
	//
	
	Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена", Истина));	
	

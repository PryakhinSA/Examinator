КонецФункции

Функция ВыставляетсяОценка(Знач ПроведениеОбучения, Знач Задание, Знач Сценарий, Знач ВидОбучения, Знач ПрохождениеОбучения, Знач Пользователь) Экспорт
	
	Если НЕ ВидОбучения.ВыставляетсяОценка Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ТипЗнч(Задание) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда
				
		МассивЗаданий = Новый Массив;
		МассивЭлектронныхРесурсов = Новый Массив;
		МассивЭлектронныхКурсов = Новый Массив;
		ТаблицаНаименований	= Документы.ПроведениеОбученияСУО.ПустаяТаблицаНаименованийЗаданий();
		
		Документы.ПроведениеОбученияСУО.ЗаполнитьМассивЗаданийИЭлектронныхРесурсов(ПроведениеОбучения, МассивЗаданий, МассивЭлектронныхРесурсов, МассивЭлектронныхКурсов, ТаблицаНаименований, ВидОбучения, Задание);
		
		СтрокаТН = ТаблицаНаименований.Найти(Задание, "Задание");		
		Если СтрокаТН <> Неопределено
			И СтрокаТН.ПриОтсутствииОценкиЗаЗадание = Перечисления.ПриОтсутствииОценкиЗаЗаданиеСУО.МаксимальныйБалл Тогда			
			Возврат Истина;			
		КонецЕсли;
		
		ДанныеПрохожденияЭР = ЭлектронныеРесурсыСУЗ.ДанныеОПрохожденииЭлектронногоРесурса(Задание,,Пользователь, ПрохождениеОбучения, Задание,,ВидОбучения);
		Если ДанныеПрохожденияЭР <> Неопределено Тогда
			Возврат ДанныеПрохожденияЭР.ВыставляетсяОценка;
		КонецЕсли;
		
	Иначе
		
		СвойстваЗадания = Документы.ПроведениеОбученияСУО.СвойстваЗадания(ПроведениеОбучения, Задание, Сценарий, ВидОбучения);	
		Если СвойстваЗадания <> Неопределено Тогда
			Возврат СвойстваЗадания.ВыставляетсяОценка;
		КонецЕсли;
		
	КонецЕсли;
		
	Возврат ВидОбучения.ВыставляетсяОценка;
	
КонецФункции

// Веб-кабинет

Процедура ОбновитьДанныеВебКабинета(ПопыткаВыполненияЗадания, ДополнительныеДанные = Неопределено) Экспорт	
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем переменные
	
	ДанныеПопыткиВыполненияЗадания = ОписаниеПопыткиВыполненияЗаданияДанные(ПопыткаВыполненияЗадания);
	
	// Удаляем старые данные
	// Здесь удаляем данные только того типа, который заполняется ниже в этой процедуре.
	// В разрезе этого документа заполняется еще тип ТипыДанныхВебКабинетаСУО.ПроверкаЗаданияОписание
	// в документе прохождения обучения. Этот тип не надо очищать, так как за него ответственен другой документ.
	РегистрыСведений.ДанныеВебКабинетаСУО_ПН.УдалитьДанные(ПопыткаВыполненияЗадания, Перечисления.ТипыДанныхВебКабинетаСУО.ВыполнениеЗаданияОписание);	
	
	// Добавляем новые данные
	
	ОбучениеОтменено = Отменено(ДанныеПопыткиВыполненияЗадания);
	
 	Если ДанныеПопыткиВыполненияЗадания.Проведен 
		И НЕ ОбучениеОтменено
		И НЕ ДанныеПопыткиВыполненияЗадания.НаОсновеЭлектронногоРесурса Тогда
		
		Зависимости = Новый Массив;
		
		// Для задания используется только описание,
		// которое содержит полную информацию о задании.
		// Краткий список выводить не требуется.
		
		ОписаниеПопыткиВыполненияЗаданияСтруктура = ОписаниеПопыткиВыполненияЗаданияСтруктура(ПопыткаВыполненияЗадания, Зависимости, ДанныеПопыткиВыполненияЗадания);
		ОписаниеПопыткиВыполненияЗадания = ОбщегоНазначенияСУ.ДанныеВJSON(ОписаниеПопыткиВыполненияЗаданияСтруктура);
		
		РегистрыСведений.ДанныеВебКабинетаСУО_ПН.ДобавитьДанные(ДанныеПопыткиВыполненияЗадания.Пользователь, Перечисления.ТипыДанныхВебКабинетаСУО.ВыполнениеЗаданияОписание, ПопыткаВыполненияЗадания, ОписаниеПопыткиВыполненияЗадания, Перечисления.ФорматыВебДанныхСУ.json);
		
		// Файлы задания
		
		Если ДанныеПопыткиВыполненияЗадания.ИспользуетсяФорматированныйДокумент Тогда
		
			ТекстЗаданияСтруктура = ОбщегоНазначенияСУ.ПредставлениеФорматированногоДокументаДляВыгрузкиHTML(ДанныеПопыткиВыполненияЗадания.ОписаниеФорматированныйДокумент.Получить(), Строка(ДанныеПопыткиВыполненияЗадания.Задание.УникальныйИдентификатор()),, Истина, Ложь);
			
			Если ТекстЗаданияСтруктура.ЕстьВложения Тогда
				ВебКабинетСУО.ВыгрузитьФайлыФорматированногоДокументаВКаталогВебКабинета(ТекстЗаданияСтруктура.ДвоичныеДанные, ТекстЗаданияСтруктура.ИдентификаторКаталога);
			КонецЕсли;
			
		КонецЕсли;
		
		// Зависимости
		
		Если ЗначениеЗаполнено(ДанныеПопыткиВыполненияЗадания.Задание) Тогда
			Зависимости.Добавить(ДанныеПопыткиВыполненияЗадания.Задание);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеПопыткиВыполненияЗадания.Вариант) Тогда
			Зависимости.Добавить(ДанныеПопыткиВыполненияЗадания.Вариант);
		КонецЕсли;
		
		Если НЕ ОписаниеПопыткиВыполненияЗаданияСтруктура.Выполнено Тогда
					
			ПрохождениеОбученияАктуально = Документы.ПрохождениеОбученияСУО.Актуально(
				ДанныеПопыткиВыполненияЗадания.ПрохождениеОбучения);
					
			Если ПрохождениеОбученияАктуально Тогда								
				РегистрыСведений.ЗависимостиДанныхВебКабинетаСУ.ДобавитьДанные(ПопыткаВыполненияЗадания, "Документ.ПопыткаВыполненияЗаданияСУО", Зависимости);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;		
	
КонецПроцедуры

Функция ОписаниеПопыткиВыполненияЗаданияДанные(ПопыткаВыполненияЗадания) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	ТребуемыеДанные = Новый Структура("	
	|Ссылка,
	|ПрохождениеОбучения,
	|ПроведениеОбучения,
	|Задание,
	|Наименование,
	|Вариант,
	|НаименованиеВарианта,
	|Баллы,
	|ЗавершеноВПроцентах,
	|ПопыткаЗавершена,
	|ТекстОтвета,
	|ПроверяетсяПреподавателем,
	|ПроверенПреподавателем,
	|КомментарийПреподавателя,
	|ТекстОписанияВарианта,
	|ТекстОписанияЗадания,
	|ДоступноПопыток,

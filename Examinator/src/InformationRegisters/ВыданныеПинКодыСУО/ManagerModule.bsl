#Если Сервер ИЛИ ТолстыйКлиентОбычноеПриложение ИЛИ ВнешнееСоединение Тогда
	
#Область ПрограммныйИнтерфейс

// ЗАПИСЬ

Процедура СоздатьКодыСерии(Знач Серия, Знач Количество, Знач Длина=Неопределено, Знач Вид=Неопределено) Экспорт
	
	// Делаем проверки
	
	Если Количество < 1 Тогда
		Количество = 1;
	КонецЕсли;
	
	Если Длина = Неопределено ИЛИ Вид=Неопределено Тогда
		
		ДанныеСерии = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Серия, "ДлинаКода, Вид");
		
		Если Длина = Неопределено Тогда
			Длина = ДанныеСерии.ДлинаКода;	
		КонецЕсли;
		
		Если Вид = Неопределено Тогда
			Вид = ДанныеСерии.Вид;	
		КонецЕсли;		
		
	КонецЕсли;
	
	// Записываем коды
	
	НаборЗаписей = РегистрыСведений.ВыданныеПинКодыСУО.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Серия.Установить(Серия);

	НаборЗаписей.Прочитать();
	
	МассивКодов   = НаборЗаписей.ВыгрузитьКолонку("Код");
	ТекущаяДата   = ТекущаяДатаСеанса();
	Ответственный = Пользователи.ТекущийПользователь();
	
	КоличествоНовыхКодов = 0;
	Генератор = Новый ГенераторСлучайныхЧисел;
	
	Для НомерНовогоКода = 1 По Количество Цикл
		
		НовыйКод = НовыйУникальныйКод(Длина, Вид, МассивКодов,, Генератор);
		
		МассивКодов.Добавить(НовыйКод);
		
		НоваяЗапись = НаборЗаписей.Добавить();
		
		НоваяЗапись.Серия = Серия;
		НоваяЗапись.Код = НовыйКод;
		НоваяЗапись.ДатаСоздания = ТекущаяДата;
		НоваяЗапись.Ответственный = Ответственный;
		
	КонецЦикла; 
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

Процедура АктивироватьКод(Знач Серия, Знач Код, Знач Пользователь, Знач ДатаИспользования=Неопределено, Знач Опция=Неопределено, Знач ОбновитьДанныеВебКабинета=Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	НачатьТранзакцию();
	
	// Получаем переменные
	
	Если ДатаИспользования = Неопределено Тогда
		ДатаИспользования = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Опция)		
		И Справочники.СерииПинКодовСУО.ЕстьОпции(Серия) Тогда
		
		ВызватьИсключение НСтр("ru = 'Вариант для выбора пин-кода не указан'");
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Опция)
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Опция, "Владелец") <> Серия Тогда
		
		ВызватьИсключение НСтр("ru = 'Вариант выбора пин-кода не соответствует вариантам выбора, указанным в настройках серии пин-кодов'");
		
	КонецЕсли;
	
	// Фиксируем факт использования пин-кода
	
	НаборЗаписей = РегистрыСведений.ВыданныеПинКодыСУО.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Серия.Установить(Серия);
	НаборЗаписей.Отбор.Код.Установить(Код);

	НаборЗаписей.Прочитать();

	Если НаборЗаписей.Количество() = 0 Тогда
		ВызватьИсключение НСтр("ru = 'Пин-код не найден'");
	КонецЕсли;
	
	Запись = НаборЗаписей[0];
	
	Если Запись.Заблокирован Тогда
		ВызватьИсключение НСтр("ru = 'Пин-код заблокирован'");
	КонецЕсли;
	
	Запись.Пользователь = Пользователь;
	Запись.ДатаИспользования = ДатаИспользования;
	
	Если НЕ ЗначениеЗаполнено(СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Серия, "Уведомление"))) Тогда
		Запись.УведомлениеПоказано = Истина; // Так как уведомление пустое
	КонецЕсли;
	
	Запись.Опция = Опция;
	
	НаборЗаписей.Записать();
	
	// Добавляем пользователя в группу доступа
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СерииПинКодовСУОГруппыДоступа.ГруппаДоступа КАК ГруппаДоступа
		|ИЗ
		|	Справочник.СерииПинКодовСУО.ГруппыДоступа КАК СерииПинКодовСУОГруппыДоступа
		|ГДЕ
		|	СерииПинКодовСУОГруппыДоступа.Ссылка = &Серия
		|	И (СерииПинКодовСУОГруппыДоступа.Опция = &Опция
		|			ИЛИ СерииПинКодовСУОГруппыДоступа.Опция = ЗНАЧЕНИЕ(Справочник.ОпцииСерииПинКодовСУО.ПустаяСсылка))";
	
	Запрос.УстановитьПараметр("Серия", Серия);	
	Запрос.УстановитьПараметр("Опция", Опция);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл

		ГруппаДоступаОбъект = ВыборкаДетальныеЗаписи.ГруппаДоступа.ПолучитьОбъект();
				
		Если ГруппаДоступаОбъект.Пользователи.Найти(Пользователь, "Пользователь") = Неопределено Тогда
			ГруппаДоступаОбъект.Пользователи.Добавить().Пользователь = Пользователь;
		КонецЕсли;
		
		ГруппаДоступаОбъект.Записать();		
		
	КонецЦикла;
	
	// Устанавливаем настройки аутентификации
	
	ДанныеСерии = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Серия, "УстановитьНастройкиАутентификации, АутентификацияOpenID, АутентификацияСтандартная, АутентификацияВебКабинета");
	ЭтоПолноправныйПользователь = Пользователи.ЭтоПолноправныйПользователь(Пользователь);
	
	Если ДанныеСерии.УстановитьНастройкиАутентификации И НЕ ЭтоПолноправныйПользователь Тогда
		
		ПользовательОбъект = Пользователь.ПолучитьОбъект();		
		
		ОписаниеПользователяИБ = Новый Структура;
		ОписаниеПользователяИБ.Вставить("Действие", "Записать");
		ОписаниеПользователяИБ.Вставить("АутентификацияВебКабинета", ДанныеСерии.АутентификацияВебКабинета);
		ОписаниеПользователяИБ.Вставить("АутентификацияOpenID", ДанныеСерии.АутентификацияOpenID);
		ОписаниеПользователяИБ.Вставить("АутентификацияСтандартная", ДанныеСерии.АутентификацияСтандартная);
		
		ПользовательОбъект.ДополнительныеСвойства.Вставить(
			"ОписаниеПользователяИБ", ОписаниеПользователяИБ);	
		
		ПользовательОбъект.ДополнительныеСвойства.Вставить("АутентификацияВебКабинета", ДанныеСерии.АутентификацияВебКабинета);
		
		ПользовательОбъект.Записать();
		
	КонецЕсли;
	
	// Продолжительность
	
	Если НЕ ЭтоПолноправныйПользователь И ПолучитьФункциональнуюОпцию("ИспользоватьОграниченияВремениДоступаКПрограммеСУО") Тогда
		
		ДатаНачалаДоступа = ТекущаяДатаСеанса();
		ПродолжительностьДоступа = Справочники.СерииПинКодовСУО.ПродолжительностьДоступаВСекундах(Серия);
		
		Если ПродолжительностьДоступа > 0 Тогда
			РегистрыСведений.ВремяДоступаПользователейСУО.УстановитьВремяДоступа(Пользователь, ДатаНачалаДоступа, ДатаНачалаДоступа + ПродолжительностьДоступа);
		КонецЕсли;
		
	КонецЕсли;
	
	// Организаторы
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОрганизаторыСерии.Организатор КАК Организатор
		|ИЗ
		|	Справочник.СерииПинКодовСУО.Организаторы КАК ОрганизаторыСерии
		|ГДЕ
		|	ОрганизаторыСерии.Ссылка = &Серия";
	
	Запрос.УстановитьПараметр("Серия", Серия);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ОрганизаторОбъект = ВыборкаДетальныеЗаписи.Организатор.ПолучитьОбъект();
				
		Если ОрганизаторОбъект.Видимость.Найти(Пользователь, "Пользователь") = Неопределено Тогда
			ОрганизаторОбъект.Видимость.Добавить().Пользователь = Пользователь;
		КонецЕсли;
		
		ОрганизаторОбъект.Записать();				
		
	КонецЦикла;		
	
	// Добавляем в учебные группы
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СерииПинКодовСУОУчебныеГруппы.УчебнаяГруппа КАК УчебнаяГруппа
		|ИЗ
		|	Справочник.СерииПинКодовСУО.УчебныеГруппы КАК СерииПинКодовСУОУчебныеГруппы
		|ГДЕ
		|	СерииПинКодовСУОУчебныеГруппы.Ссылка = &Серия
		|	И (СерииПинКодовСУОУчебныеГруппы.Опция = &Опция
		|			ИЛИ СерииПинКодовСУОУчебныеГруппы.Опция = ЗНАЧЕНИЕ(Справочник.ОпцииСерииПинКодовСУО.ПустаяСсылка))";
	
	Запрос.УстановитьПараметр("Серия", Серия);
	Запрос.УстановитьПараметр("Опция", Опция);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		УчебнаяГруппаОбъект = ВыборкаДетальныеЗаписи.УчебнаяГруппа.ПолучитьОбъект();
				
		Если УчебнаяГруппаОбъект.Состав.Найти(Пользователь, "Пользователь") = Неопределено Тогда
			УчебнаяГруппаОбъект.Состав.Добавить().Пользователь = Пользователь;
		КонецЕсли;
		
		УчебнаяГруппаОбъект.Записать();				
		
	КонецЦикла;

	// Группы пользователей
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СерииПинКодовСУОГруппыПользователей.ГруппаПользователей КАК ГруппаПользователей
		|ИЗ
		|	Справочник.СерииПинКодовСУО.ГруппыПользователей КАК СерииПинКодовСУОГруппыПользователей
		|ГДЕ
		|	СерииПинКодовСУОГруппыПользователей.Ссылка = &Серия
		|	И (СерииПинКодовСУОГруппыПользователей.Опция = &Опция
		|			ИЛИ СерииПинКодовСУОГруппыПользователей.Опция = ЗНАЧЕНИЕ(Справочник.ОпцииСерииПинКодовСУО.ПустаяСсылка))";
	
	Запрос.УстановитьПараметр("Серия", Серия);
	Запрос.УстановитьПараметр("Опция", Опция);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ГруппаПользователейОбъект = ВыборкаДетальныеЗаписи.ГруппаПользователей.ПолучитьОбъект();
				
		Если ГруппаПользователейОбъект.Состав.Найти(Пользователь, "Пользователь") = Неопределено Тогда
			ГруппаПользователейОбъект.Состав.Добавить().Пользователь = Пользователь;
		КонецЕсли;
		
		ГруппаПользователейОбъект.Записать();			
		
	КонецЦикла;
	
	// Раздел форума
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СерииПинКодовСУОРазделыФорума.РазделФорума КАК РазделФорума
		|ИЗ
		|	Справочник.СерииПинКодовСУО.РазделыФорума КАК СерииПинКодовСУОРазделыФорума
		|ГДЕ
		|	СерииПинКодовСУОРазделыФорума.Ссылка = &Серия
		|	И (СерииПинКодовСУОРазделыФорума.Опция = &Опция
		|			ИЛИ СерииПинКодовСУОРазделыФорума.Опция = ЗНАЧЕНИЕ(Справочник.ОпцииСерииПинКодовСУО.ПустаяСсылка))";
	
	Запрос.УстановитьПараметр("Серия", Серия);
	Запрос.УстановитьПараметр("Опция", Опция);

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		РазделФорумаОбъект = ВыборкаДетальныеЗаписи.РазделФорума.ПолучитьОбъект();
				
		Если РазделФорумаОбъект.Видимость.Найти(Пользователь, "Пользователь") = Неопределено Тогда
			РазделФорумаОбъект.Видимость.Добавить().Пользователь = Пользователь;
		КонецЕсли;
		
		РазделФорумаОбъект.Записать();	
		
	КонецЦикла;
	
	// Разделы библиотеки
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СерииПинКодовСУОРазделыБиблиотеки.РазделБиблиотеки КАК РазделБиблиотеки
		|ИЗ
		|	Справочник.СерииПинКодовСУО.РазделыБиблиотеки КАК СерииПинКодовСУОРазделыБиблиотеки
		|ГДЕ
		|	СерииПинКодовСУОРазделыБиблиотеки.Ссылка = &Серия
		|	И (СерииПинКодовСУОРазделыБиблиотеки.Опция = &Опция
		|			ИЛИ СерииПинКодовСУОРазделыБиблиотеки.Опция = ЗНАЧЕНИЕ(Справочник.ОпцииСерииПинКодовСУО.ПустаяСсылка))";
	
	Запрос.УстановитьПараметр("Серия", Серия);
	Запрос.УстановитьПараметр("Опция", Опция);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл

		РазделБиблиотекиОбъект = ВыборкаДетальныеЗаписи.РазделБиблиотеки.ПолучитьОбъект();
				
		Если РазделБиблиотекиОбъект.Видимость.Найти(Пользователь, "Пользователь") = Неопределено Тогда
			РазделБиблиотекиОбъект.Видимость.Добавить().Пользователь = Пользователь;
		КонецЕсли;
		
		РазделБиблиотекиОбъект.Записать();	
		
	КонецЦикла;
	
	// Новости
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СерииПинКодовСУОНовости.Новость КАК Новость
		|ИЗ
		|	Справочник.СерииПинКодовСУО.Новости КАК СерииПинКодовСУОНовости
		|ГДЕ
		|	СерииПинКодовСУОНовости.Ссылка = &Серия
		|	И (СерииПинКодовСУОНовости.Опция = &Опция
		|			ИЛИ СерииПинКодовСУОНовости.Опция = ЗНАЧЕНИЕ(Справочник.ОпцииСерииПинКодовСУО.ПустаяСсылка))";
	
	Запрос.УстановитьПараметр("Серия", Серия);
	Запрос.УстановитьПараметр("Опция", Опция);

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл

		НовостьОбъект = ВыборкаДетальныеЗаписи.Новость.ПолучитьОбъект();
				
		Если НовостьОбъект.Получатели.Найти(Пользователь, "Пользователь") = Неопределено Тогда
			НовостьОбъект.Получатели.Добавить().Пользователь = Пользователь;
		КонецЕсли;
		
		Если НовостьОбъект.Проведен Тогда
			НовостьОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Иначе
			НовостьОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
		
	КонецЦикла;

	// Зачисляем на обучение
	
	// Примечение: на обучение следует зачислять
	// в последнюю очередь, так как этот процесс может зависеть
	// от данных выше.
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СерииПинКодовСУООбучение.Проведение КАК Проведение
		|ИЗ
		|	Справочник.СерииПинКодовСУО.Обучение КАК СерииПинКодовСУООбучение
		|ГДЕ
		|	СерииПинКодовСУООбучение.Ссылка = &Серия
		|	И (СерииПинКодовСУООбучение.Опция = &Опция
		|			ИЛИ СерииПинКодовСУООбучение.Опция = ЗНАЧЕНИЕ(Справочник.ОпцииСерииПинКодовСУО.ПустаяСсылка))";
	
	Запрос.УстановитьПараметр("Серия", Серия);
	Запрос.УстановитьПараметр("Опция", Опция);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ТипЗнч(ВыборкаДетальныеЗаписи.Проведение) = Тип("ДокументСсылка.ПроведениеОбученияСУО") Тогда			
			ПрохождениеОбучения = УправлениеОбучениемСУО.ЗачислитьУчастникаНаОбучение(
				ВыборкаДетальныеЗаписи.Проведение,,Пользователь,,,,Ложь,,ОбновитьДанныеВебКабинета);			
		КонецЕсли;
		
		Если ТипЗнч(ВыборкаДетальныеЗаписи.Проведение) = Тип("ДокументСсылка.ПроведениеПрограммыОбученияСУО") Тогда			
			ПрохождениеПрограммыОбучения = УправлениеОбучениемСУО.ЗачислитьУчастникаНаПрограммуОбучения(
				ВыборкаДетальныеЗаписи.Проведение, Пользователь,,,,ОбновитьДанныеВебКабинета);			
		КонецЕсли;		
		
	КонецЦикла;
	
	// Завершаем
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

Функция ВыдатьКод(Знач Серия, Знач Сообщение=Неопределено, Знач ЭлектроннаяПочта=Неопределено) Экспорт
	
	// Получаем переменные
	
	КодСерии = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Серия, "Код");
	
	// Ищем ранее выданный пин-код
	
	Если Сообщение <> Неопределено Тогда
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ВыданныеПинКодыСУО.Код КАК Код
			|ИЗ
			|	РегистрСведений.ВыданныеПинКодыСУО КАК ВыданныеПинКодыСУО
			|ГДЕ
			|	ВыданныеПинКодыСУО.Серия = &Серия
			|	И ВыданныеПинКодыСУО.Сообщение = &Сообщение
			|	И ВыданныеПинКодыСУО.Выдан = ИСТИНА";
		
		Запрос.УстановитьПараметр("Серия", Серия);
		Запрос.УстановитьПараметр("Сообщение", Сообщение);
		
		РезультатЗапроса = Запрос.Выполнить();

		Если НЕ РезультатЗапроса.Пустой() Тогда
		
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			ВыборкаДетальныеЗаписи.Следующий();

			Возврат КодСерии + ВыборкаДетальныеЗаписи.Код;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭлектроннаяПочта <> Неопределено Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ВыданныеПинКодыСУО.Код КАК Код
			|ИЗ
			|	РегистрСведений.ВыданныеПинКодыСУО КАК ВыданныеПинКодыСУО
			|ГДЕ
			|	ВыданныеПинКодыСУО.Серия = &Серия
			|	И ВыданныеПинКодыСУО.ЭлектроннаяПочта = &ЭлектроннаяПочта
			|	И ВыданныеПинКодыСУО.Выдан = ИСТИНА";
		
		Запрос.УстановитьПараметр("Серия", Серия);
		Запрос.УстановитьПараметр("ЭлектроннаяПочта", ЭлектроннаяПочта);
		
		РезультатЗапроса = Запрос.Выполнить();

		Если НЕ РезультатЗапроса.Пустой() Тогда
		
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			ВыборкаДетальныеЗаписи.Следующий();

			Возврат КодСерии + ВыборкаДетальныеЗаписи.Код;
			
		КонецЕсли;		
		
	КонецЕсли;
	
	//Выдаем новый пин-код
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВыданныеПинКодыСУО.Код КАК Код
		|ИЗ
		|	РегистрСведений.ВыданныеПинКодыСУО КАК ВыданныеПинКодыСУО
		|ГДЕ
		|	ВыданныеПинКодыСУО.Серия = &Серия
		|	И ВыданныеПинКодыСУО.Пользователь = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		|	И ВыданныеПинКодыСУО.Выдан = ЛОЖЬ
		|	И ВыданныеПинКодыСУО.Заблокирован = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Серия", Серия);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		ВызватьИсключение НСтр("ru = 'Отсутствует свободный пин-код для рассылки'");
	КонецЕсли;
	
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	УстановитьСнятьОтметкуВыдан(Серия, ВыборкаДетальныеЗаписи.Код, Истина, Сообщение, ЭлектроннаяПочта);
	
	Возврат КодСерии + ВыборкаДетальныеЗаписи.Код;
	
КонецФункции

Процедура УстановитьСнятьОтметкуВыдан(Серия, Код, Выдан=Неопределено, Сообщение=Неопределено, ЭлектроннаяПочта=Неопределено) Экспорт
	
	НаборЗаписей = РегистрыСведений.ВыданныеПинКодыСУО.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Серия.Установить(Серия);
	НаборЗаписей.Отбор.Код.Установить(Код);

	НаборЗаписей.Прочитать();

	Если НаборЗаписей.Количество() = 0 Тогда
		ВызватьИсключение НСтр("ru = 'Пин-код не найден'");
	КонецЕсли;
	
	Запись = НаборЗаписей[0];	
	
	Запись.Сообщение = Неопределено;
	Запись.ЭлектроннаяПочта = Неопределено;
	
	Если Сообщение <> Неопределено Тогда
		Запись.Сообщение = Сообщение;
	КонецЕсли;
	
	Если ЭлектроннаяПочта <> Неопределено Тогда
		Запись.ЭлектроннаяПочта = ЭлектроннаяПочта;
	КонецЕсли;
	
	Если Выдан = Неопределено Тогда
		Запись.Выдан = НЕ Запись.Выдан;
	Иначе
		Запись.Выдан = Выдан;
	КонецЕсли;	
	
	Запись.ДатаВыдачи = ТекущаяДатаСеанса();
	Запись.Выдавший = Пользователи.ТекущийПользователь();
	
	НаборЗаписей.Записать();	
	
КонецПроцедуры

Процедура УстановтьСнятьОтметкуЗаблокирован(Серия, Код, Заблокирован=Неопределено) Экспорт
	
	НаборЗаписей = РегистрыСведений.ВыданныеПинКодыСУО.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Серия.Установить(Серия);
	НаборЗаписей.Отбор.Код.Установить(Код);

	НаборЗаписей.Прочитать();

	Если НаборЗаписей.Количество() = 0 Тогда
		ВызватьИсключение НСтр("ru = 'Пин-код не найден'");
	КонецЕсли;
	
	Запись = НаборЗаписей[0];	
	
	Если Заблокирован = Неопределено Тогда
		Запись.Заблокирован = НЕ Запись.Заблокирован;
	Иначе
		Запись.Заблокирован = Заблокирован;
	КонецЕсли;	
	
	Запись.Заблокировал = Пользователи.ТекущийПользователь();
	Запись.ДатаБлокировки = ТекущаяДатаСеанса();
	
	НаборЗаписей.Записать();	
	
КонецПроцедуры

Функция ПолучитьТекстУведомленияИЗапомнить(Знач Пользователь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Ищем
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВыданныеПинКодыСУО.Серия.Уведомление КАК Уведомление,
		|	ВыданныеПинКодыСУО.Серия КАК Серия,
		|	ВыданныеПинКодыСУО.Код КАК Код
		|ИЗ
		|	РегистрСведений.ВыданныеПинКодыСУО КАК ВыданныеПинКодыСУО
		|ГДЕ
		|	ВыданныеПинКодыСУО.Пользователь = &Пользователь
		|	И ВыданныеПинКодыСУО.Заблокирован = ЛОЖЬ
		|	И ВыданныеПинКодыСУО.УведомлениеПоказано = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат "";
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();

	// Запоминаем
	
	НаборЗаписей = РегистрыСведений.ВыданныеПинКодыСУО.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Серия.Установить(ВыборкаДетальныеЗаписи.Серия);
	НаборЗаписей.Отбор.Код.Установить(ВыборкаДетальныеЗаписи.Код);

	НаборЗаписей.Прочитать();	
	
	Если НаборЗаписей.Количество() <> 1 Тогда
		ВызватьИсключение НСтр("ru = 'Пин-код не найден'");
	КонецЕсли;
	
	Запись = НаборЗаписей[0];	
	
	Запись.УведомлениеПоказано = Истина;
	Запись.ДатаПоказаУведомления = ТекущаяДатаСеанса();
	
	НаборЗаписей.Записать();
	
	// Завершаем
	
	Возврат ВыборкаДетальныеЗаписи.Уведомление;
	
КонецФункции

// ЧТЕНИЕ

Функция КодДоступенДляАктивации(Знач ПинКод, Знач ИдентификаторОпции=Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПинКод = СтрЗаменить(ПинКод, "-", "");
	
	ДанныеПинКода = Новый Структура("Серия, Код, Опция, ДоступенДляАктивации, ТребуетсяОпция, КодОшибки, ТекстОшибки", Неопределено, Сред(ПинКод, 5), Неопределено, Ложь, Ложь, "error", "");	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СерииПинКодовСУО.Ссылка
		|ИЗ
		|	Справочник.СерииПинКодовСУО КАК СерииПинКодовСУО
		|ГДЕ
		|	СерииПинКодовСУО.Код = &КодСерии";
	
	Запрос.УстановитьПараметр("КодСерии", Сред(ПинКод, 1, 4));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		ДанныеПинКода.КодОшибки = "noPinCode";
		ДанныеПинКода.ТекстОшибки = НСтр("ru = 'Пин-код не найден'");
		Возврат ДанныеПинКода;		
	КонецЕсли;			
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();			
	ВыборкаДетальныеЗаписи.Следующий();			
	
	ДанныеПинКода.Серия = ВыборкаДетальныеЗаписи.Ссылка;
	ДанныеПинКода.Опция = Справочники.СерииПинКодовСУО.НайтиОпциюПоИдентификатору(ИдентификаторОпции);
	
	Если НЕ ЗначениеЗаполнено(ДанныеПинКода.Опция)
		И Справочники.СерииПинКодовСУО.ЕстьОпции(ДанныеПинКода.Серия) Тогда
		
		ДанныеПинКода.КодОшибки = ""; // Это не ошибка, но и активировать нельзя
		ДанныеПинКода.ТребуетсяОпция = Истина;
		Возврат ДанныеПинКода;		
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВыданныеПинКодыСУО.ДатаИспользования КАК ДатаИспользования,
		|	ВыданныеПинКодыСУО.Заблокирован КАК Заблокирован
		|ИЗ
		|	РегистрСведений.ВыданныеПинКодыСУО КАК ВыданныеПинКодыСУО
		|ГДЕ
		|	ВыданныеПинКодыСУО.Серия = &Серия
		|	И ВыданныеПинКодыСУО.Код = &Код";
	
	Запрос.УстановитьПараметр("Код", ДанныеПинКода.Код);
	Запрос.УстановитьПараметр("Серия", ДанныеПинКода.Серия);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		ДанныеПинКода.КодОшибки = "noPinCode";
		ДанныеПинКода.ТекстОшибки = НСтр("ru = 'Пин-код не найден'");
		Возврат ДанныеПинКода;
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ВыборкаДетальныеЗаписи.Следующий();
	
	Если ВыборкаДетальныеЗаписи.Заблокирован Тогда
		ДанныеПинКода.КодОшибки = "disabledPinCode";
		ДанныеПинКода.ТекстОшибки = НСтр("ru = 'Пин-код заблокирован'");
		Возврат ДанныеПинКода;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ДатаИспользования) Тогда
		ДанныеПинКода.КодОшибки = "usedPinCode";
		ДанныеПинКода.ТекстОшибки = НСтр("ru = 'Пин-код использован ранее'");
		Возврат ДанныеПинКода;
	КонецЕсли;	
	
	ДанныеПинКода.ДоступенДляАктивации = Истина;
	ДанныеПинКода.КодОшибки = "";
	ДанныеПинКода.ТекстОшибки = "";
	
	Возврат ДанныеПинКода;
	
КонецФункции

Функция КодыПользователя(Знач Пользователь) Экспорт	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВыданныеПинКодыСУО.Серия.Описание КАК Описание,
		|	ВыданныеПинКодыСУО.Серия.Код + ВыданныеПинКодыСУО.Код КАК ПинКод,
		|	ВыданныеПинКодыСУО.ДатаИспользования КАК ДатаИспользования,
		|	ВыданныеПинКодыСУО.Опция.Наименование КАК НаименованиеОпции
		|ИЗ
		|	РегистрСведений.ВыданныеПинКодыСУО КАК ВыданныеПинКодыСУО
		|ГДЕ
		|	ВыданныеПинКодыСУО.Заблокирован = ЛОЖЬ
		|	И ВыданныеПинКодыСУО.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

#КонецОбласти


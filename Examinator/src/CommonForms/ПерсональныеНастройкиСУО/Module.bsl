// ЭКСПОРТНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

&НаСервере
Процедура УдалитьПерсональныеНастройкиЭлектронныхРесурсовНаСервере()
	
	НаборЗаписей = РегистрыСведений.НастройкиПрохожденияЭлектронныхРесурсовСУЗ.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Пользователь.Установить(АвторизованныйПользователь);
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

&НаКлиенте
Функция ВыполнитьОчисткуКаталогаВременныхФайлов() 
	
	ПутьККаталогу = ОбъектыСУЗПовтИсп.ПутьКаталогуОбъектов();
	
	Если ЗначениеЗаполнено(ПутьККаталогу) Тогда
		
		Попытка
		    УдалитьФайлы(ПутьККаталогу);  
		Исключение
		    Возврат ОписаниеОшибки();
		КонецПопытки;

	КонецЕсли
		
КонецФункции

//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//

&НаСервереБезКонтекста
Процедура ЗаписатьНастройкуСУО(ИмяНастройки, ЗначениеНастройки)
	
	РегистрыСведений.НастройкиПользователейСУО.ЗаписатьНастройку(Пользователи.ТекущийПользователь(), ИмяНастройки, ЗначениеНастройки);	
	
КонецПроцедуры

//----------------------------------//

&НаСервере
Процедура ЗаписатьНастройкиНаСервере()
		
	ОбщегоНазначения.ХранилищеОбщихНастроекСохранить(
		"НастройкиПрограммы/ПредлагатьУстановкуРасширенияРаботыСФайлами",
		ИдентификаторКлиента,
		НапоминатьОбУстановкеРасширенияРаботыСФайлами);
		
	СохранитьСвойстваКоллекции("ОбщиеНастройкиПользователя", ЭтотОбъект,
		"ЗапрашиватьПодтверждениеПриЗавершенииПрограммы");		
		
	ОбновитьПовторноИспользуемыеЗначения();
	
КонецПроцедуры

&НаСервере
Процедура СохранитьСвойстваКоллекции(КлючОбъекта, Коллекция, ИменаРеквизитов)
	СтруктураРеквизитов = Новый Структура(ИменаРеквизитов);
	ЗаполнитьЗначенияСвойств(СтруктураРеквизитов, Коллекция);
	Для Каждого КлючИЗначение Из СтруктураРеквизитов Цикл
		ОбщегоНазначения.ХранилищеОбщихНастроекСохранить(КлючОбъекта, КлючИЗначение.Ключ, КлючИЗначение.Значение);
	КонецЦикла;
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Получаем переменные
	
	АвторизованныйПользователь = Пользователи.АвторизованныйПользователь();
	
	ЗапрашиватьПодтверждениеПриЗавершенииПрограммы = СтандартныеПодсистемыСервер.ЗапрашиватьПодтверждениеПриЗавершенииПрограммы();
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	НастройкиПользователяИзБД = Неопределено;
	
	РегистрыСведений.НастройкиПользователейСУО.ЗаполнитьСтруктуруНастроек(Пользователи.ТекущийПользователь(), НастройкиПользователяИзБД);
	
	Если НастройкиПользователяИзБД <> Неопределено Тогда
	
		ЗапретитьРассылкуНаАдресЭлектроннойПочты = НастройкиПользователяИзБД.ЗапретитьРассылкуНаАдресЭлектроннойПочты;
		СкрытьКонтактнуюИнформацию = НастройкиПользователяИзБД.СкрытьКонтактнуюИнформацию;
		СкрытьДополнительныеСведения = НастройкиПользователяИзБД.СкрытьДополнительныеСведения;
		ЗапретитьУведомленияОНовыхЛичныхСообщениях = НастройкиПользователяИзБД.ЗапретитьУведомленияОНовыхЛичныхСообщениях;
		ЗапретитьУведомленияОНовыхСообщенияхФорума = НастройкиПользователяИзБД.ЗапретитьУведомленияОНовыхСообщенияхФорума;
		
	КонецЕсли;
	
	Если НЕ ПолучитьФункциональнуюОпцию("ПолныйИнтерфейсСУО") Тогда
		Элементы.ОбщаяКомандаМоиПинКодыСУО.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.СкрытьДополнительныеСведения.Видимость = ПолучитьФункциональнуюОпцию("ИспользоватьДополнительныеРеквизитыИСведения");
	
	//----------------------------------//
	
	ИспользуетсяЛокальныйКэшНаКлиенте = ПараметрыСеанса.ИспользуетсяЛокальныйКэшНаКлиентеСУЗ;
	
	ЭтоВебКлиент = ОбщегоНазначенияКлиентСервер.ЭтоВебКлиент();
	
	// Устанавливаем видимость элементов
	
	Элементы.ГруппаВебКлиент.Видимость = ЭтоВебКлиент;
	Элементы.ОчиститьКаталогВременныхФайлов.Видимость = ИспользуетсяЛокальныйКэшНаКлиенте;
	
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	#Если ВебКлиент Тогда	
	НапоминатьОбУстановкеРасширенияРаботыСФайлами = ОбщегоНазначенияКлиент.ПредлагатьУстановкуРасширенияРаботыСФайлами();
	#КонецЕсли	

	СистемнаяИнформация = Новый СистемнаяИнформация;
	ИдентификаторКлиента = СистемнаяИнформация.ИдентификаторКлиента;
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ДЕЙСТВИЯ КОМАНД

&НаКлиенте
Процедура ОбновитьПараметрыСистемы(Команда)
	ОбновитьПовторноИспользуемыеЗначения();
	ОбновитьИнтерфейс();
	ПоказатьПредупреждение(,НСтр("ru = 'Параметры системы обновлены'"));
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьКаталогВременныхФайлов(Команда)
	
	#Если НЕ ВебКлиент Тогда
		
	ОписаниеОповещения = Новый ОписаниеОповещения("ОчиститьКаталогВременныхФайловПродолжение", ЭтотОбъект);		
		
	ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'После удаления временных файлов программа будет перезапущена. Продолжить?'"), РежимДиалогаВопрос.ДаНет, 0);
		
	#КонецЕсли	
	
КонецПроцедуры

#Если НЕ ВебКлиент Тогда

&НаКлиенте
Процедура ОчиститьКаталогВременныхФайловПродолжение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
	    Возврат;
	КонецЕсли;

	СообщениеОбОшибке = ВыполнитьОчисткуКаталогаВременныхФайлов();
	
	Если СообщениеОбОшибке <> Неопределено Тогда
		
		ПоказатьПредупреждение(,НСтр("ru = 'В процессе удаления файлов произошла ошибка. Рекомендуется закрыть все используемые файлы и после перезапуска выполнить очистку повторно. Описание ошибки: '") + СообщениеОбОшибке);
		
	Иначе
		
		ЗавершитьРаботуСистемы(Ложь, Истина);

	КонецЕсли;

КонецПроцедуры	

#КонецЕсли

&НаКлиенте
Процедура ПерсональнаяНастройкаПроксиСервера(Команда)
	
	ОткрытьФорму("ОбщаяФорма.ПараметрыПроксиСервера",
				Новый Структура("НастройкаПроксиНаКлиенте", Истина));

КонецПроцедуры

&НаКлиенте
Процедура СведенияОПользователе(Команда)
	ПоказатьЗначение(,АвторизованныйПользователь);
КонецПроцедуры

&НаКлиенте
Процедура УдалитьПерсональныеНастройкиЭлектронныхРесурсов(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("УдалитьПерсональныеНастройкиЭлектронныхРесурсовПродолжение", ЭтотОбъект);		
		
	ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'Удалить настройки?'"), РежимДиалогаВопрос.ДаНет, 0);
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьПерсональныеНастройкиЭлектронныхРесурсовПродолжение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
	    Возврат;
	КонецЕсли;

	УдалитьПерсональныеНастройкиЭлектронныхРесурсовНаСервере();
	
	ПоказатьПредупреждение(,НСтр("ru = 'Настройки успешно удалены'"));	
	
КонецПроцедуры	

&НаКлиенте
Процедура УстановитьРасширениеРаботыСФайламиНаКлиенте(Команда)
	НачатьУстановкуРасширенияРаботыСФайлами();
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПароль(Команда)
	ОткрытьФорму("ОбщаяФорма.ИзменениеПароляПользователяИБ",,,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура УчебныеБазы(Команда)
	ОткрытьФорму("РегистрСведений.УчебныеБазыСУЗ.Форма.ФормаПерсональныеУчебныеБазы");
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура НапоминатьОбУстановкеРасширенияРаботыСФайламиПриИзменении(Элемент)
	
	ЗаписатьНастройкиНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапрашиватьПодтверждениеПриЗавершенииПрограммыПриИзменении(Элемент)
		
	ЗаписатьНастройкиНаСервере();
	
КонецПроцедуры

//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//

&НаКлиенте
Процедура СкрытьКонтактнуюИнформациюПриИзменении(Элемент)
	ЗаписатьНастройкуСУО("СкрытьКонтактнуюИнформацию", СкрытьКонтактнуюИнформацию);
КонецПроцедуры

&НаКлиенте
Процедура ЗапретитьРассылкуНаАдресЭлектроннойПочтыПриИзменении(Элемент)
	ЗаписатьНастройкуСУО("ЗапретитьРассылкуНаАдресЭлектроннойПочты", ЗапретитьРассылкуНаАдресЭлектроннойПочты);
КонецПроцедуры

&НаКлиенте
Процедура СкрытьДополнительныеСведенияПриИзменении(Элемент)
	ЗаписатьНастройкуСУО("СкрытьДополнительныеСведения", СкрытьДополнительныеСведения);
КонецПроцедуры

&НаКлиенте
Процедура ЗапретитьУведомленияОНовыхСообщенияхФорумаПриИзменении(Элемент)
	ЗаписатьНастройкуСУО("ЗапретитьУведомленияОНовыхСообщенияхФорума", ЗапретитьУведомленияОНовыхСообщенияхФорума);
КонецПроцедуры

&НаКлиенте
Процедура ЗапретитьУведомленияОНовыхЛичныхСообщенияхПриИзменении(Элемент)
	ЗаписатьНастройкуСУО("ЗапретитьУведомленияОНовыхЛичныхСообщениях", ЗапретитьУведомленияОНовыхЛичныхСообщениях);
КонецПроцедуры


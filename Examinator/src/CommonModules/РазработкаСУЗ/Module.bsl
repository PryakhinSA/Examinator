КонецФункции

// Сохраняет содержимое файла в базу данных
//
Процедура СохранитьДвоичныеДанныеФайла(ФайлОбъект, ДвоичныеДанные) Экспорт
	
	Если ФайлОбъект.ТипФайла = Перечисления.ТипыФайловСУЗ.Default Тогда 
	
		// Извлекаем текст файла
		
		ТекстФайла = ОбщегоНазначенияСУ.ИзвлечьТекстИзДвоичныхДанных(ДвоичныеДанные, ОбщегоНазначенияСУКлиентСервер.РасширениеИмениФайла(ФайлОбъект.ИмяФайла));
		
	КонецЕсли;
	
	// Сохраняем двоичные данные
	
	Если ЗначениеЗаполнено(ТекстФайла) Тогда
		
		ДанныеДляСохранения = Новый Структура;
		ДанныеДляСохранения.Вставить("ТекстовыеДанные", ТекстФайла);
		ДанныеДляСохранения.Вставить("ДвоичныеДанные", ДвоичныеДанные);
		
		ИмяРеквизитаДляСохранения = "ВсеРеквизиты";
		
	Иначе
		
		ДанныеДляСохранения       = ДвоичныеДанные;
		ИмяРеквизитаДляСохранения = "ДвоичныеДанные";
		
	КонецЕсли;
	
	РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ФайлОбъект, ДанныеДляСохранения, "ДвоичныеДанные", ИмяРеквизитаДляСохранения);
	
КонецПроцедуры

// Определяет, является файл HTML
Функция ЭтоФайлHTML(Знач Расширение) Экспорт
	
	Расширение = СтрЗаменить(Расширение, ".", "");
	
	Если НРег(Расширение) = "htm" ИЛИ НРег(Расширение) = "html" Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

// Подготавливает двоичные данные для сохранения в базу.
//
Функция ПоместитьДанныеФайлаВХранилищеЗначения(Объект, ДвоичныеДанные)
	
	Если ТипЗнч(ДвоичныеДанные) = Тип("ДвоичныеДанные") Тогда
		
		МаксимальныйРазмерФайла = РазработкаСУЗПовтИсп.ПолучитьМаксимальныйРазмерФайла();
		Загрузка                = Ложь;
		
		Если ТипЗнч(Объект) = Тип("СправочникОбъект.ФайлыСУЗ") Тогда
			Загрузка = Объект.ОбменДанными.Загрузка;
		КонецЕсли;
		
		Если МаксимальныйРазмерФайла > 0 И НЕ Загрузка Тогда
			
			РазмерФайла = ДвоичныеДанные.Размер(); 
			
			Если РазмерФайла > МаксимальныйРазмерФайла Тогда
				
				ВызватьИсключение ПолучитьТекстОПревышенииРазмераФайла(Объект.Наименование, РазмерФайла, МаксимальныйРазмерФайла);
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		ВызватьИсключение НСтр("ru = 'Неверный формат двоичных данных'");
		
	КонецЕсли;		
		
	Возврат ДвоичныеДанные; 
	
КонецФункции

// Получает текст предупреждения, если размер файла превышает допустимый.
//
Функция ПолучитьТекстОПревышенииРазмераФайла(ИмяФайла, РазмерФайла, МаксимальныйРазмерФайла)
	
	РазмерВМб = РазмерФайла / (1024 * 1024);
	РазмерВМбМакс = МаксимальныйРазмерФайла / (1024 * 1024);

	ТекстИсключения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Размер файла ""%1"" (%2 Мб) превышает максимально допустимый (%3 Мб)'"),
		ИмяФайла,
		?(РазмерВМб >= 1, Формат(РазмерВМб, "ЧДЦ=0"), Формат(РазмерВМб, "ЧДЦ=1; ЧН=0")),
		?(РазмерВМбМакс >= 1, Формат(РазмерВМбМакс, "ЧДЦ=0"), Формат(РазмерВМбМакс, "ЧДЦ=1; ЧН=0")));
	
	Возврат ТекстИсключения;
	
КонецФункции

Процедура РазметитьПолеРедактированияНастройкиИнтерактивногоРесурса(Форма, ОписаниеТипов) Экспорт
	
	// Получаем тип
	
	Типы = ОписаниеТипов.Типы();
	
	Если Типы.Количество() = 1 Тогда		
		ТипНастройки = Типы[0];		
	Иначе		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Количество типов значения настройки должно быть равным одному'"));
		Возврат;		
	КонецЕсли;
	
	// Создаем новый реквизит или обновляем существующий

	РеквизитыФормы       = Форма.ПолучитьРеквизиты();
	ДобавляемыеРеквизиты = Новый Массив();
	Удаляемыереквизиты   = Новый Массив();

	Для каждого РеквизитФормы Из РеквизитыФормы Цикл

		Если РеквизитФормы.Имя = "ЗначениеНастройки" Тогда
			Удаляемыереквизиты.Добавить("ЗначениеНастройки");
			Прервать;
		КонецЕсли;

	КонецЦикла;

	НовыйРеквизит = Новый РеквизитФормы("ЗначениеНастройки",
								   ОписаниеТипов,
								   "",
								   НСтр("ru = 'Значение настройки'"),
								   Истина); 
								   
	ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);

	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты, Удаляемыереквизиты);
   
	// Создаем элемент формы

	ЭлементФормы = Форма.Элементы.Найти("ЗначениеНастройки");

	Если ЭлементФормы = Неопределено Тогда

		ЭлементФормы = Форма.Элементы.Добавить("ЗначениеНастройки",
										 Тип("ПолеФормы"),
										 Форма.Элементы.ГруппаЗначениеНастройки); 	
										 
		ЭлементФормы.ПутьКДанным    = "ЗначениеНастройки";
		
	КонецЕсли;
										 
	ЭлементФормы.Вид                      = ВидПоляФормы.ПолеВвода;
	ЭлементФормы.Заголовок                = "Значение настройки";
	ЭлементФормы.ПоложениеЗаголовка       = ПоложениеЗаголовкаЭлементаФормы.Нет;
	ЭлементФормы.МногострочныйРежим       = ?(ТипНастройки = Тип("Строка") И ОписаниеТипов.КвалификаторыСтроки.Длина = 0, Истина, Ложь);
    ЭлементФормы.РастягиватьПоГоризонтали = Истина;


КонецПроцедуры

// Документы

Функция ПользовательскиеШаблоныДокументов() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШаблоныДокументовСУЗ.ИмяФайла,
		|	ШаблоныДокументовСУЗ.ДатаИзменения,
		|	ШаблоныДокументовСУЗ.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ШаблоныДокументовСУЗ КАК ШаблоныДокументовСУЗ
		|ГДЕ
		|	ШаблоныДокументовСУЗ.ПометкаУдаления = ЛОЖЬ";
	
	Возврат ОбщегоНазначенияСУ.ТаблицаВФиксированныйМассив(Запрос.Выполнить().Выгрузить());
	
КонецФункции

Функция ОписаниеДокумента(НастройкиКартинок) Экспорт
	
	ТекстОписания = "";
	
	Если НастройкиКартинок <> Неопределено И НастройкиКартинок.Свойство("СерииКартинок") И НастройкиКартинок.СерииКартинок.Количество() > 0 Тогда
					
		ТекстОписания = ТекстОписания + "{{IMAGES>" + Символы.ПС;

		КартинкиXDTO = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/ImportFilesSettings", "Картинки"));
		
		КартинкиXDTO.ВариантЗагрузкиКартинок = НастройкиКартинок.ВариантЗагрузкиКартинок;
		
		СерияКартинокXDTOТип = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/ImportFilesSettings", "СерияКартинок");
		КартинкаXDTOТип      = ФабрикаXDTO.Тип("http://v8.1c.ru/kms/1/ImportFilesSettings", "Картинка");
		
		Для каждого Строка Из НастройкиКартинок.СерииКартинок Цикл
		
			СерияКартинокXDTO = ФабрикаXDTO.Создать(СерияКартинокXDTOТип);	
			
			СерияКартинокXDTO.Имя = Строка.Имя;
			
			Для каждого СвойстваКартинки Из Строка.Картинки Цикл
				
				РазмерКартинкиМассив = ОбщегоНазначенияСУКлиентСервер.РасщепитьСтроку(СвойстваКартинки.РазмерКартинки, "x");
				
				Если РазмерКартинкиМассив.Количество() <> 2 Тогда
					Продолжить;
				КонецЕсли;
					
				КартинкаXDTO = ФабрикаXDTO.Создать(КартинкаXDTOТип);		
				
				РазмерКартинкиМассив[0] = СокрЛП(РазмерКартинкиМассив[0]);
				РазмерКартинкиМассив[0] = СтрЗаменить(РазмерКартинкиМассив[0], Символ(8234), "");
				РазмерКартинкиМассив[0] = СтрЗаменить(РазмерКартинкиМассив[0], Символ(8236), "");

				РазмерКартинкиМассив[1] = СокрЛП(РазмерКартинкиМассив[1]);
				РазмерКартинкиМассив[1] = СтрЗаменить(РазмерКартинкиМассив[1], Символ(8234), "");
				РазмерКартинкиМассив[1] = СтрЗаменить(РазмерКартинкиМассив[1], Символ(8236), "");				
				
				КартинкаXDTO.Имя    = СвойстваКартинки.Имя;
				КартинкаXDTO.Ширина = Число(РазмерКартинкиМассив[0]);
				КартинкаXDTO.Высота = Число(РазмерКартинкиМассив[1]);
				КартинкаXDTO.Размер = Число(СвойстваКартинки.РазмерФайла);
				
				СерияКартинокXDTO.Картинка.Добавить(КартинкаXDTO);
				
			КонецЦикла;
			
			КартинкиXDTO.СерияКартинок.Добавить(СерияКартинокXDTO);
				
		КонецЦикла;
		
		ЗаписьXML = Новый ЗаписьXML;
		ЗаписьXML.УстановитьСтроку();
		ЗаписьXML.ЗаписатьОбъявлениеXML();
		
		ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, КартинкиXDTO);
		
		ТекстОписания = ТекстОписания + ЗаписьXML.Закрыть();
		
		ТекстОписания = ТекстОписания + Символы.ПС + "<IMAGES}}";
		
	КонецЕсли;	
	
	Возврат ТекстОписания;
	
КонецФункции


КонецФункции

Функция ФорматВидеоФайлаДляОтображения(Знач Файл, Знач ИмяФайла, ПараметрыЭкспорта=Неопределено) Экспорт
	
	БазовыйФормат = БазовыйФорматВидеоФайла(ИмяФайла);
	
	ДопФорматыФайла = РазработкаСУЗПовтИсп.ДополнительныеФорматыВидео(Файл);
	
	Если ДопФорматыФайла.Количество() = 0 Тогда
		Возврат БазовыйФормат;
	КонецЕсли;
	
	МассивФорматов = Новый Массив;
	
	Для каждого Строка Из ДопФорматыФайла Цикл	
		МассивФорматов.Добавить(Строка.Формат);	
	КонецЦикла;
	
	Если МассивФорматов.Найти(БазовыйФормат) = Неопределено Тогда
		МассивФорматов.Добавить(БазовыйФормат);
	КонецЕсли;
	
	Если ПараметрыЭкспорта = Неопределено Тогда 
		
		// Отображение в 1С
		
		Если МассивФорматов.Найти("MP4") <> Неопределено Тогда			
			Возврат "MP4";
		КонецЕсли;		
		
		Если МассивФорматов.Найти("FLV") <> Неопределено Тогда			
			Возврат "FLV";
		КонецЕсли;				
		
	Иначе
		
		// Публикация
		
		Если ПараметрыЭкспорта.Свойство("ФорматыВидео") И ПараметрыЭкспорта.ФорматыВидео <> Неопределено Тогда
			
			Для каждого Формат Из ПараметрыЭкспорта.ФорматыВидео Цикл
			
				Если МассивФорматов.Найти(Формат) <> Неопределено Тогда			
					Возврат Формат;
				КонецЕсли;				
			
			КонецЦикла;
			
		КонецЕсли;	
	
		Если МассивФорматов.Найти("MP4") <> Неопределено Тогда			
			Возврат "MP4"; // Для отображения в экспорта лучше MP4
		КонецЕсли;
		
		Если МассивФорматов.Найти("WEBM") <> Неопределено Тогда			
			Возврат "WEBM";
		КонецЕсли;			
		
		Если МассивФорматов.Найти("FLV") <> Неопределено Тогда			
			Возврат "FLV";
		КонецЕсли;		
		
	КонецЕсли;	
		
	Возврат БазовыйФормат;
	
КонецФункции


&НаКлиенте
Процедура ОбсуждениеПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Если НЕ ДанныеСобытия.Свойство("Href") Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураСсылки = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(ДанныеСобытия.Href);
	
	Действие = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "action");
	
	Если ЗначениеЗаполнено(Действие) Тогда
		
		СтандартнаяОбработка = Ложь;
		
		Если Действие = "edit" Тогда
			
			НомерСообщения = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "message");
			
			ДокументСообщения = ПолучитьДокументСообщения(НомерСообщения);
			
			Если ЗначениеЗаполнено(ДокументСообщения) Тогда
				ПоказатьЗначение(,ДокументСообщения);
			КонецЕсли;
			
		КонецЕсли;
		
		Если Действие = "reply" Тогда
			
			НомерСообщения = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "message");
			
			ДокументСообщения = ПолучитьДокументСообщения(НомерСообщения);
			
			Оповещение = Новый ОписаниеОповещения("ПослеОтветаНаСообщение", ЭтотОбъект);
			
			ОткрытьФорму("Документ.СообщениеСУО.ФормаОбъекта", Новый Структура("Тема, Контекст, РодительскоеСообщение", ТекущаяТема, ТекущийКонтекст, ДокументСообщения),,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		КонецЕсли;
		
		Если Действие = "user" Тогда
			
			ИдентификаторПользователя = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "ref");
			ИдентификаторПользователя = Новый УникальныйИдентификатор(ИдентификаторПользователя);
			
			АвторСообщения = ПолучитьАвтораСообщения(ИдентификаторПользователя);
			
			Если ЗначениеЗаполнено(АвторСообщения) Тогда
				ПоказатьЗначение(,АвторСообщения);
			КонецЕсли;
		
		КонецЕсли;
		
		Если Действие = "attached" Тогда
			
			НомерСообщения = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "message");
			
			ДокументСообщения = ПолучитьДокументСообщения(НомерСообщения, УникальныйИдентификатор);
			
			Если ТипЗнч(ДокументСообщения) = Тип("Структура") Тогда
				
				ПрисоединенныеФайлыКлиент.ОткрытьФайл(ДокументСообщения, Ложь);
				
			Иначе
				
				ПараметрыФормы = Новый Структура("ВладелецФайла, ТолькоПросмотр", ДокументСообщения, Истина);
				ОткрытьФорму("Обработка.РаботаСФайлами.Форма.ПрисоединенныеФайлы", ПараметрыФормы);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры


// Выполняет обновление до версии 3.0.5.1
// 
//
Процедура ВыполнитьОбновлениеДоВерсии3051() Экспорт
	
	// Меняем ссылки на страницах с элементов содержания на объекты и актуализируем справочник СсылкиОбъектовСУЗ
	
	МассивСтраниц = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеСтраницыСУЗ.ФорматированныйДокумент,
		|	ДанныеСтраницыСУЗ.СсылкаНаОбъектСУЗ,
		|	ДанныеСтраницыСУЗ.Поставщик,
		|	ДанныеСтраницыСУЗ.Версия,
		|	ДанныеСтраницыСУЗ.КодДанных,
		|	""ДанныеСтраницыСУЗ"" КАК ИмяРегистра
		|ИЗ
		|	РегистрСведений.ДанныеСтраницыСУЗ КАК ДанныеСтраницыСУЗ
		|ГДЕ
		|	ДанныеСтраницыСУЗ.КодДанных = ""ТекстСтраницы""";
	
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	Для каждого Результат Из МассивРезультатов Цикл
	
		ВыборкаДетальныеЗаписи = Результат.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
			ФорматированныйДокумент = ВыборкаДетальныеЗаписи.ФорматированныйДокумент.Получить();
			
			// Делаем проверки
			
			Если ТипЗнч(ФорматированныйДокумент) <> Тип("ФорматированныйДокумент") Тогда
				Продолжить;
			КонецЕсли;	
			
			// Обрабатываем ссылки на в форматированном документе	
			
			ТекстHTML = "";
			Вложения = Неопределено;
			
			ФорматированныйДокумент.ПолучитьHTML(ТекстHTML, Вложения);		
			
			ЧтениеHTML = Новый ЧтениеHTML;
			ЧтениеHTML.УстановитьСтроку(ТекстHTML);
			
			ПостроительDOM = Новый ПостроительDOM;
			ДокументHTML = ПостроительDOM.Прочитать(ЧтениеHTML);
					
			Гиперссылки = ДокументHTML.ПолучитьЭлементыПоИмени("a");
			
			ОбновитьФорматированныйДокумент = Ложь;
			
			Для каждого ЭлементВебСсылки Из Гиперссылки Цикл
				
				// Получаем реквизиты ссылки
				
				ОбъектСУЗ = Неопределено;
				
				СтруктураСсылки = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(ЭлементВебСсылки.Гиперссылка);
				
				Действие = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "action");
				ИдентификаторОбъекта = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "id");
				ЦелевоеОкно = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "window");
				
				Если ЗначениеЗаполнено(Действие) И ЗначениеЗаполнено(ИдентификаторОбъекта) И Действие = "openKnowledgeBaseElementLink" Тогда
					
					ЭлементСодержания = Справочники.СодержаниеСУЗ.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторОбъекта));
					
					Если ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(ЭлементСодержания) Тогда				
						
						ОбновитьФорматированныйДокумент = Истина;
						
						ЭлементВебСсылки.Гиперссылка = ОбъектыСУЗПовтИсп.СсылкаНаОбъектСУЗ(ЭлементСодержания, ЦелевоеОкно);
						
					КонецЕсли;
					
				КонецЕсли;		
				
			КонецЦикла;
			
			Если ОбновитьФорматированныйДокумент Тогда
				
				ЗаписьHTML = Новый ЗаписьHTML;
				ЗаписьHTML.УстановитьСтроку();

				ЗаписьDOM = Новый ЗаписьDOM;
				ЗаписьDOM.Записать(ДокументHTML, ЗаписьHTML); 

				ТекстHTML = ЗаписьHTML.Закрыть();
				
				ФорматированныйДокумент.УстановитьHTML(ТекстHTML, Вложения);
				
		
				НаборЗаписей = РегистрыСведений[ВыборкаДетальныеЗаписи.ИмяРегистра].СоздатьНаборЗаписей();
				
				НаборЗаписей.Отбор.СсылкаНаОбъектСУЗ.Установить(ВыборкаДетальныеЗаписи.СсылкаНаОбъектСУЗ);
				НаборЗаписей.Отбор.Поставщик.Установить(ВыборкаДетальныеЗаписи.Поставщик);
				НаборЗаписей.Отбор.Версия.Установить(ВыборкаДетальныеЗаписи.Версия);
				НаборЗаписей.Отбор.КодДанных.Установить(ВыборкаДетальныеЗаписи.КодДанных);
				
				НаборЗаписей.Прочитать();
				
				НаборЗаписей[0].ФорматированныйДокумент = Новый ХранилищеЗначения(ФорматированныйДокумент);
				
				НаборЗаписей.Записать();
				
			КонецЕсли;		
			
			Если МассивСтраниц.Найти(ВыборкаДетальныеЗаписи.СсылкаНаОбъектСУЗ) = Неопределено Тогда
				МассивСтраниц.Добавить(ВыборкаДетальныеЗаписи.СсылкаНаОбъектСУЗ);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Для каждого СсылкаНаСтраницу Из МассивСтраниц Цикл
		
		ФорматированныйДокумент = ОбъектыСУЗ.ПолучитьДанные(СсылкаНаСтраницу, "ТекстСтраницы", Истина, "ФорматированныйДокумент"); 

		Гиперссылки = ОбщегоНазначенияСУ.ГиперссылкиФорматированногоДокумента(ФорматированныйДокумент);
		
		РазработкаСУЗ.ОбновитьГиперссылкиОбъектаСУЗ(СсылкаНаСтраницу, Гиперссылки);
	
	КонецЦикла;
	
	// Обновляем гиперссылки ресурсов
	
	РазработкаСУЗ.ОбновитьГиперссылкиРесурса(); // Всех ресурсов
	
	
КонецПроцедуры


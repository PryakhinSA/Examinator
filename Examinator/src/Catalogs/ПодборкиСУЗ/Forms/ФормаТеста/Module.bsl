#Область ОбработчикиКомандФормы

// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ПереместитьЭлементВверх(Команда)
	РазработкаСУЗКлиент.ПереместитьЭлемент("Вверх", Элементы.Вопросы);
КонецПроцедуры

&НаКлиенте
Процедура ПереместитьЭлементВниз(Команда)
	РазработкаСУЗКлиент.ПереместитьЭлемент("Вниз", Элементы.Вопросы);
КонецПроцедуры

&НаКлиенте
Процедура СоздатьВопрос(Команда)
	РазработкаСУЗКлиент.СоздатьЭлементТаблицыСУЗ(ЭтотОбъект, Элементы.Вопросы, "Вопрос", ЭлектронныйРесурс, Объект.Ссылка);
КонецПроцедуры	

&НаКлиенте
Процедура РедактироватьВопрос(Команда)
	ОткрытьВопрос();
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьВопросы(Команда)
	РазработкаСУзКлиент.ЗагрузитьЭлементыВТаблицуСУЗ(ЭтотОбъект, Элементы.Вопросы, ЭлектронныйРесурс, Объект.Ссылка,,, "тест");
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВопросИзРанееСозданных(Команда)
	ПараметрыФормыПодбора = Новый Структура("ЗакрыватьПриВыборе", Ложь);
	РазработкаСУЗКлиент.ДобавитьЭлементВТаблицуСУЗ(ЭтотОбъект, Элементы.Вопросы, "ВопросыСУЗ", ПараметрыФормыПодбора);
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьВремяВыполнения(Команда)
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("НачальноеЗначение", ОбъектыSCORM.ПолучитьКоличествоСекундИзДаты(Объект.ВремяТеста));
    ПараметрыФормы.Вставить("ТолькоВремя", Истина);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ИзменитьВремяВыполненияПродолжение", ЭтотОбъект);		
	
	ОткрытьФорму("ОбщаяФорма.ВводПериодаСУ", ПараметрыФормы, ЭтотОбъект,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьВремяВыполненияПродолжение(НоваяСтруктураПериода, ДополнительныеПараметры) Экспорт
	
	Если НоваяСтруктураПериода <> Неопределено Тогда
		
		ПродолжительностьВСекундах = ОбъектыSCORM.ПолучитьКоличествоСекундИзСтруктурыВременногоИнтервала(НоваяСтруктураПериода);
		Объект.ВремяТеста =  ОбъектыSCORM.ПолучитьДатуИзКоличестваСекунд(ПродолжительностьВСекундах);
		
	КонецЕсли;
	
КонецПроцедуры


				НоваяСтрока.ДатаВозвратаНаДоработку = Дата("00010101");	
				
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(НоваяСтрока.ШкалаОценки) Тогда
				Если ШкалаОценкиПроведения = Неопределено Тогда
					ШкалаОценкиПроведения = Документы.ПроведениеОбученияСУО.ШкалаОценки(ПрохождениеОбученияСвойства.ПроведениеОбучения);
				КонецЕсли;
				НоваяСтрока.ШкалаОценки = ШкалаОценкиПроведения;
			КонецЕсли;
			
		КонецЦикла;		
		
	КонецЕсли;	
		
	ТаблицаЗаданий.Сортировать("Номер");
	
	Возврат ТаблицаЗаданий;
	
КонецФункции

Функция ДоступенСписокПреподавателей(Знач ПрохождениеОбучения, Знач ВидОбучения = Неопределено, Знач СкрытьПреподавателей = Неопределено) Экспорт
	
	Если НЕ Актуально(ПрохождениеОбучения) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ВидОбучения = Неопределено ИЛИ СкрытьПреподавателей = Неопределено Тогда
		
		ДанныеПрохожденияОбучения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, Новый Структура("ПроведениеОбучения, Сценарий, СкрытьПреподавателей", "ПроведениеОбучения", "Сценарий", "ПроведениеОбучения.СкрытьПреподавателей"));
		
		СкрытьПреподавателей = ДанныеПрохожденияОбучения.СкрытьПреподавателей; 
		ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.Сценарий);
		
	КонецЕсли;
	
	Если СкрытьПреподавателей Тогда
		Возврат Ложь;
	КонецЕсли;	
	
	Возврат ВидОбучения.ТребуетсяПреподаватель;
	
КонецФункции

Функция ДоступныйСписокПреподавателей(Знач ПрохождениеОбучения) Экспорт
	
	Если НЕ Актуально(ПрохождениеОбучения) ИЛИ НЕ ДоступенСписокПреподавателей(ПрохождениеОбучения) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеПрохождения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, "Сценарий, ПроведениеОбучения");
	
	Возврат Документы.ПроведениеОбученияСУО.Преподаватели(ДанныеПрохождения.ПроведениеОбучения, ДанныеПрохождения.Сценарий, Истина);
	
КонецФункции

Функция РодительскоеОбучение(Знач ПрохождениеОбучения) Экспорт
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПрохождениеОбучения, "РодительскоеПрохождение");
КонецФункции

Функция ДанныеОПрохожденииПодчиненныхМероприятий(ПрохождениеОбучения, Пользователь = Неопределено, ПроведениеОбучения = Неопределено, СхемаПроведения = Неопределено, ВидОбучения = Неопределено) Экспорт
	
	// Получаем недостающие переменные
	
	Если Пользователь = Неопределено Тогда
		Пользователь = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПрохождениеОбучения, "Пользователь");
	КонецЕсли;
	
	Если ПроведениеОбучения = Неопределено Тогда
		ПроведениеОбучения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПрохождениеОбучения, "ПроведениеОбучения");
	КонецЕсли;
	
	Если СхемаПроведения = Неопределено Тогда
		СхемаПроведения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПроведениеОбучения, "СхемаПроведения");
	КонецЕсли;
	
	Если ВидОбучения = Неопределено Тогда
		ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(ПроведениеОбучения, ПрохождениеОбучения.Сценарий);
	КонецЕсли;
	
	// Получаем необходимые данные
	
	ТаблицаПодчиненныхМероприятий = Документы.ПроведениеОбученияСУО.ПодчиненныеМероприятия(ПроведениеОбучения,,СхемаПроведения);
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	УчастникиОбученияСУО.Баллы КАК Баллы,
	               |	УчастникиОбученияСУО.Регистратор КАК Прохождение,
	               |	УчастникиОбученияСУО.Статус КАК Статус,
	               |	УчастникиОбученияСУО.Сценарий КАК Сценарий,
	               |	УчастникиОбученияСУО.ПроверяетсяПреподавателем КАК ПроверяетсяПреподавателем,
	               |	УчастникиОбученияСУО.ПроверенПреподавателем КАК ПроверенПреподавателем,
	               |	УчастникиОбученияСУО.ВозвращеноНаДоработку КАК ВозвращеноНаДоработку,
	               |	УчастникиОбученияСУО.ВыставляетсяОценка КАК ВыставляетсяОценка
	               |ИЗ
	               |	РегистрСведений.УчастникиОбученияСУО КАК УчастникиОбученияСУО
	               |ГДЕ
	               |	УчастникиОбученияСУО.Пользователь = &Пользователь
	               |	И УчастникиОбученияСУО.ПроведениеОбучения = &ПроведениеОбучения
	               |	И УчастникиОбученияСУО.Регистратор <> &ПрохождениеОбщегоОбучения";
	
				   
	Запрос.УстановитьПараметр("ПрохождениеОбщегоОбучения", ПрохождениеОбучения);			   
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("ПроведениеОбучения", ПроведениеОбучения);

	Результат = Запрос.Выполнить();
	
	ТаблицаПрохожденийПодчиненныхМероприятий = Результат.Выгрузить();	
	
	// Считаем переменные, которые надо вернуть
	
	ДанныеОПрохождении = Новый Структура("
		|Баллы,
		|ТекущиеБаллы,
		|ЗавершеноВПроцентах,
		|ПроверяетсяПреподавателем,
		|ПроверенПреподавателем,
		|ВозвращеноНаДоработку,
		|КоличествоЗавершенных,
		|ВыставляетсяОценка", 
		0,
		0,
		0,
		Ложь,
		Истина,
		Ложь,
		0,
		Ложь);
	
	Для каждого СтрокаТПМ Из ТаблицаПрохожденийПодчиненныхМероприятий Цикл
		
		Если СтрокаТПМ.ПроверяетсяПреподавателем Тогда
			ДанныеОПрохождении.ПроверяетсяПреподавателем = Истина;
		КонецЕсли;
		
		Если СтрокаТПМ.ПроверяетсяПреподавателем И НЕ СтрокаТПМ.ПроверенПреподавателем Тогда
			ДанныеОПрохождении.ПроверенПреподавателем = Ложь;
		КонецЕсли;						
		
		Если СтрокаТПМ.ВозвращеноНаДоработку Тогда
			ДанныеОПрохождении.ВозвращеноНаДоработку = Истина;
		КонецЕсли;
		
		Если СтрокаТПМ.ВыставляетсяОценка Тогда
			ДанныеОПрохождении.ВыставляетсяОценка = Истина;
		КонецЕсли;		
		
	КонецЦикла;						
	
	// Определяем процент завершенных
	
	// Важно. При учете завершенных мероприятий НЕ учитываем, что некоторые могут
	// еще быть на проверке. Мероприятие завершено - это значит, что пользователь
	// завершил его выполнение, а то, что оно требует проверки не влияет на этот статус.
	
	ВсегоМероприятий           = 0;
	ЗавершеноМероприятий       = 0;
	ПроходитсяМероприятий      = 0;
	НеЗавершеноМероприятий     = 0;
	ЗачисленоНаМероприятия     = 0;
	
	Для каждого СтрокаТПМ Из ТаблицаПодчиненныхМероприятий Цикл
		
		// Примечание: подчиненные мероприятия у которых значимость равна нулю не учитываем.
		
		Если СтрокаТПМ.Значимость = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ВсегоМероприятий = ВсегоМероприятий + 1;
		
		Строка2 = ТаблицаПрохожденийПодчиненныхМероприятий.Найти(СтрокаТПМ.Мероприятие, "Сценарий");
		
		Если Строка2 <> Неопределено Тогда  // Прохождение найдено			
			
			Если Строка2.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Завершил
				ИЛИ Строка2.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Автомат Тогда				
				ЗавершеноМероприятий = ЗавершеноМероприятий + 1;				
			КонецЕсли;
			
			Если Строка2.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Проходит Тогда
				ПроходитсяМероприятий = ПроходитсяМероприятий + 1;
			КонецЕсли;
			
			Если Строка2.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.НеЗавершил Тогда
				НеЗавершеноМероприятий = НеЗавершеноМероприятий + 1;
			КонецЕсли;
			
			Если Строка2.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Зачислен Тогда
				ЗачисленоНаМероприятия = ЗачисленоНаМероприятия + 1;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ДанныеОПрохождении.КоличествоЗавершенных = ЗавершеноМероприятий;
	
	Если ВсегоМероприятий  > 0 Тогда
		ДанныеОПрохождении.ЗавершеноВПроцентах = Окр((ЗавершеноМероприятий / ВсегоМероприятий)*100);
	Иначе
		ДанныеОПрохождении.ЗавершеноВПроцентах = 100;
	КонецЕсли;
	
	// Считаем баллы
	
	НабранноеКоличествоБаллов = 0;
	МаксимумБаллов            = 0;
	МаксимумТекущихБаллов     = 0;
							
	Для каждого СтрокаТПМ Из ТаблицаПодчиненныхМероприятий Цикл
	
		МаксимумБаллов = МаксимумБаллов + 100*СтрокаТПМ.Значимость; 
		
		Строка2 = ТаблицаПрохожденийПодчиненныхМероприятий.Найти(СтрокаТПМ.Мероприятие, "Сценарий");
		
		Если Строка2 <> Неопределено Тогда
			НабранноеКоличествоБаллов = НабранноеКоличествоБаллов + Строка2.Баллы*СтрокаТПМ.Значимость;
			МаксимумТекущихБаллов = МаксимумТекущихБаллов + 100*СтрокаТПМ.Значимость; 
		КонецЕсли;
		
	КонецЦикла;	
	
	Если ЗначениеЗаполнено(СхемаПроведения) 
		И ДанныеОПрохождении.ЗавершеноВПроцентах = 100
		И МаксимумБаллов > 0
		И (НЕ ДанныеОПрохождении.ПроверяетсяПреподавателем 
			ИЛИ ДанныеОПрохождении.ПроверенПреподавателем 
			ИЛИ НЕ Справочники.ВидыМероприятийСУО.ЗаданияПроверяютсяВыборочно(ВидОбучения)) Тогда	
					
		ДанныеОПрохождении.Баллы = Окр((НабранноеКоличествоБаллов / МаксимумБаллов)*100);		
		
	Иначе
		
		ДанныеОПрохождении.Баллы = 0;
		
	КонецЕсли;
	
	Если МаксимумТекущихБаллов > 0 Тогда
		ДанныеОПрохождении.ТекущиеБаллы = Окр((НабранноеКоличествоБаллов / МаксимумТекущихБаллов)*100);		
	Иначе
		ДанныеОПрохождении.ТекущиеБаллы = 0;
	КонецЕсли;
	
	Возврат ДанныеОПрохождении;
	
КонецФункции

Функция ПодчиненныеПрохождения(ПрохождениеОбучения) Экспорт
	
	ПрохожденияОбучения = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрохождениеОбученияСУО.Ссылка
		|ИЗ
		|	Документ.ПрохождениеОбученияСУО КАК ПрохождениеОбученияСУО
		|ГДЕ
		|	ПрохождениеОбученияСУО.РодительскоеПрохождение = &РодительскоеПрохождение
		|	И ПрохождениеОбученияСУО.Проведен = ИСТИНА";
	
	Запрос.УстановитьПараметр("РодительскоеПрохождение", ПрохождениеОбучения);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ПрохожденияОбучения.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
	
	Возврат ПрохожденияОбучения;
	
КонецФункции

Функция КоличествоНовыхОбучений(Пользователь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПрохожденияОбученияСУО.Регистратор) КАК КоличествоОбучений
		|ИЗ
		|	РегистрСведений.ПрохожденияОбученияСУО КАК ПрохожденияОбученияСУО
		|ГДЕ
		|	ПрохожденияОбученияСУО.Пользователь = &Пользователь
		|	И ПрохожденияОбученияСУО.СтатусПроцессаОбучения = &СтатусПроцессаОбучения";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("СтатусПроцессаОбучения", Перечисления.СтатусыПроцессаОбученияСУО.Новое);
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();	
	ВыборкаДетальныеЗаписи.Следующий();
	
	Возврат ВыборкаДетальныеЗаписи.КоличествоОбучений;
	
КонецФункции

Функция РегистраторыЗаданийНаПроверкуПрохожденияОбучения(ПрохождениеОбучения)
	
	// В результат включены документы со статусом Отменено
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПопыткаВыполненияЗаданияСУО.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПопыткаВыполненияЗаданияСУО КАК ПопыткаВыполненияЗаданияСУО
		|ГДЕ
		|	ПопыткаВыполненияЗаданияСУО.ПрохождениеОбучения = &ПрохождениеОбучения
		|	И ПопыткаВыполненияЗаданияСУО.Задание ССЫЛКА Справочник.ЗаданияСУО
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПопыткаВыполненияПодборкиВопросовСУЗ.Ссылка
		|ИЗ
		|	Документ.ПопыткаВыполненияПодборкиВопросовСУЗ КАК ПопыткаВыполненияПодборкиВопросовСУЗ
		|ГДЕ
		|	ПопыткаВыполненияПодборкиВопросовСУЗ.ПрохождениеОбучения = &ПрохождениеОбучения
		|	И ПопыткаВыполненияПодборкиВопросовСУЗ.ПроверяетсяПреподавателем = ИСТИНА
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СессияЭлектронногоРесурсаСУЗ.Ссылка
		|ИЗ
		|	Документ.СессияЭлектронногоРесурсаСУЗ КАК СессияЭлектронногоРесурсаСУЗ
		|ГДЕ
		|	СессияЭлектронногоРесурсаСУЗ.ПрохождениеОбучения = &ПрохождениеОбучения
		|	И СессияЭлектронногоРесурсаСУЗ.ТипСессии = &ТипСессии";
	
	Запрос.УстановитьПараметр("ПрохождениеОбучения", ПрохождениеОбучения);
	Запрос.УстановитьПараметр("ТипСессии", Перечисления.ТипыСессийЭлектронныхРесурсовСУЗ.quiz);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

Функция ДатаНачалаОтсчетаПродолжительности(ДанныеПрохожденияОбучения) Экспорт
	
	// Требуемые свойства для ДанныеПрохожденияОбучения:
	// - ВариантПродолжительности
	// - ДатаЗачисления
	// - ДатаНачалаПрохождения
	
	Если ДанныеПрохожденияОбучения.ВариантПродолжительности = Перечисления.ПродолжительностьОбученияСУО.СЗачисления Тогда
		Возврат ДанныеПрохожденияОбучения.ДатаЗачисления;
	КонецЕсли;
	
	Если ДанныеПрохожденияОбучения.ВариантПродолжительности = Перечисления.ПродолжительностьОбученияСУО.СНачалаОбучения Тогда
		Возврат ДанныеПрохожденияОбучения.ДатаНачалаПрохождения;
	КонецЕсли;
	
	Если ДанныеПрохожденияОбучения.ВариантПродолжительности = Перечисления.ПродолжительностьОбученияСУО.Фиксированная Тогда
		Возврат ДанныеПрохожденияОбучения.ДатаНачалаПрохождения; // Равна дате начала проведения обучения	
	КонецЕсли;
	
	Возврат Дата("00010101");
	
КонецФункции

Функция ВремяНачалаОбученияНастало(ДатаНачалаПрохождения) Экспорт
	
	// Так как ДатаНачалаПрохождения показывает либо личную дату начала,
	// которая не может быть больше текущей, то можно ее брать, либо
	// дату начала обучения и если она больше текущей, то дата начала 
	// еще не настала.
	
	Если ЗначениеЗаполнено(ДатаНачалаПрохождения)
		И ДатаНачалаПрохождения > ТекущаяДатаСеанса() Тогда		
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция ВремяИстекло(Знач ПрохождениеОбучения) Экспорт
	
	// Требуемые свойства для ДанныеПрохожденияОбучения:
	// - ДатаКонтроля
	// - ДатаОкончанияПроведения
	// - ДатаНачалаПрохождения
	// - ВариантПродолжительности
	// - ДатаЗачисления
	// - ПродолжительностьВСекундах
	
	Если ТипЗнч(ПрохождениеОбучения) = Тип("ДокументСсылка.ПрохождениеОбученияСУО") Тогда
		
		ТребуемыеДанныеПрохожденияОбучения = Новый Структура(
			"ДатаКонтроля,
			|ДатаОкончанияПроведения,
			|ДатаНачалаПрохождения,
			|ВариантПродолжительности,
			|ДатаЗачисления,
			|ПродолжительностьВСекундах",		
			"ПроведениеОбучения.ДатаКонтроля",
			"ПроведениеОбучения.ДатаОкончанияПроведения",
			"ДатаНачалаПрохождения",
			"ПроведениеОбучения.ВариантПродолжительности",
			"Дата",
			"ПродолжительностьВСекундах");
	
		ДанныеПрохожденияОбучения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			ПрохождениеОбучения, ТребуемыеДанныеПрохожденияОбучения);		
	
	Иначе
		
		ДанныеПрохожденияОбучения = ПрохождениеОбучения;
		
	КонецЕсли;
	
	ВремяИстекло = Ложь;
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Если ЗначениеЗаполнено(ДанныеПрохожденияОбучения.ПродолжительностьВСекундах) Тогда		
										
		ДатаНачалаОтсчета = ДатаНачалаОтсчетаПродолжительности(ДанныеПрохожденияОбучения);
	
		Если ЗначениеЗаполнено(ДатаНачалаОтсчета)
			И ТекущаяДата > ДатаНачалаОтсчета + ДанныеПрохожденияОбучения.ПродолжительностьВСекундах Тогда
			
			ВремяИстекло = Истина;
			
		КонецЕсли;	
			
	Иначе	
		
		Если ЗначениеЗаполнено(ДанныеПрохожденияОбучения.ДатаКонтроля)
			И ДанныеПрохожденияОбучения.ДатаКонтроля < ТекущаяДата Тогда
			
			ВремяИстекло = Истина; // Проверяем не наступила ли дата контроля
			
		КонецЕсли;		
		
		Если ЗначениеЗаполнено(ДанныеПрохожденияОбучения.ДатаОкончанияПроведения)
			И ДанныеПрохожденияОбучения.ДатаОкончанияПроведения < ТекущаяДата Тогда
			
			ВремяИстекло = Истина; // Проверяем не наступила ли дата окончания проведения
			
		КонецЕсли;
		
	КонецЕсли;

	Возврат ВремяИстекло;
	
КонецФункции

Функция ОсталосьВремениЧисло(Актуально, СтатусПроцессаОбучения, ВариантПродолжительности, ПродолжительностьВСекундах, ДатаНачалаОтсчетаПродолжительности, ДатаОкончанияПроведения) Экспорт
	
	// Получаем сколько осталось в секундах
	// Такой же алгоритм есть в функции durationLeft веб-кабинета
	// и в списке Участники формы документа ПроведениеОбученияСУО.
	
	ТекущаяДата = ТекущаяДатаСеанса();
	ОсталосьВремениВСекундах = Неопределено;
	
	Если НЕ Актуально Тогда
		Возврат 0;
	КонецЕсли;
	
	Если СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.Запланировано Тогда
		Возврат 0;
	КонецЕсли;
	
	Если СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.Новое
		И ВариантПродолжительности = Перечисления.ПродолжительностьОбученияСУО.СНачалаОбучения Тогда
		
		Возврат 0;
		
	КонецЕсли;
	
	Если ВариантПродолжительности = Перечисления.ПродолжительностьОбученияСУО.Фиксированная
		И ЗначениеЗаполнено(ДатаОкончанияПроведения) Тогда
		
		Если ТекущаяДата >  ДатаОкончанияПроведения Тогда
			Возврат -1;
		КонецЕсли;
		
	КонецЕсли;		
	
	Если ВариантПродолжительности <> Перечисления.ПродолжительностьОбученияСУО.СНачалаОбучения
		И ВариантПродолжительности <> Перечисления.ПродолжительностьОбученияСУО.СЗачисления Тогда
		
		Возврат 0;
		
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(ПродолжительностьВСекундах)
		ИЛИ НЕ ЗначениеЗаполнено(ДатаНачалаОтсчетаПродолжительности) Тогда
		
		Возврат 0;
		
	КонецЕсли;
	
	ДатаОкончанияОбучения = ДатаНачалаОтсчетаПродолжительности + ПродолжительностьВСекундах;
	
	Если ДатаНачалаОтсчетаПродолжительности > ТекущаяДата Тогда
		Возврат 0;
	КонецЕсли;
	
	Если ТекущаяДата > ДатаОкончанияОбучения Тогда
		Возврат -1;
	КонецЕсли;
	
	Возврат ДатаОкончанияОбучения - ТекущаяДата;
	
КонецФункции

Функция ОсталосьВремениСтрока(Актуально, СтатусПроцессаОбучения, ВариантПродолжительности, ПродолжительностьВСекундах, ДатаНачалаОтсчетаПродолжительности, ДатаОкончанияПроведения) Экспорт
	
	ОсталосьВремениВСекундах = ОсталосьВремениЧисло(Актуально, СтатусПроцессаОбучения, ВариантПродолжительности, ПродолжительностьВСекундах, ДатаНачалаОтсчетаПродолжительности, ДатаОкончанияПроведения);
				
	Если НЕ ЗначениеЗаполнено(ОсталосьВремениВСекундах) Тогда
		Возврат "";
	КонецЕсли;
	
	Если ОсталосьВремениВСекундах = -1 Тогда
		Возврат НСтр("ru = 'Время истекло'");
	КонецЕсли;
			
	ОсталосьВремениСтрока = ОбъектыSCORM.ПолучитьПолнуюСтрокуИзКоличестваСекунд(ОсталосьВремениВСекундах,,Истина);

	Возврат СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Осталось %1'"), ОсталосьВремениСтрока);					
	
КонецФункции

Процедура ДобавитьВремя(ПрохождениеОбучения, ДобавленоВремениВСекундах) Экспорт
	
	ПрохождениеОбученияОбъект = ПрохождениеОбучения.ПолучитьОбъект();	
	
	Если ПрохождениеОбученияОбъект.Отменено Тогда
		ВызватьИсключение НСтр("ru = 'Невозможно добавить время отмененному участнику'");
	КонецЕсли;
	
	Попытка 
		ПрохождениеОбученияОбъект.Заблокировать();
	Исключение
		ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось заблокировать объект %1'"),
			Строка(ПрохождениеОбученияОбъект));
	КонецПопытки;

	ПрохождениеОбученияОбъект.ДобавленоВремениВСекундах = ДобавленоВремениВСекундах;
	ПрохождениеОбученияОбъект.ДобавленоВремениСтрока = ОбъектыSCORM.ПолучитьПолнуюСтрокуИзКоличестваСекунд(ДобавленоВремениВСекундах);
	
	ПрохождениеОбученияОбъект.ДополнительныеСвойства.Вставить("ОбновлятьПодчиненныеДокументы", Ложь);
	ПрохождениеОбученияОбъект.Записать(РежимЗаписиДокумента.Проведение);
	ПрохождениеОбученияОбъект.Разблокировать();
	
КонецПроцедуры

Функция ДоступенБлокОцениванияКачестваОбучения(СтатусПроцессаОбучения, КачествоОбученияОцениваетсяУчастниками) Экспорт
	
	Если НЕ КачествоОбученияОцениваетсяУчастниками Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.Окончено
		ИЛИ СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.ОконченоБезПроверки Тогда
		
		Возврат Истина;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ОценкаЗаОбучение(Знач ПрохождениеОбучения) Экспорт
	
	ДанныеПрохожденияОбучения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, "ПроведениеОбучения, Баллы");
	ШкалаОценки = Документы.ПроведениеОбученияСУО.ШкалаОценки(ДанныеПрохожденияОбучения.ПроведениеОбучения);
	ДанныеОценки = Справочники.ШкалыОценокСУО.ОценкаИзБаллов(ДанныеПрохожденияОбучения.Баллы, ШкалаОценки, Истина);
	
	Возврат ДанныеОценки;
	
КонецФункции

Функция ВыставляетсяОценка(Знач ПрохождениеОбучения, Знач ВидОбучения, Знач ЭлектронныйРесурс, Знач Задания, Знач Статус) Экспорт	
	
	Если НЕ ВидОбучения.Электронное Тогда
		Возврат ВидОбучения.ВыставляетсяОценка;
	КонецЕсли;
	
	Если НЕ ВидОбучения.ВыставляетсяОценка Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПрохождениеОбучения) Тогда
	
		Если Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Автомат Тогда
			Возврат Истина;
		КонецЕсли;
		
		Если Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Завершил Тогда
			
			ПопыткиВыполненияЗаданий = Документы.ПопыткаВыполненияЗаданияСУО.ПопыткиВыполненияЗаданий(ПрохождениеОбучения);
			
			Если ПопыткиВыполненияЗаданий.Найти(Истина, "ВыставляетсяОценка") <> Неопределено Тогда
				Возврат Истина;
			КонецЕсли;
			
			Возврат Ложь;
			
		КонецЕсли;	
		
	КонецЕсли;
		
	Возврат Документы.ПроведениеОбученияСУО.ВыставляетсяОценка(ВидОбучения, ЭлектронныйРесурс, Задания); 	
	
КонецФункции		



// ВЕБ-КАБИНЕТ

Процедура ОбновитьДанныеВебКабинета(ПрохождениеОбучения, ДополнительныеДанные = Неопределено) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем переменные
	
	ТребуемыеДанные = Новый Структура("
	|Ссылка,
	|Проведен,
	|Пользователь,
	|НаименованиеПользователя,
	|ДатаНачалаПрохождения,
	|Сценарий,
	|Статус,
	|ПроведениеОбучения,
	|РодительскоеПрохождение,
	|ВыставляетсяОценка",
	"Ссылка",
	"Проведен",
	"Пользователь",
	"Пользователь.Наименование",
	"ДатаНачалаПрохождения",
	"Сценарий",
	"Статус",
	"ПроведениеОбучения",
	"РодительскоеПрохождение",
	"ВыставляетсяОценка");
	
	ДанныеПрохожденияОбучения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, ТребуемыеДанные);
	ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.Сценарий); 
	Электронное = Документы.ПроведениеОбученияСУО.ЭтоЭлектронноеОбучение(ДанныеПрохожденияОбучения.ПроведениеОбучения, ВидОбучения,ДанныеПрохожденияОбучения.Сценарий); 
	ЭлектронноДистанционное = Документы.ПроведениеОбученияСУО.ЭлектронноДистанционноеОбучение(ДанныеПрохожденияОбучения.ПроведениеОбучения, ВидОбучения, ДанныеПрохожденияОбучения.Сценарий);
	
	// Удаляем старые данные
	
	РегистрыСведений.ДанныеВебКабинетаСУО_ПН.УдалитьДанные(ПрохождениеОбучения);
	РегистрыСведений.ДанныеВебКабинетаСУО_ПП.УдалитьДанные(ПрохождениеОбучения);	
	РегистрыСведений.ДанныеВебКабинетаСУО_ОН.УдалитьДанные(ПрохождениеОбучения, Перечисления.ТипыДанныхВебКабинетаСУО.УчастникОбучения);
	РегистрыСведений.ДанныеВебКабинетаСУО_ПН.УдалитьДанные(ДанныеПрохожденияОбучения.ПроведениеОбучения, Перечисления.ТипыДанныхВебКабинетаСУО.РазделФорума, ДанныеПрохожденияОбучения.Пользователь);
	РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.УдалитьОтбор(ПрохождениеОбучения);
	РегистрыСведений.ЗависимостиДанныхВебКабинетаСУ.УдалитьДанные(ПрохождениеОбучения, "Документ.ПрохождениеОбученияСУО");
	
	ВозможныеРегистраторыЗаданий = РегистраторыЗаданийНаПроверкуПрохожденияОбучения(ПрохождениеОбучения);
		
	Для каждого ВозможныйРегистратор Из ВозможныеРегистраторыЗаданий Цикл
		РегистрыСведений.ДанныеВебКабинетаСУО_ПН.УдалитьДанные(ВозможныйРегистратор, Перечисления.ТипыДанныхВебКабинетаСУО.ПроверкаЗаданияОписание);
		РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.УдалитьОтбор(ВозможныйРегистратор);
	КонецЦикла;
		
	ТаблицаФайловОбъекта = ОбучениеСУО.ПрикрепленныеФайлыКОбъектуОбучения(ПрохождениеОбучения, Ложь);	
	Для каждого Строка Из ТаблицаФайловОбъекта Цикл
		РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.УдалитьОтбор(Строка.Ссылка);
		РегистрыСведений.ДанныеВебКабинетаСУО_ОН.УдалитьДанные(Строка.Ссылка, Перечисления.ТипыДанныхВебКабинетаСУО.ФайлУчащегося);
		РегистрыСведений.ДанныеВебКабинетаСУО_ПП.УдалитьДанные(Строка.Ссылка);	
	КонецЦикла;
	
	// Добавляем новые данные
	
	Зависимости = Новый Массив;
	
	РегистрыСведений.БиблиотекаПользователейСУО.ОбновитьДанныеВебКабинета(ДанныеПрохожденияОбучения.Пользователь); // Библиотека пользователя		
	
	Если ДанныеПрохожденияОбучения.Проведен И НЕ Отменено(ПрохождениеОбучения) Тогда
		
		// Прикрепленные файлы
		
		ФайлыОбъекта = Новый Массив;
		
		Для каждого Строка Из ТаблицаФайловОбъекта Цикл
			Если НЕ Строка.ПометкаУдаления Тогда
				ФайлыОбъекта.Добавить(Строка.Ссылка);
			КонецЕсли;		
		КонецЦикла;
		
		Для каждого Файл Из ФайлыОбъекта Цикл
			
			Зависимости.Добавить(Файл);
			
			// Описание файла учащегося (общее)
			
			ОписаниеФайлаУчащегося = ФайлУчащегосяJSON(ДанныеПрохожденияОбучения, Файл);
			РегистрыСведений.ДанныеВебКабинетаСУО_ОН.ДобавитьДанные(Перечисления.ТипыДанныхВебКабинетаСУО.ФайлУчащегося, Файл, ОписаниеФайлаУчащегося, Перечисления.ФорматыВебДанныхСУ.json); 
			
			// Данные о проверке файла преподавателем
			
			РегистрыСведений.ФайлыПроверенныеПреподавателямиСУО.ОбновитьДанныеВебКабинета(Файл);
						
			// Отбор файлов по преподавателям
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	ФайлыНаПроверкуПреподавателюСУО.Преподаватель КАК Преподаватель
				|ИЗ
				|	РегистрСведений.ФайлыНаПроверкуПреподавателюСУО КАК ФайлыНаПроверкуПреподавателюСУО
				|ГДЕ
				|	ФайлыНаПроверкуПреподавателюСУО.Файл = &Файл";
			
			Запрос.УстановитьПараметр("Файл", Файл);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(Файл, ВыборкаДетальныеЗаписи.Преподаватель);
			КонецЦикла;
			
			// Отбор по проведению обучения
			
			РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(Файл, ДанныеПрохожденияОбучения.ПроведениеОбучения);
			
			// Отбор по сценарию
			
			РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(Файл, ДанныеПрохожденияОбучения.Сценарий);
			
			// Отбор по пользователю
			
			РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(Файл, ДанныеПрохожденияОбучения.Пользователь);
			
		КонецЦикла;
		
		// Результаты тестирования
		
		ЕстьРезультатыТестирования = Ложь;
		
		Если ВидОбучения.ПоказыватьРезультатыТестирования Тогда
		
			ВыборкаТестирований = Неопределено;
			
			ТаблицаПрисоединенныхЭлектронныхКурсов = Документы.ПроведениеОбученияСУО.ПрикрепленныеЭлектронныеРесурсы(ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.Сценарий, Истина);
			ПрисоединенныеЭлектронныеКурсы = ТаблицаПрисоединенныхЭлектронныхКурсов.ВыгрузитьКолонку("ЭлектронныйРесурс");

			Если Электронное ИЛИ ПрисоединенныеЭлектронныеКурсы.Количество() > 0 Тогда			
				ВыборкаТестирований = РегистрыСведений.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.ПопыткиПрохожденияТестов(ДанныеПрохожденияОбучения.Пользователь, ?(Электронное, ПрохождениеОбучения, Неопределено), ПрисоединенныеЭлектронныеКурсы);
			КонецЕсли;		
			
			Если ВыборкаТестирований <> Неопределено И ВыборкаТестирований.Количество() > 0 Тогда
				
				ЕстьРезультатыТестирования = Истина;
				
				// Получаем массив сессий тестирований
				
				МассивСессийТестирования = Новый Массив;
				
				Пока ВыборкаТестирований.Следующий() Цикл
					МассивСессийТестирования.Добавить(ВыборкаТестирований.СессияВыполненияТеста);
				КонецЦикла;
				
				ВыборкаТестирований.Сбросить();
				
				// Получаем ответы на вопрос
				
				ОписаниеРезультатовТестирования = Новый Массив;
				
				ВыборкаОтветовНаВопросы = РегистрыСведений.ВопросыТестированийСУЗ.ВопросыТестирований(МассивСессийТестирования);
				
				// Получаем варианты ответов на вопросы
				
				МассивПростыхВопросов = Новый Массив;
				
				Пока ВыборкаОтветовНаВопросы.Следующий() Цикл
					
					Если ВыборкаОтветовНаВопросы.ТипВопроса = Перечисления.ТипыВопросовСУЗ.ОдинИзМногих
						ИЛИ ВыборкаОтветовНаВопросы.ТипВопроса = Перечисления.ТипыВопросовСУЗ.МногиеИзМногих
						ИЛИ ВыборкаОтветовНаВопросы.ТипВопроса = Перечисления.ТипыВопросовСУЗ.ПоШаблону
						ИЛИ ВыборкаОтветовНаВопросы.ТипВопроса = Перечисления.ТипыВопросовСУЗ.Последовательность Тогда
						
						МассивПростыхВопросов.Добавить(ВыборкаОтветовНаВопросы.Вопрос);
						
					КонецЕсли;
					
				КонецЦикла;
				
				ВыборкаОтветовНаВопросы.Сбросить();
				
				ВыборкаВариантовОтветов = РегистрыСведений.ВыбранныеВариантыОтветовВопросовСУЗ.ВыбранныеВарианты(МассивСессийТестирования, МассивПростыхВопросов);				
				
				// Формируем информацию о тестировании
				
				Пока ВыборкаТестирований.Следующий() Цикл	
					
					ОписаниеТестирования = Новый Структура();
					ОписаниеТестирования.Вставить("Дата", ВыборкаТестирований.Дата);
					ОписаниеТестирования.Вставить("Результат", ВыборкаТестирований.Результат);
					ОписаниеТестирования.Вставить("ВыставляетсяОценка", ВыборкаТестирований.ВыставляетсяОценка);
					ОписаниеТестирования.Вставить("ПроверяетсяПреподавателем", ВыборкаТестирований.ПроверяетсяПреподавателем);
					ОписаниеТестирования.Вставить("ПроверенПреподавателем", ВыборкаТестирований.ПроверенПреподавателем);
					ОписаниеТестирования.Вставить("ДатаНачалаПрохождения", ВыборкаТестирований.ДатаНачалаПрохождения);
					ОписаниеТестирования.Вставить("ДатаОкончанияПрохождения", ВыборкаТестирований.ДатаОкончанияПрохождения);
					ОписаниеТестирования.Вставить("ОтветыНаВопросы", Новый Массив());					
					ОписаниеТестирования.Вставить("ЭлектронныйРесурс", Новый Структура("Наименование, Идентификатор", ВыборкаТестирований.НаименованиеЭлементаСодержания, ВыборкаТестирований.ЭлектронныйРесурс));
					ОписаниеТестирования.Вставить("ЭлементСодержания", Новый Структура("Наименование, Идентификатор", ВыборкаТестирований.НаименованиеЭлементаСодержания, ВыборкаТестирований.ЭлементСодержания));					
					ОписаниеТестирования.Вставить("Оценка", "");
					
					Если ДанныеПрохожденияОбучения.ВыставляетсяОценка Тогда
						
						ШкалаОценки = Документы.ПроведениеОбученияСУО.ШкалаОценки(ДанныеПрохожденияОбучения.ПроведениеОбучения);
						
						ВыставленнаяОценка = УправлениеОбучениемСУОПовтИсп.ОценкаИзБаллов(ВыборкаТестирований.Результат, ШкалаОценки);
						
						Если ЗначениеЗаполнено(ВыставленнаяОценка) Тогда
							ОписаниеТестирования.Вставить("Оценка", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыставленнаяОценка, "Наименование"));
						КонецЕсли;
										
					КонецЕсли;					
					
					Зависимости.Добавить(ВыборкаТестирований.ЭлектронныйРесурс);

					ВыборкаОтветовНаВопросы.Сбросить();					
					
					Пока ВыборкаОтветовНаВопросы.НайтиСледующий(ВыборкаТестирований.СессияВыполненияТеста, "СессияВыполненияТеста") Цикл
						
						ОписаниеОтветаНаВопрос = Новый Структура;
						
						ОписаниеОтветаНаВопрос.Вставить("Вопрос", Новый Структура("
								|Наименование,
								|Идентификатор,
								|Задание",
								ВыборкаОтветовНаВопросы.НаименованиеВопроса,
								ВыборкаОтветовНаВопросы.Вопрос,
								Справочники.ВопросыСУЗ.ТекстЗаданияВопроса(ВыборкаОтветовНаВопросы.Вопрос)));						
						
						ОписаниеОтветаНаВопрос.Вставить("Вес", ВыборкаОтветовНаВопросы.Вес);
						ОписаниеОтветаНаВопрос.Вставить("Дата", ВыборкаОтветовНаВопросы.Дата);
						ОписаниеОтветаНаВопрос.Вставить("Психологический", ВыборкаОтветовНаВопросы.ПсихологическийВопрос);
						ОписаниеОтветаНаВопрос.Вставить("Результат", ВыборкаОтветовНаВопросы.Результат);
						ОписаниеОтветаНаВопрос.Вставить("ПроверяетсяПреподавателем", ВыборкаОтветовНаВопросы.ПроверяетсяПреподавателем);
						ОписаниеОтветаНаВопрос.Вставить("ПроверенПреподавателем", ВыборкаОтветовНаВопросы.ПроверенПреподавателем);
						ОписаниеОтветаНаВопрос.Вставить("Преподаватель", Новый Структура("Идентификатор", ВыборкаОтветовНаВопросы.ПроверившийПреподаватель));
						ОписаниеОтветаНаВопрос.Вставить("РазвернутыйОтветПользователя", ВыборкаОтветовНаВопросы.РазвернутыйОтветПользователя);
						ОписаниеОтветаНаВопрос.Вставить("КомментарийПреподавателя", ВыборкаОтветовНаВопросы.КомментарийПреподавателя);
						ОписаниеОтветаНаВопрос.Вставить("ИспользованаПодсказка", ВыборкаОтветовНаВопросы.ИспользованаПодсказка);
						ОписаниеОтветаНаВопрос.Вставить("КоличествоПоказов", ВыборкаОтветовНаВопросы.КоличествоПоказов);
						
						ОписаниеОтветаНаВопрос.Вставить("Варианты", Новый Массив());
						
						ВыборкаВариантовОтветов.Сбросить();
						
						Пока ВыборкаВариантовОтветов.НайтиСледующий(Новый Структура("СессияВыполненияТеста, Вопрос", ВыборкаТестирований.СессияВыполненияТеста, ВыборкаОтветовНаВопросы.Вопрос)) Цикл
							
							ОписаниеВариантаОтвета = Новый Структура;
							ОписаниеВариантаОтвета.Вставить("Текст", ВыборкаВариантовОтветов.ТекстВарианта);
							ОписаниеВариантаОтвета.Вставить("Номер", ВыборкаВариантовОтветов.Номер);
							ОписаниеВариантаОтвета.Вставить("Выбран", ВыборкаВариантовОтветов.Выбран);
							ОписаниеВариантаОтвета.Вставить("ОшибочныйНеВыбран", ВыборкаВариантовОтветов.ОшибочныйНеВыбран);
							ОписаниеВариантаОтвета.Вставить("ОшибочныйВыбран", ВыборкаВариантовОтветов.ОшибочныйВыбран);
							ОписаниеВариантаОтвета.Вставить("ВерныйНеВыбран", ВыборкаВариантовОтветов.ВерныйНеВыбран);
							ОписаниеВариантаОтвета.Вставить("ВерныйВыбран", ВыборкаВариантовОтветов.ВерныйВыбран);
							ОписаниеВариантаОтвета.Вставить("ВариантОтвета", ВыборкаВариантовОтветов.ВариантОтвета);
							ОписаниеВариантаОтвета.Вставить("Верный", ВыборкаВариантовОтветов.Верный);
							
							ОписаниеОтветаНаВопрос.Варианты.Добавить(ОписаниеВариантаОтвета);
							
						КонецЦикла;
						
						ОписаниеТестирования.ОтветыНаВопросы.Добавить(ОписаниеОтветаНаВопрос);
						
					КонецЦикла;
					
					ОписаниеРезультатовТестирования.Добавить(ОписаниеТестирования);
					
				КонецЦикла;
				
				ОписаниеРезультатовТестированияJSON = ОбщегоНазначенияСУ.ДанныеВJSON(ОписаниеРезультатовТестирования);
				
				РегистрыСведений.ДанныеВебКабинетаСУО_ПН.ДобавитьДанные(ДанныеПрохожденияОбучения.Пользователь, Перечисления.ТипыДанныхВебКабинетаСУО.РезультатыТестирования, ПрохождениеОбучения, ОписаниеРезультатовТестированияJSON, Перечисления.ФорматыВебДанныхСУ.json);
				
			КонецЕсли;			
			
		КонецЕсли;
			
		// Учебная активность
		
		УчебнаяАктивностьСтруктура = УчебнаяАктивностьСтруктура(ПрохождениеОбучения);
		СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.ЧислоВЗначение(УчебнаяАктивностьСтруктура.СтатусОбучения);
		ПрохождениеАктуально = Актуально(ПрохождениеОбучения, СтатусПроцессаОбучения);
		ДанныеУчебнойАктивности = ОбщегоНазначенияСУ.ДанныеВJSON(УчебнаяАктивностьСтруктура);
		
		ДатаНачалаПроведенияОбучения = Документы.ПроведениеОбученияСУО.ДатаНачалаПроведения(ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.Сценарий);
		
		Если НЕ ЗначениеЗаполнено(ДатаНачалаПроведенияОбучения) Тогда
			РегистрыСведений.ДанныеВебКабинетаСУО_ПН.ДобавитьДанные(ДанныеПрохожденияОбучения.Пользователь, Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивность, ПрохождениеОбучения, ДанныеУчебнойАктивности, Перечисления.ФорматыВебДанныхСУ.json); 
		Иначе			
			РегистрыСведений.ДанныеВебКабинетаСУО_ПП.ДобавитьДанные(ДатаНачалаПроведенияОбучения, ДанныеПрохожденияОбучения.Пользователь, Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивность, ПрохождениеОбучения, ДанныеУчебнойАктивности, Перечисления.ФорматыВебДанныхСУ.json);
		КонецЕсли;
		
		// Описание учебной активности
		
		ДанныеПрохожденияДляПолногоОписания = Неопределено; // Будет заполнено ниже и пригодится далее
		ОписаниеУчебнойАктивности = УчебнаяАктивностьОписаниеXML(ПрохождениеОбучения,, ДанныеПрохожденияДляПолногоОписания, ТаблицаФайловОбъекта, Зависимости, ЕстьРезультатыТестирования);
		
		РегистрыСведений.ДанныеВебКабинетаСУО_ПН.ДобавитьДанные(ДанныеПрохожденияОбучения.Пользователь, Перечисления.ТипыДанныхВебКабинетаСУО.УчебнаяАктивностьОписание, ПрохождениеОбучения, ОписаниеУчебнойАктивности, Перечисления.ФорматыВебДанныхСУ.xml);
		
		// Отборы учебной активности
		
		РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(ПрохождениеОбучения, ДанныеПрохожденияОбучения.ПроведениеОбучения);
		
		РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(ПрохождениеОбучения, ДанныеПрохожденияОбучения.Сценарий);
		
		Если ПрохождениеАктуально ИЛИ (ЗначениеЗаполнено(ДанныеПрохожденияОбучения.РодительскоеПрохождение) И Актуально(ДанныеПрохожденияОбучения.РодительскоеПрохождение)) Тогда
			РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(ПрохождениеОбучения, Перечисления.ОтборыДанныхВебКабинетаСУО.Активные);
		Иначе
			РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(ПрохождениеОбучения, Перечисления.ОтборыДанныхВебКабинетаСУО.Завершенные);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеПрохожденияОбучения.РодительскоеПрохождение) Тогда
			РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(ПрохождениеОбучения, ДанныеПрохожденияОбучения.РодительскоеПрохождение);
		КонецЕсли;
		
		// Участник обучения
		
		УчастникОбучения = УчастникОбученияJSON(ПрохождениеОбучения);
		
		РегистрыСведений.ДанныеВебКабинетаСУО_ОН.ДобавитьДанные(Перечисления.ТипыДанныхВебКабинетаСУО.УчастникОбучения, ПрохождениеОбучения, УчастникОбучения, Перечисления.ФорматыВебДанныхСУ.json);
		
		// Тесты и задания на проверку преподавателю
				
		ТаблицаПреподавателей = Неопределено;
		
		Если СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.Активно
			ИЛИ СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.Проверяется
			ИЛИ СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.ВозвращеноНаДоработку
			ИЛИ СтатусПроцессаОбучения = Перечисления.СтатусыПроцессаОбученияСУО.ОконченоБезПроверки Тогда
		
			ТестыНаПроверку = РегистрыСведений.ТестыНаПроверкуСУЗ.ТестыНаПроверкуПрохожденияОбучения(ДанныеПрохожденияОбучения.Пользователь, ПрохождениеОбучения);
			
			Если ТестыНаПроверку.Количество() > 0 Тогда
				
				Если ТаблицаПреподавателей = Неопределено Тогда
					ТаблицаПреподавателей = Документы.ПроведениеОбученияСУО.Преподаватели(ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.Сценарий, Ложь);
				КонецЕсли;
				
				ОписаниеПользователяСтруктура = ВебКабинетСУО.ПользовательСтруктура(ДанныеПрохожденияОбучения.Пользователь, ДанныеПрохожденияОбучения.НаименованиеПользователя);
				
				Для каждого СтрокаТП Из ТаблицаПреподавателей Цикл
					
					Если СтрокаТП.Проведено Тогда
						Продолжить;
					КонецЕсли;
					
					Для каждого СтрокаТНП Из ТестыНаПроверку Цикл					
						
						ОписаниеТестаНаПроверку = Документы.ПопыткаВыполненияЗаданияСУО.НоваяПустаяСтруктураПопыткиВыполненияЗадания();
													
						ОписаниеТестаНаПроверку.Вставить("ПопыткаВыполненияЗадания", Строка(СтрокаТНП.Регистратор.УникальныйИдентификатор()));
						ОписаниеТестаНаПроверку.Вставить("ЭлектронныйРесурс", СтрокаТНП.ЭлектронныйРесурс);
						ОписаниеТестаНаПроверку.Вставить("ЭлементСодержания", СтрокаТНП.ЭлементСодержания);
						ОписаниеТестаНаПроверку.Вставить("ПрохождениеОбучения", СтрокаТНП.ПрохождениеОбучения);
						ОписаниеТестаНаПроверку.Вставить("Задание", СтрокаТНП.Задание);
						ОписаниеТестаНаПроверку.Вставить("Наименование", СтрокаТНП.НаименованиеЗадания);
						ОписаниеТестаНаПроверку.Вставить("НаОсновеЭлектронногоРесурса", Истина);
						ОписаниеТестаНаПроверку.Вставить("Пользователь", ОписаниеПользователяСтруктура);
						ОписаниеТестаНаПроверку.Вставить("ПроведениеОбучения", СтрокаТНП.ПроведениеОбучения);						
						
						Если ЗначениеЗаполнено(ДанныеПрохожденияДляПолногоОписания.РодительскоеПрохождение) Тогда
							ОписаниеТестаНаПроверку.Вставить("НаименованиеРодительскогоСценария", ДанныеПрохожденияДляПолногоОписания.НаименованиеРодительскогоПрохождения);
						Иначе
							ОписаниеТестаНаПроверку.Вставить("НаименованиеРодительскогоСценария", "");
						КонецЕсли;
						ОписаниеТестаНаПроверку.Вставить("НаименованиеСценария", НаименованиеОбучения(ДанныеПрохожденияДляПолногоОписания));
						ОписаниеТестаНаПроверку.Вставить("ДатаОтправкиНаПроверку", СтрокаТНП.Дата);
						
						ОписаниеТестаНаПроверкуJSON = ОбщегоНазначенияСУ.ДанныеВJSON(ОписаниеТестаНаПроверку);
						РегистрыСведений.ДанныеВебКабинетаСУО_ПН.ДобавитьДанные(СтрокаТП.Преподаватель, Перечисления.ТипыДанныхВебКабинетаСУО.ПроверкаЗаданияОписание, СтрокаТНП.Регистратор, ОписаниеТестаНаПроверкуJSON, Перечисления.ФорматыВебДанныхСУ.json);
						
						РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(СтрокаТНП.Регистратор, ДанныеПрохожденияОбучения.ПроведениеОбучения);
						
					КонецЦикла;
					
				КонецЦикла;
				
			КонецЕсли;
			
			ЗаданияНаПроверку = Документы.ПопыткаВыполненияЗаданияСУО.ЗаданияНаПроверку(ПрохождениеОбучения);
			
			Если ЗаданияНаПроверку.Количество() > 0 Тогда
				
				Если ТаблицаПреподавателей = Неопределено Тогда
					ТаблицаПреподавателей = Документы.ПроведениеОбученияСУО.Преподаватели(ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.Сценарий, Ложь);
				КонецЕсли;			
				
				Для каждого СтрокаТЗП Из ЗаданияНаПроверку Цикл
					
					Для каждого СтрокаТП Из ТаблицаПреподавателей Цикл
						
						Если СтрокаТП.Проведено Тогда
							Продолжить;
						КонецЕсли;
						
						ОписаниеПопыткиВыполненияЗаданияСтруктура = Документы.ПопыткаВыполненияЗаданияСУО.ОписаниеПопыткиВыполненияЗаданияСтруктура(СтрокаТЗП.Ссылка);
						ОписаниеПопыткиВыполненияЗаданияJSON = ОбщегоНазначенияСУ.ДанныеВJSON(ОписаниеПопыткиВыполненияЗаданияСтруктура);
						РегистрыСведений.ДанныеВебКабинетаСУО_ПН.ДобавитьДанные(
							СтрокаТП.Преподаватель,
							Перечисления.ТипыДанныхВебКабинетаСУО.ПроверкаЗаданияОписание,
							СтрокаТЗП.Ссылка,
							ОписаниеПопыткиВыполненияЗаданияJSON,
							Перечисления.ФорматыВебДанныхСУ.json);
						
						РегистрыСведений.ОтборыДанныхВебКабинетаСУО_О.ДобавитьОтбор(СтрокаТЗП.Ссылка, ДанныеПрохожденияОбучения.ПроведениеОбучения);
							
					КонецЦикла;
				
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
			
		// Авто-раздел форума
			
		ТаблицаПользовательскихРазделов = РегистрыСведений.АвтоРазделыФорумаСУО.РазделыПользователя(ДанныеПрохожденияОбучения.Пользователь, ДанныеПрохожденияОбучения.ПроведениеОбучения);

		ОписаниеРазделаJSON = Справочники.РазделыФорумаСУО.РазделJSON(ДанныеПрохожденияОбучения.ПроведениеОбучения);

		Для каждого Строка Из ТаблицаПользовательскихРазделов Цикл
			// Таблица не может содержать более одной строки
			РегистрыСведений.ДанныеВебКабинетаСУО_ПН.ДобавитьДанные(Строка.Пользователь, Перечисления.ТипыДанныхВебКабинетаСУО.РазделФорума, ДанныеПрохожденияОбучения.ПроведениеОбучения, ОписаниеРазделаJSON, Перечисления.ФорматыВебДанныхСУ.json);
		КонецЦикла;		
		
		// Зависимости
		
		Зависимости.Добавить(ДанныеПрохожденияОбучения.Пользователь);
		
		Если ТипЗнч(ДанныеПрохожденияОбучения.Сценарий) <> Тип("ДокументСсылка.ПроведениеОбученияСУО") Тогда
			Зависимости.Добавить(ДанныеПрохожденияОбучения.Сценарий);
		КонецЕсли;
		
		Если ПолучитьФункциональнуюОпцию("ОбразовательнаяОрганизацияОО") Тогда
			
			УчебнаяГруппаПользователей = Справочники.УчебныеГруппыОО.УчебнаяГруппаПользователя(ДанныеПрохожденияОбучения.Пользователь);
			
			Если УчебнаяГруппаПользователей <> Неопределено Тогда
				Зависимости.Добавить(УчебнаяГруппаПользователей.УчебнаяГруппа);
			КонецЕсли;
			
		КонецЕсли;
		
		Зависимости.Добавить(ВидОбучения);
		
		Если ПрохождениеАктуально Тогда			
			РегистрыСведений.ЗависимостиДанныхВебКабинетаСУ.ДобавитьДанные(ПрохождениеОбучения, "Документ.ПрохождениеОбученияСУО", Зависимости);			
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

Функция УчебнаяАктивностьПустаяСтруктура() Экспорт
	
	Возврат Новый Структура("
	|Тип,
	|Идентификатор,
	|Наименование,
	|ДатаНачала,
	|ДатаОкончания,
	|ЭлектронноДистанционное,
	|СтатусОбучения,
	|Актуально,
	|ЕдинственноеЗадание,
	|КомментарийДляУчастника,
	|Цвет,
	|СкрытьВремяПроведения,
	|РодительскаяАктивность,
	|ПодчиненныеАктивности,
	|Сценарий,
	|ЗавершаетУчащийся,
	|ПрохождениеОбучения,
	|ДатаОткрытияЗаписи,
	|ДатаЗакрытияЗаписи,
	|НомерМероприятия,
	|ПорядковыйНомер,
	|Картинка,
	|ДатаПоследнейАктивности,
	|ДатаНачалаПрохождения,
	|ДатаОкончанияПрохождения,
	|Баллы,
	|ЗавершеноВПроцентах,
	|Оценка,
	|ДатаНачалаОтсчетаПродолжительности,
	|ПродолжительностьВСекундах,
	|ВариантПродолжительности,
	|СредняяОценкаКачестваОбучения,
	|КоличествоОценокКачестваОбучения,
	|ПроведениеОбучения,
	|Дисциплина,
	|ПрограммаОбучения,
	|ВидОбучения");
	
КонецФункции

Функция УчебнаяАктивностьСтруктура(ПрохождениеОбучения) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем данные
	//
	
	ТребуемыеДанные = Новый Структура("
		|Ссылка,
		|Сценарий,
		|Статус,
		|ПроведениеОбучения,
		|СтатусПроведенияОбучения,
		|ДатаНачалаДоступа,
		|ДатаКонтроля,	
		|КомментарийДляУчастника,
		|ДатаНачалаПрохождения,
		|ДатаОкончанияПрохождения,  
		|НаОсновеЭлектронногоРесурса,
		|НаОсновеМероприятия,
		|НаименованиеСценария,
		|ЦветАктивногоМероприятияНаКалендареУчащегося,
		|ЦветЗапланированногоМероприятияНаКалендареУчащегося,
		|ЦветЗавершенногоМероприятияНаКалендареУчащегося,
		|ЦветОтмененногоМероприятияНаКалендареУчащегося,
		|СкрытьВремяПроведения,
		|РодительскоеПрохождение,
		|СхемаПроведения,
		|ВозвращеноНаДоработку,
		|НаименованиеПроведенияОбучения,
		|НомерМероприятия,
		|ПорядковыйНомер,
		|ФайлКартинки,
		|РасширениеКартинки,
		|ДатаПоследнейАктивности,
		|Баллы,
		|ЗавершеноВПроцентах,
		|ВариантПродолжительности,
		|ДатаЗачисления,
		|ПродолжительностьВСекундах,
		|КачествоОбученияОцениваетсяУчастниками,
		|ПоказыватьОценкиИКомментарииВсемУчастникам,
		|ВыставляетсяОценка,		
		|Дисциплина,
		|НаименованиеДисциплины,
		|ПроведениеПрограммыОбучения,
		|НаименованиеПрограммыОбучения,
		|НаименованиеПрограммыОбученияДляУчастника,
		|ВыставленаОценка",
		"Ссылка",
		"Сценарий",
		"Статус",
		"ПроведениеОбучения",
		"ПроведениеОбучения.Статус",
		"ПроведениеОбучения.ДатаНачалаДоступа",
		"ПроведениеОбучения.ДатаКонтроля",
		"ПроведениеОбучения.КомментарийДляУчастника",
		"ДатаНачалаПрохождения",
		"ДатаОкончанияПрохождения",
		"ПроведениеОбучения.НаОсновеЭлектронногоРесурса",
		"ПроведениеОбучения.НаОсновеМероприятия",
		"Сценарий.Наименование",
		"ПроведениеОбучения.ЦветАктивногоМероприятияНаКалендареУчащегося",
		"ПроведениеОбучения.ЦветЗапланированногоМероприятияНаКалендареУчащегося",
		"ПроведениеОбучения.ЦветЗавершенногоМероприятияНаКалендареУчащегося",
		"ПроведениеОбучения.ЦветОтмененногоМероприятияНаКалендареУчащегося",
		"ПроведениеОбучения.СкрытьВремяПроведения",
		"РодительскоеПрохождение",
		"ПроведениеОбучения.СхемаПроведения",
		"ВозвращеноНаДоработку",
		"ПроведениеОбучения.Наименование",
		"Сценарий.РеквизитДопУпорядочивания",
		"ПроведениеОбучения.ПорядковыйНомер",
		"ПроведениеОбучения.ФайлКартинки",
		"ПроведениеОбучения.ФайлКартинки.Расширение",
		"ДатаПоследнейАктивности",
		"Баллы",
		"ЗавершеноВПроцентах",
		"ПроведениеОбучения.ВариантПродолжительности",
		"Дата",
		"ПродолжительностьВСекундах",
		"ПроведениеОбучения.КачествоОбученияОцениваетсяУчастниками",
		"ПроведениеОбучения.ПоказыватьОценкиИКомментарииВсемУчастникам",
		"ВыставляетсяОценка",
		"ПроведениеОбучения.Дисциплина",
		"ПроведениеОбучения.Дисциплина.Наименование",
		"ПроведениеОбучения.ПроведениеПрограммыОбучения",
		"ПроведениеОбучения.ПроведениеПрограммыОбучения.Наименование",
		"ПроведениеОбучения.ПроведениеПрограммыОбучения.НаименованиеДляУчастника",
		"ВыставленаОценка"
	);
		
	ДанныеПрохожденияОбучения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПрохождениеОбучения, ТребуемыеДанные);	
	ЭлектронноДистанционное = Документы.ПроведениеОбученияСУО.ЭлектронноДистанционноеОбучение(ДанныеПрохожденияОбучения.ПроведениеОбучения,,ДанныеПрохожденияОбучения.Сценарий);	
	ВидОбучения = Документы.ПроведениеОбученияСУО.ВидОбучения(ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.Сценарий);	
	ПрохождениеАктуально = Актуально(ПрохождениеОбучения);	
	СтатусПроцессаОбучения = СтатусПроцессаОбучения(ПрохождениеОбучения);	
	ЗаданияДоступны  = ЗаданияДоступны(ПрохождениеОбучения, ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.Сценарий, ВидОбучения, СтатусПроцессаОбучения, ДанныеПрохожденияОбучения.ВариантПродолжительности, ДанныеПрохожденияОбучения.ДатаНачалаПрохождения);
	Общее = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидОбучения, "Общее");
	ШкалаОценки = Документы.ПроведениеОбученияСУО.ШкалаОценки(ДанныеПрохожденияОбучения.ПроведениеОбучения);
	
	// Заполняем свойства
	//
	
	СтруктураДанных = УчебнаяАктивностьПустаяСтруктура();
	
	// Основные свойства	
	
	СтруктураДанных.Идентификатор = Строка(ПрохождениеОбучения.УникальныйИдентификатор());
	СтруктураДанных.Тип = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ТипАктивности());
	СтруктураДанных.Наименование = НаименованиеОбучения(ДанныеПрохожденияОбучения);
	СтруктураДанных.СтатусОбучения = Перечисления.СтатусыПроцессаОбученияСУО.ЗначениеВЧисло(СтатусПроцессаОбучения);
	СтруктураДанных.Актуально = ПрохождениеАктуально;
	СтруктураДанных.ЭлектронноДистанционное = ЭлектронноДистанционное;
	СтруктураДанных.СкрытьВремяПроведения = ДанныеПрохожденияОбучения.СкрытьВремяПроведения;
	СтруктураДанных.Сценарий = ДанныеПрохожденияОбучения.Сценарий;
	СтруктураДанных.ЗавершаетУчащийся = ДоступноЗавершениеУчащимся(ПрохождениеОбучения, ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.Сценарий, ВидОбучения);
	СтруктураДанных.ПорядковыйНомер = ДанныеПрохожденияОбучения.ПорядковыйНомер;
	СтруктураДанных.ДатаПоследнейАктивности = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ДанныеПрохожденияОбучения.ДатаПоследнейАктивности);
	СтруктураДанных.ДатаНачалаПрохождения = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ДанныеПрохожденияОбучения.ДатаНачалаПрохождения);
	СтруктураДанных.ДатаОкончанияПрохождения = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ДанныеПрохожденияОбучения.ДатаОкончанияПрохождения);
	СтруктураДанных.Баллы = ДанныеПрохожденияОбучения.Баллы;
	СтруктураДанных.ЗавершеноВПроцентах = ДанныеПрохожденияОбучения.ЗавершеноВПроцентах;
	СтруктураДанных.ПроведениеОбучения = ДанныеПрохожденияОбучения.ПроведениеОбучения;
	
	Если ЗначениеЗаполнено(ДанныеПрохожденияОбучения.Дисциплина) Тогда		
		СтруктураДанных.Дисциплина = Новый Структура("Идентификатор, Наименование");
		СтруктураДанных.Дисциплина.Идентификатор = Строка(ДанныеПрохожденияОбучения.Дисциплина.УникальныйИдентификатор());
		СтруктураДанных.Дисциплина.Наименование = ДанныеПрохожденияОбучения.НаименованиеДисциплины;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеПрохожденияОбучения.ПроведениеПрограммыОбучения) Тогда
		СтруктураДанных.ПрограммаОбучения = Новый Структура("Идентификатор, Наименование");
		СтруктураДанных.ПрограммаОбучения.Идентификатор =  Строка(ДанныеПрохожденияОбучения.ПроведениеПрограммыОбучения.УникальныйИдентификатор());
		Если ЗначениеЗаполнено(ДанныеПрохожденияОбучения.НаименованиеПрограммыОбученияДляУчастника) Тогда
			СтруктураДанных.ПрограммаОбучения.Наименование = ДанныеПрохожденияОбучения.НаименованиеПрограммыОбученияДляУчастника;
		Иначе
			СтруктураДанных.ПрограммаОбучения.Наименование = ДанныеПрохожденияОбучения.НаименованиеПрограммыОбучения
		КонецЕсли;
	КонецЕсли;
	
	СтруктураДанных.ВидОбучения = Новый Структура("Идентификатор, Наименование");
	СтруктураДанных.ВидОбучения.Идентификатор = Строка(ВидОбучения.УникальныйИдентификатор());
	СтруктураДанных.ВидОбучения.Наименование = Строка(ВидОбучения.Наименование);
	
	// Оценка
	
	СтруктураДанных.Оценка = Неопределено;
	
	Если ДанныеПрохожденияОбучения.ВыставляетсяОценка
		И ДанныеПрохожденияОбучения.ВыставленаОценка Тогда
	
		ДанныеОценки = Справочники.ШкалыОценокСУО.ОценкаИзБаллов(ДанныеПрохожденияОбучения.Баллы, ШкалаОценки, Истина);
		
		Если ТипЗнч(ДанныеОценки) = Тип("Структура") Тогда
			СтруктураДанных.Оценка = Новый Структура("Идентификатор, Наименование",
				Строка(ДанныеОценки.Ссылка.УникальныйИдентификатор()), ДанныеОценки.Наименование);
		КонецЕсли;
			
	КонецЕсли;
		
	// Картинка обучения
	
	СтруктураДанных.Картинка = "";
	Если ЗначениеЗаполнено(ДанныеПрохожденияОбучения.ФайлКартинки) Тогда
		СтруктураДанных.Картинка = Документы.ПроведениеОбученияСУО.АдресФайлаКартинки(
			ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.РасширениеКартинки); 
	КонецЕсли;
		
	// Номер сценария
	
	Если ЗначениеЗаполнено(ДанныеПрохожденияОбучения.РодительскоеПрохождение) Тогда
		СтруктураДанных.НомерМероприятия = ДанныеПрохожденияОбучения.НомерМероприятия;
	КонецЕсли;
	
	// Родительская активность
	
	СтруктураДанных.РодительскаяАктивность = ДанныеПрохожденияОбучения.РодительскоеПрохождение;
	
	// Цвет
	
	СтруктураДанных.Цвет = Документы.ПроведениеОбученияСУО.ЦветНаКалендаре(ДанныеПрохожденияОбучения.ПроведениеОбучения, ВидОбучения, Перечисления.ТипыУчебныхАктивностейСУО.Обучение);
	
	// Комментарии
	
	СтруктураДанных.КомментарийДляУчастника = ДанныеПрохожденияОбучения.КомментарийДляУчастника;
	
	// Электронное задание
	
	Если ЗаданияДоступны Тогда
		СтруктураДанных.ЕдинственноеЗадание = Документы.ПрохождениеОбученияСУО.ОписаниеЕдинственногоЗаданияПрохождения(ПрохождениеОбучения, ДанныеПрохожденияОбучения.ПроведениеОбучения, ДанныеПрохожденияОбучения.Сценарий);
	КонецЕсли;
	
	// Дата начала и окончания
	
	СтруктураДанных.ДатаНачала = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ДанныеПрохожденияОбучения.ДатаНачалаПрохождения);
	СтруктураДанных.ДатаОкончания = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ДанныеПрохожденияОбучения.ДатаОкончанияПрохождения);
	
	// Продолжительность
	
	СтруктураДанных.ДатаНачалаОтсчетаПродолжительности = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(
		ДатаНачалаОтсчетаПродолжительности(ДанныеПрохожденияОбучения));
	
	СтруктураДанных.ПродолжительностьВСекундах = ДанныеПрохожденияОбучения.ПродолжительностьВСекундах;
	
	СтруктураДанных.ВариантПродолжительности = Перечисления.ПродолжительностьОбученияСУО.ЗначениеВЧисло(
		ДанныеПрохожденияОбучения.ВариантПродолжительности);
		
	// Качество обучения
	
	СтруктураДанных.СредняяОценкаКачестваОбучения = 0;
	СтруктураДанных.КоличествоОценокКачестваОбучения = 0;
					
	Если ДанныеПрохожденияОбучения.КачествоОбученияОцениваетсяУчастниками
		И ДанныеПрохожденияОбучения.ПоказыватьОценкиИКомментарииВсемУчастникам Тогда
		
		ОписаниеОценокКачества = УправлениеОбучениемСУОПовтИсп.ОценкаКачестваПроведенияОбучения(
			ДанныеПрохожденияОбучения.ПроведениеОбучения);
			
		СтруктураДанных.СредняяОценкаКачестваОбучения = ОписаниеОценокКачества.СредняяОценка;
		СтруктураДанных.КоличествоОценокКачестваОбучения = ОписаниеОценокКачества.КоличествоОценок;
			
	КонецЕсли;
			
	// Подчиненные мероприятия (для общих)
	
	Если Общее Тогда		
		СтруктураДанных.ПодчиненныеАктивности = Документы.ПроведениеОбученияСУО.ПодчиненныеМероприятия(ДанныеПрохожденияОбучения.ПроведениеОбучения,,ДанныеПрохожденияОбучения.СхемаПроведения);		
	КонецЕсли;
	
	// Завершаем
	//
	
	Возврат СтруктураДанных;
	
КонецФункции

Функция УчебнаяАктивностьОписаниеXML(ПрохождениеОбучения, ИдентификаторФормы = Неопределено, ДанныеПрохождения = Неопределено, ПрикрепленныеФайлы = Неопределено, Зависимости = Неопределено, ЕстьРезультатыТестирования = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем переменные
	//
	
	Если ДанныеПрохождения = Неопределено Тогда
		

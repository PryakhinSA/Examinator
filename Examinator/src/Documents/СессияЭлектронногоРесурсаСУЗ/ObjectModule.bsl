#Если Сервер ИЛИ ТолстыйКлиентОбычноеПриложение ИЛИ ВнешнееСоединение Тогда

Перем ТаблицаСтатистикиПараметровSCORM Экспорт;
	
#Область ОбработчикиСобытий

// ОБРАБОТЧИКИ СОБЫТИЙ

Процедура ОбработкаПроведения(Отказ, Режим)
	
	Движения.ПрохожденияЭлектронныхРесурсовСУЗ.Записывать = Истина;
	Движения.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Записывать = Истина;
	Движения.ОтветыНаВопросыСУЗ.Записывать = Истина;
	Движения.ВыбранныеВариантыОтветовВопросовСУЗ.Записывать = Истина;	
	Движения.ВопросыТестированийСУЗ.Записывать = Истина;
	Движения.ТестыНаПроверкуСУЗ.Записывать = Истина;
	Движения.ПовторноеПрохождениеЭлектронныхРесурсовСУЗ.Записывать = Истина;	
	
	Если ЭлектронныеРесурсыПереопределяемый.ОбучениеОтменено(Отменено, ПрохождениеОбучения, Задание) Тогда
		Возврат;
	КонецЕсли;	
	
	СформироватьДвижения();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

Процедура СформироватьДвижения() Экспорт
		
	СтруктураДанных = Данные.Получить();
	
	Если ТипСессии = Перечисления.ТипыСессийЭлектронныхРесурсовСУЗ.cabinetLearning Тогда
		
		Движение = Движения.ПрохожденияЭлектронныхРесурсовСУЗ.Добавить();
		
		Движение.ЭлектронныйРесурс = ЭлектронныйРесурс;
		Движение.Пользователь = Пользователь;
		Движение.ПрохождениеОбучения = ПрохождениеОбучения;
		Движение.Задание = ОбъектыСУЗ.ЗаданиеПопытки(ПрохождениеОбучения, ЭлектронныйРесурс, Задание);
		Движение.ПлеерВебКабинета = Перечисления.ПлеерыКурсовВебКабинетаСУЗ.Встроенный;
		
		Если НЕ ТипЗнч(СтруктураДанных) = Тип("ФиксированнаяСтруктура")
			ИЛИ НЕ СтруктураДанных.Свойство("uuid") Тогда
		
			ВызватьИсключение НСтр("ru = 'Неверный формат структуры данных веб-кабинета'")
		
		КонецЕсли;
		
		ИдентификаторАктивности = Новый УникальныйИдентификатор(СтруктураДанных.uuid);
	
		ВсеДанныеИзучения = РегистрыСведений.ДанныеИзученияЭлектронныхКурсовВебКабинетаСУО.ВсеДанныеИзучения(ИдентификаторАктивности, ЭлектронныйРесурс);
		
		Если ВсеДанныеИзучения.Свойство("score") Тогда			
			
			Движение.Результат = ВсеДанныеИзучения.score;
			
			Если Движение.Результат > 100 Тогда
				Движение.Результат = 100;
			КонецЕсли;
			
		КонецЕсли;
				
		Движение.Завершено = ВсеДанныеИзучения.complete;
		
		Движение.КонтрольнаяСумма = КонтрольнаяСумма;
		

		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СодержаниеСУЗ.Ссылка КАК Ссылка,
			|	СодержаниеСУЗ.СсылкаНаЭлемент КАК СсылкаНаЭлемент
			|ИЗ
			|	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
			|ГДЕ
			|	СодержаниеСУЗ.Владелец = &ЭлектронныйРесурс
			|	И СодержаниеСУЗ.ЭтоГруппа = ЛОЖЬ";
		
		Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);
		
		ТаблицаЭлементовСодержания = Запрос.Выполнить().Выгрузить();
		
		ТаблицаЭлементовСодержания.Колонки.Добавить("ИдентификаторЭлемента", Новый ОписаниеТипов("УникальныйИдентификатор"));
		
		Для каждого СтрокаТЭС Из ТаблицаЭлементовСодержания Цикл		
			СтрокаТЭС.ИдентификаторЭлемента = СтрокаТЭС.СсылкаНаЭлемент.УникальныйИдентификатор();			
		КонецЦикла;
		
		Для каждого ЭлементСтруктуры Из ВсеДанныеИзучения Цикл
			
			Если НЕ СтрНачинаетсяС(ЭлементСтруктуры.Ключ, "activity_") Тогда
				Продолжить;
			КонецЕсли;
			
			ДанныеАктивности = ЭлементСтруктуры.Значение;
			
			СтрокаТЭС = ТаблицаЭлементовСодержания.Найти(Новый УникальныйИдентификатор(ДанныеАктивности.slide), "ИдентификаторЭлемента");
				
			Если СтрокаТЭС = Неопределено Тогда
				Продолжить;	
			КонецЕсли;
			
			ЭлементСодержания = СтрокаТЭС.Ссылка; 
			СсылкаНаЭлемент   = СтрокаТЭС.СсылкаНаЭлемент;
			ВремяПрохожденияВСекундах = ?(ЗначениеЗаполнено(ДанныеАктивности.end), ДанныеАктивности.end - ДанныеАктивности.start, ТекущаяДатаСеанса() - ДанныеАктивности.start);
			
			Если ДанныеАктивности.type = "STATIC" Тогда
				
				Движение = Движения.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Добавить();
		
				Движение.Период = ДанныеАктивности.start;
				Движение.Пользователь = Пользователь;
				Движение.ПрохождениеОбучения = ПрохождениеОбучения;
				ЭлектронныеРесурсыПереопределяемый.ПроведениеОбучения(Движение.ПроведениеОбучения, ПрохождениеОбучения);
				Движение.Задание = ОбъектыСУЗ.ЗаданиеПопытки(ПрохождениеОбучения, ЭлектронныйРесурс, Задание);
				Движение.ЭлементСодержания = ЭлементСодержания;
					
				Если ДанныеАктивности.complete Тогда
					Движение.Результат = 100;
				Иначе
					Движение.Результат = 0;
				КонецЕсли;
				
				Движение.ВремяПрохожденияВСекундах = ВремяПрохожденияВСекундах;
				Движение.ЭлектронныйРесурс         = ЭлектронныйРесурс;
				Движение.СсылкаНаОбъектСУЗ         = СсылкаНаЭлемент;
				Движение.ПопыткаЗавершена          = ДанныеАктивности.complete;
				Движение.ДатаНачалаПрохождения     = ДанныеАктивности.start;
				Движение.ДатаОкончанияПрохождения  = ДанныеАктивности.end;
				Движение.ЭтоТест                   = Ложь;
				Движение.НомерРегистратора         = Номер;
				Движение.ВыставляетсяОценка        = Ложь;
				Движение.ЗавершеноВПроцентах       = ?(ДанныеАктивности.complete, 100, 0);		
				
			КонецЕсли;
			
			Если ДанныеАктивности.type = "QUIZ" Тогда
				
				Для каждого ДанныеТестирования Из ДанныеАктивности.quizAttempts Цикл
					
					Если НЕ ДанныеТестирования.complete Тогда
						Продолжить;
					КонецЕсли;
					
					Движение = Движения.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Добавить();
				
					Движение.Период = ДанныеТестирования.start;
					Движение.Пользователь = Пользователь;
					Движение.ПрохождениеОбучения = ПрохождениеОбучения;
					
					ЭлектронныеРесурсыПереопределяемый.ПроведениеОбучения(Движение.ПроведениеОбучения, ПрохождениеОбучения);
					
					Движение.Задание = ОбъектыСУЗ.ЗаданиеПопытки(ПрохождениеОбучения, ЭлектронныйРесурс, Задание);
					Движение.ЭлементСодержания = ЭлементСодержания;

					Движение.Результат = ДанныеТестирования.score;
					
					Если Движение.Результат > 100 Тогда
						Движение.Результат = 100;
					КонецЕсли;		
					
					Движение.ВремяПрохожденияВСекундах = ДанныеТестирования.end - ДанныеТестирования.start;				
					Движение.ЭлектронныйРесурс = ЭлектронныйРесурс;
					Движение.СсылкаНаОбъектСУЗ = СсылкаНаЭлемент;
					Движение.ПопыткаЗавершена  =  ДанныеТестирования.complete;
					Движение.ДатаНачалаПрохождения     = ДанныеТестирования.start;
					Движение.ДатаОкончанияПрохождения  = ДанныеТестирования.end;
					Движение.ЭтоТест = Истина;
					Движение.НомерРегистратора = Номер;
					Движение.ВыставляетсяОценка = Истина;
					Движение.ЗавершеноВПроцентах = ?(ДанныеТестирования.complete, 100, 0);

					Если ДанныеТестирования.Свойство("requiredTeacher") Тогда
						Движение.ПроверяетсяПреподавателем = ДанныеТестирования.requiredTeacher;
					КонецЕсли;
					
					Если ДанныеТестирования.Свойство("checkTeacher") Тогда
						Движение.ПроверенПреподавателем = ДанныеТестирования.checkTeacher;
					КонецЕсли;		
					
					Движение.Сложность = Неопределено;
					
					Для каждого ДанныеСтраницыТеста Из ДанныеТестирования.pages Цикл
					
						Для каждого ДанныеОтветаНаВопрос Из ДанныеСтраницыТеста.questions Цикл
							
							Если НЕ ДанныеОтветаНаВопрос.complete Тогда
								Продолжить;
							КонецЕсли;
							
							ВопросТеста = ОбъектыСУЗ.ПолучитьСсылкуПоИдентификатору("question", ДанныеОтветаНаВопрос.question);
							
							Движение = Движения.ВопросыТестированийСУЗ.Добавить();
							
							Движение.СессияВыполненияТеста = Ссылка;
							Движение.Вопрос = ВопросТеста;
							Движение.Вес = 1;
							Движение.ГруппаПодборки = ВопросТеста;														
														
							ПроведениеОбучения = Неопределено;
							
							Если ЗначениеЗаполнено(ПрохождениеОбучения) Тогда
								ЭлектронныеРесурсыПереопределяемый.ПроведениеОбучения(ПроведениеОбучения, ПрохождениеОбучения);
							КонецЕсли;			
							
							Движение = Движения.ОтветыНаВопросыСУЗ.Добавить();
								
							Движение.Период = ДанныеОтветаНаВопрос.start;
							Движение.Пользователь = Пользователь;
							Движение.Вопрос = ВопросТеста;
							Движение.ПрохождениеОбучения = ПрохождениеОбучения;
							Движение.Задание = ОбъектыСУЗ.ЗаданиеПопытки(ПрохождениеОбучения, ЭлектронныйРесурс, Задание);
							Движение.ЭлементСодержания = ЭлементСодержания;
							
							Движение.Результат = ДанныеОтветаНаВопрос.score;
							
							Если Движение.Результат > 100 Тогда
								Движение.Результат = 100;
							КонецЕсли;		
							
							Движение.ПроведениеОбучения = ПроведениеОбучения;
							Движение.ЭлектронныйРесурс = ЭлектронныйРесурс;
							Движение.Тест = СсылкаНаЭлемент;
							
							Если ДанныеОтветаНаВопрос.Свойство("requiredTeacher") Тогда
								Движение.ПроверяетсяПреподавателем = ДанныеОтветаНаВопрос.requiredTeacher;
							КонецЕсли;
							
							Если ДанныеОтветаНаВопрос.Свойство("checkTeacher") Тогда
								Движение.ПроверенПреподавателем = ДанныеОтветаНаВопрос.checkTeacher;
							КонецЕсли;		
							
							Если ДанныеОтветаНаВопрос.Свойство("teacher") И ЗначениеЗаполнено(ДанныеОтветаНаВопрос.teacher) Тогда
								Движение.ПроверившийПреподаватель = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеОтветаНаВопрос.teacher));
							КонецЕсли;
							
							Если ДанныеОтветаНаВопрос.Свойство("teacherComment") Тогда
								Движение.КомментарийПреподавателя = ДанныеОтветаНаВопрос.teacherComment;
							КонецЕсли;
							
							Движение.СессияВыполненияТеста = Ссылка;
							Движение.КоличествоПоказов     = 0; // Не поддерживается
							Движение.ИспользованаПодсказка = Ложь; // Не поддерживается
							Движение.ПсихологическийВопрос = Ложь; // Не поддерживается
													
							Если ДанныеОтветаНаВопрос.Свойство("fullAnswer") Тогда
								Движение.РазвернутыйОтветПользователя = ДанныеОтветаНаВопрос.fullAnswer;
							КонецЕсли;		
							
							НомерВариантаОтвета = 1;
							
							Для каждого ДанныеВариантаОтвета Из ДанныеОтветаНаВопрос.variants Цикл
																														
								Движение = Движения.ВыбранныеВариантыОтветовВопросовСУЗ.Добавить();
								
								Движение.Период = ДанныеОтветаНаВопрос.start;
								Движение.СессияВыполненияТеста = Ссылка;
								Движение.Пользователь = Пользователь;
								Движение.Вопрос = ВопросТеста;
								Движение.ВариантОтвета = Справочники.ВариантыОтветовНаВопросСУЗ.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеВариантаОтвета.variant));
								
								Движение.ПрохождениеОбучения = ПрохождениеОбучения;
								Движение.ПроведениеОбучения = ПроведениеОбучения;			
								Движение.Задание = ОбъектыСУЗ.ЗаданиеПопытки(ПрохождениеОбучения, ЭлектронныйРесурс, Задание);
								
								Движение.ЭлементСодержания = ЭлементСодержания;
								
								Движение.Выбран = ДанныеВариантаОтвета.selected;
								
								Движение.ЭлектронныйРесурс = ЭлектронныйРесурс;
								Движение.Тест = СсылкаНаЭлемент;
								Движение.Номер = НомерВариантаОтвета;
																		
								Движение.ВерныйВыбран = ДанныеВариантаОтвета.trueSelected;
								Движение.ВерныйНеВыбран = ДанныеВариантаОтвета.trueNotSelected;
								Движение.ОшибочныйВыбран = ДанныеВариантаОтвета.falseSelected;
								Движение.ОшибочныйНеВыбран = ДанныеВариантаОтвета.falseNotSelected;			
						
								НомерВариантаОтвета = НомерВариантаОтвета + 1;
						
							КонецЦикла;
							
							
						КонецЦикла;	
					
					КонецЦикла;
					
					Если ДанныеТестирования.Свойство("requiredTeacher") И ДанныеТестирования.requiredTeacher Тогда
						
						Движение = Движения.ТестыНаПроверкуСУЗ.Добавить();
						
						Движение.Период = ДанныеТестирования.start;
						Движение.Пользователь = Пользователь;
						Движение.ПрохождениеОбучения = ПрохождениеОбучения;
						Движение.Задание = ОбъектыСУЗ.ЗаданиеПопытки(ПрохождениеОбучения, ЭлектронныйРесурс, Задание);
						Движение.ЭлементСодержания = ЭлементСодержания;
						Движение.Тест = СсылкаНаЭлемент;
						
						Если ДанныеТестирования.Свойство("checkTeacher") Тогда
							Движение.Проверен = ДанныеТестирования.checkTeacher;
						КонецЕсли;
						
						Движение.ЭлектронныйРесурс = ЭлектронныйРесурс;
						
					КонецЕсли;
					
					
					Если ДанныеТестирования.score < 100 Тогда
					
						АвтоРубрикатор = Справочники.РубрикаторыСУЗ.ПолучитьСсылку(ЭлектронныйРесурс.УникальныйИдентификатор());
					
						Если ОбщегоНазначенияСУКлиентСервер.СсылкаСуществуетВБазе(АвтоРубрикатор, Ложь) Тогда		
							
							АвтоРубрики = РегистрыСведений.РубрикиОбъектовСУЗ.РубрикиЭлемента(АвтоРубрикатор, ВопросТеста);
							
							Для каждого АвтоРубрика Из АвтоРубрики Цикл
							
								Движение = Движения.ПовторноеПрохождениеЭлектронныхРесурсовСУЗ.Добавить();
								Движение.Период = ДанныеТестирования.start;
								Движение.Пользователь = Пользователь;
								Движение.ПрохождениеОбучения = ПрохождениеОбучения;
								Движение.Задание = ОбъектыСУЗ.ЗаданиеПопытки(ПрохождениеОбучения, ЭлектронныйРесурс, Задание);
								Движение.ЭлементСодержания = Справочники.СодержаниеСУЗ.ПолучитьСсылку(АвтоРубрика.УникальныйИдентификатор());
								
							КонецЦикла;			
							
						КонецЕсли;

					КонецЕсли;			
				
				КонецЦикла;
				
			КонецЕсли;
			
			Если ДанныеАктивности.type = "SCO" Тогда
				
				Для каждого ДанныеПопыткиSCO Из ДанныеАктивности.scoAttempts Цикл
										
					Движение = Движения.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ.Добавить();
					
					Движение.Период                 = ДанныеПопыткиSCO.start;
					Движение.Пользователь           = Пользователь;
					Движение.ПрохождениеОбучения    = ПрохождениеОбучения;
					Движение.Задание                = ОбъектыСУЗ.ЗаданиеПопытки(ПрохождениеОбучения, ЭлектронныйРесурс, Задание);
					Движение.ЭлектронныйРесурс      = ЭлектронныйРесурс;
					Движение.СсылкаНаОбъектСУЗ      = СсылкаНаЭлемент;
					Движение.ЭтоТест                   = Ложь;
					Движение.НомерРегистратора         = Номер;	
					
					ЭлектронныеРесурсыПереопределяемый.ПроведениеОбучения(Движение.ПроведениеОбучения, ПрохождениеОбучения);
					
					Движение.ЭлементСодержания = ЭлементСодержания;					
					Движение.ДатаНачалаПрохождения     = ДанныеПопыткиSCO.start;
					Движение.ДатаОкончанияПрохождения  = ДанныеПопыткиSCO.end;
					
					ЗаполнитьДвижениеПопыткиSCORM(Движение, ДанныеПопыткиSCO.cmi);
					
				КонецЦикла;
				
			КонецЕсли;
		

// Учет истории разработки

Процедура УчетИсторииРазработкиЭлектронныхРесурсовПередЗаписьюСУОПередЗаписью(Источник, Отказ) Экспорт
	Если Источник.ОбменДанными.Загрузка Тогда 
    	Возврат; 
	КонецЕсли;		
	Источник.ДополнительныеСвойства.Вставить("ЭтоНовый", Источник.ЭтоНовый());
КонецПроцедуры

Процедура УчетИсторииРазработкиЭлектронныхРесурсовСУОПриЗаписи(Источник, Отказ) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда 
    	Возврат; 
	КонецЕсли;		
	
	Если НЕ ПолучитьФункциональнуюОпцию("ВестиИсториюРазработкиЭлектронныхРесурсовСУО") Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Источник.ДополнительныеСвойства.Свойство("ЭтоНовый")
		И Источник.ДополнительныеСвойства.ЭтоНовый Тогда
		
		Действие = Перечисления.ДействияНадЭлектроннымиРесурсамиСУО.Добавление;
		
	Иначе
		
		Действие = ?(Источник.ПометкаУдаления, Перечисления.ДействияНадЭлектроннымиРесурсамиСУО.Удаление, Перечисления.ДействияНадЭлектроннымиРесурсамиСУО.Изменение);
				
	КонецЕсли;
	
	Пользователь = Пользователи.ТекущийПользователь();
	Период       = ТекущаяДата();
	
	НаборЗаписей = РегистрыСведений.ИсторияРазработкиЭлектронныхРесурсовСУО.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Период.Установить(Период);
	НаборЗаписей.Отбор.СсылкаНаОбъектСУЗ.Установить(Источник.Ссылка);
	
	НоваяЗапись = НаборЗаписей.Добавить();
    НоваяЗапись.Период            = Период;
	НоваяЗапись.СсылкаНаОбъектСУЗ = Источник.Ссылка;
	НоваяЗапись.Пользователь      = Пользователь;
	НоваяЗапись.Действие          = Действие;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

	

// ПРОЦЕДУРЫ - ДЕЙСТВИЯ КОМАНД

&НаКлиенте
Процедура Утвердить(Команда)
	
	Если Объект.Участники.Количество() > 0 Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("УтвердитьПользователейПродолжение", ЭтотОбъект);		
		Текст = НСтр("ru = 'Записать пользователей из списка на мероприятие?'");
		
		ПоказатьВопрос(ОписаниеОповещения, Текст, РежимДиалогаВопрос.ДаНет, 0);
		
	Иначе
		
		Если ЗначениеЗаполнено(Объект.Прохождение) Тогда
			
			УтвердитьПользователя();
			
		Иначе
			
			Режим = РежимДиалогаВопрос.ДаНет;
			Текст = НСтр("ru = 'Записать пользователя %1 на мероприятие?'");
			Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Текст, Объект.Пользователь);
			ОписаниеОповещения = Новый ОписаниеОповещения("ЗаписатьПользователяПродолжение", ЭтотОбъект);		
				
			ПоказатьВопрос(ОписаниеОповещения, Текст, Режим, 0);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УтвердитьПользователейПродолжение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	ЗачислитьУчастников();
	
КонецПроцедуры	

&НаКлиенте
Процедура ЗаписатьПользователяПродолжение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	Объект.Прохождение = ЗачислитьУчастника(Объект.ПредметЗаявки, Объект.ОбъектЗаявки, Объект.Пользователь, Объект.Ссылка);
	
	УтвердитьПользователя();
	
КонецПроцедуры

&НаКлиенте
Процедура УтвердитьПользователя() Экспорт
	
	Объект.Статус  = ПредопределенноеЗначение("Перечисление.СтатусыЗаявокНаОбучениеСУО.Утверждена");
		
	Объект.ДатаРассмотрения = ТекущаяДата();
	
	РежимЗаписи = Новый Структура();
	РежимЗаписи.Вставить("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	Записать(РежимЗаписи);
	
КонецПроцедуры

&НаКлиенте
Процедура Отклонить(Команда)
	
	Объект.Статус  = ПредопределенноеЗначение("Перечисление.СтатусыЗаявокНаОбучениеСУО.Отклонена");
	
	Объект.ДатаРассмотрения = ТекущаяДата();
	
	РежимЗаписи = Новый Структура();
	РежимЗаписи.Вставить("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	Записать(РежимЗаписи);
	
КонецПроцедуры

&НаКлиенте
Процедура Отменить(Команда)
	
	Объект.Статус  = ПредопределенноеЗначение("Перечисление.СтатусыЗаявокНаОбучениеСУО.Отменена");
	
	Объект.ДатаРассмотрения = ТекущаяДата();
	
	РежимЗаписи = Новый Структура();
	РежимЗаписи.Вставить("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	Записать(РежимЗаписи);
	
КонецПроцедуры


#Область ОбработчикиСобытий

// ОБРАБОТЧИКИ

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Поля.Добавить("Наименование");
	Поля.Добавить("Тип");

КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Представление = "%2 ""%1""";
	
	Представление = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Представление, Данные.Наименование, Данные.Тип);

КонецПроцедуры

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		
		Если Параметры.Свойство("Ключ") И НЕ ПравоДоступа("Изменение", Метаданные.Справочники.СводыЗнанийСУЗ) Тогда
			
			СтандартнаяОбработка = Ложь;			
			Параметры.Вставить("СводЗнаний", Параметры.Ключ);			
			ВыбраннаяФорма = "ОбщаяФорма.ОбозревательОбъектовСУЗ";			
			Возврат; // Просмотр курса
			
		КонецЕсли;
		
		Если Параметры.Свойство("Ключ")
			ИЛИ Параметры.Свойство("ЭтоГруппа")
			ИЛИ Параметры.Свойство("ЗначениеКопирования") Тогда
			
			Если Параметры.Свойство("Ключ") И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.Ключ, "Тип") = Перечисления.ТипыЭлектронныхРесурсовСУЗ.Тест Тогда
				СтандартнаяОбработка = Ложь;						
				Параметры.Вставить("ЭлектронныйРесурс", Параметры.Ключ);
				Параметры.Ключ = Справочники.СводыЗнанийСУЗ.Тест(Параметры.Ключ);					
				ВыбраннаяФорма = "Справочник.ПодборкиСУЗ.Форма.ФормаТеста";						
				Возврат;
			КонецЕсли;
			
			Возврат; // Форма курса	
			
		Иначе
			
			Если Параметры.Свойство("ЗначенияЗаполнения") И Параметры.ЗначенияЗаполнения.Свойство("Тип") Тогда					
				
				Если Параметры.ЗначенияЗаполнения.Тип = Перечисления.ТипыЭлектронныхРесурсовСУЗ.Тест Тогда
					
					СтандартнаяОбработка = Ложь;						
					Параметры.Вставить("СоздатьЭлектронныйРесурс", Истина);						
					ВыбраннаяФорма = "Справочник.ПодборкиСУЗ.Форма.ФормаТеста";						
					Возврат; // Создание теста
					
				КонецЕсли;
				
				Если Параметры.ЗначенияЗаполнения.Тип = Перечисления.ТипыЭлектронныхРесурсовСУЗ.ЭлектронныйКурс Тогда
					
					СтандартнаяОбработка = Ложь;						
					Параметры.Вставить("СоздатьЭлектронныйРесурс", Истина);						
					ВыбраннаяФорма = "Справочник.СводыЗнанийСУЗ.ФормаОбъекта";						
					Возврат; // Создание курса
					
				КонецЕсли;
				
			Иначе
				
				СтандартнаяОбработка = Ложь;					
				ВыбраннаяФорма = "ФормаСоздания";					
				Возврат; // Форма создания
				
			КонецЕсли;
			
			
		КонецЕсли;			
						
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#КонецЕсли

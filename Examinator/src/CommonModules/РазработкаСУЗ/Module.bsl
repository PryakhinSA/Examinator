// Дата изменения

Процедура УстановитьДатуИзмененияПередЗаписью(Источник, Отказ) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда 
    	Возврат; 
	КонецЕсли;	

	ДатаИзменения = Неопределено;
	Источник.ДополнительныеСвойства.Свойство("ДатаИзменения", ДатаИзменения);
	Если ДатаИзменения = Неопределено Тогда
		ДатаИзменения = ТекущаяДатаСеанса();
	КонецЕсли;
	Источник.ДатаИзменения = ДатаИзменения;

КонецПроцедуры

Процедура УстановитьДатуИзмененияРегистраСУЗПередЗаписью(Источник, Отказ, Замещение) Экспорт
	Если Источник.ОбменДанными.Загрузка Тогда 
    	Возврат; 
	КонецЕсли;	
	Для каждого ЗаписьРегистра Из Источник Цикл
		ЗаписьРегистра.ДатаИзменения = ТекущаяДатаСеанса();
	КонецЦикла;
КонецПроцедуры

// Код

Процедура УстановитьКодКратныйДесятиСУЗПриУстановкеНовогоКода(Источник, СтандартнаяОбработка, Префикс) Экспорт
	
	ОтменитьУстановкуКода = Ложь;
	ОтменитьУстановкуКода = Источник.ДополнительныеСвойства.Свойство("ОтменитьУстановкуКода");
	
	Если НЕ ОтменитьУстановкуКода Тогда
	
		ИмяСправочника = Источник.Метаданные().Имя;
		
		ТекстЗапроса = "
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	"+ИмяСправочника+".Код КАК Код
		|ИЗ
		|	Справочник."+ИмяСправочника+" КАК "+ИмяСправочника+"
		|ГДЕ
		|	"+ИмяСправочника+".Родитель = &Родитель";
		
		Если Источник.Владелец <> Неопределено Тогда
			ТекстЗапроса = ТекстЗапроса + " И "+ИмяСправочника+".Владелец = &Владелец ";
		КонецЕсли;
		
		ТекстЗапроса = ТекстЗапроса + " УПОРЯДОЧИТЬ ПО
		|	Код УБЫВ";
		
		Запрос = Новый Запрос(ТекстЗапроса);
		
		Запрос.УстановитьПараметр("Родитель", Источник.Родитель); 
		
		Если Источник.Владелец <> Неопределено Тогда
			Запрос.УстановитьПараметр("Владелец", Источник.Владелец); 
		КонецЕсли;
		
		Результат = Запрос.Выполнить().Выбрать();
		Результат.Следующий();
		
		МаксимальныйКод = Результат.Код;
		
		СтандартнаяОбработка = Ложь;
		
		Если МаксимальныйКод = Неопределено Тогда
			Источник.Код = 10;
		Иначе
			Источник.Код = МаксимальныйКод - ОбщегоНазначенияСУКлиентСервер.ОстатокОтДеления(МаксимальныйКод, 10) + 10;
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

// Возможность записи

Процедура ПроверитьВозможностьЗаписиОбъектаСУЗПередЗаписью(Источник, Отказ) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда 
    	Возврат; 
	КонецЕсли;
	
	ОтменитьКонтрольЗаписиОбъекта = Ложь;
	ОтменитьКонтрольЗаписиОбъекта = Источник.ДополнительныеСвойства.Свойство("ОтменитьКонтрольЗаписиОбъекта");
	
	Если НЕ ОтменитьКонтрольЗаписиОбъекта Тогда
		
		ОбъектыСУЗ.ИзменениеДанныхОтПоставщикаЗапрещено(Источник.Поставщик, Отказ);
		
		Если НЕ Отказ И НЕ Источник.ЭтоНовый() Тогда
			
			// Для существующих в базе объектов, которые не могут иметь версии запрещаем изменение поставщика.
			// Группы объектов с версиями так же не имеют версий, но для них проверка не делается.
			Если Источник.Метаданные().Реквизиты.Найти("Версия") = Неопределено Тогда
				ОбъектыСУЗ.ИзменениеДанныхОтПоставщикаЗапрещено(Источник.Ссылка.Поставщик, Отказ);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

Процедура ПроверитьВозможностьЗаписиРегистраСУЗПередЗаписью(Источник, Отказ, Замещение) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда 
    	Возврат; 
	КонецЕсли;	
	
	ОбъектыСУЗ.ИзменениеДанныхОтПоставщикаЗапрещено(Источник.Отбор.Поставщик.Значение, Отказ);

КонецПроцедуры


// Выполняет обновление до версии 3.0.9.155
//
Процедура ВыполнитьОбновлениеДоВерсии309155() Экспорт
	
	// Удаляем дубли документов ПопыткаВыполненияЗаданияСУО, которые возникли
	// из-за того, что для обучений у которых есть только один один электронный
	// ресурс или созданное на основе электронного ресурса не заполнялась таблица
	// заданий при проведении документа ПопыткаВыполненияЗаданияСУО. Это приводило
	// к отсутствию движений, а значит документ создавался каждый раз, как только
	// пользователь начинал изучать электронный курс.
	
	// Ищем все попытки выполнения заданий у которых заполнен реквизит ЭлектронныйРесурс
	// проведения обучения. Отбираем те, число которых больше 1 для каждого прохождения обучения.
	// Далее отбираем все документы ПопыткаВыполненияЗаданияСУО этих прохождений обучений.
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПопыткаВыполненияЗаданияСУО.ПрохождениеОбучения,
		|	КОЛИЧЕСТВО(ПопыткаВыполненияЗаданияСУО.Ссылка) КАК КоличествоДокументов
		|ПОМЕСТИТЬ Дубли
		|ИЗ
		|	Документ.ПопыткаВыполненияЗаданияСУО КАК ПопыткаВыполненияЗаданияСУО
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(ПопыткаВыполненияЗаданияСУО.Задание) = ТИП(Справочник.СводыЗнанийСУЗ)
		|	И ПопыткаВыполненияЗаданияСУО.Задание = ПопыткаВыполненияЗаданияСУО.ПроведениеОбучения.ЭлектронныйРесурс
		|	И ПопыткаВыполненияЗаданияСУО.ПометкаУдаления = ЛОЖЬ
		|
		|СГРУППИРОВАТЬ ПО
		|	ПопыткаВыполненияЗаданияСУО.ПрохождениеОбучения
		|
		|ИМЕЮЩИЕ
		|	КОЛИЧЕСТВО(ПопыткаВыполненияЗаданияСУО.Ссылка) > 1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПопыткаВыполненияЗаданияСУО.Ссылка,
		|	ПопыткаВыполненияЗаданияСУО.ПрохождениеОбучения КАК ПрохождениеОбучения,
		|	ПопыткаВыполненияЗаданияСУО.Дата КАК Дата
		|ИЗ
		|	Дубли КАК Дубли
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПопыткаВыполненияЗаданияСУО КАК ПопыткаВыполненияЗаданияСУО
		|		ПО (ПопыткаВыполненияЗаданияСУО.ПрохождениеОбучения = Дубли.ПрохождениеОбучения)
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(ПопыткаВыполненияЗаданияСУО.Задание) = ТИП(Справочник.СводыЗнанийСУЗ)
		|	И ПопыткаВыполненияЗаданияСУО.Задание = ПопыткаВыполненияЗаданияСУО.ПроведениеОбучения.ЭлектронныйРесурс
		|	И ПопыткаВыполненияЗаданияСУО.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПрохождениеОбучения,
		|	Дата УБЫВ";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ТекущееПрохождениеОбучения = Неопределено;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если НЕ ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Ссылка) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ВыборкаДетальныеЗаписи.ПрохождениеОбучения <> ТекущееПрохождениеОбучения Тогда
			ТекущееПрохождениеОбучения = ВыборкаДетальныеЗаписи.ПрохождениеОбучения;
			РегистрыСведений.ДокументыТребующиеПерепроведенияСУО.ДобавитьДокумент(ВыборкаДетальныеЗаписи.Ссылка, РежимЗаписиДокумента.Проведение, Ложь,,0);
			Продолжить; // Пропускаем последнюю попытку
		КонецЕсли;
		
		ДокументОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		ДокументОбъект.УстановитьПометкуУдаления(Истина);
		
	КонецЦикла;	
	
КонецПроцедуры


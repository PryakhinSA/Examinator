
////////////////////////////////////////////////////////////////////////////////
// ОБЩЕЕ

Процедура УстановкаПараметровСеанса(ИмяПараметра, УстановленныеПараметры) Экспорт

	УстановитьПривилегированныйРежим(Истина);
		
	ПутьКОбщемуКаталогу = ОбъектыСУЗПовтИсп.ПутьКОбщемуКаталогу();
	
	Если ЗначениеЗаполнено(ПутьКОбщемуКаталогу) Тогда
		ПараметрыСеанса.ПутьКРабочемуКаталогуСУ = ПутьКОбщемуКаталогу;
	Иначе
		ПараметрыСеанса.ПутьКРабочемуКаталогуСУ = "";
	КонецЕсли;
		
	УстановленныеПараметры.Добавить("ПутьКРабочемуКаталогуСУ");
			
	АдресОбщегоКаталога = Константы.АдресОбщегоКаталогаСУ.Получить();
	
	Если ЗначениеЗаполнено(АдресОбщегоКаталога) Тогда
		ПараметрыСеанса.АдресРабочегоКаталогаСУ = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(АдресОбщегоКаталога);
	Иначе
		ПараметрыСеанса.АдресРабочегоКаталогаСУ = "";	
	КонецЕсли;
	
	УстановленныеПараметры.Добавить("АдресРабочегоКаталогаСУ");
		
КонецПроцедуры

// ПРЕДСТАВЛЕНИЕ

// Служит для получения данных для представления объекта.
// Функция может использоваться рекурсивно, вызываясь при создании
// структур данных вложенных объектов.
//
// Параметры:
//  ПараметрыСсылки     - Структура, содержит параметры необходимые для отображения объекта.
//  КонтекстВыполнения  - Структура с дополнительными параметрами.
//
// Возвращаемое значение:
//  Структура. Ключи структуры: "Представление", "Скрипт", "Стили" и др. 
//  Полный список элементов структуры представлен в функции "ПолучитьПредставлениеПустогоОбъекта".
//
Функция ПолучитьПредставление(Ссылка, ПараметрыСсылки, КонтекстВыполнения) Экспорт
	
	//////////////////////////////////////////////////////////////////////////////////
	// Получаем основные переменные
	                 
	Префикс                   = "СУЗ";
	ИмяОбъекта                = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "object");
	ВложенныйОбъект           = ?(КонтекстВыполнения.СписокШаблонов = Неопределено, Ложь, Истина);
	СтруктураДанных           = ОбъектыСУЗ.ПолучитьПредставлениеПустогоОбъекта();
	ТипОбъектаСУЗ             = ПолучитьТипОбъектаСУЗ(Ссылка);
	
	Если ЗначениеЗаполнено(КонтекстВыполнения.ЭлектронныйРесурс) Тогда
		ДанныеЭлектронногоРесурса = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КонтекстВыполнения.ЭлектронныйРесурс, "Глоссарий, ПоказыватьПервуюСсылкуНаТермин, ПоказыватьТерминВсплывающейПодсказкой");
	Иначе
		ДанныеЭлектронногоРесурса = Неопределено;
	КонецЕсли;
	
	//////////////////////////////////////////////////////////////////////////////////
	// Получаем представление объекта
	
	Если НЕ ВложенныйОбъект Тогда
		
		// Массив содержит ссылки на элементы справочника ШаблоныСУЗ,
		// Которые используются при формировании XML объекта.
		// Добавляются все шаблоны вложенных объектов и самого объекта.		
		КонтекстВыполнения.Вставить("СписокШаблонов", Новый Массив);
		
		// Массив содержит список всех ресурсов, которые необходимо
		// Выгрузить в кэш для отображения объекта. Используется
		// Для формирования кэша на клиенте или сервере.
		КонтекстВыполнения.Вставить("СписокРесурсов", Новый Массив);
		
		// Массив элементов справочника СсылкиОбъектовСУЗ, объекты
		// Которых нужно выгрузить при экспорте в автономный пакет.
		КонтекстВыполнения.Вставить("СписокСсылок", Новый Массив);
		
		// Массив подсказок из справочника РесурсыОбъектовСУЗ.
		КонтекстВыполнения.Вставить("СписокПодсказок", Новый Массив);
		
		// Массив ссылок на файлы предопределенного ресурса "Модули".
		КонтекстВыполнения.Вставить("СписокМодулей", Новый Массив);
		
	КонецЕсли;
	
	XMLДанные = "<?xml version=""1.0""?>";
	
	ИмяСправочника = Ссылка.Метаданные().Имя;
	XMLДанные      = XMLДанные + Справочники[ИмяСправочника].ПолучитьXMLПредставление(Ссылка, ПараметрыСсылки, КонтекстВыполнения);

	// Вставляем в структуру данных стили, только если требуется получить
	// Данные объекта верхнего уровня (объекта не вложенного в другой объект).
	Если НЕ ВложенныйОбъект Тогда
		
		// На основании списка вложенных шаблонов получаем текст необходимых стилей.
		CSSДанные = ОбъектыСУЗ.ПолучитьТекстСтилейОбъекта(КонтекстВыполнения.СписокШаблонов);
		СтруктураДанных.Вставить("Стили", CSSДанные);
	
	КонецЕсли;
								   
	Шаблон = ОбъектыСУЗ.ПолучитьСсылкуНаXSLШаблонОбъекта(Ссылка);
	СтруктураДанныхШаблона = ОбъектыСУЗ.ПолучитьИзКэшаТекстШаблона(Шаблон, Префикс);
	
	Преобразование = Новый ПреобразованиеXSL;
	Преобразование.ЗагрузитьИзСтроки(СтруктураДанныхШаблона.ШаблонПредставления);
	HTMLДанные = Преобразование.ПреобразоватьИзСтроки(XMLДанные);
	
	Если Прав(HTMLДанные, 1) = Символы.ПС Тогда
		HTMLДанные = Лев(HTMLДанные, СтрДлина(HTMLДанные) - 1); // Убираем лишний перевод строки в конце
	КонецЕсли;	
	
	Преобразование.ЗагрузитьИзСтроки(СтруктураДанныхШаблона.ШаблонСкрипта);
	JavaScriptДанные = Преобразование.ПреобразоватьИзСтроки(XMLДанные);
	
	СтруктураДанных.Вставить("Представление", HTMLДанные);
	СтруктураДанных.Вставить("Скрипт", JavaScriptДанные);
	
	//////////////////////////////////////////////////////////////////////////////////
	// Получаем дополнительные данные объекта
	
	// Заголовок
	
	Если ТипОбъектаСУЗ = Перечисления.ТипыОбъектовСУЗ.map Тогда
		
		ПредметКарты                         = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "targetMap");
		ИдентификаторПредметаКарты           = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "idTargetMap");
		УникальныйИдентификаторПредметаКарты = Новый УникальныйИдентификатор(ИдентификаторПредметаКарты);
		
		СсылкаНаПредметКарты = Справочники.КартыСУЗ.ПолучитьСсылкуНаПредметКарты(ПредметКарты, УникальныйИдентификаторПредметаКарты);
		
		СтруктураДанных.Вставить("Заголовок", "Карта " + СсылкаНаПредметКарты.Наименование);
		
	Иначе
		
		СтруктураДанных.Вставить("Заголовок", Ссылка.Наименование);
		
	КонецЕсли;
	
	// Ресурсы
	
	Если ДанныеЭлектронногоРесурса <> Неопределено И НЕ ВложенныйОбъект И ЗначениеЗаполнено(ДанныеЭлектронногоРесурса.Глоссарий) Тогда
		
		ДатаИзмененияГлоссария = Неопределено;
		
		Для каждого Строка Из КонтекстВыполнения.СписокРесурсов Цикл
		
			Если Строка.ПодключитьAPI Тогда
				
				Если ДатаИзмененияГлоссария = Неопределено Тогда
					ДатаИзмененияГлоссария = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЭлектронногоРесурса.Глоссарий, "ДатаИзменения");
				КонецЕсли;
				
				Если ДатаИзмененияГлоссария > Строка.ДатаИзменения Тогда
					Строка.ДатаИзменения = ДатаИзмененияГлоссария;	
				КонецЕсли;
				
			КонецЕсли;
		
		КонецЦикла;
		
	КонецЕсли;
	
	СтруктураДанных.Вставить("Ресурсы", КонтекстВыполнения.СписокРесурсов);
	
	// Ссылки
	
	СтруктураДанных.Вставить("СписокСсылок", КонтекстВыполнения.СписокСсылок);
	
	СтруктураДанных.Вставить("АдресОбъекта", КонтекстВыполнения.АдресОбъекта);
	
	// Параметры тестирования (необязательные свойства)
	
	Если КонтекстВыполнения.Свойство("СессияТестирования") Тогда
		СтруктураДанных.Вставить("СессияТестирования", КонтекстВыполнения.СессияТестирования);
	КонецЕсли;
	
	Если КонтекстВыполнения.Свойство("ВыполняетсяТестирование") Тогда
		СтруктураДанных.Вставить("ВыполняетсяТестирование", КонтекстВыполнения.ВыполняетсяТестирование);
	КонецЕсли;
	
	Если КонтекстВыполнения.Свойство("ВсеВопросыТестированияОтвечены") Тогда
		СтруктураДанных.Вставить("ВсеВопросыТестированияОтвечены", КонтекстВыполнения.ВсеВопросыТестированияОтвечены);
	КонецЕсли;
	
	//////////////////////////////////////////////////////////////////////////////////
	// Изменяем и дополняем представление, если необходимо
	
	ПодключитьМодульПодсказок = Ложь;
	
	Если ДанныеЭлектронногоРесурса <> Неопределено
		И ИмяСправочника = "СтраницыСУЗ"
		И ЗначениеЗаполнено(КонтекстВыполнения.ЭлементСодержания)
		И ЗначениеЗаполнено(ДанныеЭлектронногоРесурса.Глоссарий) Тогда
		
		// Делаем ссылки на термины глоссария
		
			
		ДанныеЭлементаСодержания = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КонтекстВыполнения.ЭлементСодержания, "СкрыватьСсылкиНаТерминыГлоссария, ЭтоГруппа");
		
		Если НЕ ДанныеЭлементаСодержания.ЭтоГруппа И НЕ ДанныеЭлементаСодержания.СкрыватьСсылкиНаТерминыГлоссария Тогда
			
			ТаблицаТерминов = ОбъектыСУЗПовтИсп.ТерминыГлоссария(ДанныеЭлектронногоРесурса.Глоссарий, ДанныеЭлектронногоРесурса.ПоказыватьТерминВсплывающейПодсказкой, КонтекстВыполнения.ДатаОткрытияОбозревателя);
			
			МассивОпределений = Новый Массив();
			
			Для каждого Термин Из ТаблицаТерминов Цикл
				СтруктураДанных.Представление = ЗаменитьТермин(СтруктураДанных.Представление, Термин, ДанныеЭлектронногоРесурса.ПоказыватьПервуюСсылкуНаТермин, ДанныеЭлектронногоРесурса.ПоказыватьТерминВсплывающейПодсказкой,, МассивОпределений);
			КонецЦикла;
			
			Если МассивОпределений.Количество() > 0 Тогда
				
				СтруктураДанных.Представление = СтруктураДанных.Представление + "<div style=""display:none;"">";
				
				Для каждого Элемент Из МассивОпределений Цикл
				
					СтруктураДанных.Представление = СтруктураДанных.Представление + Символы.ПС + "<div id=""text_tip_"+СтрЗаменить(Строка(Элемент.Термин.УникальныйИдентификатор()), "-", "")+""">" + Элемент.Определение + "</div>";
					
				КонецЦикла;
				
				СтруктураДанных.Представление = СтруктураДанных.Представление + "</div>";
				
				ПодключитьМодульПодсказок = Истина;
				
			КонецЕсли;				
			
		КонецЕсли;			

			
	КонецЕсли;	
	
	Если ИмяСправочника = "СтраницыСУЗ" Тогда
		
		// Делаем ссылки на подсказки
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	РесурсыОбъектовСУЗ.Текст,
			|	РесурсыОбъектовСУЗ.Ссылка
			|ИЗ
			|	Справочник.РесурсыОбъектовСУЗ КАК РесурсыОбъектовСУЗ
			|ГДЕ
			|	РесурсыОбъектовСУЗ.ПометкаУдаления = ЛОЖЬ
			|	И РесурсыОбъектовСУЗ.Владелец = &Владелец
			|	И РесурсыОбъектовСУЗ.Подсказка = ИСТИНА";
		
		Запрос.УстановитьПараметр("Владелец", Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Если ВыборкаДетальныеЗаписи.Количество() > 0 Тогда
		
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				
				СтруктураДанных.Представление = СтруктураДанных.Представление + "<div style=""display:none;"">";
				СтруктураДанных.Представление = СтруктураДанных.Представление + Символы.ПС + "<div id=""text_tip_"+СтрЗаменить(Строка(ВыборкаДетальныеЗаписи.Ссылка.УникальныйИдентификатор()), "-", "")+""">" + ВыборкаДетальныеЗаписи.Текст + "</div>";
				СтруктураДанных.Представление = СтруктураДанных.Представление + "</div>";
				
				ПодключитьМодульПодсказок = Истина;

			КонецЦикла;
			
		КонецЕсли;
		
		
	КонецЕсли;
	
	// Подключаем модули

	Если ПодключитьМодульПодсказок Тогда
		ДобавитьМодульВМассив("qtip2", КонтекстВыполнения.СписокМодулей);
	КонецЕсли;
	
	// Подключаем дополнительные скрипты
	
	Если НЕ ВложенныйОбъект Тогда
		
		Для каждого Модуль Из КонтекстВыполнения.СписокМодулей Цикл
		
			ФайлыМодуля = ОбъектыСУЗПовтИсп.ФайлыМодуля(Модуль, КонтекстВыполнения.ДатаОткрытияОбозревателя);
			
			Если КонтекстВыполнения.ПараметрыЭкспорта = Неопределено Тогда
			
				Для каждого ФайлМодуля Из ФайлыМодуля Цикл
				
					Если ФайлМодуля.Расширение = "js" Тогда
						СтруктураДанных.Скрипт = "$('head').append( $('<script type=""text/javascript"" src="""+ФайлМодуля.ОтносительныйПуть+"""/>') );" + Символы.ПС + СтруктураДанных.Скрипт;
					КонецЕсли;
					
					Если ФайлМодуля.Расширение = "css" Тогда
						СтруктураДанных.Скрипт = "$('head').append( $('<link rel=""stylesheet"" type=""text/css"" href="""+ФайлМодуля.ОтносительныйПуть+""" />') );" + Символы.ПС + СтруктураДанных.Скрипт;
					КонецЕсли;
				
				КонецЦикла;
				
			Иначе
				
				Для каждого ФайлМодуля Из ФайлыМодуля Цикл
				
					Если ФайлМодуля.Расширение = "js" Тогда
						СтруктураДанных.Представление = СтруктураДанных.Представление + Символы.ПС + "<script type=""text/javascript"" src="""+ФайлМодуля.ОтносительныйПуть+"""/></script>";
					КонецЕсли;
					
					Если ФайлМодуля.Расширение = "css" Тогда
						СтруктураДанных.Представление = СтруктураДанных.Представление + Символы.ПС + "<link rel=""stylesheet"" type=""text/css"" href="""+ФайлМодуля.ОтносительныйПуть+""" />";
					КонецЕсли;				
					
				КонецЦикла;
					
			КонецЕсли;			
				
			Если Модуль.Наименование = "qtip2" Тогда
				ПодключитьМодульПодсказок = Истина;	
			КонецЕсли;
			
		КонецЦикла;
		
		Если ПодключитьМодульПодсказок Тогда
			СтруктураДанных.Скрипт = СтруктураДанных.Скрипт + Символы.ПС + "oClient.processTips();" + Символы.ПС;
		КонецЕсли;
		
		Если ПараметрыСсылки.Свойство("anchor") Тогда
			СтруктураДанных.Скрипт = СтруктураДанных.Скрипт + Символы.ПС + "$(document).ready(function(){oClient.scrollToBookmark('"+ПараметрыСсылки.anchor+"')});";
		КонецЕсли;
		
	КонецЕсли;
		
	Возврат СтруктураДанных;
	
КонецФункции

// Служит для получения объекта СУЗ по его имени и идентификатору.
//
// Параметры:
//  ИмяОбъекта - Строка, содержащая имя объекта.
//  id - Строка, содержащая GUID объекта.
//
// Возвращаемое значение:
//  Ссылку на элемент справочника.
//  Неопределено, если объект не найден.
//
Функция ПолучитьСсылкуПоИдентификатору(ИмяОбъекта, id) Экспорт
	
	Если ПустаяСтрока(id) ИЛИ ПустаяСтрока(ИмяОбъекта) Тогда
		Возврат Неопределено;
	КонецЕсли;

    Попытка
    	ТипОбъекта = Перечисления["ТипыОбъектовСУЗ"][ИмяОбъекта];
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	ИмяСправочника = Строка(ТипОбъекта)+"СУЗ";
	
	Попытка
		УникальныйИдентификатор = Новый УникальныйИдентификатор(id);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Попытка 
		СправочникСсылка = Справочники[ИмяСправочника].ПолучитьСсылку(УникальныйИдентификатор);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат СправочникСсылка;
		
КонецФункции

// Функция позволяет заполнить структуру данных, которая описывает
// Контекст выполнения объекта СУЗ.
Функция ЗаполнитьКонтекстВыполненияОбъекта(ЭлектронныйРесурс = Неопределено,
	                                       ЭлементСодержания=Неопределено,
										   ТекущийПользователь=Неопределено,
										   ПрохождениеОбучения=Неопределено,
										   Задание=Неопределено,
										   Вариант=Неопределено,
										   ЗначенияНастроекЭР=Неопределено,
										   Симуляция=Ложь,
										   ПараметрыЭкспорта=Неопределено,
										   ДатаОткрытияОбозревателя=Неопределено,
										   АдресЗагруженногоОбъекта=Неопределено,
										   ПодключитьAPI=Ложь,
										   ЭтоВстроенныйWeKit = Неопределено) Экспорт
	
	
	Если ПрохождениеОбучения = Неопределено Тогда
		ПрохождениеОбучения = Метаданные.ОпределяемыеТипы.ПрохождениеЭлектронногоОбучения.Тип.ПривестиЗначение(ПрохождениеОбучения);
	КонецЕсли;		
	
	Если Задание = Неопределено Тогда
		Задание = Метаданные.ОпределяемыеТипы.ЗаданиеЭлектронногоОбучения.Тип.ПривестиЗначение(Задание);
	КонецЕсли;
	
	Если Вариант = Неопределено Тогда
		Вариант = Метаданные.ОпределяемыеТипы.ВариантЗаданияЭлектронногоОбучения.Тип.ПривестиЗначение(Вариант);
	КонецЕсли;
	
	Если ЭлектронныйРесурс = Неопределено И ТипЗнч(ЭлементСодержания) = Тип("СправочникСсылка.СодержаниеСУЗ") Тогда
		ЭлектронныйРесурс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлементСодержания, "Владелец");
	КонецЕсли;
	
	КонтекстВыполнения = Новый Структура;
	
	КонтекстВыполнения.Вставить("ЭлектронныйРесурс", ЭлектронныйРесурс);
	КонтекстВыполнения.Вставить("ЭлементСодержания", ЭлементСодержания);
	КонтекстВыполнения.Вставить("ПрохождениеОбучения", ПрохождениеОбучения);
	КонтекстВыполнения.Вставить("Задание", Задание);
	КонтекстВыполнения.Вставить("Вариант", Вариант);
	КонтекстВыполнения.Вставить("ЗначенияНастроекЭР", ЗначенияНастроекЭР);
	КонтекстВыполнения.Вставить("Симуляция", Симуляция);
	КонтекстВыполнения.Вставить("ПараметрыЭкспорта", ПараметрыЭкспорта);
	КонтекстВыполнения.Вставить("ТекущийПользователь", ?(ЗначениеЗаполнено(ТекущийПользователь), ТекущийПользователь, Пользователи.ТекущийПользователь()));
	КонтекстВыполнения.Вставить("ДатаОткрытияОбозревателя", ДатаОткрытияОбозревателя);
	КонтекстВыполнения.Вставить("АдресЗагруженногоОбъекта", АдресЗагруженногоОбъекта);
	КонтекстВыполнения.Вставить("ПодключитьAPI", ПодключитьAPI);
	КонтекстВыполнения.Вставить("ЭтоВстроенныйWeKit", ЭтоВстроенныйWeKit);
	
	// Параметры, которые будут заполняться по мере сборки объекта:
	// Первоначально не определены.
	
	КонтекстВыполнения.Вставить("СписокШаблонов", Неопределено);
	КонтекстВыполнения.Вставить("СписокРесурсов", Неопределено);
	КонтекстВыполнения.Вставить("СписокСсылок", Неопределено);
	КонтекстВыполнения.Вставить("СписокПодсказок", Неопределено);
	КонтекстВыполнения.Вставить("СписокМодулей", Неопределено);
	
	// Симуляция
	
	КонтекстВыполнения.Вставить("АдресОбъекта", Неопределено);
	
	Возврат КонтекстВыполнения;
	
КонецФункции

// Функция возвращает представление пустого объекта СУЗ
// Требуется для того, чтобы гарантировать наличие всех указанных свойств
// у объекта СУЗ.
//
Функция ПолучитьПредставлениеПустогоОбъекта() Экспорт
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("Представление", ""); // Строка. HTML-представление объекта.
	СтруктураДанных.Вставить("Скрипт", ""); // Строка. Скрипты объекта на JavaScript.
	СтруктураДанных.Вставить("Стили", ""); // Строка. Стили CSS объекта.
	СтруктураДанных.Вставить("Заголовок", ""); // Строка. 
	СтруктураДанных.Вставить("ПроцентЗавершенныхЭлементовОбучения", -1); // Число в диапазоне от 0 до 100. -1 - значение не определено.
	СтруктураДанных.Вставить("ПопыткаВыполненияСтатичногоОбъекта", Неопределено); // Ссылка на документ ПопыткаВыполненияСтатичногоОбъектаСУЗ.
	СтруктураДанных.Вставить("ТекущийЭлементСодержания", Неопределено); // Ссылка на элемент справочника СодержаниеСУЗ или Неопределено.
	СтруктураДанных.Вставить("СледующийЭлементСодержания", Неопределено);  // Ссылка на элемент справочника СодержаниеСУЗ или Неопределено.
	СтруктураДанных.Вставить("ПредыдущийЭлементСодержания", Неопределено);  // Ссылка на элемент справочника СодержаниеСУЗ или Неопределено.
	СтруктураДанных.Вставить("Пройден", Неопределено); // Булево или Неопределено.
	СтруктураДанных.Вставить("ВозможноДобавитьВИзбранное", Неопределено);  // Булево или Неопределено.
	СтруктураДанных.Вставить("ВыполняетсяТестирование", Неопределено);  // Булево или Неопределено.
	СтруктураДанных.Вставить("СессияТестирования", Неопределено); // Ссылка на документ ПопыткаВыполненияПодборкиВопросовСУЗ.
	СтруктураДанных.Вставить("ВсеВопросыТестированияОтвечены", Неопределено); // Булево или Неопределено.
	СтруктураДанных.Вставить("АдресОбъекта", Неопределено); // Строка или Неопределено. Используется при симуляции для автоматического перехода к следующим элементам.
	
	Ресурсы = Новый Массив();
	СтруктураДанных.Вставить("Ресурсы", Ресурсы); // Массив
	
	СписокСсылок = Новый Массив();
	СтруктураДанных.Вставить("СписокСсылок", СписокСсылок); // Массив. Хранит объекты на которые есть ссылки.
	
	Возврат СтруктураДанных;
	
КонецФункции

// Получает тип объекта
//
Функция ПолучитьТипОбъектаСУЗ(Ссылка) Экспорт

	Если НЕ ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Перечисления.ТипыОбъектовСУЗ.ПустаяСсылка();
	КонецЕсли;
	
	ИмяСправочника = Ссылка.Метаданные().Имя;
	
	Возврат Справочники[ИмяСправочника].ТипОбъектаСУЗ();
	
КонецФункции

// Формирует ссылки на термины
//
Функция ЗаменитьТермин(Текст, Термин, ТолькоПервоеВхождение, ПоказыватьТерминВсплывающейПодсказкой, СтартоваяПозиция = 1, МассивОпределений, ЭтоВнешнийHTML=Ложь) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Термин.Наименование) Тогда
		Возврат Текст;
	КонецЕсли;
	
	Если Термин.СкрытьАвтоСсылки Тогда
		Возврат Текст;
	КонецЕсли;
	
	Если СтрДлина(Термин.Наименование) < 3 Тогда
		Возврат Текст;
	КонецЕсли;
	
	
	КопияТекстовогоПредставления = НРег(Текст);
	КопияТекстовогоПредставления = СтрЗаменить(КопияТекстовогоПредставления, Символы.ВК, " ");
	КопияТекстовогоПредставления = СтрЗаменить(КопияТекстовогоПредставления, Символы.ВТаб, " ");
	КопияТекстовогоПредставления = СтрЗаменить(КопияТекстовогоПредставления, Символы.НПП, " ");
	КопияТекстовогоПредставления = СтрЗаменить(КопияТекстовогоПредставления, Символы.ПС, " ");
	КопияТекстовогоПредставления = СтрЗаменить(КопияТекстовогоПредставления, Символы.ПФ, " ");
	КопияТекстовогоПредставления = СтрЗаменить(КопияТекстовогоПредставления, Символы.Таб, " ");		
	
	~ПродолжениеПоиска: 
	
	ПозицияТермина = Найти(Сред(КопияТекстовогоПредставления, СтартоваяПозиция), Термин.Наименование); 
	
	Если ПозицияТермина > 0 Тогда
		
		ПозицияТермина = ПозицияТермина + СтартоваяПозиция - 1; 
		
		СовпадениеНайдено = Истина;
		
		СимволПередТермином = Сред(КопияТекстовогоПредставления, ПозицияТермина-1, 1);
		СимволПослеТермина  = Сред(КопияТекстовогоПредставления, ПозицияТермина+СтрДлина(Термин.Наименование), 1);
		
		ПредставлениеЛеваяЧасть       = Лев(Текст, ПозицияТермина - 1);
		ПредставлениеЦентральнаяЧасть = Сред(Текст, ПозицияТермина, СтрДлина(Термин.Наименование));
		ПредставлениеПраваяЧасть      = Прав(Текст, СтрДлина(Текст)-СтрДлина(ПредставлениеЛеваяЧасть)-СтрДлина(Термин.Наименование));
		
		СсылкаЛеваяЧасть              = "";
		СсылкаПраваяЧасть             = "";		
				
		Если ОбщегоНазначенияСУ.ЭтоБуква(СимволПередТермином)
			ИЛИ ОбщегоНазначенияСУ.ЭтоБуква(СимволПослеТермина)
			ИЛИ ОбщегоНазначенияСУ.ЭтоЦифра(СимволПередТермином)
			ИЛИ ОбщегоНазначенияСУ.ЭтоЦифра(СимволПослеТермина)			
			ИЛИ СимволПередТермином = "<" // Это тег
			ИЛИ СимволПослеТермина = ">"
			ИЛИ СимволПослеТермина = "_"
			ИЛИ СимволПередТермином = "_"
			ИЛИ СимволПослеТермина = "-"
			ИЛИ СимволПередТермином = "-"
			ИЛИ СимволПередТермином = "="
			ИЛИ СимволПослеТермина = "="
			ИЛИ СимволПослеТермина = "&"
			ИЛИ СимволПередТермином = "&"
			ИЛИ СимволПослеТермина = "}"
			ИЛИ СимволПередТермином = "{"
			ИЛИ ЭтоЧастьТега(ПредставлениеЛеваяЧасть) Тогда
			
			// Это часть слова, поэтому ссылку не делаем.
			СовпадениеНайдено = Ложь;
			
		Иначе
			
			Если ЭтоВнешнийHTML Тогда				
				
				СсылкаЛеваяЧасть = "<a class=""term"" href=""javascript:oAPI_1C_V8_SUZ.goToLink('"+Термин.ТекстоваяСсылка+"')"" isTip=""true""  ";				
				
				Если ПоказыватьТерминВсплывающейПодсказкой Тогда					
					СсылкаЛеваяЧасть = СсылкаЛеваяЧасть + " title="" " + ОбщегоНазначенияСУКлиентСервер.HTMLСтрока(Термин.Определение) + " "" ";
				КонецЕсли;
				
				
			Иначе			
				
				СсылкаЛеваяЧасть  = "<a class=""term"" href="""+Термин.ТекстоваяСсылка+""" isTip=""true"" ";				
				
				Если ПоказыватьТерминВсплывающейПодсказкой Тогда					
					СсылкаЛеваяЧасть = СсылкаЛеваяЧасть + " id=""tip_"+СтрЗаменить(Строка(Термин.Термин.УникальныйИдентификатор()), "-", "")+ """";					
				КонецЕсли;
					
					
			КонецЕсли;
			
			Если ПоказыватьТерминВсплывающейПодсказкой Тогда
				
				УжеДобавленоОпределениеВМассив = Ложь;
				
				Для каждого ОпределениеВМассив Из МассивОпределений Цикл
				
					Если ОпределениеВМассив.Термин = Термин.Термин Тогда
						УжеДобавленоОпределениеВМассив = Истина;
					КонецЕсли;					
				
				КонецЦикла;
				
				Если НЕ УжеДобавленоОпределениеВМассив Тогда
					МассивОпределений.Добавить(Новый Структура("Термин, Определение", Термин.Термин, Термин.Определение));
				КонецЕсли;
				
			КонецЕсли;			
			
					
			СсылкаЛеваяЧасть = СсылкаЛеваяЧасть + ">";
			
			
			СсылкаПраваяЧасть = "</a>";
			
		КонецЕсли;
		
		Если СовпадениеНайдено Тогда
		
			Если НЕ ТолькоПервоеВхождение Тогда
				ПредставлениеПраваяЧасть = ЗаменитьТермин(ПредставлениеПраваяЧасть, Термин, Ложь, ПоказыватьТерминВсплывающейПодсказкой,, МассивОпределений, ЭтоВнешнийHTML); // Рекурсия
			КонецЕсли;
			
			Текст = ПредставлениеЛеваяЧасть + СсылкаЛеваяЧасть + ПредставлениеЦентральнаяЧасть + СсылкаПраваяЧасть + ПредставлениеПраваяЧасть; 
			
		Иначе
			
			СтартоваяПозиция = ПозицияТермина + СтрДлина(Термин.Наименование);
			
			Перейти ~ПродолжениеПоиска;
			
			//Текст = ЗаменитьТермин(Текст, Термин, ТолькоПервоеВхождение, ПоказыватьТерминВсплывающейПодсказкой, ПозицияТермина + СтрДлина(Термин.Наименование), МассивОпределений, ЭтоВнешнийHTML); // Рекурсия
			
		КонецЕсли;
		
			
	КонецЕсли;

	Возврат Текст;
	
КонецФункции

Функция ЭтоЧастьТега(ПредставлениеЛеваяЧасть)
	
	ЭтоЧастьТега = Ложь;

	НомерСимвола = СтрДлина(ПредставлениеЛеваяЧасть);

	Пока НомерСимвола > 0 Цикл

		ТекСимвол = Сред(ПредставлениеЛеваяЧасть, НомерСимвола, 1);
		
		Если ТекСимвол = ">" Тогда
			Прервать;
		КонецЕсли;
		
		Если ТекСимвол = "<" Тогда
			ЭтоЧастьТега = Истина;
			Прервать;
		КонецЕсли;
		
		НомерСимвола = НомерСимвола - 1;
		
	КонецЦикла;
	
	Возврат ЭтоЧастьТега;
	
КонецФункции

// ДАННЫЕ

// Возвращает данные объекта из регистра с данными.
//
Функция ПолучитьДанные(Знач Ссылка,
	                   Знач КодДанных=Неопределено,
					   Знач ПолучитьПоследнююВерсию=Ложь,
					   Знач ИмяРеквизита="ТекстовыеДанные",
					   Знач Поставщик=Неопределено,
					   Знач Версия=Неопределено,
					   Знач ТолькоПроверитьНаличие=Ложь) Экспорт
	
					   
	ИмяРегистраСДанными = ПолучитьИмяРегистраСДанными(Ссылка);
	
	Запрос = Новый Запрос();
	
	ТекстЗапроса = "ВЫБРАТЬ
	| ";
	
	Если ТипЗнч(ИмяРеквизита) = Тип("Массив") Тогда
		
		Если ИмяРегистраСДанными = "ДанныеФайлыСУЗ" И ИмяРеквизита.Найти("ДвоичныеДанные") <> Неопределено Тогда
			ВызватьИсключение НСтр("ru = 'Получение нескольких ресурсов для регистра ДанныеФайлыСУЗ не предусмотрено'");
		КонецЕсли;			
		
		Для каждого Реквизит Из ИмяРеквизита Цикл
			ТекстЗапроса = ТекстЗапроса + Символы.ПС + ИмяРегистраСДанными +"."+ Реквизит + ",";	
		КонецЦикла;
		
		ТекстЗапроса = Сред(ТекстЗапроса, 1, СтрДлина(ТекстЗапроса)-1); // Убираем последнюю запятую
		
	Иначе
		
		ТекстЗапроса = ТекстЗапроса + ИмяРегистраСДанными +"."+ ИмяРеквизита;
		
		Если ИмяРеквизита = "ДвоичныеДанные" Тогда
			ТекстЗапроса = ТекстЗапроса + "," + ИмяРегистраСДанными +".ПрисоединенныйФайл";
		КонецЕсли;		
		
	КонецЕсли;
	
	Если КодДанных = Неопределено Тогда
		ТекстЗапроса = ТекстЗапроса + ",
		|"+ИмяРегистраСДанными+".КодДанных";
	КонецЕсли;
	
	ТекстЗапроса = ТекстЗапроса + "
	|ИЗ
	|	РегистрСведений."+ИмяРегистраСДанными+" КАК "+ИмяРегистраСДанными+"
	|ГДЕ
	|	"+ИмяРегистраСДанными+".СсылкаНаОбъектСУЗ = &СсылкаНаОбъектСУЗ
	|	И "+ИмяРегистраСДанными+".Версия = &Версия
	|	И "+ИмяРегистраСДанными+".Поставщик = &Поставщик
	|"; 
	
	Если КодДанных <> Неопределено Тогда
		ТекстЗапроса = ТекстЗапроса + "	И "+ИмяРегистраСДанными+".КодДанных = &КодДанных";
		Запрос.УстановитьПараметр("КодДанных", КодДанных); 
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СсылкаНаОбъектСУЗ", Ссылка); 
	
	Запрос.Текст = ТекстЗапроса;
	
	// Примечание: для всех объектов, данные которых получаются при помощи данной
	// Функции каждый поставщик должен иметь полный набор всех необходимых
	// Для отображения данных.

	Если Поставщик <> Неопределено И Версия <> Неопределено Тогда
		
		// Если поставщик и версия переданы в функцию,
		// То они имеют самый высокий приоритет.
		
		Запрос.УстановитьПараметр("Поставщик", Поставщик); 
		Запрос.УстановитьПараметр("Версия", Версия); 
		
	Иначе
	
		Если ПолучитьПоследнююВерсию И Поставщик <> Неопределено Тогда
			
			// Ищем последнюю версию объекта переданного в функцию поставщика.
			ПоследняяВерсия = ПолучитьПоследнююВерсию(Ссылка, Поставщик);
			
			Запрос.УстановитьПараметр("Поставщик", ПоследняяВерсия.Поставщик); 
			Запрос.УстановитьПараметр("Версия", ПоследняяВерсия.Версия); 
			
		Иначе
			
			// Загружаем данные от поставщика, который указан в самом объекте СУЗ.
			Запрос.УстановитьПараметр("Поставщик", Ссылка.Поставщик); 
			Запрос.УстановитьПараметр("Версия", Ссылка.Версия); 
			
		КонецЕсли;
		
	КонецЕсли;
		
	Результат = Запрос.Выполнить().Выбрать();
	
	Если ТолькоПроверитьНаличие Тогда
		
		Возврат ?(Результат.Количество() > 0, Истина, Ложь);
		
	Иначе
	
		Если КодДанных <> Неопределено Тогда
			
			РезультатНайден = Результат.Следующий(); // Всегда один только результат, так как отбор по всем измерениям.
			
			Если ТипЗнч(ИмяРеквизита) = Тип("Массив") Тогда
				
				Возврат Результат;
				
			Иначе
				
				Если ИмяРеквизита = "ДвоичныеДанные" Тогда
					
					Если ИмяРегистраСДанными <> "ДанныеФайлыСУЗ" Тогда
						ВызватьИсключение НСтр("ru = 'Данный регистр не содержит двоичные данные'");
					КонецЕсли;
					
					Если НЕ РезультатНайден Тогда
						ВызватьИсключение НСтр("ru = 'Двоичные данные не найдены'");
					КонецЕсли;
					
					Если ЗначениеЗаполнено(Результат.ПрисоединенныйФайл) Тогда
						Возврат ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(Результат.ПрисоединенныйФайл);
					Иначе
						Возврат Результат[ИмяРеквизита].Получить();
					КонецЕсли;												
					
				ИначеЕсли ИмяРеквизита = "ФорматированныйДокумент" Тогда
					
					Если РезультатНайден Тогда
						Возврат Результат[ИмяРеквизита].Получить();
					Иначе
						Возврат Неопределено;
					КонецЕсли;					
					
				Иначе
					
					Если РезультатНайден Тогда
						Возврат Результат[ИмяРеквизита];
					Иначе
						Возврат "";
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		Иначе
			
			Возврат Результат;
			
		КонецЕсли;
		
	КонецЕсли;
		
КонецФункции

// Позволяет получить последний номер версии объекта и поставщика этой версии.
//
// Параметры:
//  ПоставщикСводаЗнаний - ссылка на элемент справочника "ПоставщикиСУЗ".
//  ПредпочитаемыйПоставщик - ссылка на элемент справочника "ПоставщикиСУЗ"
//
// Возвращаемое значение:
//  Структура со значениями "Версия" и "Поставщик".
//
Функция ПолучитьПоследнююВерсию(Знач Ссылка, Знач ПредпочитаемыйПоставщик=Неопределено) Экспорт
	
	ИмяРегистраСДанными = ПолучитьИмяРегистраСДанными(Ссылка);
	
	// Загружаем последние версии объекта от всех поставщиков
	
	ТекстЗапроса = "ВЫБРАТЬ
	|	ДанныеСУЗ.Версия КАК Версия,
	|	ДанныеСУЗ.Поставщик КАК Поставщик
	|ИЗ
	|	РегистрСведений."+ИмяРегистраСДанными+" КАК ДанныеСУЗ
	|ГДЕ
	|	ДанныеСУЗ.КодДанных = &КодДанных
	|	И ДанныеСУЗ.СсылкаНаОбъектСУЗ = &СсылкаНаОбъектСУЗ
	|ИТОГИ
	|	МАКСИМУМ(Версия)
	|ПО
	|	Поставщик";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	
	Запрос.УстановитьПараметр("КодДанных", "Описание");
	Запрос.УстановитьПараметр("СсылкаНаОбъектСУЗ", Ссылка);
	
	// Получаем дерево. На первом уровне находятся записи с максимальным
	// Номером версии для каждого поставщика.
	Результат = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	ПоследняяВерсия = -1; // Пока не найдена версия.
	ПоставщикПоследнейВерсии = Неопределено;
	
	// 0. Первый приоритет имеет поставщик переданный непосредственно в функцию
	// Через параметр ПредпочитаемыйПоставщик.
	
	// Примечание: для проверки на заполненность переменной ПредпочитатьПоставщика
	// Нельзя использовать функцию ЗначениеЗаполнено, так как ПустаяСсылка на поставщика
	// Так же может быть "поставщиком". Аналогично ниже.
	Если ПредпочитаемыйПоставщик <> Неопределено Тогда
		
		ВерсияПоставщика = Результат.Строки.Найти(ПредпочитаемыйПоставщик, "Поставщик");
		
		Если ВерсияПоставщика <> Неопределено Тогда
			ПоследняяВерсия          = ВерсияПоставщика.Версия;
			ПоставщикПоследнейВерсии = ВерсияПоставщика.Поставщик;
		КонецЕсли;
		
	КонецЕсли;
	
	// 1. Затем ищем версию от поставщика установленного в настройках базы.
	// Но только, если стоит в настройках ПоказыватьПоследнююВерсию = Истина.
	
	Если ПоследняяВерсия = -1 Тогда
	
		ПоказыватьПоследнююВерсию = Константы.ПоказыватьПоследнююВерсиюСУЗ.Получить();
		
		Если ПоказыватьПоследнююВерсию Тогда
			
			ПредпочитаемыйПоставщик = Константы.ПредпочитатьПоставщикаСУЗ.Получить();
			
			ВерсияПоставщика = Результат.Строки.Найти(ПредпочитаемыйПоставщик, "Поставщик");
			
			Если ВерсияПоставщика <> Неопределено Тогда
				ПоследняяВерсия          = ВерсияПоставщика.Версия;
				ПоставщикПоследнейВерсии = ВерсияПоставщика.Поставщик;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// 2. Если нет ни одной версии, то возвращаем поставщика и номер версии
	// Последней сохраненной версии. Она есть всегда.
	
	Если ПоследняяВерсия = -1 Тогда // Еще не найдена версия
		ПоследняяВерсия          = Ссылка.Версия;
		ПоставщикПоследнейВерсии = Ссылка.Поставщик;
	КонецЕсли;
	
	СтруктураВерсии = Новый Структура();
	СтруктураВерсии.Вставить("Версия", ПоследняяВерсия);
	СтруктураВерсии.Вставить("Поставщик", ПоставщикПоследнейВерсии);
	
	Возврат СтруктураВерсии;
	
КонецФункции

// Возвращает имя регистра, где хранятся данные объекта СУЗ.
//
Функция ПолучитьИмяРегистраСДанными(Ссылка) Экспорт
	
	ИмяСправочника = Ссылка.Метаданные().Имя;
	ИмяСправочника = СтрЗаменить(ИмяСправочника, "Справочник.", "");

	Возврат "Данные" + ИмяСправочника;
	
КонецФункции

// Позволяет получить набор записей о версиях объекта СУЗ из регистра сведений, где
// хранятся его данные. Каждая запись регистра данных объекта, имеющая значение
// реквизита КодДанных - "Описание" говорит, что существует версия объекта с параметрами
// поставщик-версия как у этой записи.
//
Функция ПолучитьНаборВерсий(Ссылка, ИмяРегистраСДанными = Неопределено) Экспорт
	
	Если ИмяРегистраСДанными = Неопределено Тогда
		ИмяРегистраСДанными = ПолучитьИмяРегистраСДанными(Ссылка);
	КонецЕсли;
	
	НаборВерсий = РегистрыСведений[ИмяРегистраСДанными].СоздатьНаборЗаписей();
	НаборВерсий.Отбор.СсылкаНаОбъектСУЗ.Установить(Ссылка);
	НаборВерсий.Отбор.КодДанных.Установить("Описание");
	НаборВерсий.Прочитать();
	
	Возврат НаборВерсий;
	
КонецФункции

// Проверяет существует ли версии объекта, от поставщика, отличного
// от того, который передан в функцию.
//
Функция СуществуютВерсииДругихПоставщиков(Ссылка, Поставщик, ИмяРегистраСДанными = Неопределено) Экспорт
	
	Если ИмяРегистраСДанными = Неопределено Тогда
		ИмяРегистраСДанными = ПолучитьИмяРегистраСДанными(Ссылка);
	КонецЕсли;
	
	ИмяРеквизита = "Версия";
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	"+ИмяРегистраСДанными+"."+ИмяРеквизита+"
	|ИЗ
	|	РегистрСведений."+ИмяРегистраСДанными+" КАК "+ИмяРегистраСДанными+"
	|ГДЕ
	|	"+ИмяРегистраСДанными+".СсылкаНаОбъектСУЗ = &СсылкаНаОбъектСУЗ
	|	И "+ИмяРегистраСДанными+".КодДанных = &КодДанных
	|	И "+ИмяРегистраСДанными+".Поставщик <> &Поставщик"); 
	
	Запрос.УстановитьПараметр("СсылкаНаОбъектСУЗ", Ссылка); 
	Запрос.УстановитьПараметр("КодДанных", "Описание"); 
	Запрос.УстановитьПараметр("Поставщик", Поставщик); 
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

// Извлекает текст из данных объекта
//
Функция ПолучитьТекстовоеПредставлениеДанных(Знач Данные) Экспорт
	
	Если ТипЗнч(Данные) = Тип("ХранилищеЗначения") Тогда
		Данные = Данные.Получить();
	КонецЕсли;
	
	Если ТипЗнч(Данные) = Тип("Строка") Тогда
		
		ФорматированныйДокумент = Новый ФорматированныйДокумент;
		ФорматированныйДокумент.УстановитьHTML(Данные, Новый Структура());
		
	ИначеЕсли ТипЗнч(Данные) = Тип("ФорматированныйДокумент") Тогда
		
		ФорматированныйДокумент = Данные;
		
	Иначе
		
		Возврат "";
		
	КонецЕсли;
	
	Возврат ФорматированныйДокумент.ПолучитьТекст();
	
КонецФункции

// Получает пользовательскую настройку
//
Функция ПолучитьПользовательскуюНастройкуОбъекта(ИмяНастройки, Настройки, ЭлементСодержания) Экспорт
	
	Если Настройки = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Настройки.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если НЕ Настройки.Свойство(ИмяНастройки) Тогда
		Возврат Неопределено;
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ЭлементСодержания)
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлементСодержания, "ОтменятьПользовательскиеНастройки") Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	Возврат Настройки[ИмяНастройки];
	
КонецФункции

// Находит документ ПопыткаВыполненияПодборкиВопросовСУЗ по его номеру
//
Функция ДокументСессииТестирования(НомерДокумента, КонтекстВыполнения, ПолучатьОбъект = Истина) Экспорт
	
	Если НомерДокумента = -1 Тогда
		
		Возврат КонтекстВыполнения.ПараметрыЭкспорта.ДокументСессииОбъект;
		
	Иначе
		
		ДокументСессииТестированияСсылка = Документы.ПопыткаВыполненияПодборкиВопросовСУЗ.НайтиПоНомеру(НомерДокумента);
		
		Если ПолучатьОбъект Тогда
			
			БлокировкаДанных = Новый БлокировкаДанных;
			ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Документ.ПопыткаВыполненияПодборкиВопросовСУЗ");
			ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ДокументСессииТестированияСсылка);
			ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
			БлокировкаДанных.Заблокировать();
			
			Возврат ДокументСессииТестированияСсылка.ПолучитьОбъект();
			
		Иначе
			
			Возврат ДокументСессииТестированияСсылка;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции

// Возвращает пользователя, который проходит объект
//
Функция ТекущийПользователь(КонтекстВыполнения = Неопределено) Экспорт

	Если КонтекстВыполнения = Неопределено
		ИЛИ НЕ ЗначениеЗаполнено(КонтекстВыполнения.ТекущийПользователь) Тогда
		
		Возврат Пользователи.ТекущийПользователь();
		
	Иначе
		
		Возврат КонтекстВыполнения.ТекущийПользователь;
		
	КонецЕсли;
	
КонецФункции

Функция ЗаданиеПопытки(ПрохождениеОбучения, ЭлектронныйРесурс, Задание) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ПрохождениеОбучения) Тогда
		Возврат неопределено;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Задание) Тогда
		Возврат Задание;
	КонецЕсли;
	
	Возврат ЭлектронныйРесурс;
	
КонецФункции

// ДЕЙСТВИЯ

// Выполняет действие переданное в параметре ссылки "action".
// 
//
Функция ВыполнитьДействие(ПараметрыСсылки, КонтекстВыполнения) Экспорт
	
	НачатьТранзакцию();
	
	Попытка
		
		УстановитьПривилегированныйРежим(Истина);
		
		// 1. Определяем основные переменные
		
		ЭлементСодержания        = КонтекстВыполнения.ЭлементСодержания;
		ПрохождениеОбучения   = КонтекстВыполнения.ПрохождениеОбучения;
		Задание                  = КонтекстВыполнения.Задание;
		Вариант                  = КонтекстВыполнения.Вариант;
		СводЗнаний               = КонтекстВыполнения.ЭлектронныйРесурс;	
		Симуляция                = КонтекстВыполнения.Симуляция;
		ПараметрыЭкспорта        = КонтекстВыполнения.ПараметрыЭкспорта;
		ДействиеСсылки           = ПараметрыСсылки.action;
		РезультатДействия        = ПолучитьПустуюСтруктуруДействия();
		ПоставщикСводаЗнаний     = Справочники.СводыЗнанийСУЗ.Поставщик(СводЗнаний);
		ИдентификаторСводаЗнаний = Справочники.СводыЗнанийСУЗ.ИдентификаторКаталога(ЭлементСодержания);
		
		// 2. Выполняем действие
		
		////////////////////////////////////////////////////////////////////////////////
		// openObjectLink (Открывает ссылку из справочника СсылкиОбъектовСУЗ)
		
		Если ДействиеСсылки = "openObjectLink" Тогда
			
			id = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "id");
			УникальныйИдентификатор = Новый УникальныйИдентификатор(id);
			
			Попытка
				ЭлементСправочникаСсылки = Справочники.СсылкиОбъектовСУЗ.ПолучитьСсылку(УникальныйИдентификатор);
			Исключение
				ЭлементСправочникаСсылки = Справочники.СсылкиОбъектовСУЗ.ПустаяСсылка();
			КонецПопытки;
			
			Если ТипЗнч(ЭлементСправочникаСсылки.СсылкаНаОбъектСУЗ) = Тип("СправочникСсылка.ФайлыСУЗ")
				И ЭлементСправочникаСсылки.СсылкаНаОбъектСУЗ.ОткрыватьВнешнимПриложением Тогда
				
				Файл  = ЭлементСправочникаСсылки.СсылкаНаОбъектСУЗ; 
				Якорь = ЭлементСправочникаСсылки.Якорь;
				
				МассивРесурсов = Новый Массив();
				ВладелецФайла = Файл.Владелец;
				ДобавитьРесурсВМассивРесурсов(ВладелецФайла, МассивРесурсов);
				
				РезультатДействия.Ресурсы = МассивРесурсов;
				
				// Определяем путь к файлу
				
				ОтносительныйПутьКФайлу = Справочники.ФайлыСУЗ.ПолучитьОтносительныйПутьКФайлу(Файл);
				
				СсылкаНаФайл = Справочники.РесурсыСУЗ.АдресКаталогаРесурсов(ИдентификаторСводаЗнаний) + ОтносительныйПутьКФайлу;
				СсылкаНаФайл = ОбщегоНазначенияСУКлиентСервер.ПривестиСлэши(СсылкаНаФайл);
				
				Если НЕ ПустаяСтрока(Якорь) Тогда
					СсылкаНаФайл = СсылкаНаФайл + "#" + Якорь;
				КонецЕсли;
				
				РезультатДействия.АдресФайла = СсылкаНаФайл;
				
			Иначе
				
				Если ЗначениеЗаполнено(ЭлементСправочникаСсылки) Тогда
					
					Если ЗначениеЗаполнено(ЭлементСправочникаСсылки.СсылкаНаОбъектСУЗ) Тогда
						РезультатДействия.АдресОбъекта = Справочники.СсылкиОбъектовСУЗ.АдресЦели(ЭлементСправочникаСсылки);
					Иначе
						РезультатДействия.ВнешняяСсылка = Справочники.СсылкиОбъектовСУЗ.АдресЦели(ЭлементСправочникаСсылки);
					КонецЕсли;
					
				Иначе
					
					РезультатДействия.ТекстСообщения = НСтр("ru = 'Объект не найден'");
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		////////////////////////////////////////////////////////////////////////////////
		// openfile (открытие файла)
		
		Если ДействиеСсылки = "openfile" Тогда
			
			ИмяОбъектаСУЗ = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "object");
			id            = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "id");
			Якорь         = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "anchor");
			
			Файл = ПолучитьСсылкуПоИдентификатору(ИмяОбъектаСУЗ, id);
			
			СвойстваФайла = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Файл, "ТипФайла, Владелец, ОткрыватьОбработкуМодально, ОткрыватьОбработкуБезопасно");
			
			Если СвойстваФайла.ТипФайла = Перечисления.ТипыФайловСУЗ.DataProcessor Тогда
				
				// Создаем внешнюю обработку
				
				ДвоичныеДанные            = ОбъектыСУЗ.ПолучитьДанные(Файл, "ДвоичныеДанные", Истина, "ДвоичныеДанные", ПоставщикСводаЗнаний);
				АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
				ИмяВнешнейОбработки       = ВнешниеОбработки.Подключить(АдресВоВременномХранилище,, СвойстваФайла.ОткрыватьОбработкуБезопасно);
				ДанныеВнешнейОбработки    = Новый Структура("Имя, ОткрыватьОбработкуМодально", ИмяВнешнейОбработки, СвойстваФайла.ОткрыватьОбработкуМодально);
				
				РезультатДействия.ВнешняяОбработка = ДанныеВнешнейОбработки;
				
			Иначе
				
				СвойстваРесурса = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СвойстваФайла.Владелец, "ИдентичныйРесурс");
				
				МассивРесурсов = Новый Массив();
				
				ДобавитьРесурсВМассивРесурсов(СвойстваФайла.Владелец, МассивРесурсов);
				
				РезультатДействия.Ресурсы = МассивРесурсов;
				
				// Определяем путь к файлу
				
				ОтносительныйПутьКФайлу = Справочники.ФайлыСУЗ.ПолучитьОтносительныйПутьКФайлу(Файл);
				
				СсылкаНаФайл = Справочники.РесурсыСУЗ.АдресКаталогаРесурсов(ИдентификаторСводаЗнаний) + ОтносительныйПутьКФайлу;
				СсылкаНаФайл = ОбщегоНазначенияСУКлиентСервер.ПривестиСлэши(СсылкаНаФайл);
				
				Если НЕ ПустаяСтрока(Якорь) Тогда
					СсылкаНаФайл = СсылкаНаФайл + "#" + Якорь;
				КонецЕсли;
				
				РезультатДействия.АдресФайла = СсылкаНаФайл;
				
			КонецЕсли;
			
		КонецЕсли;
		
		
		////////////////////////////////////////////////////////////////////////////////
		// openKnowledgeBaseElementLink (Открывает ссылку из справочника СодержаниеСУЗ)
		
		Если ДействиеСсылки = "openKnowledgeBaseElementLink" Тогда
			
			id = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "id");
			УникальныйИдентификатор = Новый УникальныйИдентификатор(id);
			
			Попытка
				ЭлементСодержания = Справочники.СодержаниеСУЗ.ПолучитьСсылку(УникальныйИдентификатор);
			Исключение
				ЭлементСодержания = Справочники.СодержаниеСУЗ.ПустаяСсылка();
			КонецПопытки;
			
			Если ЗначениеЗаполнено(ЭлементСодержания) Тогда
				РезультатДействия.АдресОбъекта = ОбъектыСУЗПовтИсп.СсылкаНаОбъектСУЗ(ЭлементСодержания);
			Иначе
				РезультатДействия.ТекстСообщения = НСтр("ru = 'Объект не найден'");
			КонецЕсли;
			
		КонецЕсли;
		
		////////////////////////////////////////////////////////////////////////////////
		// openTip (Открывает подсказку)
		
		Если ДействиеСсылки = "openTip" Тогда
			
			id = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "id");
			УникальныйИдентификатор = Новый УникальныйИдентификатор(id);
			
			Попытка
				ЭлементСправочникаСсылки = Справочники.РесурсыОбъектовСУЗ.ПолучитьСсылку(УникальныйИдентификатор);
			Исключение
				ЭлементСправочникаСсылки = Справочники.СсылкиОбъектовСУЗ.ПустаяСсылка();
			КонецПопытки;
			
			РезультатДействия.ТекстСообщения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлементСправочникаСсылки, "Текст");
			
		КонецЕсли;
		
		////////////////////////////////////////////////////////////////////////////////
		// newDocument (Открывается новая попытка выполнения подборки вопросов.
		// Документ ПопыткаВыполненияПодборкиВопросовСУЗ.
		
		Если ДействиеСсылки = "newDocument" Тогда
			
			ИмяОбъектаСУЗ = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "object");
			id            = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "id");
			
			Подборка = ПолучитьСсылкуПоИдентификатору(ИмяОбъектаСУЗ, id);
			
			// Создаем новый документ "ПопыткаВыполненияПодборкиВопросовСУЗ".
			
			ДокументСессии = Документы.ПопыткаВыполненияПодборкиВопросовСУЗ.СоздатьДокумент();
			
			ДокументСессии.Дата                      = ТекущаяДата();
			ДокументСессии.ДатаНачалаВыполненияТеста = ТекущаяДата();
			
			ДокументСессии.ПрохождениеОбучения    = ПрохождениеОбучения;
			ДокументСессии.Задание                   = Задание;
			ДокументСессии.Вариант                   = Вариант;
			
			Если ЗначениеЗаполнено(ЭлементСодержания) Тогда
				ДокументСессии.СводЗнаний                   = ЭлементСодержания.Владелец;
				ДокументСессии.ЭлементСодержанияСводаЗнаний = ЭлементСодержания;
			КонецЕсли;
			
			ДокументСессии.Подборка                     = Подборка;
			ДокументСессии.НазначениеТестирования       = Подборка.НазначениеТестирования;
			ДокументСессии.Пользователь                 = ОбъектыСУЗ.ТекущийПользователь(КонтекстВыполнения);
			
			ИдентификаторСложности = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "level");
			
			Если ЗначениеЗаполнено(ИдентификаторСложности)
				И ИдентификаторСложности <> "default" Тогда
				
				ИдентификаторСложности = Новый УникальныйИдентификатор(ИдентификаторСложности);
				ДокументСессии.Сложность = Справочники.СложностиТестовСУЗ.ПолучитьСсылку(ИдентификаторСложности);
				
			КонецЕсли;
			
			ИсточникНастроек = Новый Структура;
			
			Если ЗначениеЗаполнено(Вариант) Тогда
				НастройкаЗадания = Вариант;	
			Иначе
				НастройкаЗадания = Задание;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ПрохождениеОбучения)
				И ЗначениеЗаполнено(ПрохождениеОбучения) 
				И ЗначениеЗаполнено(Задание)
				И ТипЗнч(НастройкаЗадания) <> Тип("СправочникСсылка.СводыЗнанийСУЗ")
				И НЕ НастройкаЗадания.ИспользоватьСтандартныеНастройкиТеста Тогда
				
				Если ЗначениеЗаполнено(ДокументСессии.Сложность) Тогда
					
					ИсточникНастроек.Вставить("ВремяТеста", ДокументСессии.Сложность.ВремяТеста);
					ИсточникНастроек.Вставить("КоличествоГруппЭлементов", ДокументСессии.Сложность.КоличествоГруппЭлементов);
					
				Иначе
					
					ИсточникНастроек.Вставить("ВремяТеста", ОбъектыSCORM.ПолучитьДатуИзКоличестваСекунд(НастройкаЗадания.ПродолжительностьВСекундах));
					ИсточникНастроек.Вставить("КоличествоГруппЭлементов", НастройкаЗадания.КоличествоСтраницВопросов);
					
				КонецЕсли;
				
				ИсточникНастроек.Вставить("ПереходитьВпередАвтоматически", НастройкаЗадания.ПереходитьВпередАвтоматически);
				ИсточникНастроек.Вставить("ПоказыватьНавигацию", НастройкаЗадания.ПоказыватьНавигацию);
				ИсточникНастроек.Вставить("ПеремешиватьГруппыЭлементов", НастройкаЗадания.ПеремешиватьСтраницыВопросов);
				
			Иначе
				
				Если ЗначениеЗаполнено(ДокументСессии.Сложность) Тогда
					
					ИсточникНастроек.Вставить("ВремяТеста", ДокументСессии.Сложность.ВремяТеста);
					ИсточникНастроек.Вставить("КоличествоГруппЭлементов", ДокументСессии.Сложность.КоличествоГруппЭлементов);
					
				Иначе
					
					ИсточникНастроек.Вставить("ВремяТеста", Подборка.ВремяТеста);
					ИсточникНастроек.Вставить("КоличествоГруппЭлементов", Подборка.КоличествоГруппЭлементов);
					
				КонецЕсли;
				
				ИсточникНастроек.Вставить("ПереходитьВпередАвтоматически", Подборка.ПереходитьВпередАвтоматически);
				ИсточникНастроек.Вставить("ПоказыватьНавигацию", Подборка.ПоказыватьНавигацию);
				ИсточникНастроек.Вставить("ПеремешиватьГруппыЭлементов", Подборка.ПеремешиватьГруппыЭлементов);
				
			КонецЕсли;
			
			Если ПараметрыЭкспорта <> Неопределено Тогда
				
				ИсточникНастроек.Вставить("КоличествоГруппЭлементов", 0);
				ИсточникНастроек.Вставить("ПереходитьВпередАвтоматически", Ложь);
				ИсточникНастроек.Вставить("ПоказыватьНавигацию", Истина);
				ИсточникНастроек.Вставить("КоличествоГруппЭлементов", 0);
				ИсточникНастроек.Вставить("ПеремешиватьГруппыЭлементов", Ложь);
				
			КонецЕСли;
			
			// Данные реквизиты копируются в документ, так как влияют на прохождение.
			// Если в справочнике "ПодборкиСУЗ" они будут изменены в дальнейшем, то 
			// В документе останутся такими, как были на момент начала прохождения теста.
			ДокументСессии.ВремяТеста                    = ИсточникНастроек.ВремяТеста; 
			ДокументСессии.ПереходитьВпередАвтоматически = ИсточникНастроек.ПереходитьВпередАвтоматически;
			ДокументСессии.ПоказыватьНавигацию           = ИсточникНастроек.ПоказыватьНавигацию;
			
			// Примечание: Реквизит ПеремешиватьГруппыЭлементов переносить не нужно,
			// Так как группы перемешиваются один раз при создании документа.
			
			// Реквизит КоличествоГруппЭлементов вычисляется в дальнейшем по
			// Количеству записей в табличной части "ГруппыПодборки".
			
			Если Подборка.ВыбиратьЭлементыИзРубрикатора Тогда // Тест из рубрикатора
				
				ВопросыИзРубрикатора = Справочники.ПодборкиСУЗ.ВопросыИзРубрикатора(Подборка, Подборка.УчитыватьПредыдущиеПопытки, ИсточникНастроек.КоличествоГруппЭлементов, ПараметрыЭкспорта, КонтекстВыполнения);
				// Колонки таблицы: Ссылка, ВесВопроса, ТипВопроса
				
				// Удаляем повторяющиеся вопросы
				
				Сч = ВопросыИзРубрикатора.Количество();
				
				Пока Сч > 0 Цикл
					
					Строка = ВопросыИзРубрикатора.Получить(Сч - 1);
					
					Отбор = Новый Структура();
					Отбор.Вставить("Ссылка", Строка.Ссылка);
					
					ПовторяющиесяСтроки = ВопросыИзРубрикатора.НайтиСтроки(Отбор);
					
					Если ПовторяющиесяСтроки.Количество() > 1 Тогда
						ВопросыИзРубрикатора.Удалить(Сч - 1);
					КонецЕсли;
					
					Сч = Сч - 1;
					
				КонецЦикла;	
				
				// Определяем количество групп элементов подборки (страниц)
				// В дальнейшем будут выбрано только нужное количество групп
				// Элементов в соответствии с настройками теста.
				
				ИндексМассив = Новый Массив();
				ИндексМассив = ОбщегоНазначенияСУ.ИндексМассив(0, ВопросыИзРубрикатора.Количество(), ИсточникНастроек.ПеремешиватьГруппыЭлементов);
				
				Если ИсточникНастроек.КоличествоГруппЭлементов > 0
					И ИсточникНастроек.КоличествоГруппЭлементов < ВопросыИзРубрикатора.Количество() Тогда
					КоличествоВопросов = ИсточникНастроек.КоличествоГруппЭлементов;
				Иначе
					КоличествоВопросов = ИндексМассив.Количество();
				КонецЕсли;
				
				// Заполняем табличные части ГруппыПодборки и Вопросы документа ДокументСессии
				
				Для Н=0 По КоличествоВопросов-1 Цикл
					
					тСтрока        = ВопросыИзРубрикатора[ИндексМассив[Н]];
					СсылкаНаВопрос = тСтрока.Ссылка;
					
					// Примечание: в случае выбора вопросов из рубрикатора
					// В табличной части ГруппыПодборки содержатся ссылки на вопросы.
					
					НоваяДоступнаяГруппа = ДокументСессии.ГруппыПодборки.Добавить();
					НоваяДоступнаяГруппа.ГруппаПодборки = СсылкаНаВопрос;
					
					// Табличная часть Вопросы
					
					ВопросВДокументе = ДокументСессии.Вопросы.Добавить();
					ВопросВДокументе.ГруппаПодборки = СсылкаНаВопрос;
					ВопросВДокументе.Вопрос = СсылкаНаВопрос;
					ВопросВДокументе.ВесВопроса = тСтрока.ВесВопроса;
					ВопросВДокументе.ЭлементПодборкиИзРубрикатора = тСтрока.ЭлементПодборки;
					ВопросВДокументе.ПсихологическийВопрос = ?(СсылкаНаВопрос.ТипВопроса = Перечисления.ТипыВопросовСУЗ.ОдинИзМногихПсихологический
					ИЛИ СсылкаНаВопрос.ТипВопроса = Перечисления.ТипыВопросовСУЗ.МногиеИзМногихПсихологический, Истина, Ложь);
					
					
				КонецЦикла;
				
			Иначе // Статичный тест
				
				// Заполняем табличную часть "ГруппыПодборки".
				
				// Сначала получаем таблицу ГруппыПодборки,
				// На основе которой заполняем табличную часть ГруппыПодборки документа ДокументСессии.
				
				ГруппыПодборки = Справочники.ПодборкиСУЗ.ПолучитьГруппыЭлементовПодборки(Подборка, Подборка.УчитыватьПредыдущиеПопытки, ИсточникНастроек.КоличествоГруппЭлементов, КонтекстВыполнения);
				// Колонки таблицы: Ссылка, ЭтоГруппа, СсылкаНаОбъектСУЗ
				
				// Удаляем повторяющиеся вопросы для тех групп, которые связаны непосредственно с вопросом.
				
				Сч = ГруппыПодборки.Количество();
				
				Пока Сч > 0 Цикл
					
					Строка = ГруппыПодборки.Получить(Сч - 1);
					
					Отбор = Новый Структура();
					Отбор.Вставить("СсылкаНаОбъектСУЗ", Строка.СсылкаНаОбъектСУЗ);
					Отбор.Вставить("ЭтоГруппа", Ложь);
					
					ПовторяющиесяСтроки = ГруппыПодборки.НайтиСтроки(Отбор);
					
					Если ПовторяющиесяСтроки.Количество() > 1 Тогда
						ГруппыПодборки.Удалить(Сч - 1);
					КонецЕсли;
					
					Сч = Сч - 1;
					
				КонецЦикла;	
				
				// Определяем количество групп элементов подборки (страниц)
				// В дальнейшем будут выбрано только нужное количество групп
				// Элементов в соответствии с настройками теста.
				
				ИндексМассив = Новый Массив();
				ИндексМассив = ОбщегоНазначенияСУ.ИндексМассив(0, ГруппыПодборки.Количество(), ИсточникНастроек.ПеремешиватьГруппыЭлементов);
				
				Если ИсточникНастроек.КоличествоГруппЭлементов > 0
					И ИсточникНастроек.КоличествоГруппЭлементов < ГруппыПодборки.Количество() Тогда
					КоличествоГрупп = ИсточникНастроек.КоличествоГруппЭлементов;
				Иначе
					КоличествоГрупп = ИндексМассив.Количество();
				КонецЕсли;
				
				// Заполняем табличные части ГруппыПодборки и Вопросы документа ДокументСессии
				
				// Выбираем группы подборки первого уровня. Сохраняем их в табличной части ГруппыПодборки.
				// Затем из каждой группы будут выбраны вопросы, которые будут сохранены в табличной части Вопросы.
				
				Для Н=0 По КоличествоГрупп-1 Цикл
					НоваяДоступнаяГруппа = ДокументСессии.ГруппыПодборки.Добавить();
					НоваяДоступнаяГруппа.ГруппаПодборки = ГруппыПодборки.Получить(ИндексМассив[Н]).Ссылка;
				КонецЦикла;
				
				Если КоличествоГрупп <= ГруппыПодборки.Количество() Тогда
					ТаблицаДоступныхГрупп = ДокументСессии.ГруппыПодборки.Выгрузить();
				Иначе
					ТаблицаДоступныхГрупп = Неопределено;
				КонецЕсли;
				
				// Выбираем элементы подборки с вопросами теста, с учетом того,
				// Что вопросы должны быть из групп, выбранных перед этим.
				
				ЗапросВопросовПодборки = Новый Запрос();
				
				ЗапросВопросовПодборки.Текст = "ВЫБРАТЬ
				|	ЭлементыПодборкиСУЗ.Ссылка,
				|	ЭлементыПодборкиСУЗ.СсылкаНаОбъектСУЗ,
				|	ЭлементыПодборкиСУЗ.Родитель КАК Родитель,
				|	ЭлементыПодборкиСУЗ.Родитель.КоличествоВопросов КАК КоличествоВопросов,
				|	ЭлементыПодборкиСУЗ.Родитель.Родитель КАК РодительРодителя,
				|	ЭлементыПодборкиСУЗ.ВесВопроса,
				|	ВЫРАЗИТЬ(ЭлементыПодборкиСУЗ.СсылкаНаОбъектСУЗ КАК Справочник.ВопросыСУЗ).ТипВопроса КАК ТипВопроса
				|ИЗ
				|	Справочник.ЭлементыПодборкиСУЗ КАК ЭлементыПодборкиСУЗ
				|ГДЕ
				|	ЭлементыПодборкиСУЗ.Владелец = &Подборка
				|	И ЭлементыПодборкиСУЗ.ПометкаУдаления = ЛОЖЬ
				|	И ТИПЗНАЧЕНИЯ(ЭлементыПодборкиСУЗ.СсылкаНаОбъектСУЗ) = ТИП(Справочник.ВопросыСУЗ)";
				
				
				ЗапросВопросовПодборки.УстановитьПараметр("Подборка", Подборка); 
				
				ВсеВопросыПодборки = ЗапросВопросовПодборки.Выполнить().Выгрузить(); // Получаем все элементы подборки с вопросами
				
				// Удаляем вопросы, которые не попали в тест, то есть элемент подборки
				// Не входит в ТаблицаДоступныхГрупп и он не является родителем для элемента
				
				Сч = ВсеВопросыПодборки.Количество();
				
				Пока Сч > 0 Цикл
					
					Строка = ВсеВопросыПодборки.Получить(Сч - 1);
					
					ЭлементВходитВТест = Ложь;
					
					Если ТаблицаДоступныхГрупп.Найти(Строка.Ссылка, "ГруппаПодборки") <> Неопределено
						ИЛИ ТаблицаДоступныхГрупп.Найти(Строка.Родитель, "ГруппаПодборки") <> Неопределено
						ИЛИ ТаблицаДоступныхГрупп.Найти(Строка.РодительРодителя, "ГруппаПодборки") <> Неопределено Тогда
						
						ЭлементВходитВТест = Истина;
						
					КонецЕсли;
					
					Если НЕ ЭлементВходитВТест Тогда 
						ВсеВопросыПодборки.Удалить(Сч - 1);
					КонецЕсли;
					
					Сч = Сч - 1;
					
				КонецЦикла;	
				
				// Удаляем повторяющиеся вопросы.
				
				Сч = ВсеВопросыПодборки.Количество();
				
				Пока Сч > 0 Цикл
					
					Строка = ВсеВопросыПодборки.Получить(Сч - 1);
					
					Отбор = Новый Структура();
					Отбор.Вставить("СсылкаНаОбъектСУЗ", Строка.СсылкаНаОбъектСУЗ);
					
					ПовторяющиесяСтроки = ВсеВопросыПодборки.НайтиСтроки(Отбор);
					
					Если ПовторяющиесяСтроки.Количество() > 1 Тогда
						ВсеВопросыПодборки.Удалить(Сч - 1);
					КонецЕсли;
					
					Сч = Сч - 1;
					
				КонецЦикла;	
				
				// Удаляем открытые вопросы, если надо
				
				Если Подборка.ИсключитьОткрытыеВопросы Тогда
					
					Сч = ВсеВопросыПодборки.Количество();
					
					Пока Сч > 0 Цикл
						
						Строка = ВсеВопросыПодборки.Получить(Сч - 1);
						
						Если Строка.ТипВопроса = Перечисления.ТипыВопросовСУЗ.Открытый Тогда
							ВсеВопросыПодборки.Удалить(Сч - 1);
						КонецЕсли;
						
						Сч = Сч - 1;
						
					КонецЦикла;	
					
				КонецЕсли;
				
				// Удаляем группы без вопросов.
				// Такое может случиться, если были два одинаковых вопроса
				// В разных группах и при свертке один был удален, а группа осталась.
				
				// ВНИМАНИЕ! В этом случае тест может содержать меньше вопросов, чем
				// Указано в его настройках.
				
				Сч = ДокументСессии.ГруппыПодборки.Количество();
				
				Пока Сч > 0 Цикл
					
					Строка = ДокументСессии.ГруппыПодборки.Получить(Сч - 1);
					
					Если ВсеВопросыПодборки.Найти(Строка.ГруппаПодборки, "Ссылка") = Неопределено
						И ВсеВопросыПодборки.Найти(Строка.ГруппаПодборки, "Родитель") = Неопределено
						И ВсеВопросыПодборки.Найти(Строка.ГруппаПодборки, "РодительРодителя") = Неопределено Тогда
						
						ДокументСессии.ГруппыПодборки.Удалить(Сч - 1);
						
					КонецЕсли;
					
					Сч = Сч - 1;
					
				КонецЦикла;	
				
				// Заполняем табличную часть "Вопросы".
				
				// В этой таблице хранятся данные о том сколько уже для каждого родителя
				// В структуре элементов подборки размещено вопросов.
				ТаблицаОграниченияКоличестваВопросов = Новый ТаблицаЗначений();
				ТаблицаОграниченияКоличестваВопросов.Колонки.Добавить("Родитель");
				ТаблицаОграниченияКоличестваВопросов.Колонки.Добавить("КоличествоРазмещенныхВопросов");
				ТаблицаОграниченияКоличестваВопросов.Колонки.Добавить("ДопустимоеКоличествоВопросов");		
				
				КоличествоВопросов = ВсеВопросыПодборки.Количество();
				ИндексМассив = ОбщегоНазначенияСУ.ИндексМассив(0, КоличествоВопросов, Истина);
				
				Для Сч=0 По КоличествоВопросов-1 Цикл
					
					иВопрос = ВсеВопросыПодборки.Получить(ИндексМассив[Сч]);
					
					// Примечание: ГруппаВТЧ содержит только группы верхнего уровня подборки, которые образуют страницы подборки
					// или страницами могут быть сами элементы, если они размещены на верхнем уровне подборки.
					
					ГруппаВТЧ = ДокументСессии.ГруппыПодборки.Найти(иВопрос.Ссылка, "ГруппаПодборки"); // Если вопрос на первом уровне иерархии и сам является группой.
					
					Если ГруппаВТЧ = Неопределено Тогда // Если вопрос принадлежит группе
						
						ГруппаВТЧ = ДокументСессии.ГруппыПодборки.Найти(иВопрос.Родитель, "ГруппаПодборки"); // Вопрос находится в группе.
						
						Если ГруппаВТЧ = Неопределено Тогда
							ГруппаВТЧ = ДокументСессии.ГруппыПодборки.Найти(иВопрос.РодительРодителя, "ГруппаПодборки"); // Вопрос в подгруппе.
						КонецЕсли;
						
						// Находим сколько уже вопросов из данной группы размещено и можно ли добавлять вопрос.
						
						РодительВТаблице = ТаблицаОграниченияКоличестваВопросов.Найти(иВопрос.Родитель, "Родитель");
						
						Если РодительВТаблице = Неопределено Тогда
							
							РодительВТаблице = ТаблицаОграниченияКоличестваВопросов.Добавить();
							РодительВТаблице.Родитель                      = иВопрос.Родитель;
							РодительВТаблице.КоличествоРазмещенныхВопросов = 0;
							
							Если ПараметрыЭкспорта = Неопределено Тогда
								РодительВТаблице.ДопустимоеКоличествоВопросов  = иВопрос.КоличествоВопросов;
							Иначе
								РодительВТаблице.ДопустимоеКоличествоВопросов = 0;
							КонецЕсли;
							
						КонецЕсли;
						
						Если РодительВТаблице.ДопустимоеКоличествоВопросов = 0
							ИЛИ РодительВТаблице.КоличествоРазмещенныхВопросов < РодительВТаблице.ДопустимоеКоличествоВопросов Тогда
							РодительВТаблице.КоличествоРазмещенныхВопросов = РодительВТаблице.КоличествоРазмещенныхВопросов + 1;	
						Иначе 
							Продолжить; // Нельзя размещать вопрос, переходим к следующему
						КонецЕсли;
						
					КонецЕсли;
					
					ВопросВДокументе = ДокументСессии.Вопросы.Добавить();
					
					ВопросВДокументе.Вопрос                = иВопрос.СсылкаНаОбъектСУЗ;
					ВопросВДокументе.ВесВопроса            = иВопрос.ВесВопроса;
					ВопросВДокументе.ГруппаПодборки        = ГруппаВТЧ.ГруппаПодборки;
					ВопросВДокументе.ПсихологическийВопрос = ?(иВопрос.СсылкаНаОбъектСУЗ.ТипВопроса = Перечисления.ТипыВопросовСУЗ.ОдинИзМногихПсихологический
					ИЛИ иВопрос.СсылкаНаОбъектСУЗ.ТипВопроса = Перечисления.ТипыВопросовСУЗ.МногиеИзМногихПсихологический, Истина, Ложь);
					
				КонецЦикла;
				
			КонецЕсли;
			
			Если ПараметрыЭкспорта = Неопределено Тогда // Обычное прохождение
				
				ДокументСессии.Записать(РежимЗаписиДокумента.Проведение); // Проводим документ. Потом он будет проведен при окончании теста.
				
				НомерДокумента = ДокументСессии.Номер;
				
			Иначе // Экспорт
				
				РезультатДействия.ДокументСессииОбъект = ДокументСессии;
				
				НомерДокумента = -1; // Условный номер для процедуры экспорта
				
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(ДокументСессии.НазначениеТестирования)
				ИЛИ ДокументСессии.НазначениеТестирования = Перечисления.НазначенияТестированийСУЗ.Аттестация Тогда
				
				РезультатДействия.ВыполняетсяТестирование = Истина;
				РезультатДействия.СессияТестирования      = НомерДокумента;
				
			КонецЕсли;
			
			РезультатДействия.АдресОбъекта = "?" + "id=" + id + "&object=collection&window=this&numGroup=1&numDocument=" + Формат(НомерДокумента, "ЧГ=0");
			
		КонецЕсли;
		
		////////////////////////////////////////////////////////////////////////////////
		// submitQuestion, getHelpQuestion, repeatQuestion, saveScoreTeacher
		// Обрабатывается ответ на вопрос
		
		Если ДействиеСсылки = "submitQuestion" // Ответ на вопрос
			ИЛИ ДействиеСсылки = "getHelpQuestion" // Получение подсказки
			ИЛИ ДействиеСсылки = "repeatQuestion" // Запрос на повторный ответ
			ИЛИ ДействиеСсылки = "saveScoreTeacher" // Оценка преподавателем вопроса
			Тогда
			
			НомерДокументаОтветаНаВопрос = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "numAnswerDocument");
			СсылкаНаДокументОтветаНаВопрос = Документы.ОтветНаВопросСУЗ.НайтиПоНомеру(Число(НомерДокументаОтветаНаВопрос));
			
			БлокировкаДанных = Новый БлокировкаДанных;
			ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Документ.ОтветНаВопросСУЗ");
			ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", СсылкаНаДокументОтветаНаВопрос);
			ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
			БлокировкаДанных.Заблокировать();
			
			ДокументОтветаНаВопрос = СсылкаНаДокументОтветаНаВопрос.ПолучитьОбъект();
			
			// submitQuestion
			Если ДействиеСсылки = "submitQuestion" Тогда
				
				РезультатОбработки = ДокументОтветаНаВопрос.ОбработатьОтветНаВопрос(ПараметрыСсылки, КонтекстВыполнения, ПоставщикСводаЗнаний);
				
				Если РезультатОбработки.Код = 0 ИЛИ РезультатОбработки.Код = 7 Тогда
					
					numGroup    = Справочники.ПодборкиСУЗ.НомерСтраницы(ПараметрыСсылки);
					numDocument = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки,"numDocument");
					
					Если НЕ ПустаяСтрока(numGroup) И НЕ ПустаяСтрока(numDocument) Тогда
						
						numGroup = Число(numGroup);
						numDocument = Число(numDocument);
						
						ПервоначальныйNumGroup = numGroup;
						
						БлокировкаДанных = Новый БлокировкаДанных;
						ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Документ.ПопыткаВыполненияПодборкиВопросовСУЗ");
						ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ДокументОтветаНаВопрос.СессияВыполненияТеста);
						ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
						БлокировкаДанных.Заблокировать();						
						
						ДокументСессии = ДокументОтветаНаВопрос.СессияВыполненияТеста.ПолучитьОбъект(); // Блокировка выше
						
						Если НЕ ЗначениеЗаполнено(ДокументСессии.НазначениеТестирования)
							ИЛИ ДокументСессии.НазначениеТестирования = Перечисления.НазначенияТестированийСУЗ.Аттестация Тогда
							
							РезультатДействия.ВыполняетсяТестирование = Истина;
							РезультатДействия.СессияТестирования = ДокументСессии.Номер;
							
						КонецЕсли;
						
						ГруппаВТЧ = ДокументСессии.ГруппыПодборки.Получить(numGroup - 1);
						
						ВсеВопросыГруппыОтвечены = ДокументСессии.ВсеВопросыГруппыОтвечены(ГруппаВТЧ.ГруппаПодборки);
						
						ТребуетсяЗаписатьДокументСессии = Ложь;
						
						Если ГруппаВТЧ.ВсеВопросыОтвечены <> ВсеВопросыГруппыОтвечены Тогда
							ГруппаВТЧ.ВсеВопросыОтвечены = ВсеВопросыГруппыОтвечены;
							ТребуетсяЗаписатьДокументСессии = Истина;
						КонецЕсли;
						
						ВопросыГруппыТребуютПроверки = ДокументСессии.ВопросыГруппыТребуютПроверки(ГруппаВТЧ.ГруппаПодборки);
						Если ГруппаВТЧ.ЕстьВопросыНаПроверку <> ВопросыГруппыТребуютПроверки Тогда
							ГруппаВТЧ.ЕстьВопросыНаПроверку = ВопросыГруппыТребуютПроверки;
							ТребуетсяЗаписатьДокументСессии = Истина;
						КонецЕсли;
						
						Если ТребуетсяЗаписатьДокументСессии Тогда
							ДокументСессии.Записать();
						КонецЕсли;
						
						ПоказатьСледующийВопрос = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "AutoNext");
						
						Если ПоказатьСледующийВопрос = "true" И ВсеВопросыГруппыОтвечены Тогда
							
							// Учитываем, что автоматически мы можем двигаться вперед,
							// Если еще не дошли до последнего вопроса или скрыта навигация.
							
							// Если навигация отображается, то пользовать сам должен закончить тест.
							
							// В режиме симуляции это правило не действует.
							
							Если numGroup < ДокументСессии.ГруппыПодборки.Количество()
								ИЛИ НЕ ДокументСессии.ПоказыватьНавигацию
								ИЛИ Симуляция Тогда
								
								numGroup = numGroup + 1;
								
							КонецЕсли;
							
						КонецЕсли;
						
						// Если ПоказатьСледующийВопрос = "true" И НЕ ДокументСессии.ПоказыватьНавигацию Тогда
						// 	РезультатДействия.НеЗаписыватьВИсториюПереходСсылке = Истина;
						// КонецЕсли;
						
						idПодборки = ДокументСессии.Подборка.УникальныйИдентификатор();
						
						Если numGroup <> ПервоначальныйNumGroup Тогда
							РезультатДействия.АдресОбъекта = "?" + "id=" + idПодборки + "&object=collection&window=this&numGroup="+ Формат(numGroup, "ЧГ=0") +"&numDocument=" + Формат(numDocument, "ЧГ=0");
							// РезультатДействия.НеЗаписыватьВИсториюПереходСсылке = Истина;
						КонецЕсли;
						
						Если numGroup > ДокументСессии.ГруппыПодборки.Количество() ИЛИ РезультатОбработки.Код = 7 Тогда
							РезультатДействия.АдресОбъекта = "?" + "id=" + idПодборки + "&object=collection&window=this&numGroup=-1&numDocument=" + Формат(numDocument, "ЧГ=0");
							// РезультатДействия.НеЗаписыватьВИсториюПереходСсылке = Истина;
						КонецЕсли;
						
						// Если нет ссылки для перехода, то страница будет обновлена.
						
						// Элементы содержания для повторного изучения
						
						РезультатДействия.ПовторноеПрохождение = РегистрыСведений.ПовторноеПрохождениеЭлектронныхРесурсовСУЗ.ЭлементыСодержанияРегистратора(ДокументОтветаНаВопрос.Ссылка);
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли; // submitQuestion
			
			// submitQuestion
			Если ДействиеСсылки = "getHelpQuestion" Тогда
				РезультатОбработки = ДокументОтветаНаВопрос.ОбработатьПолучениеПодсказки(ПараметрыСсылки);
				// Так как нет ссылки для перехода и сообщения, то страница будет просто обновлена.
			КонецЕсли;
			
			Если ДействиеСсылки = "repeatQuestion" Тогда
				РезультатОбработки = ДокументОтветаНаВопрос.ОбработатьЗапросНаПовторныйОтвет(ПараметрыСсылки);
				// Страница будет обновлена
			КонецЕсли;
			
			Если ДействиеСсылки = "saveScoreTeacher" Тогда
				
				РезультатОбработки = ДокументОтветаНаВопрос.ОбработатьОценкуПреподавателя(ПараметрыСсылки, КонтекстВыполнения);
				
				numGroup    = Справочники.ПодборкиСУЗ.НомерСтраницы(ПараметрыСсылки);
				numDocument = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки,"numDocument");
				
				Если НЕ ПустаяСтрока(numGroup) И НЕ ПустаяСтрока(numDocument) Тогда
					
					numGroup = Число(numGroup);
					numDocument = Число(numDocument);
					
					БлокировкаДанных = Новый БлокировкаДанных;
					ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Документ.ПопыткаВыполненияПодборкиВопросовСУЗ");
					ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ДокументОтветаНаВопрос.СессияВыполненияТеста);
					ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
					БлокировкаДанных.Заблокировать();
					
					
					ДокументСессии = ДокументОтветаНаВопрос.СессияВыполненияТеста.ПолучитьОбъект();
					
					ГруппаВТЧ = ДокументСессии.ГруппыПодборки.Получить(numGroup - 1);
					ГруппаВТЧ.ЕстьВопросыНаПроверку = ДокументСессии.ВопросыГруппыТребуютПроверки(ГруппаВТЧ.ГруппаПодборки);
					
					ДокументСессии.ЗакрытьСессию();
					ДокументСессии.Записать(РежимЗаписиДокумента.Проведение);
					
				КонецЕсли;
				
				// Страница будет обновлена
				
			КонецЕсли;
			
			Если РезультатОбработки.Код <> 0 Тогда
				
				РезультатДействия.ТекстСообщения = РезультатОбработки.Текст;
				
				Если РезультатОбработки.Свойство("Форма") Тогда
					РезультатДействия.Форма = РезультатОбработки.Форма;
				КонецЕсли;
				
			КонецЕсли;
			
			// Устанавливаем якорь
			
			СледуетУстановитьЯкорьВопроса = Истина;
			
			Если ЗначениеЗаполнено(КонтекстВыполнения.АдресЗагруженногоОбъекта) Тогда
				
				СтруктураАдресаЗагруженногоОбъекта = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(КонтекстВыполнения.АдресЗагруженногоОбъекта);
				
				ИмяЗагруженногоОбъекта           = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураАдресаЗагруженногоОбъекта, "object");
				ИдентификаторЗагруженногоОбъекта = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураАдресаЗагруженногоОбъекта, "id");
				
				Если ИмяЗагруженногоОбъекта = "collection" Тогда
					
					Подборка = ПолучитьСсылкуПоИдентификатору(ИмяЗагруженногоОбъекта, ИдентификаторЗагруженногоОбъекта);
					
					ТипНавигацииПодборки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Подборка, "ТипНавигации");
					
					Если ТипНавигацииПодборки = Перечисления.ТипыНавигацииПодборкиСУЗ.Слайды Тогда
						СледуетУстановитьЯкорьВопроса = Ложь;	
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
			Если СледуетУстановитьЯкорьВопроса Тогда
				РезультатДействия.Якорь = "questionForm_" + СтрЗаменить(ПараметрыСсылки.id, "-", "");
			КонецЕсли;
			
		КонецЕсли;
		
		////////////////////////////////////////////////////////////////////////////////
		// addAttempt Добавляется попытка к тесту.
		
		Если ДействиеСсылки = "addAttempt" Тогда
			
			ИмяОбъектаСУЗ = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "object");
			id            = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "id");
			
			Подборка = ПолучитьСсылкуПоИдентификатору(ИмяОбъектаСУЗ, id);
			
			ДобавившийПользователь = ОбъектыСУЗ.ТекущийПользователь(КонтекстВыполнения);		
			Пользователь           = ДобавившийПользователь; // Кому добавляем
			
			ЭлектронныеРесурсыПереопределяемый.ПередДобавлениемПопыткиТестирования(Пользователь, СводЗнаний, Подборка, ПрохождениеОбучения, Задание); 		
			
			Период = ТекущаяДата();
			
			НаборЗаписей = РегистрыСведений.ДополнительныеПопыткиПрохожденияТестовСУЗ.СоздатьНаборЗаписей();
			
			НаборЗаписей.Отбор.Период.Установить(Период);
			НаборЗаписей.Отбор.Пользователь.Установить(Пользователь);
			НаборЗаписей.Отбор.ЭлементСодержания.Установить(ЭлементСодержания);
			НаборЗаписей.Отбор.ПрохождениеОбучения.Установить(ПрохождениеОбучения);
			НаборЗаписей.Отбор.Задание.Установить(Задание);
			НаборЗаписей.Отбор.Тест.Установить(Подборка);
			
			НоваяЗапись = НаборЗаписей.Добавить();
			
			НоваяЗапись.Период                 = Период;
			НоваяЗапись.Пользователь           = Пользователь;
			НоваяЗапись.ЭлементСодержания      = ЭлементСодержания;
			НоваяЗапись.ПрохождениеОбучения    = ПрохождениеОбучения;
			НоваяЗапись.Задание                = Задание;
			НоваяЗапись.Тест                   = Подборка;
			
			НоваяЗапись.ДобавившийПользователь = ДобавившийПользователь;
			НоваяЗапись.ЭлектронныйРесурс      = СводЗнаний;
			
			НаборЗаписей.Записать();
			
			ЭлектронныеРесурсыПереопределяемый.ПослеДобавленияПопыткиТестирования(Пользователь, СводЗнаний, Подборка, ПрохождениеОбучения, Задание); 		
			
		КонецЕсли;
		
		////////////////////////////////////////////////////////////////////////////////
		// SCORequest (действия объектов SCORM)
		
		Если ДействиеСсылки = "SCORequest" Тогда
			
			КодОшибки = 0;
			
			ИмяЗапроса  = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "nameRequest");
			НомерСессии = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "numSession");
			
			Если ЗначениеЗаполнено(НомерСессии) Тогда
				ДокументПопыткиСсылка = Документы.ПопыткаВыполненияАктивногоРесурсаSCORM.НайтиПоНомеру(Число(НомерСессии));	
			КонецЕсли;
			
			ИмяОбъектаСУЗ     = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки,"object");
			id                = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки,"id");
			РесурсСсылка      = ПолучитьСсылкуПоИдентификатору(ИмяОбъектаСУЗ, id);
			Пользователь      = ОбъектыСУЗ.ТекущийПользователь(КонтекстВыполнения);
			
			//
			// Инициализация сессии (Initialize)
			//
			
			Если ИмяЗапроса = "Initialize" Тогда
				
				ПараметрЗапроса = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "request");
				
				Если ЗначениеЗаполнено(ПараметрЗапроса) Тогда
					
					КодОшибки = 201;
					
				Иначе
					
					Если ЗначениеЗаполнено(НомерСессии) Тогда
						
						КодОшибки = 103;
						
					Иначе
						
						// Ищем незавершенную попытку
						
						ПопыткаАктивногоРесурсаСсылка = ОбъектыSCORM.ПолучитьНезавершеннуюПопыткуВыполненияОбъектаSCORM(Пользователь, СводЗнаний, ЭлементСодержания, РесурсСсылка, ПрохождениеОбучения, Задание);
						
						Если ЗначениеЗаполнено(ПопыткаАктивногоРесурсаСсылка) Тогда
							
							БлокировкаДанных = Новый БлокировкаДанных;
							ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Документ.ПопыткаВыполненияАктивногоРесурсаSCORM");
							ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ПопыткаАктивногоРесурсаСсылка);
							ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
							БлокировкаДанных.Заблокировать();

							
							ДокументПопыткиОбъект = ПопыткаАктивногоРесурсаСсылка.ПолучитьОбъект();
							
						Иначе
							
							// Создаем новую попытку
							
							ДокументПопыткиОбъект = Документы.ПопыткаВыполненияАктивногоРесурсаSCORM.СоздатьДокумент();
							
							ДокументПопыткиОбъект.Дата                          = ТекущаяДата();
							ДокументПопыткиОбъект.Пользователь                  = Пользователь;
							ДокументПопыткиОбъект.Ресурс                        = РесурсСсылка;
							ДокументПопыткиОбъект.СводЗнаний                    = СводЗнаний;
							ДокументПопыткиОбъект.ПрохождениеОбучения           = ПрохождениеОбучения;
							ДокументПопыткиОбъект.Задание                       = Задание;
							ДокументПопыткиОбъект.ЭлементСодержанияСводаЗнаний  = ЭлементСодержания;
							ДокументПопыткиОбъект.ДатаНачалаВыполнения          = ТекущаяДата();
							ДокументПопыткиОбъект.СостояниеВыполнения           = Перечисления.СостоянияВыполненияОбъектовSCORM.unknown;
							ДокументПопыткиОбъект.СостояниеПрохождения          = Перечисления.СостоянияПрохожденияОбъектовSCORM.unknown;
							
						КонецЕсли;
						
						НоваяСессияСтрока = ДокументПопыткиОбъект.Сессии.Добавить();
						НоваяСессияСтрока.ДатаИнициализации = ТекущаяДатаСеанса();
						
						ДокументПопыткиОбъект.Записать(РежимЗаписиДокумента.Проведение);
						
						НомерСессии = ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(ДокументПопыткиОбъект.Номер);
						
						// Создаем структуру данных
						
						СтруктураДанныхXDTO = ОбъектыSCORM.ПолучитьМодельДанныхПопыткиОбъектаSCORM(ДокументПопыткиОбъект, КонтекстВыполнения, НЕ ЗначениеЗаполнено(ПопыткаАктивногоРесурсаСсылка));
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли; // Initialize
			
			//
			// Запись данных (Commit)
			// Примечание: запись данных выполняется и при вызове Terminate.
			//
			
			Если ИмяЗапроса = "Commit" ИЛИ ИмяЗапроса = "Terminate" Тогда
				
				ТаблицаСтатистикиПараметровSCORM = Перечисления.ИспользуемыеПараметрыSCORM.НоваяТаблицаСтатистикиПараметровSCORM();
				
				ЗапросНаСохранение = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(ПараметрыСсылки, "request");
				
				Если ДокументПопыткиСсылка = Неопределено Тогда
					
					КодОшибки = 142;
					
				Иначе
					
					Если ЗапросНаСохранение <> Неопределено Тогда
						
						Если ТипЗнч(ЗапросНаСохранение) = Тип("Строка") Тогда
							МассивЗначений = Новый Массив();
							МассивЗначений.Добавить(ЗапросНаСохранение);
						Иначе
							МассивЗначений = ЗапросНаСохранение;
						КонецЕсли;
						
						БлокировкаДанных = Новый БлокировкаДанных;
						ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Документ.ПопыткаВыполненияАктивногоРесурсаSCORM");
						ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ДокументПопыткиСсылка);
						ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
						БлокировкаДанных.Заблокировать();

						
						ДокументПопыткиОбъект = ДокументПопыткиСсылка.ПолучитьОбъект();	
						
						// Перебираем значения для сохранения.
						Для каждого ЗначениеЗапроса Из МассивЗначений Цикл
							
							ЗначениеЗадано = Истина;
							
							ПозицияРазделителя = Найти(ЗначениеЗапроса, "==");
							
							Если ПозицияРазделителя = 0 Тогда
								ИмяСохраняемогоЗначенияСтрока = ЗначениеЗапроса;
								ЗначениеСохраняемогоЗначения  = "";
								ЗначениеЗадано = Ложь;
							Иначе
								ИмяСохраняемогоЗначенияСтрока = Сред(ЗначениеЗапроса, 1, ПозицияРазделителя-1);
								ЗначениеСохраняемогоЗначения  = Сред(ЗначениеЗапроса, ПозицияРазделителя+2, СтрДлина(ЗначениеЗапроса)-ПозицияРазделителя-1);
							КонецЕсли;
							
							ИмяСохраняемогоЗначения = ОбщегоНазначенияСУКлиентСервер.РасщепитьСтроку(ИмяСохраняемогоЗначенияСтрока, "."); // Массив
							
							Если ИмяСохраняемогоЗначения.Количество() > 1 Тогда
								
								// cmi
								
								Если ИмяСохраняемогоЗначения[0] = "cmi" Тогда
									
									// completion_status
									Если ИмяСохраняемогоЗначения[1] = "completion_status" Тогда
										
										ПереданоСОшибкой = Ложь;
										
										Попытка
											ДокументПопыткиОбъект.СостояниеВыполнения = Перечисления.СостоянияВыполненияОбъектовSCORM[СтрЗаменить(ЗначениеСохраняемогоЗначения, " ", "")];
										Исключение
											ПереданоСОшибкой = Истина;
											КодОшибки = 101;											
											ТекстСообщения = "Невозможно интерпретировать переданное значение состояния объекта.";
										КонецПопытки;
										
										Перечисления.ИспользуемыеПараметрыSCORM.ДобавитьСтрокуВТаблицуСтатистики(
											ТаблицаСтатистикиПараметровSCORM,
											Неопределено,
											Неопределено,
											Перечисления.ИспользуемыеПараметрыSCORM.completion_status,
											ЗначениеЗаполнено(ЗначениеСохраняемогоЗначения),
											ПереданоСОшибкой,
											ЗначениеСохраняемогоЗначения);
												
									КонецЕсли;
									
									// location
									Если ИмяСохраняемогоЗначения[1] = "location" Тогда
										ДокументПопыткиОбъект.ТекущееПоложение = ЗначениеСохраняемогоЗначения;
									КонецЕсли;
									
									// suspend_data
									Если ИмяСохраняемогоЗначения[1] = "suspend_data" Тогда
										ДокументПопыткиОбъект.ДанныеПопытки = ЗначениеСохраняемогоЗначения;
									КонецЕсли;
									
									// progress_measure
									Если ИмяСохраняемогоЗначения[1] = "progress_measure" Тогда
										
										ПереданоСОшибкой = Ложь;

										Попытка
											ДокументПопыткиОбъект.ПроцентВыполнения = Число(ЗначениеСохраняемогоЗначения);
										Исключение
											КодОшибки = 101;
											ТекстСообщения = "Невозможно интерпретировать переданное значение процента выполнения (progress_measure).";
											ПереданоСОшибкой = Истина;
										КонецПопытки;
																				
										Перечисления.ИспользуемыеПараметрыSCORM.ДобавитьСтрокуВТаблицуСтатистики(
											ТаблицаСтатистикиПараметровSCORM,
											Неопределено,
											Неопределено,
											Перечисления.ИспользуемыеПараметрыSCORM.progress_measure,
											ЗначениеЗаполнено(ЗначениеСохраняемогоЗначения),
											ПереданоСОшибкой,
											ЗначениеСохраняемогоЗначения); 											
											
									КонецЕсли;
									
									// session_time
									Если ИмяСохраняемогоЗначения[1] = "session_time" Тогда
										
										ПереданоСОшибкой = Ложь;
										
										Попытка
											КоличествоСекунд = ОбъектыSCORM.ПолучитьКоличествоСекундВременногоИнтервалаSCORM(ЗначениеСохраняемогоЗначения);
										Исключение
											КодОшибки = 406;
											ТекстСообщения = "Невозможно интерпретировать переданный временной интервал.";
											ПереданоСОшибкой = Истина;
										КонецПопытки;
																			
										Перечисления.ИспользуемыеПараметрыSCORM.ДобавитьСтрокуВТаблицуСтатистики(
											ТаблицаСтатистикиПараметровSCORM,
											Неопределено,
											Неопределено,
											Перечисления.ИспользуемыеПараметрыSCORM.session_time,
											ЗначениеЗаполнено(ЗначениеСохраняемогоЗначения),
											ПереданоСОшибкой,
											ЗначениеСохраняемогоЗначения); 										
											
										ДокументПопыткиОбъект.ПродолжительностьПоследнейСессии = ЗначениеСохраняемогоЗначения;
										
									КонецЕсли;
									
									// exit
									Если ИмяСохраняемогоЗначения[1] = "exit" Тогда
										
										ДокументПопыткиОбъект.ПричинаВыхода = ЗначениеСохраняемогоЗначения;
										
										Перечисления.ИспользуемыеПараметрыSCORM.ДобавитьСтрокуВТаблицуСтатистики(
											ТаблицаСтатистикиПараметровSCORM,
											Неопределено,
											Неопределено,
											Перечисления.ИспользуемыеПараметрыSCORM.exit,
											ЗначениеЗаполнено(ЗначениеСохраняемогоЗначения),
											Ложь,
											ЗначениеСохраняемогоЗначения);
											
									КонецЕсли;
									
									// success_status
									Если ИмяСохраняемогоЗначения[1] = "success_status" Тогда
										
										ПереданоСОшибкой = Ложь;
										
										Попытка
											ДокументПопыткиОбъект.СостояниеПрохождения = Перечисления.СостоянияПрохожденияОбъектовSCORM[ЗначениеСохраняемогоЗначения];
										Исключение
											КодОшибки = 101;
											ТекстСообщения = "Невозможно интерпретировать переданное значение состояния прохождения объекта (success_status) (101).";
											ПереданоСОшибкой = Истина;
										КонецПопытки;										
										
										Перечисления.ИспользуемыеПараметрыSCORM.ДобавитьСтрокуВТаблицуСтатистики(
											ТаблицаСтатистикиПараметровSCORM,
											Неопределено,
											Неопределено,
											Перечисления.ИспользуемыеПараметрыSCORM.success_status,
											ЗначениеЗаполнено(ЗначениеСохраняемогоЗначения),
											ПереданоСОшибкой,
											ЗначениеСохраняемогоЗначения);																				
										
									КонецЕсли;
									
									// score
									Если ИмяСохраняемогоЗначения[1] = "score" Тогда
										
										Передано = Ложь;
										ПереданоСОшибкой = Ложь;
										
										Если ИмяСохраняемогоЗначения[2] = "scaled" Тогда
											
											Если ЗначениеЗаполнено(ЗначениеСохраняемогоЗначения) Тогда
												
												Передано = Истина;
												
												Попытка
													ДокументПопыткиОбъект.РезультатВПроцентах = Число(ЗначениеСохраняемогоЗначения);
												Исключение
													КодОшибки = 407;
													ТекстСообщения = "Невозможно интерпретировать переданное значение оценки в процентах (score.scaled) (407).";
													ПереданоСОшибкой = Истина;
												КонецПопытки;
												
											Иначе
												
												ДокументПопыткиОбъект.РезультатВПроцентах = 0;
												
											КонецЕсли;											
											
										КонецЕсли;
										

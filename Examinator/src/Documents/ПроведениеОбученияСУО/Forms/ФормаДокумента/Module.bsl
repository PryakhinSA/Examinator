&НаКлиенте
Процедура УчастникиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
	ЗачислитьУчастникаКоманда(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура УчастникиОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранноеЗначение) <> Тип("Массив") Тогда		
		Возврат;		
	КонецЕсли;
	
	УдаленныеПрохождения = УдаленныеПрохождения(Объект.Ссылка, ВыбранноеЗначение);
	
	Если УдаленныеПрохождения.Количество() = 0 Тогда
		ЗачислитьУчастников(Объект.Ссылка, ВыбранноеЗначение);	
	Иначе
		ТекстВопроса = НСтр("ru = 'Среди зачисляемых участников есть ранее удаленные. Выберите действие для них:'");
		ДополнительныеПараметры = Новый Структура("ВыбранныеУчастники, УдаленныеПрохождения", ВыбранноеЗначение, УдаленныеПрохождения);
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗачислитьУчастниковПослеВыбораДействияНадУдаленными", ЭтотОбъект, ДополнительныеПараметры);
		Кнопки = Новый СписокЗначений;
		Кнопки.Добавить(КодВозвратаДиалога.Да, НСтр("ru = 'Восстановить'"));
		Кнопки.Добавить(КодВозвратаДиалога.Нет, НСтр("ru = 'Отменить и зачислить заново'"));
		Кнопки.Добавить(КодВозвратаДиалога.Отмена, НСтр("ru = 'Оставить удаленными'"));
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, Кнопки, , КодВозвратаДиалога.Да, НСтр("ru = 'Выбор действия для удаленных участников'"));		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗачислитьУчастниковПослеВыбораДействияНадУдаленными(РезультатОтвета, ДополнительныеПараметры) Экспорт
	
	Если РезультатОтвета = КодВозвратаДиалога.Да Тогда
		ЗачислитьУчастников(Объект.Ссылка, ДополнительныеПараметры.ВыбранныеУчастники, ДополнительныеПараметры.УдаленныеПрохождения, Ложь); 
		Возврат;
	КонецЕсли;
	
	Если РезультатОтвета = КодВозвратаДиалога.Нет Тогда
		ЗачислитьУчастников(Объект.Ссылка, ДополнительныеПараметры.ВыбранныеУчастники, ДополнительныеПараметры.УдаленныеПрохождения, Истина); 
		Возврат;
	КонецЕсли;
	
	ЗачислитьУчастников(Объект.Ссылка, ДополнительныеПараметры.ВыбранныеУчастники);
	
КонецПроцедуры

#КонецОбласти


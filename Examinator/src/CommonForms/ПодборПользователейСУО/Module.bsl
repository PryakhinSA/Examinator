&НаКлиенте
Процедура ФормированиеПоляВводаТаблицыНастроекДоступа(Элемент)
		
	ТабличноеПоле = Элемент;
	
	Если ТабличноеПоле.ТекущиеДанные <> Неопределено Тогда
		
		// Формируем текущее выбранное поле ввода
		
		ПолеВвода = ТабличноеПоле.ПодчиненныеЭлементы[ТабличноеПоле.Имя + "Значение"];
		ПолеВвода.ОграничениеТипа = ТабличноеПоле.ТекущиеДанные.ДопустимыеТипы;
		
		ВыборГруппИЭлементов = ТабличноеПоле.ТекущиеДанные.ВыборГруппИЭлементов;
		
		Если ЗначениеЗаполнено(ВыборГруппИЭлементов) Тогда
			ПолеВвода.ВыборГруппИЭлементов = ГруппыИЭлементы[ВыборГруппИЭлементов];
		Иначе
			ПолеВвода.ВыборГруппИЭлементов = ГруппыИЭлементы.Авто;
		КонецЕсли;
		
	КонецЕсли;
	
	Для каждого СтрокаТабличногоПоля Из ТаблицаНастроекДоступа Цикл
		
		// Формируем все поля
		
		Если ТипЗнч(СтрокаТабличногоПоля.НедоступныеПоля) = Тип("ФиксированныйМассив") Тогда
			
			ВыставленоЗначениеНедоступности = Ложь;
			Для каждого ЗначениеПоля Из СтрокаТабличногоПоля.ЗначенияНедоступностиПолей Цикл				
				Если ЗначениеПоля = Неопределено
					И НЕ СтрокаТабличногоПоля.ИспользоватьНастройку Тогда
					ВыставленоЗначениеНедоступности = Истина;
					Прервать;
				КонецЕсли;				
				Если СтрокаТабличногоПоля.Значение = ЗначениеПоля Тогда
					ВыставленоЗначениеНедоступности = Истина;
					Прервать;
				КонецЕсли;							
			КонецЦикла;
			
			Для каждого НедоступноеПоле Из СтрокаТабличногоПоля.НедоступныеПоля Цикл
				НедоступнаяСтрока = ТаблицаНастроекДоступа.НайтиСтроки(Новый Структура("ИмяСвойства", НедоступноеПоле))[0];
				НедоступнаяСтрока.ТолькоПросмотр = ВыставленоЗначениеНедоступности;
				Если ВыставленоЗначениеНедоступности Тогда
					НедоступнаяСтрока.ИспользоватьНастройку = Ложь;
					НедоступнаяСтрока.Значение = НедоступнаяСтрока.ЗначениеПоУмолчанию;
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;	
	
КонецПроцедуры


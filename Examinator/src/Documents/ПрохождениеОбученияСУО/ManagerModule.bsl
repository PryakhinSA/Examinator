				АвторXDTO.Номер = ВыборкаАвторов.НомерСтроки;
				
				АвторыXDTO.Автор.Добавить(АвторXDTO);
				
			КонецЦикла;		
			
			КнигаXDTO.Авторы = АвторыXDTO;
			
			КнигиXDTO.Книга.Добавить(КнигаXDTO);
			
		КонецЦикла;
		
		РесурсыXDTO.Книги = КнигиXDTO;
		
	КонецЕсли;
	
	// Электронные ресурсы

	ЭлектронныеРесурсыXDTOТип = ФабрикаXDTO.Тип("http://v8.1c.ru/lms/1/ElectronicResource", "ЭлектронныеРесурсы");
	ЭлектронныеРесурсыXDTO    = ФабрикаXDTO.Создать(ЭлектронныеРесурсыXDTOТип);	
		
	ВыборкаДетальныеЗаписи = Документы.ПроведениеОбученияСУО.ПрикрепленныеЭлектронныеРесурсы(Данные.ПроведениеОбучения, Данные.Сценарий);
	
	Если ВыборкаДетальныеЗаписи.Количество() > 0 Тогда

		ЭлектронныйРесурсXDTOТип = ФабрикаXDTO.Тип("http://v8.1c.ru/lms/1/ElectronicResource", "ЭлектронныйРесурс");
		ФрагментXDTOТип          = ФабрикаXDTO.Тип("http://v8.1c.ru/lms/1/ElectronicResource", "Фрагмент");
		
		СписокРазмещенныхЭР = Новый Массив;
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			Если СписокРазмещенныхЭР.Найти(ВыборкаДетальныеЗаписи.ЭлектронныйРесурс) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;			
			
			Если Зависимости <> Неопределено тогда
				Зависимости.Добавить(ВыборкаДетальныеЗаписи.ЭлектронныйРесурс);
			КонецЕсли;
			
			
			Если ЭтоУченик Тогда
				
				Если ВыборкаДетальныеЗаписи.СкрыватьОтУченика Тогда
					Продолжить;
				КонецЕсли;			
				
				Если ВыборкаДетальныеЗаписи.ПоказатьПослеПрохождения
					И СтатусПроцессаОбучения <> Перечисления.СтатусыПроцессаОбученияСУО.Окончено
					И СтатусПроцессаОбучения <> Перечисления.СтатусыПроцессаОбученияСУО.ОконченоАвтоматом Тогда					
					Продолжить;					
				КонецЕсли;				
				
			КонецЕсли;
				
			Если НЕ Документы.ПроведениеОбученияСУО.МожноПоказатьРесурсПроведения(
					Данные.СтатусПроведенияОбучения,
					ВыборкаДетальныеЗаписи.ПоказатьПриСтатусеЗапланировано,
		            ВыборкаДетальныеЗаписи.ПоказатьПриСтатусеАктивно,
				    ВыборкаДетальныеЗаписи.ПоказатьПриСтатусеЗавершено) Тогда
				
				Продолжить;
				
			КонецЕсли;
			
			ЭлектронныйРесурсXDTO = ФабрикаXDTO.Создать(ЭлектронныйРесурсXDTOТип);
			ЭлектронныйРесурсXDTO.Наименование  = ВыборкаДетальныеЗаписи.НаименованиеЭлектронногоРесурса; 
			ЭлектронныйРесурсXDTO.Идентификатор = ВыборкаДетальныеЗаписи.ЭлектронныйРесурс.УникальныйИдентификатор();
			
			Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Фрагмент) Тогда
				
				ФрагментXDTO = ФабрикаXDTO.Создать(ФрагментXDTOТип);
				ФрагментXDTO.Наименование  = ВыборкаДетальныеЗаписи.НаименованиеФрагмента; 
				ФрагментXDTO.Идентификатор = ВыборкаДетальныеЗаписи.Фрагмент.УникальныйИдентификатор();
				
				ЭлектронныйРесурсXDTO.Фрагмент = ФрагментXDTO;
				
			КонецЕсли;
			
			ЭлектронныеРесурсыXDTO.ЭлектронныйРесурс.Добавить(ЭлектронныйРесурсXDTO);
	
			СписокРазмещенныхЭР.Добавить(ВыборкаДетальныеЗаписи.ЭлектронныйРесурс);
	
		КонецЦикла;

		РесурсыXDTO.ЭлектронныеРесурсы = ЭлектронныеРесурсыXDTO;	
	
	КонецЕсли;
	
	// Файлы
	

	ФайлыXDTOТип = ФабрикаXDTO.Тип("http://v8.1c.ru/lms/3/EduFiles", "Файлы");
	ФайлыXDTO    = ФабрикаXDTO.Создать(ФайлыXDTOТип);	

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПроведениеОбученияСУОФайлы.Файл,
		|	ПроведениеОбученияСУОФайлы.ПоказатьПослеПрохождения,
		|	ПроведениеОбученияСУОФайлы.Файл.Наименование КАК Представление,
		|	ПроведениеОбученияСУОФайлы.СкрыватьОтУченика,
		|	ПроведениеОбученияСУОФайлы.ПоказатьПриСтатусеЗапланировано,
		|	ПроведениеОбученияСУОФайлы.ПоказатьПриСтатусеАктивно,
		|	ПроведениеОбученияСУОФайлы.ПоказатьПриСтатусеЗавершено,
		|	ПроведениеОбученияСУОФайлы.Файл.Расширение КАК Расширение,
		|	ПроведениеОбученияСУОФайлы.Файл.Размер КАК Размер
		|ИЗ
		|	Документ.ПроведениеОбученияСУО.Файлы КАК ПроведениеОбученияСУОФайлы
		|ГДЕ
		|	ПроведениеОбученияСУОФайлы.Ссылка = &ПроведениеОбучения";
		
	Запрос.УстановитьПараметр("ПроведениеОбучения", Данные.ПроведениеОбучения);
		
	Если ТипЗнч(Данные.Сценарий) = Тип("СправочникСсылка.КаталогМероприятийСУО")
		И ЗначениеЗаполнено(Данные.Сценарий) Тогда		
		
		Запрос.Текст = Запрос.Текст + " 
		| ОБЪЕДИНИТЬ ВСЕ 
		|";
		
		Запрос.Текст = Запрос.Текст + 
			"ВЫБРАТЬ
			|	КаталогМероприятийСУОФайлы.Файл,
			|	КаталогМероприятийСУОФайлы.ПоказатьПослеПрохождения,
			|	КаталогМероприятийСУОФайлы.Файл.Наименование,
			|	КаталогМероприятийСУОФайлы.СкрыватьОтУченика,
			|	КаталогМероприятийСУОФайлы.ПоказатьПриСтатусеЗапланировано,
			|	КаталогМероприятийСУОФайлы.ПоказатьПриСтатусеАктивно,
			|	КаталогМероприятийСУОФайлы.ПоказатьПриСтатусеЗавершено,
			|	КаталогМероприятийСУОФайлы.Файл.Расширение,
			|	КаталогМероприятийСУОФайлы.Файл.Размер
			|ИЗ
			|	Справочник.КаталогМероприятийСУО.Файлы КАК КаталогМероприятийСУОФайлы
			|ГДЕ
			|	КаталогМероприятийСУОФайлы.Ссылка = &Мероприятие";

	
		Запрос.УстановитьПараметр("Мероприятие", Данные.Сценарий);
	
	КонецЕсли;
			
	Результат = Запрос.Выполнить();
		
	Если НЕ Результат.Пустой() Тогда
		
		ВыборкаДетальныеЗаписи = Результат.Выбрать();
		
		СписокРазмещенныхФайлов = Новый Массив;
		
		ФайлXDTOТип = ФабрикаXDTO.Тип("http://v8.1c.ru/lms/3/EduFiles", "Файл");
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			Если НЕ ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Файл) Тогда
				Продолжить;
			КонецЕсли;			
			
			Если Зависимости <> Неопределено тогда
				Зависимости.Добавить(ВыборкаДетальныеЗаписи.Файл);
			КонецЕсли;			
			
			Если СписокРазмещенныхФайлов.Найти(ВыборкаДетальныеЗаписи.Файл) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;			
			
			Если ЭтоУченик Тогда
			
				Если ВыборкаДетальныеЗаписи.СкрыватьОтУченика Тогда
					Продолжить;
				КонецЕсли;			
				
				Если ВыборкаДетальныеЗаписи.ПоказатьПослеПрохождения
					И СтатусПроцессаОбучения <> Перечисления.СтатусыПроцессаОбученияСУО.Окончено
					И СтатусПроцессаОбучения <> Перечисления.СтатусыПроцессаОбученияСУО.ОконченоАвтоматом Тогда					
					Продолжить;					
				КонецЕсли;				
				
			КонецЕсли;
				
			Если НЕ Документы.ПроведениеОбученияСУО.МожноПоказатьРесурсПроведения(
					Данные.СтатусПроведенияОбучения,
					ВыборкаДетальныеЗаписи.ПоказатьПриСтатусеЗапланировано,
		            ВыборкаДетальныеЗаписи.ПоказатьПриСтатусеАктивно,
				    ВыборкаДетальныеЗаписи.ПоказатьПриСтатусеЗавершено) Тогда
				
				Продолжить;
				
			КонецЕсли;
			
			ФайлXDTO = ФабрикаXDTO.Создать(ФайлXDTOТип);
			ФайлXDTO.Наименование  = ВыборкаДетальныеЗаписи.Представление; 
			ФайлXDTO.Идентификатор = ВыборкаДетальныеЗаписи.Файл.УникальныйИдентификатор();
			ФайлXDTO.Расширение  = ВыборкаДетальныеЗаписи.Расширение;
			ФайлXDTO.Размер  = ВыборкаДетальныеЗаписи.Размер;			
			
			ФайлыXDTO.Файл.Добавить(ФайлXDTO);
			
			СписокРазмещенныхФайлов.Добавить(ВыборкаДетальныеЗаписи.Файл);
	
		КонецЦикла;

		РесурсыXDTO.Файлы = ФайлыXDTO;
		
	КонецЕсли;
	
	Возврат РесурсыXDTO;
	
КонецФункции

Функция ФайлУчащегосяJSON(Знач ДанныеПрохожденияОбучения, Знач Файл)
	
	ОписаниеФайла = Новый Структура;
	ОписаниеФайла.Вставить("Пользователь", Неопределено);
	ОписаниеФайла.Вставить("Файл", Новый Структура("Наименование, Идентификатор, ДатаЧисло, Автор, Расширение, Размер"));
	ОписаниеФайла.Вставить("ПрохождениеОбучения", Неопределено);
	
	ДанныеФайлаИменаРеквизитов = Новый Структура;
	ДанныеФайлаИменаРеквизитов.Вставить("Наименование", "Наименование");
	ДанныеФайлаИменаРеквизитов.Вставить("ДатаСоздания", "ДатаСоздания");
	ДанныеФайлаИменаРеквизитов.Вставить("Автор", "Автор");
	ДанныеФайлаИменаРеквизитов.Вставить("НаименованиеАвтора", "Автор.Наименование");
	ДанныеФайлаИменаРеквизитов.Вставить("Расширение", "Расширение");
	ДанныеФайлаИменаРеквизитов.Вставить("Размер", "Размер");

	ДанныеФайла = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Файл, ДанныеФайлаИменаРеквизитов);
		
	ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Файл, "Наименование, ДатаСоздания, Автор");
	
	ОписаниеФайла.ПрохождениеОбучения = ДанныеПрохожденияОбучения.Ссылка.УникальныйИдентификатор();
	ОписаниеФайла.Пользователь = ВебКабинетСУО.ПользовательСтруктура(ДанныеПрохожденияОбучения.Пользователь, ДанныеПрохожденияОбучения.НаименованиеПользователя);
	ОписаниеФайла.Файл.Наименование = ДанныеФайла.Наименование;
	ОписаниеФайла.Файл.Идентификатор = Файл.УникальныйИдентификатор();
	ОписаниеФайла.Файл.ДатаЧисло = ОбщегоНазначенияСУКлиентСервер.ДатаВЧислоJS(ДанныеФайла.ДатаСоздания);
	ОписаниеФайла.Файл.Автор = ВебКабинетСУО.ПользовательСтруктура(ДанныеФайла.Автор, ДанныеФайла.НаименованиеАвтора);	
	ОписаниеФайла.Файл.Расширение = ДанныеФайла.Расширение;
	ОписаниеФайла.Файл.Размер = ДанныеФайла.Размер;
	
	Возврат ОбщегоНазначенияСУ.ДанныеВJSON(ОписаниеФайла);
	
КонецФункции

// 1С-КАБИНЕТ

Функция УчебнаяАктивностьОписаниеHTML(ПрохождениеОбучения, ИдентификаторФормы = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеПрохождения = Неопределено;
	
	XMLДанные = УчебнаяАктивностьОписаниеXML(ПрохождениеОбучения, ИдентификаторФормы, ДанныеПрохождения);
	
	// Получаем представление HTML.
	
	Преобразование = Новый ПреобразованиеXSL;
	ШаблонXSL = ПолучитьОбщийМакет("ШаблонОписанияУчебнойАктивностиСУО").ПолучитьТекст();	
	
	Преобразование.ЗагрузитьИзСтроки(ШаблонXSL);
	Преобразование.ДобавитьПараметр("ПросматриваетВладелец", ОбщегоНазначенияСУКлиентСервер.БулевоВЧисло(Пользователи.ТекущийПользователь() = ДанныеПрохождения.Пользователь));
	
	ИтоговыйHTML = Преобразование.ПреобразоватьИзСтроки(XMLДанные);
	
	Возврат ИтоговыйHTML;
	
КонецФункции


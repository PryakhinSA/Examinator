#Область СлужебныеПроцедурыИФункции

// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаСервере
Процедура ЗагрузитьФоруму()
	
	АдресИнформационнойБазыСУ = Константы.АдресИнформационнойБазыСУ.Получить();
	АдресОбщегоКаталогаСУ = Константы.АдресОбщегоКаталогаСУ.Получить();
	ПутьКОбщемуКаталогуСУ = Константы.ПутьКОбщемуКаталогуСУ.Получить();
	СлужебныйПользовательУказанВПубликацииСУ = Константы.СлужебныйПользовательУказанВПубликацииСУ.Получить();
	РазрешитьЗапросыКСервисамСДругихДоменовСУ = Константы.РазрешитьЗапросыКСервисамСДругихДоменовСУ.Получить();
		
	ПараметрыКлиента = СтандартныеПодсистемыСервер.ПараметрыКлиентаНаСервере();	
	СтрокаСоединенияИнформационнойБазы = ПараметрыКлиента.Получить("СтрокаСоединенияИнформационнойБазы");	
	СтрокаСоединенияСтруктура = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(СтрокаСоединенияИнформационнойБазы,,";");
	Если СтрокаСоединенияСтруктура.Свойство("ws") Тогда
		АвтоАдресИнформационнойБазы = СтрЗаменить(СтрокаСоединенияСтруктура.ws, """", "");
		Элементы.ЗаполнитьАдресБазыАвтоматически.Видимость = Истина;
	Иначе
		Элементы.ЗаполнитьАдресБазыАвтоматически.Видимость = Ложь;
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьНастройку(ИмяЭлемента)
	
	УстановитьПривилегированныйРежим(Истина);
	Константы[ИмяЭлемента].Установить(ЭтотОбъект[ИмяЭлемента]);
	УстановитьПривилегированныйРежим(Ложь);	
	ОбновитьПовторноИспользуемыеЗначения();
	БылиИзменения = Истина;
	
КонецПроцедуры

//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//

// КК: удалить группу формы формы ГруппаИнтеграция

&НаКлиенте
Процедура НачатьВводКлючаИнтеграции(ИмяКлюча)
	Подсказка = "Укажите ключ удаленной базы";
	Оповещение = Новый ОписаниеОповещения("ПослеВводаКлюча", ЭтотОбъект, ИмяКлюча);
	ПоказатьВводСтроки(Оповещение, "", Подсказка, 0, Ложь);	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВводаКлюча(ЗначениеКлюча, ИмяКлюча) Экспорт
	Если ЗначениеКлюча <> Неопределено Тогда
		УстановитьКлючДоступаНаСервере(ИмяКлюча, ЗначениеКлюча);
		ПоказатьПредупреждение(,НСтр("ru = 'Ключ успешно установлен'"));
    КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьКлючДоступаНаСервере(ИмяКлюча, ЗначениеКлюча)
	
	Хеширование = Новый ХешированиеДанных(ХешФункция.SHA1);
	Хеширование.Добавить(ЗначениеКлюча);		
	ХэшКлюча = Base64Строка(Хеширование.ХешСумма);
	
	УстановитьПривилегированныйРежим(Истина);
	Константы[ИмяКлюча].Установить(ХэшКлюча);
	УстановитьПривилегированныйРежим(Ложь);		
	
КонецПроцедуры


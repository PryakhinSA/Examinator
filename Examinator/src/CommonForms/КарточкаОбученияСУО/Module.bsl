				Если ВыборкаДетальныеЗаписи.НайтиСледующий(СтруктураПоиска)
					И ВыборкаДетальныеЗаписи.НесколькоВариантов Тогда
					
					НомерЗадания = ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(Элемент.Номер);
					
					Строка["ВариантЗадания"+НомерЗадания] = ВыборкаДетальныеЗаписи.Вариант;
					Строка["ВариантЗадания"+НомерЗадания+"Прохождение"] = ВыборкаДетальныеЗаписи.Прохождение;
					
				КонецЕсли;
				
			КонецЦикла;
		 
		КонецЦикла;
		
	КонецЕсли; // ВыставляетсяОценка
	
	///////////////////////////////////////////////////////////////////
	// Учебные группы
	
	Если ЭтоОбразовательнаяОрганизация ИЛИ ИспользоватьСтудентов Тогда
		ЗаполнитьСписокУчебныхГруппИСтудентов();	
	КонецЕсли;
	
	///////////////////////////////////////////////////////////////////
	// Вопросы
	
	ЗаполнитьВопросыНаПроверку();
	
	///////////////////////////////////////////////////////////////////
	// Устанавливаем доступность элементов
	
	Элементы.СтраницаВопросыНаПроверку.Видимость = ?(ВопросынаПроверку.Количество() > 0, Истина, Ложь);
		
	Ведомость.Сортировать("ПолноеИмяПользователя");
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьРеквизитыЗаданияВВедомости(Строка, НомерЗадания, Данные, Оценка)
	
	Строка["Задание"+НомерЗадания+"ПроверенПреподавателем"]     = Данные.ПроверенПреподавателем;
	Строка["Задание"+НомерЗадания+"КомментарийПреподавателя"]   = Данные.КомментарийПреподавателя;
	Строка["Задание"+НомерЗадания+"ПопыткаЗавершена"]           = Данные.ПопыткаЗавершена;
	Строка["Задание"+НомерЗадания+"ВозвращеноНаДоработку"]      = Данные.ВозвращеноНаДоработку;				
	Строка["Задание"+НомерЗадания+"ПричинаВозвратаНаДоработку"] = Данные.ПричинаВозвратаНаДоработку;										
	Строка["Задание"+НомерЗадания+"ВыставляетсяОценка"]         = Данные.ВыставляетсяОценка;
	
	Если Данные.ВозвращеноНаДоработку Тогда
		
		Если ЗначениеЗаполнено(Данные.ПричинаВозвратаНаДоработку) Тогда
			Строка["Задание"+НомерЗадания] = Данные.ПричинаВозвратаНаДоработку;
		Иначе
			Строка["Задание"+НомерЗадания] = НСтр("ru = 'Возвращено на доработку'");
		КонецЕсли;
		
		Строка["Задание"+НомерЗадания+"Оценка"] = Неопределено;
		
	ИначеЕсли (Данные.ПопыткаЗавершена И Данные.ПроверенПреподавателем И Данные.ВыставляетсяОценка)
		ИЛИ (Данные.ПопыткаЗавершена И НЕ Данные.ПроверяетсяПреподавателем И Данные.ВыставляетсяОценка) Тогда
		
		Строка["Задание"+НомерЗадания+"Оценка"] = Оценка;
		Строка["Задание"+НомерЗадания]          = Оценка;
		
	Иначе
		
		Строка["Задание"+НомерЗадания+"Оценка"] = Неопределено;
		Строка["Задание"+НомерЗадания] = Неопределено;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Функция ЗаписатьСтрокуВедомости(НомерСтроки, НомерЗадания)
	
	Строка = Ведомость.НайтиПоИдентификатору(НомерСтроки);
	
	КомментарийПреподавателя   = Строка["Задание"+НомерЗадания+"КомментарийПреподавателя"];
	ОценкаЗаЗадание            = Строка["Задание"+НомерЗадания+"Оценка"];
	НесколькоВариантов         = Строка["Задание"+НомерЗадания+"НесколькоВариантов"];
	ПричинаВозвратаНаДоработку = Строка["Задание"+НомерЗадания+"ПричинаВозвратаНаДоработку"];
	ПопыткаЗавершена           = Строка["Задание"+НомерЗадания+"ПопыткаЗавершена"];
	ПопыткаВыполненияЗадания   = Строка["Задание"+НомерЗадания+"Прохождение"];
	Задание                    = Строка["Задание"+НомерЗадания+"Ссылка"];
	
	Возврат ОбучениеСУО.ПриПрохожденииЗадания(Строка.Прохождение, Задание, ОценкаЗаЗадание, КомментарийПреподавателя, Истина, Неопределено,,,ПопыткаЗавершена,,Ложь,ПопыткаВыполненияЗадания,ПричинаВозвратаНаДоработку,Пользователи.ТекущийПользователь());	
		
КонецФункции

&НаСервере
Процедура УстановитьАктуальностьПроведенияПреподавателемОбучения(Значение)
	
	Документы.ПроведениеПреподавателемОбученияСУО.УстановитьОтметкуПроведено(Обучение, Значение); 
	Актуально = Документы.ПроведениеПреподавателемОбученияСУО.Актуально(Обучение);
	
	УстановитьДоступностьЭлементовВедомости();
		
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьЭлементовВедомости() 
	
	Если ВидОбучения.ВыставляетсяОценка Тогда
		
		Элементы.ВедомостьИтоговаяОценка.Видимость = Истина;
		
		Если Задания.Количество() = 0 И НЕ ЭтоЭлектронноеОбучение Тогда			
			Элементы.ВедомостьИтоговаяОценка.ТолькоПросмотр = Ложь;
			Элементы.ВедомостьЗаписатьИтоговыеОценкиВедомости.Видимость = Истина;
		Иначе			
			Элементы.ВедомостьИтоговаяОценка.ТолькоПросмотр = Истина;			
			Элементы.ВедомостьЗаписатьИтоговыеОценкиВедомости.Видимость = Ложь;
		КонецЕсли;
		
	Иначе
		
		Элементы.ВедомостьИтоговаяОценка.Видимость = Ложь;
		Элементы.ВедомостьЗаписатьИтоговыеОценкиВедомости.Видимость = Ложь;
		
	КонецЕсли;
	
	Элементы.ВедомостьТекущаяОценка.Видимость = ПоказыватьТекущуюОценку;
	
	Если Задания.Количество() > 0 ИЛИ ТипЗнч(Сценарий) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда
		Элементы.ВедомостьПроверитьОбучениеУчащегося.Видимость = Истина;
	Иначе
		Элементы.ВедомостьПроверитьОбучениеУчащегося.Видимость = Ложь;
	КонецЕсли;
	
	Если ТипЗнч(Сценарий) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда
		Элементы.ВедомостьПроверитьОбучениеУчащегося.Заголовок = НСтр("ru = 'Проверить'");
	КонецЕсли;
	
	СтатусПроцессаПреподавания = Документы.ПроведениеПреподавателемОбученияСУО.СтатусПроцессаПреподавания(Обучение);
	
	Если СтатусПроцессаПреподавания = Перечисления.СтатусыПроцессаПреподаванияСУО.Провожу Тогда
		Элементы.ВедомостьЗакончитьПроведениеПреподавателемОбучения.Видимость = Истина;
	Иначе
		Элементы.ВедомостьЗакончитьПроведениеПреподавателемОбучения.Видимость = Ложь;
	КонецЕсли;
	
	Если СтатусПроцессаПреподавания = Перечисления.СтатусыПроцессаПреподаванияСУО.Провел Тогда
		Элементы.ВедомостьАктивизироватьПроведениеПреподавателемОбучения.Видимость = Истина;
	Иначе
		Элементы.ВедомостьАктивизироватьПроведениеПреподавателемОбучения.Видимость = Ложь;
	КонецЕсли;
	
	
	Элементы.ВедомостьЗаписатьИтоговыеОценкиВедомости.Доступность = Актуально;
	Элементы.ВедомостьПроверитьОбучениеУчащегося.Доступность = Актуально;
	Элементы.ВедомостьНаписатьКомментарийУчастнику.Доступность = Актуально;
	
	Если СтатусПроцессаПреподавания = Перечисления.СтатусыПроцессаПреподаванияСУО.Запланировано Тогда
		Элементы.ВедомостьУстановитьСтатусПроходит.Доступность = Истина;
		Элементы.ВедомостьУстановитьСтатусЗавершил.Доступность = Ложь;
		Элементы.ВедомостьУстановитьСтатусНеЗавершил.Доступность = Ложь;
		Элементы.ВедомостьУстановитьСтатусНеДопущен.Доступность = Истина;
		Элементы.ВедомостьУстановитьСтатусАвтомат.Доступность = Истина;		
		Элементы.ВедомостьУстановитьСтатусПроходитДляВсех.Доступность = Истина;
		Элементы.ВедомостьУстановитьСтатусЗавершилДляВсех.Доступность = Ложь;
		Элементы.ВедомостьУстановитьСтатусНеЗавершилДляВсех.Доступность = Ложь;
		Элементы.ВедомостьУстановитьСтатусНеДопущенДляВсех.Доступность = Истина;
		Элементы.ВедомостьУстановитьСтатусАвтоматДляВсех.Доступность = Истина;	
	Иначе
		Элементы.ВедомостьГруппаКнопокСтатусы.Доступность = Актуально;	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокУчебныхГруппИСтудентов()
	
	УстановитьПривилегированныйРежим(Истина);
	
	УчебныеГруппыОО.Очистить();	
	
	МассивПользователей = Новый Массив();
	
	Для каждого Строка Из Ведомость Цикл
		МассивПользователей.Добавить(Строка.Пользователь);	
	КонецЦикла;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтудентыООСрезПоследних.Пользователь,
		|	СтудентыООСрезПоследних.УчебнаяГруппа
		|ИЗ
		|	РегистрСведений.СтудентыОО.СрезПоследних КАК СтудентыООСрезПоследних
		|ГДЕ
		|	СтудентыООСрезПоследних.Пользователь В (&МассивПользователей)";

	Запрос.УстановитьПараметр("МассивПользователей", МассивПользователей);

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	//Заполняем таблицы
	//
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		//Ведомость
		
		НайденныеСтроки = Ведомость.НайтиСтроки(Новый Структура("Пользователь", ВыборкаДетальныеЗаписи.Пользователь));
		СтрокаВедомости = НайденныеСтроки[0]; //Есть всегда
		
		СтрокаВедомости.УчебнаяГруппаОО = ВыборкаДетальныеЗаписи.УчебнаяГруппа;
		
		//Учебные группы
		
		НайденныеСтроки = УчебныеГруппыОО.НайтиСтроки(Новый Структура("УчебнаяГруппа", ВыборкаДетальныеЗаписи.УчебнаяГруппа));
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			
			СтрокаУчебнойГруппы = УчебныеГруппыОО.Добавить();                                 
			СтрокаУчебнойГруппы.УчебнаяГруппа = ВыборкаДетальныеЗаписи.УчебнаяГруппа;
			СтрокаУчебнойГруппы.Наименование  = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыборкаДетальныеЗаписи.УчебнаяГруппа, "Наименование");
			
		Иначе
			
			СтрокаУчебнойГруппы = НайденныеСтроки[0];
			
		КонецЕсли;
		
		СтрокаУчебнойГруппы.КоличествоСтудентов = СтрокаУчебнойГруппы.КоличествоСтудентов + 1;
		СтрокаУчебнойГруппы.СуммаБалловСтудентов = СтрокаУчебнойГруппы.СуммаБалловСтудентов + СтрокаВедомости.Баллы;
		
		Если СтрокаВедомости.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Зачислен Тогда
			СтрокаУчебнойГруппы.КоличествоЗачисленныхСтудентов = СтрокаУчебнойГруппы.КоличествоЗачисленныхСтудентов + 1;
		КонецЕсли;
		
		Если СтрокаВедомости.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Проходит Тогда
			СтрокаУчебнойГруппы.КоличествоВыполняющихСтудентов = СтрокаУчебнойГруппы.КоличествоВыполняющихСтудентов + 1;
		КонецЕсли;
		
		Если СтрокаВедомости.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Завершил Тогда
			СтрокаУчебнойГруппы.КоличествоЗавершившихСтудентов = СтрокаУчебнойГруппы.КоличествоЗавершившихСтудентов + 1;
		КонецЕсли;
		
		Если СтрокаВедомости.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.Автомат Тогда
			СтрокаУчебнойГруппы.КоличествоЗавершившихСтудентов = СтрокаУчебнойГруппы.КоличествоЗавершившихСтудентов + 1;
		КонецЕсли;
		
		Если СтрокаВедомости.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.НеЗавершил Тогда
			СтрокаУчебнойГруппы.КоличествоНеЗавершившихСтудентов = СтрокаУчебнойГруппы.КоличествоНеЗавершившихСтудентов + 1;
		КонецЕсли;
		
		Если СтрокаВедомости.Статус = Перечисления.СтатусыПрохожденияОбъектовСУО.НеДопущен Тогда
			СтрокаУчебнойГруппы.КоличествоНеДопущенныхСтудентов = СтрокаУчебнойГруппы.КоличествоНеДопущенныхСтудентов + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	//Считаем сводные данные
	//
	
	//Учебные группы
	
	Для каждого Строка Из УчебныеГруппыОО Цикл
		
		Если Строка.СуммаБалловСтудентов > 0 Тогда
			Строка.СреднийБалл = Окр(Строка.СуммаБалловСтудентов / Строка.КоличествоСтудентов, 2);
		КонецЕсли;
		
	КонецЦикла;
	
	//Сортируем и делаем отбор
	//
	
	УчебныеГруппыОО.Сортировать("Наименование");	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВопросыНаПроверку()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОтветНаВопросСУЗ.Ссылка,
		|	ОтветНаВопросСУЗ.Пользователь,
		|	ОтветНаВопросСУЗ.ДатаОтвета,
		|	ОтветНаВопросСУЗ.ПроверенПреподавателем,
		|	ОтветНаВопросСУЗ.Вопрос.Наименование КАК Наименование,
		|	ОтветНаВопросСУЗ.СессияВыполненияТеста,
		|	ОтветНаВопросСУЗ.СессияВыполненияТеста.ПрохождениеОбучения КАК ПрохождениеОбучения,
		|	ОтветНаВопросСУЗ.СессияВыполненияТеста.Задание КАК Задание,
		|	ПопыткаВыполненияПодборкиВопросовСУЗГруппыПодборки.НомерСтроки КАК НомерГруппыПодборки
		|ИЗ
		|	Документ.ОтветНаВопросСУЗ КАК ОтветНаВопросСУЗ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПопыткаВыполненияПодборкиВопросовСУЗ.Вопросы КАК ПопыткаВыполненияПодборкиВопросовСУЗВопросы
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПопыткаВыполненияПодборкиВопросовСУЗ.ГруппыПодборки КАК ПопыткаВыполненияПодборкиВопросовСУЗГруппыПодборки
		|			ПО ПопыткаВыполненияПодборкиВопросовСУЗВопросы.ГруппаПодборки = ПопыткаВыполненияПодборкиВопросовСУЗГруппыПодборки.ГруппаПодборки
		|				И ПопыткаВыполненияПодборкиВопросовСУЗВопросы.Ссылка = ПопыткаВыполненияПодборкиВопросовСУЗГруппыПодборки.Ссылка
		|		ПО ОтветНаВопросСУЗ.СессияВыполненияТеста = ПопыткаВыполненияПодборкиВопросовСУЗВопросы.Ссылка
		|			И ОтветНаВопросСУЗ.Вопрос = ПопыткаВыполненияПодборкиВопросовСУЗВопросы.Вопрос
		|ГДЕ
		|	ОтветНаВопросСУЗ.ПроверяетсяПреподавателем = ИСТИНА
		|	И ОтветНаВопросСУЗ.Проведен = ИСТИНА
		|	И ОтветНаВопросСУЗ.ВопросОтвечен = ИСТИНА
		|   И ОтветНаВопросСУЗ.Отменено = ЛОЖЬ
		|	И ОтветНаВопросСУЗ.СессияВыполненияТеста.ПрохождениеОбучения.ПроведениеОбучения = &ПроведениеМероприятия
		|	И ОтветНаВопросСУЗ.СессияВыполненияТеста.Подборка.НазначениеТестирования <> &НазначениеТестированияАнкета";

	Запрос.УстановитьПараметр("ПроведениеМероприятия", ПроведениеОбучения);
	Запрос.УстановитьПараметр("НазначениеТестированияАнкета", Перечисления.НазначенияТестированийСУЗ.Анкетирование);

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		НайденныеСтроки = ВопросыНаПроверку.НайтиСтроки(Новый Структура("ОтветНаВопрос", ВыборкаДетальныеЗаписи.Ссылка));
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			НоваяСтрока = ВопросыНаПроверку.Добавить();
		Иначе
			НоваяСтрока = НайденныеСтроки[0];
		КонецЕсли;
		
		НоваяСтрока.Наименование = ВыборкаДетальныеЗаписи.Наименование;
		НоваяСтрока.ОтветНаВопрос = ВыборкаДетальныеЗаписи.Ссылка;
		НоваяСтрока.Проверен = ВыборкаДетальныеЗаписи.ПроверенПреподавателем;
		НоваяСтрока.ДатаОтвета = ВыборкаДетальныеЗаписи.ДатаОтвета;
		НоваяСтрока.Пользователь = ВыборкаДетальныеЗаписи.Пользователь;
		НоваяСтрока.СессияТестирования = ВыборкаДетальныеЗаписи.СессияВыполненияТеста;
		НоваяСтрока.ПрохождениеОбучения = ВыборкаДетальныеЗаписи.ПрохождениеОбучения;
		НоваяСтрока.Задание = ВыборкаДетальныеЗаписи.Задание;
		НоваяСтрока.НомерГруппыПодборки = ВыборкаДетальныеЗаписи.НомерГруппыПодборки;
		
		НайденныеСтроки = Ведомость.НайтиСтроки(Новый Структура("Пользователь", НоваяСтрока.Пользователь));
		
		Если НайденныеСтроки.Количество() > 0 Тогда
			НоваяСтрока.УчебнаяГруппа = НайденныеСтроки[0].УчебнаяГруппаОО;		
		КонецЕсли;
		
	КонецЦикла;
	
	//Считаем сводные данные
	//
	
	// Ведомость
	
	Для каждого Строка Из Ведомость Цикл
		
		СтрокиВопросыНаПроверку = ВопросыНаПроверку.НайтиСтроки(Новый Структура("Пользователь, Проверен", Строка.Пользователь, Ложь));
		
		Строка.КоличествоВопросовНаПроверку = СтрокиВопросыНаПроверку.Количество();
	
	КонецЦикла;
	
	//Учебные группы
	
	Для каждого Строка Из УчебныеГруппыОО Цикл
		
		СтрокиВопросыНаПроверку = ВопросыНаПроверку.НайтиСтроки(Новый Структура("УчебнаяГруппа, Проверен", Строка.УчебнаяГруппа, Ложь));
		
		Строка.КоличествоВопросовНаПроверку = СтрокиВопросыНаПроверку.Количество();
		
	КонецЦикла;
	
	//Сортируем
	
	ВопросыНаПроверку.Сортировать("ДатаОтвета");
	
КонецПроцедуры

&НаКлиенте
Процедура НаписатьПользователюВедомости(Команда)

	ТекущиеДанные = Элементы.Ведомость.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("Контекст", ТекущиеДанные.Пользователь);
	ОткрытьФорму("Документ.СообщениеСУО.ФормаОбъекта", ПараметрыФормы);	
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьИтоговыеОценкиВедомостиНаСервере()
	
	Для каждого СтрокаВедомости Из Ведомость Цикл
		Если ЗначениеЗаполнено(СтрокаВедомости.ИтоговаяОценка) Тогда
			ОбучениеСУО.ПриПрохожденииМероприятия(СтрокаВедомости.Прохождение, Перечисления.СтатусыПрохожденияОбъектовСУО.Завершил,,СтрокаВедомости.ИтоговаяОценка);
		КонецЕсли;		
	КонецЦикла;

	ЗагрузитьВедомость();

	Модифицированность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура НаписатьКомментарийУчастнику()
	
	ТекущиеДанные = Элементы.Ведомость.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("КомментарийЗавершениеВвода", ЭтотОбъект, Элементы.Ведомость.ТекущаяСтрока);
	ОбщегоНазначенияКлиент.ПоказатьФормуРедактированияМногострочногоТекста(Оповещение, ТекущиеДанные.Комментарий, НСтр("ru = 'Укажите комментарий для участника'"));
	
КонецПроцедуры

&НаКлиенте
Процедура КомментарийЗавершениеВвода(Знач ВведенныйТекст, Знач ДополнительныеПараметры) Экспорт
	Если ВведенныйТекст = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекущаяСтрока = Ведомость.НайтиПоИдентификатору(ДополнительныеПараметры);
	ТекущаяСтрока.Комментарий = ВведенныйТекст;
	ЗаписатьКомментарийПрохождения(ТекущаяСтрока.Прохождение, ВведенныйТекст);
КонецПроцедуры

// Общее

&НаКлиенте
Процедура ОткрытьОбъект(СтруктураСсылки, УникальныйИдентификатор, Владелец, Пользователь=Неопределено) Экспорт
	
	ИмяОбъекта = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "object");
	
	Если ЗначениеЗаполнено(ИмяОбъекта) Тогда
		
		ОписаниеОбъекта = УправлениеОбучениемСУОВызовСервера.ПолучитьОписаниеОбъектаДляОткрытияПоСсылке(СтруктураСсылки); // Вызов сервера
		
		Если ОписаниеОбъекта.ИмяОбъекта = "book" Тогда
			ПараметрыФормы = Новый Структура("Книга", ОписаниеОбъекта.Ссылка);
			ОткрытьФорму("Справочник.ЛитератураСУО.Форма.ФормаКарточка", ПараметрыФормы);
		КонецЕсли;
	
		Если ОписаниеОбъекта.ИмяОбъекта = "teacher" Тогда
			
			ПоказатьЗначение(,ОписаниеОбъекта.Пользователь);
			
			//--| БШ |--//
			// ПараметрыФормы = Новый Структура("Контекст", ОписаниеОбъекта.Пользователь);
			// ОткрытьФорму("Документ.СообщениеСУО.ФормаОбъекта", ПараметрыФормы);
			//----------//
			
		КонецЕсли;
		
		Если ОписаниеОбъекта.ИмяОбъекта = "file" Тогда
			
			ДанныеФайла = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаДляОткрытия(ОписаниеОбъекта.Ссылка,, УникальныйИдентификатор);
			РаботаСФайламиКлиент.ОткрытьФайл(ДанныеФайла);
			
		КонецЕсли;
		
		Если ОписаниеОбъекта.ИмяОбъекта = "electronicResource" Тогда
			
			ОбъектыСУЗКлиент.ОткрытьОбозреватель(ОписаниеОбъекта.Ссылка,
												 ?(ОписаниеОбъекта.Свойство("Фрагмент"), ОписаниеОбъекта.Фрагмент, Неопределено),
												 ?(ОписаниеОбъекта.Свойство("Фрагмент"), Истина, Ложь),
												 ?(ОписаниеОбъекта.Свойство("Фрагмент"), ОписаниеОбъекта.Фрагмент, Неопределено)
                                                 ,
									             ,
									             ,
                                                 ,
                                                 ,
                                                 Пользователь);
												 
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура СформироватьОписание(Знач МенеджерОбучения = Неопределено)
	
	Если МенеджерОбучения = Неопределено Тогда
		МенеджерОбучения = ОбщегоНазначения.МенеджерОбъектаПоСсылке(Обучение);
	КонецЕсли;
	
	Описание = МенеджерОбучения.УчебнаяАктивностьОписаниеHTML(Обучение, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредложитьЗавершитьОбучение()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПредложитьЗавершитьОбучениеПродолжение", ЭтотОбъект);		
		
	ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'Завершить обучение?'"), РежимДиалогаВопрос.ДаНет, 0);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредложитьЗавершитьОбучениеПродолжение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда

		РезультатЗавершения = ОбучениеСУО.ПриПрохожденииМероприятия(Обучение, "Завершил",,,,,,Истина);
		
		Если РезультатЗавершения.Свойство("Сообщение")
			И ЗначениеЗаполнено(РезультатЗавершения.Сообщение.Текст) Тогда
			
			ПоказатьПредупреждение(,РезультатЗавершения.Сообщение.Текст);
			
		КонецЕсли;

		СформироватьОписание();

		Оповестить("ОбновитьМоеОбучение");
		
	КонецЕсли;	
	
КонецПроцедуры	

&НаКлиенте
Процедура ОткрытьФайл(Файл) Экспорт
	
	ДанныеФайла = РаботаСФайламиСлужебныйВызовСервера.ПолучитьДанныеФайла(Файл, УникальныйИдентификатор);
	
	ПрисоединенныеФайлыКлиент.ОткрытьФайл(ДанныеФайла);		
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьТаблицуЗаданий()
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем таблицу заданий
	
	Задания.Очистить();
	
	Если ТипЗнч(Обучение) = Тип("ДокументСсылка.ПроведениеПреподавателемОбученияСУО") Тогда
		Возврат;
	КонецЕсли;
	
	УчитыватьПоследовательностьПрохождения = Документы.ПрохождениеОбученияСУО.ПоследовательноеПрохождениеЗаданий(Обучение, ПроведениеОбучения, Сценарий);
	
	ТаблицаЗаданий = Документы.ПрохождениеОбученияСУО.ЗаданияПрохождения(Обучение);
	ЗаданияДоступны = Документы.ПрохождениеОбученияСУО.ЗаданияДоступны(Обучение, ПроведениеОбучения, Сценарий, ВидОбучения);
	ПредыдущееЗаданиеСтрока = Неопределено;
	ПоказатьКолонкуПроходнойБалл = Ложь;
	
	Для каждого Строка Из ТаблицаЗаданий Цикл
	
		НоваяСтрока = Задания.Добавить();
		
		НоваяСтрока.Задание                      = Строка.Задание;
		НоваяСтрока.Наименование                 = Строка.Наименование;
		НоваяСтрока.Значимость                   = Строка.Значимость;
		НоваяСтрока.Вариант                      = Строка.Вариант;
		
		НоваяСтрока.НаОсновеЭлектронногоРесурса  = Строка.НаОсновеЭлектронногоРесурса;
		НоваяСтрока.ЭлектронныйРесурс            = Строка.ЭлектронныйРесурс;
		НоваяСтрока.Фрагмент                     = Строка.Фрагмент;
		
		НоваяСтрока.ПроверяетсяПреподавателем    = Строка.ПроверяетсяПреподавателем;
		НоваяСтрока.ПроверенПреподавателем       = Строка.ПроверенПреподавателем;
		НоваяСтрока.ПопыткаВыполнения            = Строка.ПопыткаВыполнения;
		НоваяСтрока.НеЖдатьПроверки              = Строка.НеЖдатьПроверки;
		НоваяСтрока.ЗаданиеЗавершено             = Строка.Завершено;
		НоваяСтрока.ПроходнойБалл                = Строка.ПроходнойБалл;
		НоваяСтрока.Баллы                        = Строка.Баллы;
		НоваяСтрока.ТолькоПросмотр               = НЕ Актуально;
		
		НоваяСтрока.ДатаОкончанияДоступаКЗаданию = Строка.ДатаОкончанияДоступаКЗаданию;
		НоваяСтрока.ДатаНачалаДоступаКЗаданию    = Строка.ДатаНачалаДоступаКЗаданию;
		НоваяСтрока.СкрытьВремяДоступаКЗаданию   = Строка.СкрытьВремяДоступаКЗаданию;
		
		Если ЗначениеЗаполнено(Строка.ПопыткаВыполнения) Тогда
			Если Строка.НаОсновеЭлектронногоРесурса Тогда
				НоваяСтрока.Завершено = Строка(Строка.ЗавершеноВПроцентах) + "%";
			Иначе
				НоваяСтрока.Завершено = ?(Строка.Завершено, "Да", "Нет");
			КонецЕсли;
		КонецЕсли;
		
		Если ВидОбучения.ЗаданияПроверяютсяВыборочно Тогда
			Если ЗначениеЗаполнено(Строка.ПопыткаВыполнения) Тогда
				Если Строка.НаОсновеЭлектронногоРесурса Тогда
					НоваяСтрока.ЗаданиеВыполнено = Строка.Завершено И Строка.Баллы >= Строка.ПроходнойБалл;
				Иначе
					НоваяСтрока.ЗаданиеВыполнено = Строка.Завершено;
				КонецЕсли;
			Иначе
				НоваяСтрока.ЗаданиеВыполнено = Ложь;
			КонецЕсли;
		Иначе			
			НоваяСтрока.ЗаданиеВыполнено = Документы.ПопыткаВыполненияЗаданияСУО.Выполнено(Строка.ПопыткаВыполнения, Строка.Завершено, Строка.ПроверяетсяПреподавателем, Строка.ПроверенПреподавателем, Строка.Баллы, Строка.ПроходнойБалл, Строка.ДатаОкончанияДоступаКЗаданию);
		КонецЕсли;
		
		ПолученаОценка = Документы.ПопыткаВыполненияЗаданияСУО.ПолученаОценка(Строка.ПопыткаВыполнения, Строка.Завершено, Строка.ПроверяетсяПреподавателем, Строка.ПроверенПреподавателем, Строка.ДатаОкончанияДоступаКЗаданию, Строка.ВыставляетсяОценка); 
		
		НоваяСтрока.Оценка = Неопределено;		
		Если ПолученаОценка Тогда
			НоваяСтрока.Оценка = УправлениеОбучениемСУОПовтИсп.ОценкаИзБаллов(Строка.Баллы, Строка.ШкалаОценки);
			Если Справочники.ШкалыОценокСУО.ПоказыватьБаллыВместеСОценкой(Строка.ШкалаОценки) Тогда
				НоваяСтрока.Оценка = НоваяСтрока.Оценка + " (" + ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(Строка.Баллы) + " баллов)";
			КонецЕсли;			
		КонецЕсли;
		
		Если НЕ ВидОбучения.ПоказыватьПодробныеСведенияОЗадании
			И НоваяСтрока.Значимость = 0 Тогда
			НоваяСтрока.Оценка = Неопределено;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Строка.ДатаНачалаДоступаКЗаданию)
			ИЛИ ЗначениеЗаполнено(Строка.ДатаОкончанияДоступаКЗаданию) Тогда
			
			НоваяСтрока.ПродолжительностьСтрока = ОбщегоНазначенияСУКлиентСервер.ПериодВСтроку(
				Строка.ДатаНачалаДоступаКЗаданию, Строка.ДатаОкончанияДоступаКЗаданию, Строка.СкрытьВремяДоступаКЗаданию);
			
		КонецЕсли;
		
		НоваяСтрока.ДоступноДляПрохождения = ЗаданияДоступны;
		
		Если НоваяСтрока.ДоступноДляПрохождения
			И ЗначениеЗаполнено(Строка.ДатаНачалаДоступаКЗаданию)
			И Строка.ДатаНачалаДоступаКЗаданию > ТекущаяДатаСеанса() Тогда
				
			НоваяСтрока.ДоступноДляПрохождения = Ложь;
				
		КонецЕсли;
			
		Если НоваяСтрока.ДоступноДляПрохождения И УчитыватьПоследовательностьПрохождения И ПредыдущееЗаданиеСтрока <> Неопределено Тогда
			Если ПредыдущееЗаданиеСтрока.ДоступноДляПрохождения Тогда				
				Если ВидОбучения.ЗаданияПроверяютсяВыборочно ИЛИ ПредыдущееЗаданиеСтрока.НеЖдатьПроверки Тогда
					Если НЕ ПредыдущееЗаданиеСтрока.ЗаданиеЗавершено Тогда
						НоваяСтрока.ДоступноДляПрохождения = Ложь;
					ИначеЕсли ПредыдущееЗаданиеСтрока.НаОсновеЭлектронногоРесурса И ПредыдущееЗаданиеСтрока.Баллы < ПредыдущееЗаданиеСтрока.ПроходнойБалл Тогда
						НоваяСтрока.ДоступноДляПрохождения = Ложь;
					КонецЕсли;
				Иначе
					НоваяСтрока.ДоступноДляПрохождения = ПредыдущееЗаданиеСтрока.ЗаданиеВыполнено;	
				КонецЕсли;	
			Иначе
				НоваяСтрока.ДоступноДляПрохождения = Ложь;
			КонецЕсли;
		КонецЕсли;	
		
		НоваяСтрока.ПроходнаяОценка = Неопределено;
		
		Если ВидОбучения.ЗаданияПроверяютсяВыборочно И НЕ НоваяСтрока.НаОсновеЭлектронногоРесурса Тогда
			НоваяСтрока.ПроходнаяОценка = "";
		Иначе
			Если Строка.ПроходнойБалл > 0 Тогда
				ПоказатьКолонкуПроходнойБалл = Истина;
				Если НоваяСтрока.ДоступноДляПрохождения Тогда
					НоваяСтрока.ПроходнаяОценка = УправлениеОбучениемСУОПовтИсп.ОценкаИзБаллов(Строка.ПроходнойБалл, Строка.ШкалаОценки);
					Если Справочники.ШкалыОценокСУО.ПоказыватьБаллыВместеСОценкой(Строка.ШкалаОценки)
						И ВидОбучения.ПоказыватьПодробныеСведенияОЗадании  Тогда
						НоваяСтрока.ПроходнаяОценка = НоваяСтрока.ПроходнаяОценка + " (" + НСтр("ru = 'мин. '") 
							+ ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(Строка.ПроходнойБалл) + " баллов)";
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;					
		КонецЕсли;		
		
		Если ЗначениеЗаполнено(Строка.ПопыткаВыполнения) И НоваяСтрока.ДоступноДляПрохождения Тогда			
			Если НоваяСтрока.ПроверяетсяПреподавателем Тогда
				Если Строка.ВозвращеноНаДоработку Тогда
					НоваяСтрока.Проверен = НСтр("ru = 'Возвращено на доработку'");
				Иначе
					Если Строка.Завершено Тогда
						НоваяСтрока.Проверен = ?(НоваяСтрока.ПроверенПреподавателем, НСтр("ru = 'Проверено'"), НСтр("ru = 'Проверяется'"));
					Иначе
						НоваяСтрока.Проверен = "";
					КонецЕсли;
				КонецЕсли;			
			Иначе
				НоваяСтрока.Проверен = НСтр("ru = 'Не требует проверки'");
			КонецЕсли;					
		Иначе
			НоваяСтрока.Проверен = "";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Строка.ПопыткаВыполнения)
			И Строка.Завершено
			И ЗначениеЗаполнено(НоваяСтрока.ПроходнаяОценка)
			И Строка.Баллы < Строка.ПроходнойБалл
			И (НЕ Строка.ПроверяетсяПреподавателем ИЛИ Строка.ПроверенПреподавателем)
			И ВидОбучения.ПоказыватьПодробныеСведенияОЗадании Тогда
			
			НоваяСтрока.ВыделитьОценку = Истина;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Строка.ПопыткаВыполнения)
			И Строка.Завершено
			И ЗначениеЗаполнено(НоваяСтрока.ПроходнаяОценка)
			И Строка.Баллы < Строка.ПроходнойБалл
			И (НЕ Строка.ПроверяетсяПреподавателем ИЛИ Строка.ПроверенПреподавателем)
			И НЕ ВидОбучения.ПоказыватьПодробныеСведенияОЗадании Тогда
			
			НоваяСтрока.Завершено = НСтр("ru = 'Улучшите оценку!'")
			
		КонецЕсли;
		
		ПредыдущееЗаданиеСтрока = НоваяСтрока;
		
	КонецЦикла;
	
	Элементы.ЗаданияПроходнаяОценка.Видимость = ПоказатьКолонкуПроходнойБалл;
	
	Если НЕ ВидОбучения.ПоказыватьПодробныеСведенияОЗадании Тогда
		Элементы.ЗаданияПроходнаяОценка.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатусПрохождения(ИмяСтатуса)
	
	ТекущиеДанные = Элементы.Ведомость.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Прохождения = Новый Массив;
	Прохождения.Добавить(ТекущиеДанные.Прохождение);
	ЗаписатьСтатусПрохождений(Прохождения, ПредопределенноеЗначение("Перечисление.СтатусыПрохожденияОбъектовСУО."+ИмяСтатуса));
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатусПрохожденияДляВсех(ИмяСтатуса)
	
	Прохождения = Новый Массив;
	Для каждого Строка Из Ведомость Цикл
		Прохождения.Добавить(Строка.Прохождение);
	КонецЦикла;
	
	ЗаписатьСтатусПрохождений(Прохождения, ПредопределенноеЗначение("Перечисление.СтатусыПрохожденияОбъектовСУО."+ИмяСтатуса));
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьСтатусПрохождений(ПрохожденияОбучения, СтатусПрохождения)
	
	НачатьТранзакцию();
	
	Попытка
		
		Для каждого ПрохождениеОбучения Из ПрохожденияОбучения Цикл	
			ЗаписатьСтатусПрохождения(ПрохождениеОбучения, СтатусПрохождения);	
		КонецЦикла;	
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
	ЗагрузитьВедомость();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьСтатусПрохождения(ПрохождениеОбучения, СтатусПрохождения)	
	ОбучениеСУО.ПриПрохожденииМероприятия(ПрохождениеОбучения, СтатусПрохождения);					
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьКомментарийПрохождения(ПрохождениеОбучения, Комментарий)	
	ОбучениеСУО.ПриПрохожденииМероприятия(ПрохождениеОбучения,,Комментарий);
КонецПроцедуры

&НаКлиенте
Процедура НаписатьПреподавателю(Команда)
	
	ТекущиеДанные = Элементы.Преподаватели.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("Контекст", ТекущиеДанные.Преподаватель);
	ОткрытьФорму("Документ.СообщениеСУО.ФормаОбъекта", ПараметрыФормы);	
	
КонецПроцедуры

#КонецОбласти


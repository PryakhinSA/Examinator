	ЧтениеXML.ОткрытьФайл(ПутьКВременномуФайлуXML);		
	
	Пока ЧтениеXML.Прочитать() Цикл
		
		Пока ВозможностьЧтенияXML(ЧтениеXML) Цикл 
			
			ТекущийОбъект = ПрочитатьXML(ЧтениеXML);
			

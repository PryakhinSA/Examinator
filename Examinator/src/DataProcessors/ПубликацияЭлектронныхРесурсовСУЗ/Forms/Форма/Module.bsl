	ПоказатьПредупреждение(,НСтр("ru = 'Удаление всех публикаций завершено'"));
КонецПроцедуры

//----------------------------------//

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ


&НаСервере
Функция ВыполнитьПубликацию()
	
	ОтменитьПроцессПубликации();
	
	Если Объект.ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS
		И НЕ ЗначениеЗаполнено(ОбъектыСУЗПовтИсп.ПутьКОбщемуКаталогу()) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			ОбщегоНазначенияСУПовтИсп.ТекстОНеобходимостиНастроитьОбщийКаталог());
		
		Возврат Неопределено;
		
	КонецЕсли;	

	ТаблицаЭР = Объект.ЭлектронныеРесурсы.Выгрузить();
	
	Если Объект.ТипПубликации <> Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS Тогда
		Для каждого СтрокаТЭР Из ТаблицаЭР Цикл
			СтрокаТЭР.РазмещениеКнопкиВыхода = Перечисления.ВариантыРазмещенияКнопкиВыходаСУЗ.ПустаяСсылка();
		КонецЦикла;	
	КонецЕсли;
	
	ПараметрыПубликации = Новый Структура("
		|ТипПубликации,
		|Описание,
		|УдалитьСтарыеПубликации,
		|ДляТестирования,
		|СохранятьАктивность,
		|ВключитьБраузер,
		|ПредпочитатьФорматВидеоWEBM,
		|ЭлектронныеРесурсы,
		|РазмещениеКнопкиВыхода,
		|УникальныйИдентификатор,
		|КаталогДляСохранения,
		|ВключитьИнтерфейсПреподавателя,
		|ПарольПользователя,
		|ПарольПреподавателя,
		|ПользовательскиеСтили,
		|ЯзыкИнтерфейса,
		|ПоискРазрешен",
		Объект.ТипПубликации,
		Объект.Описание,
		Объект.УдалитьСтарыеПубликации,
		Объект.ДляТестирования,
		Объект.СохранятьАктивность,
		Объект.ВключитьБраузер,
		Объект.ПредпочитатьФорматВидеоWEBM,
		ТаблицаЭР.ВыгрузитьКолонку("ЭлектронныйРесурс"),
		ТаблицаЭР.ВыгрузитьКолонку("РазмещениеКнопкиВыхода"),
		УникальныйИдентификатор,
		Объект.КаталогДляСохранения,
	    Объект.ВключитьИнтерфейсПреподавателя,
		Объект.ПарольПользователя,
		Объект.ПарольПреподавателя,
		Объект.ПользовательскиеСтили,
		Объект.ЯзыкИнтерфейса,
		Объект.ПоискРазрешен);
	
	РезультатВыполнения = ДлительныеОперации.ЗапуститьВыполнениеВФоне(
		УникальныйИдентификатор, 
		"РазработкаСУЗ.ОпубликоватьПакетДанных", 
		ПараметрыПубликации, 
		НСтр("ru = 'Публикация электронных ресурсов'"),
		Истина);
					
	АдресХранилища               = РезультатВыполнения.АдресХранилища;
	АдресХранилищаДополнительный = РезультатВыполнения.АдресХранилищаДополнительный;
	ИдентификаторЗадания         = РезультатВыполнения.ИдентификаторЗадания;

	УстановитьДоступностьЭлементовФормы();
	
	Возврат РезультатВыполнения;
	
КонецФункции

&НаКлиенте
Процедура Подключаемый_ПроверитьВыполнениеПубликации()  
	
	Попытка
		Если ЗаданиеВыполнено(ИдентификаторЗадания) Тогда 
			ЗагрузитьПодготовленныеДанные();
		Иначе
			ДлительныеОперацииКлиент.ОбновитьПараметрыОбработчикаОжидания(ПараметрыОбработчикаОжидания);
			ПодключитьОбработчикОжидания(
				"Подключаемый_ПроверитьВыполнениеПубликации", 
				ПараметрыОбработчикаОжидания.ТекущийИнтервал, 
				Истина);
		КонецЕсли;
	Исключение
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Функция УстановитьДоступностьЭлементовФормы()	
	
	Если Объект.ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS Тогда
						
		Объект.СохранятьАктивность = Ложь;
		Объект.ВключитьБраузер = Ложь;
		
		Элементы.УдалитьСтарыеПубликации.Видимость = Истина;
		Элементы.ЭлектронныеРесурсыРазмещениеКнопкиВыхода.Видимость = Истина;
		Элементы.ЯзыкИнтерфейса.Видимость = Ложь;
		
	Иначе
		
		Элементы.УдалитьСтарыеПубликации.Видимость = Ложь;
		Элементы.ЯзыкИнтерфейса.Видимость = Истина;
		Элементы.ЭлектронныеРесурсыРазмещениеКнопкиВыхода.Видимость = Ложь;
		
	КонецЕсли;
	
	Элементы.СохранятьАктивность.Видимость = ?(Объект.ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.HTML, Истина, Ложь);
	Элементы.ВключитьБраузер.Видимость = ?(Объект.ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.HTML И Метаданные.Обработки.ПубликацияЭлектронныхРесурсовСУЗ.Макеты.Найти("БраузерGoogleChrome") <> Неопределено, Истина, Ложь);
	
	Элементы.ГруппаПредупреждение.Видимость = ?(
		Объект.ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.HTML
		И Объект.СохранятьАктивность
		И НЕ Объект.ВключитьБраузер, Истина, Ложь);
		

	Элементы.ДекорацияПрогресс.Видимость = ЗначениеЗаполнено(ИдентификаторЗадания);
	Элементы.КомандаОтменить.Видимость = ЗначениеЗаполнено(ИдентификаторЗадания);
	Элементы.КомандаОпубликовать.Доступность = НЕ ЗначениеЗаполнено(ИдентификаторЗадания);
	
	Если Объект.ТипПубликации <> ПредопределенноеЗначение("Перечисление.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS")
		И НЕ ЗначениеЗаполнено(ИдентификаторЗадания)
		И ДанныеВыгрузки <> Неопределено
		И ЗначениеЗаполнено(АдресХранилищаДополнительный) Тогда
		
		Если МожноПубликоватьВКаталогНаКлиенте Тогда
			Элементы.КомандаСохранить.Видимость = Ложь;
			Элементы.КомандаОткрыть.Видимость = Истина;
		Иначе
			Элементы.КомандаСохранить.Видимость = Истина;
			Элементы.КомандаОткрыть.Видимость = Ложь;
		КонецЕсли;		
		
	Иначе
		
		Элементы.КомандаСохранить.Видимость = Ложь;
		Элементы.КомандаОткрыть.Видимость = Ложь;
		
	КонецЕсли;
			
	Элементы.ТипПубликации.ТолькоПросмотр = ЗначениеЗаполнено(ИдентификаторЗадания);
	Элементы.Страницы.ТолькоПросмотр = ЗначениеЗаполнено(ИдентификаторЗадания);
	Элементы.ДекорацияВыполнено.Видимость = ?(НЕ ЗначениеЗаполнено(ИдентификаторЗадания) И ДанныеВыгрузки <> Неопределено, Истина, Ложь);	
	
	Если Объект.СохранятьАктивность
		И Объект.ТипПубликации = перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.HTML Тогда
		
		Элементы.ВключитьИнтерфейсПреподавателя.Видимость = Истина;		
		
	Иначе
		
		Элементы.ВключитьИнтерфейсПреподавателя.Видимость = Ложь;
		
	КонецЕсли;	
	
	Если Объект.ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.HTML
		ИЛИ Объект.ТипПубликации = Перечисления.ТипыПубликацийЭлектронныхРесурсовСУЗ.SCORM_1_3 Тогда
		
		Элементы.СтраницаЗащита.Видимость = Истина;
		
		Если Объект.СохранятьАктивность
			И Объект.ВключитьИнтерфейсПреподавателя Тогда
			
			Элементы.ГруппаПарольПреподавателя.Видимость = Истина;
			
		Иначе
			
			Элементы.ГруппаПарольПреподавателя.Видимость = Ложь;
			
		КонецЕсли;
		
	Иначе
		
		Элементы.СтраницаЗащита.Видимость = Ложь;
		
	КонецЕсли;
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	Элементы.КомандаУдалитьСтарыеПубликации.Видимость = (Объект.ТипПубликации = ПредопределенноеЗначение("Перечисление.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS"));
	Элементы.ФормаУдалитьВсеПубликации.Видимость = (Объект.ТипПубликации = ПредопределенноеЗначение("Перечисление.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS"));
	
	//----------------------------------//

	Элементы.ДекорацияРаботаИсчезающейКнопки.Видимость = Ложь;
	
	Если Объект.ТипПубликации = ПредопределенноеЗначение("Перечисление.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS") Тогда
	
		Для каждого СтрокаТЧ Из Объект.ЭлектронныеРесурсы Цикл
		
			Если СтрокаТЧ.РазмещениеКнопкиВыхода = Перечисления.ВариантыРазмещенияКнопкиВыходаСУЗ.СлеваИсчезающая
				ИЛИ СтрокаТЧ.РазмещениеКнопкиВыхода = Перечисления.ВариантыРазмещенияКнопкиВыходаСУЗ.СправаИсчезающая Тогда
				
				Элементы.ДекорацияРаботаИсчезающейКнопки.Видимость = Истина;
				Прервать;
				
			КонецЕсли;
		
		КонецЦикла;
		
	КонецЕсли;
		
КонецФункции

&НаСервере
Процедура ОтменитьПроцессПубликации()
	
	ДлительныеОперации.ОтменитьВыполнениеЗадания(ИдентификаторЗадания);
	
	ТекущаяОперация = "";
	ИдентификаторЗадания = Неопределено;
	АдресХранилища = "";
	АдресХранилищаДополнительный = "";
	ДанныеВыгрузки = Неопределено;
	
	УстановитьДоступностьЭлементовФормы();
	
КонецПроцедуры

&НаСервере
Функция ЗаданиеВыполнено(ИдентификаторЗадания)
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторЗадания) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ДлительныеОперации.ЗаданиеВыполнено(ИдентификаторЗадания) Тогда
		
		ТекущаяОперация = НСтр("ru = 'Выполнено'");		
		ИдентификаторЗадания = Неопределено;		
		УстановитьДоступностьЭлементовФормы();
		
		Возврат Истина;
		
	Иначе
		
		ДанныеПрогресса = ДлительныеОперации.ПрочитатьПрогресс(ИдентификаторЗадания);
		
		Если ДанныеПрогресса = Неопределено Тогда			
			ТекущаяОперация = НСтр("ru = 'Публикация....'");			
		Иначе			
			ТекущаяОперация = ДанныеПрогресса.Текст;			
		КонецЕсли;		
		
		Возврат Ложь;
		
	КонецЕсли;
	
	
КонецФункции

&НаКлиенте
Процедура ЗагрузитьПодготовленныеДанные()
	
	ТекущаяОперация = "";
	ДанныеВыгрузки = Неопределено;
	
	Если ЗначениеЗаполнено(АдресХранилища) Тогда
		ДанныеВыгрузки = ПолучитьИзВременногоХранилища(АдресХранилища);
		Если ДанныеВыгрузки = Неопределено Тогда
			ВызватьИсключение НСтр("ru = 'В процессе публикации произошла ошибка'");
		КонецЕсли;
		Если ДанныеВыгрузки <> Неопределено И ЗначениеЗаполнено(ДанныеВыгрузки.Размер) Тогда
			ТекущаяОперация = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Размер: %1 Мб'"), Строка(Окр(ДанныеВыгрузки.Размер / (1024 * 1024), 2)));
		КонецЕсли;
	КонецЕсли;		
	
	ИдентификаторЗадания = Неопределено;
	
	УстановитьДоступностьЭлементовФормы();
	
	Если ДанныеВыгрузки <> неопределено 
		И Объект.ТипПубликации = ПредопределенноеЗначение("Перечисление.ТипыПубликацийЭлектронныхРесурсовСУЗ.WS") Тогда
		
		ПоказатьПредупреждение(, НСтр("ru = 'Публикация завершена'"));
		
	КонецЕсли;	

КонецПроцедуры

//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//

&НаСервере
Процедура УдалитьПубликацииНаСервере(ПропуститьАктуальную = Истина)
	
	Если НЕ ЗначениеЗаполнено(Константы.ПутьКОбщемуКаталогуСУ.Получить()) Тогда
		Возврат;
	КонецЕсли;
	
	// Выбираем все публикации
	
	МассивЭлектронныхРесурсов = Новый Массив;
	
	Для каждого Строка Из Объект.ЭлектронныеРесурсы Цикл	
		МассивЭлектронныхРесурсов.Добавить(Строка.ЭлектронныйРесурс);	
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПубликацииЭлектронныхРесурсов.ЭлектронныйРесурс КАК ЭлектронныйРесурс,
		|	ПубликацииЭлектронныхРесурсов.КонтрольнаяСумма,
		|	ПубликацииЭлектронныхРесурсов.Период КАК ДатаПубликации
		|ИЗ
		|	РегистрСведений.ПубликацииЭлектронныхРесурсовСУЗ КАК ПубликацииЭлектронныхРесурсов
		|ГДЕ
		|	ПубликацииЭлектронныхРесурсов.ЭлектронныйРесурс В(&МассивЭлектронныхРесурсов)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЭлектронныйРесурс,
		|	ДатаПубликации УБЫВ";
	
	Запрос.УстановитьПараметр("МассивЭлектронныхРесурсов", МассивЭлектронныхРесурсов);
	
	ТаблицаПубликаций = Запрос.Выполнить().Выгрузить();	
	
	ПутьККаталогуВыгрузки = ОбъектыСУЗПовтИсп.ПутьКОбщемуКаталогу();
	
	Для каждого ЭлектронныйРесурс Из МассивЭлектронныхРесурсов Цикл
		
		НачатьТранзакцию();
		
		Попытка
		
			ПубликацииРесурса = ТаблицаПубликаций.НайтиСтроки(Новый Структура("ЭлектронныйРесурс", ЭлектронныйРесурс));
			
			ПервыйПропущен = Ложь;
			Для каждого СвойстваПубликации Из ПубликацииРесурса Цикл
			
				Если ПропуститьАктуальную И НЕ ПервыйПропущен Тогда
					ПервыйПропущен = Истина;
					Продолжить;
				КонецЕсли;
				
				ПутьККаталогуПубликации = ЭлектронныеРесурсыСУЗКлиентСервер.ПутьККаталогуПубликацииЭлектронногоРесурса(ЭлектронныйРесурс, СвойстваПубликации.КонтрольнаяСумма, ПутьККаталогуВыгрузки);				
				
				УдалитьФайлы(ПутьККаталогуПубликации);
				
				НаборЗаписей = РегистрыСведений.ПубликацииЭлектронныхРесурсовСУЗ.СоздатьНаборЗаписей();				
				НаборЗаписей.Отбор.ЭлектронныйРесурс.Установить(ЭлектронныйРесурс);
				НаборЗаписей.Отбор.Период.Установить(СвойстваПубликации.ДатаПубликации);
				НаборЗаписей.Записать();				
				
			КонецЦикла;
				
			Если НЕ ПропуститьАктуальную Тогда
				
				// Удаляем каталог хранения всех публикаций
				
				ПутьККаталогуПубликацийЭлектронногоРесурса = ЭлектронныеРесурсыСУЗКлиентСервер.ПутьККаталогуПубликацийЭлектронногоРесурса(ЭлектронныйРесурс, ПутьККаталогуВыгрузки);				
				ККаталогПубликацийЭлектронногоРесурса = Новый Файл(ПутьККаталогуПубликацийЭлектронногоРесурса);
				Если ККаталогПубликацийЭлектронногоРесурса.Существует() И ККаталогПубликацийЭлектронногоРесурса.ЭтоКаталог() Тогда
					УдалитьФайлы(ККаталогПубликацийЭлектронногоРесурса.ПолноеИмя);
				КонецЕсли;
				
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
		
		 	ОтменитьТранзакцию();
			ВызватьИсключение;
			
		КонецПопытки;					
		
	КонецЦикла;
	
КонецПроцедуры


//----------------------------------//

#КонецОбласти


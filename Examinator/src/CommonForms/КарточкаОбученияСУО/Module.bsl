
#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Делаем проверки
	//
	
	Обучение = Параметры.Обучение; // Реквизит
	
	Если НЕ ЗначениеЗаполнено(Обучение) Тогда
		Текст = НСтр("ru = 'Элемент обучения не задан'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст,,,,Отказ);
		Возврат;
	КонецЕсли;	
	
	МенеджерОбучения = ОбщегоНазначения.МенеджерОбъектаПоСсылке(Обучение);
	
	ОбучениеОтменено = МенеджерОбучения.Отменено(Обучение);
	
	Если ОбучениеОтменено Тогда
		Текст = НСтр("ru = 'Обучение отменено и не может быть открыто'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст,,,,Отказ);
		Возврат;
	КонецЕсли;
	
	// Получаем общие данные
	//
	
	ЭтоОбразовательнаяОрганизация = ПолучитьФункциональнуюОпцию("ОбразовательнаяОрганизацияОО");
	ИспользоватьСтудентов = ПолучитьФункциональнуюОпцию("ИспользоватьСтудентовСУО");
	ЭтоПолныйИнтерфейс = ПолучитьФункциональнуюОпцию("ПолныйИнтерфейсСУО");	
	
	ПроведениеОбучения     = МенеджерОбучения.ПроведениеОбучения(Обучение);
	Сценарий               = МенеджерОбучения.СценарийОбучения(Обучение);
	Заголовок              = МенеджерОбучения.Представление(Обучение);
	Актуально              = МенеджерОбучения.Актуально(Обучение);
	РодительскоеПроведение = МенеджерОбучения.РодительскоеОбучение(Обучение);	
	
	Пользователь = Пользователи.ТекущийПользователь();
	
	ВидОбучения         = Документы.ПроведениеОбученияСУО.ВидОбучения(ПроведениеОбучения, Сценарий);
	ЭтоЭлектронноеОбучение = Документы.ПроведениеОбученияСУО.ЭтоЭлектронноеОбучение(ПроведениеОбучения, ВидОбучения, Сценарий);
	ЗавершаетУчащийся   = ВидОбучения.ЗавершаетУчащийся;
	
	Если ТипЗнч(Обучение) = Тип("ДокументСсылка.ПроведениеПреподавателемОбученияСУО") Тогда		
		ТипАктивности = "Преподавание";		
	Иначе		
		Если Пользователь = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Обучение, "Пользователь") Тогда			
			ТипАктивности = "Обучение";			
		Иначе			
			ТипАктивности = "Проверка";			
		КонецЕсли;
	КонецЕсли;	
	
	// Описание
	//
	
	СформироватьОписание(МенеджерОбучения);
	
	// Участники
	//
	
	Если ТипАктивности = "Обучение" Тогда
		Элементы.СтраницаУчастники.Видимость = МенеджерОбучения.ДоступноОбщение(Обучение);
	Иначе
		Элементы.СтраницаУчастники.Видимость = Ложь;
	КонецЕсли;	
	
	Если ЭтоОбразовательнаяОрганизация Тогда
		Элементы.СтраницаУчастники.Заголовок = НСтр("ru = 'Студенты'");
	КонецЕсли;
	
	Участники.Параметры.УстановитьЗначениеПараметра("ПроведениеОбучения", ПроведениеОбучения);
	Участники.Параметры.УстановитьЗначениеПараметра("Сценарий", Сценарий);	
	
	// Преподаватели
	//
	
	Если ТипАктивности = "Обучение" Тогда		
		Элементы.СтраницаПреподаватели.Видимость = Документы.ПрохождениеОбученияСУО.ДоступенСписокПреподавателей(Обучение);		
	КонецЕсли;	
	
	Элементы.ПреподавателиНаименованиеРоли.Видимость = ЭтоПолныйИнтерфейс;
	
	// Мои файлы
	//
	
	ПрисоединенныеФайлыСписок.Параметры.УстановитьЗначениеПараметра("ПрохождениеОбучения", Обучение);
	
	Если ТипАктивности = "Обучение" Тогда
		Элементы.СтраницаМоиФайлы.Видимость = Документы.ПрохождениеОбученияСУО.ДоступноПрикреплениеФайлов(Обучение);
	Иначе
		Элементы.СтраницаМоиФайлы.Видимость = Ложь;
	КонецЕсли;
	
	// Список преподавателей
	//
	
	Если Элементы.СтраницаПреподаватели.Видимость Тогда
		
		ТаблицаПреподавателей = Документы.ПроведениеОбученияСУО.Преподаватели(ПроведениеОбучения, Сценарий, ?(ТипЗнч(Обучение) = Тип("ДокументСсылка.ПрохождениеОбученияСУО"), Истина, Ложь));
		
		Для каждого СтрокаТП Из ТаблицаПреподавателей Цикл
			
			НоваяСтрока = Преподаватели.Добавить();
			НоваяСтрока.Преподаватель                    = СтрокаТП.Преподаватель;
			НоваяСтрока.ИмяПреподавателя                 = СтрокаТП.ИмяПреподавателя;
			НоваяСтрока.ПроведениеПреподавателемОбучения = СтрокаТП.ПроведениеПреподавателемОбучения;
			НоваяСтрока.НаименованиеРоли                 = СтрокаТП.НаименованиеРоли;
			НоваяСтрока.Картинка                         = 0;
		
		КонецЦикла;
		
		Преподаватели.Сортировать("ИмяПреподавателя");
		
	КонецЕсли;
	
	// Задания
	//
	
	Если ТипАктивности = "Обучение" ИЛИ ТипАктивности = "Проверка" Тогда
	
		ЗагрузитьТаблицуЗаданий();
		
		Если ТипАктивности = "Обучение" Тогда
			Если Задания.Количество() < 2 Тогда
				// Ученик откроет задание по команде Открыть
				Элементы.СтраницаЗадания.Видимость = Ложь;
			КонецЕсли;			
		Иначе
			Если Задания.Количество() = 0 Тогда
				Элементы.СтраницаЗадания.Видимость = Ложь;
			КонецЕсли;			
		КонецЕсли;
		
		ПоказатьКолонкуЗначимость = Ложь;
		
		Если ВидОбучения.ПоказыватьПодробныеСведенияОЗадании Тогда
		
			Для каждого Строка Из Задания Цикл		
				Если Строка.Значимость <> 1 Тогда
					ПоказатьКолонкуЗначимость = Истина;
					Прервать;
				КонецЕсли;				
			КонецЦикла;
			
		КонецЕсли;
			
		Элементы.ЗаданияЗначимость.Видимость = ПоказатьКолонкуЗначимость;
		
	Иначе
		
		Элементы.СтраницаЗадания.Видимость = Ложь;
		
	КонецЕсли;
	
	// Задания преподавателя
	
	Если ТипАктивности = "Преподавание" Тогда
		
		Если Документы.ПроведениеОбученияСУО.ЗаданияОбучения(ПроведениеОбучения).Количество() > 0 Тогда
			
			Если ТипЗнч(Сценарий) = Тип("СправочникСсылка.КаталогМероприятийСУО") Тогда
				ОбщегоНазначенияСУКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(ЗаданияСценария, Сценарий, "Владелец");
				Элементы.ЗаданияСценария.Видимость = Истина;
			Иначе
				Элементы.ЗаданияСценария.Видимость = Ложь;
			КонецЕсли;
			
		Иначе
			
			Элементы.СтраницаЗаданияПреподавателя.Видимость = Ложь;	
			
		КонецЕсли;
		
		
	Иначе
		
		Элементы.СтраницаЗаданияПреподавателя.Видимость = Ложь;
		
	КонецЕсли;
	
	
	// Ведомость
	//
	
	Если ТипАктивности = "Преподавание" Тогда
	
		ЗагрузитьВедомость();
			
		Элементы.СтраницаВедомость.Видимость = Истина;		
		
		УстановитьДоступностьЭлементовВедомости();
		
		Если ЭтоОбразовательнаяОрганизация Тогда
			Элементы.СтраницаВедомость.Заголовок = НСтр("ru = 'Студенты'");
			Элементы.ВедомостьПользователь.Заголовок = НСтр("ru = 'Студент'");
		КонецЕсли;
		
		Элементы.ВопросыНаПроверкуУчебнаяГруппа.Видимость = ЭтоОбразовательнаяОрганизация ИЛИ ИспользоватьСтудентов;
		
		Элементы.ФайлыУчастников.Видимость = Документы.ПроведениеОбученияСУО.ДоступноПрикреплениеФайлов(ПроведениеОбучения, Сценарий);
		
		Если ЭтоОбразовательнаяОрганизация Тогда
			Элементы.ФайлыУчастников.Заголовок = НСтр("ru = 'Файлы студентов'");
		КонецЕсли;		
		
	Иначе
		
		Элементы.СтраницаВедомость.Видимость = Ложь;
		
	КонецЕсли;		
	
	
	// Учебные группы для ОО
	//
	
	Если ТипАктивности = "Преподавание" Тогда
		Элементы.СтраницаУчебныеГруппыОО.Видимость = ЭтоОбразовательнаяОрганизация ИЛИ ИспользоватьСтудентов;		
	Иначе
		Элементы.СтраницаУчебныеГруппыОО.Видимость = Ложь;
	КонецЕсли;
	
	// Вопросы на проверку
	// 
	
	Если ТипАктивности <> "Преподавание" Тогда
		Элементы.СтраницаВопросыНаПроверку.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)

	Если ЗавершениеРаботы = Неопределено Тогда
		ЗавершениеРаботы = Ложь;
	КонецЕсли;
	
	Если ЗавершениеРаботы Тогда			
		Отказ = Истина;			
		ТекстПредупреждения = НСтр("ru = 'Прохождение обучения будет прервано без сохранения последних результатов.
		|Перед выходом из программы закройте все открытые обучения для правильного сохранения данных.'");			
		Возврат;
	КонецЕсли;	
	
	Если ЗавершаетУчащийся И ТипЗнч(Обучение) = Тип("ДокументСсылка.ПрохождениеОбученияСУО") Тогда

		ВозможныйРезультат = ОбучениеСУО.ПриПрохожденииМероприятия(Обучение,,,,,Ложь);

		Если ВозможныйРезультат.СтатусРасчетныйСтрока = "Завершил"
			И ВозможныйРезультат.СтатусСтрока <> ВозможныйРезультат.СтатусРасчетныйСтрока Тогда
			ПредложитьЗавершитьОбучение();
		КонецЕсли;
		
	Иначе
		
		Если НЕ ЗакрытьБезПредупреждения
			И Модифицированность Тогда
			
			// Только для преподавателя
			
			СтандартнаяОбработка = Ложь;
			Отказ = Истина;
			ОписаниеОповещения = Новый ОписаниеОповещения("ПредложитьСохранитьИзмененияПродолжение", ЭтотОбъект);				
			ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'Данные ведомости были изменены. Сохранить изменения?'"), РежимДиалогаВопрос.ДаНетОтмена, 0);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПредложитьСохранитьИзмененияПродолжение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		ЗаписатьИтоговыеОценкиВедомостиНаСервере();
		ЗакрытьБезПредупреждения = Истина;
		Закрыть();		
	ИначеЕсли Ответ = КодВозвратаДиалога.Нет Тогда
		ЗакрытьБезПредупреждения = Истина;
		Закрыть();
	КонецЕсли;	
	
КонецПроцедуры	

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
		
	Если ИмяСобытия = "ОбновитьПрохождениеОбучения" ИЛИ ИмяСобытия = "ОбновитьМоеОбучение" ИЛИ ИмяСобытия = "ПриЗакрытииЭлектронногоКурса" Тогда
		
		СформироватьОписание();
		
		Если ВопросыНаПроверку.НайтиСтроки(Новый Структура("ПрохождениеОбучения", Параметр)).Количество() > 0 Тогда
			ЗаполнитьВопросыНаПроверку();
		КонецЕсли;
		
		Если Ведомость.НайтиСтроки(Новый Структура("Прохождение", Параметр)).Количество() > 0 Тогда
			ЗагрузитьВедомость();
		КонецЕсли;		
		
		Если Элементы.СтраницаЗадания.Видимость Тогда
			ЗагрузитьТаблицуЗаданий();
		КонецЕсли;
		
		Если Параметр = Обучение
			И ЗначениеЗаполнено(РодительскоеОбучение) Тогда

			Оповестить("ОбновитьПрохождениеОбучения", РодительскоеОбучение, ЭтотОбъект)

		КонецЕсли;
		
	КонецЕсли;
	 
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура ОписаниеПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Если НЕ ДанныеСобытия.Свойство("Href") Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураСсылки = ОбъектыСУЗКлиентСервер.СтруктураСтрокиПараметров(ДанныеСобытия.Href);
	
	ИмяОбъекта = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "object");
	ИмяДействия = ОбъектыСУЗКлиентСервер.ПолучитьЗначениеПараметраСсылки(СтруктураСсылки, "action");
	
	Если ЗначениеЗаполнено(ИмяДействия) Тогда
		
		СтандартнаяОбработка = Ложь;
		
		Если ИмяДействия = "openOneTask" Тогда
			
			Если ТипЗнч(Обучение) = Тип("ДокументСсылка.ПрохождениеОбученияСУО") Тогда
				
				ОписаниеМероприятияСОднимЭлектроннымЗаданием = ОбучениеСУОВызовСервера.ОписаниеЕдинственногоЗаданияПрохождения(Обучение);
				
				Если ОписаниеМероприятияСОднимЭлектроннымЗаданием <> Неопределено Тогда
					ОбучениеСУОКлиент.ОткрытьЗадание(ОписаниеМероприятияСОднимЭлектроннымЗаданием, Обучение, Параметры.ОткрытоВнешнимПользователем);
				КонецЕсли;
				
			КонецЕсли;
			
			Если ТипЗнч(Обучение) = Тип("ДокументСсылка.ПроведениеПреподавателемОбученияСУО") Тогда
				
				ОписаниеМероприятияСОднимЭлектроннымЗаданием = ОбучениеСУОВызовСервера.ОписаниеЕдинственногоЗаданияОбучения(ПроведениеОбучения);
				
				Если ОписаниеМероприятияСОднимЭлектроннымЗаданием <> Неопределено И ОписаниеМероприятияСОднимЭлектроннымЗаданием.НаОсновеЭлектронногоРесурса Тогда
					ОбъектыСУЗКлиент.ОткрытьОбозреватель(ОписаниеМероприятияСОднимЭлектроннымЗаданием.ЭлектронныйРесурс, ОписаниеМероприятияСОднимЭлектроннымЗаданием.Фрагмент, ?(ЗначениеЗаполнено(ОписаниеМероприятияСОднимЭлектроннымЗаданием.Фрагмент), Истина, Ложь), ОписаниеМероприятияСОднимЭлектроннымЗаданием.Фрагмент);
				Иначе
					ПоказатьЗначение(,ОписаниеМероприятияСОднимЭлектроннымЗаданием.Задание);
				КонецЕсли;
					
			КонецЕсли;
			
		КонецЕсли;
		
		Если ИмяДействия = "openContextForum" Тогда			
			ОткрытьФорму("ОбщаяФорма.ФорумСУО", Новый Структура("ВыделенныйРаздел", ПроведениеОбучения));			
		КонецЕсли;		
		
		Если ИмяДействия = "completeActivity" Тогда			
			ПредложитьЗавершитьОбучение();			
		КонецЕсли;
		
		Если ИмяДействия = "openTestResult" Тогда			
			ПараметрыФормы = Новый Структура("ПрохождениеОбучения, Задание, Пользователь, ОткрытоВнешнимПользователем",  Обучение,, Пользователь, Параметры.ОткрытоВнешнимПользователем);
			ОткрытьФорму("Документ.ПрохождениеОбученияСУО.Форма.ФормаРезультатыТестирования", ПараметрыФормы);			
		КонецЕсли;		
		
		Если ИмяДействия = "start" Тогда
			ОбучениеСУО.ПриПрохожденииМероприятия(Обучение, ПредопределенноеЗначение("Перечисление.СтатусыПрохожденияОбъектовСУО.Проходит") ,,,,,,,,Ложь);
			СформироватьОписание();
			ЗагрузитьТаблицуЗаданий();
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИмяОбъекта) Тогда
		
		СтандартнаяОбработка = Ложь;
		
		ОткрытьОбъект(СтруктураСсылки, УникальныйИдентификатор, Обучение, Пользователь);
		
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыУчастники

// ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЦЫ ФОРМЫ Участники

&НаКлиенте
Процедура УчастникиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если НЕ ОбщегоНазначенияСУКлиент.ТекущиеДанныеТаблицыДоступны(ТекущиеДанные) Тогда
		Возврат;
	КонецЕсли;
	
	ПоказатьЗначение(,ТекущиеДанные.Пользователь);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПреподаватели

// ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЦЫ ФОРМЫ Преподаватели

&НаКлиенте
Процедура ПреподавателиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПоказатьЗначение(,ТекущиеДанные.Преподаватель);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПрисоединенныеФайлы

// ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЦЫ ФОРМЫ ПрисоединенныеФайлы

&НаКлиенте
Процедура ПрисоединенныеФайлыСписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.Зашифрован Тогда
		Возврат;	
	КонецЕсли;
	
	ОткрытьФайл(ТекущиеДанные.Ссылка);	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗадания

// ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЦЫ ФОРМЫ Задания

&НаКлиенте
Процедура ЗаданияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные = Неопределено 
		ИЛИ НЕ Элемент.ТекущиеДанные.ДоступноДляПрохождения Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыЗадания = Новый Структура("Задание, НаОсновеЭлектронногоРесурса", Элемент.ТекущиеДанные.Задание, Элемент.ТекущиеДанные.НаОсновеЭлектронногоРесурса);
	
	ОбучениеСУОКлиент.ОткрытьЗадание(ПараметрыЗадания, Обучение,,, Элемент.ТекущиеДанные.ТолькоПросмотр);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыВопросыНаПроверку

// ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЦЫ ФОРМЫ ВопросыНаПроверку

&НаКлиенте
Процедура ВопросыНаПроверкуВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	НастройкиТестирования = ПолучитьНастройкиТестирования(ТекущиеДанные.СессияТестирования, ТекущиеДанные.НомерГруппыПодборки);
	
	ОбъектыСУЗКлиент.ОткрытьОбозреватель(НастройкиТестирования.СводЗнаний,
										 НастройкиТестирования.СсылкаНаЭлемент,
										 Истина,
										 НастройкиТестирования.ЭлементСодержанияСводаЗнаний,
										 ТекущиеДанные.ПрохождениеОбучения,
										 ТекущиеДанные.Задание);
	
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьНастройкиТестирования(СессияВыполненияТеста, НомерГруппыПодборки=Неопределено)
	Возврат Документы.ПопыткаВыполненияПодборкиВопросовСУЗ.ДанныеТестированияДляПросмотра(СессияВыполненияТеста, НомерГруппыПодборки);
КонецФункции

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыВедомость

// ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЦЫ ФОРМЫ Ведомость

&НаКлиенте
Процедура ВедомостьВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Поле.Имя = "ВедомостьПользователь" Тогда				
		СтандартнаяОбработка = Ложь;		
		ПоказатьЗначение(,ТекущиеДанные.Пользователь);			
	КонецЕсли;
	
	Если Найти(Поле.Имя, "ВедомостьЗадание") = 1 Тогда
		СтандартнаяОбработка = Ложь;
		ПроверитьОбучениеУчащегося();
	КонецЕсли;
	
	Если Поле.Имя = "ВедомостьКомментарий" Тогда				
		СтандартнаяОбработка = Ложь;		
		НаписатьКомментарийУчастнику();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВедомостьПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	Если НЕ ОтменаРедактирования Тогда
		Модифицированность = Истина;
	КонецЕсли;
КонецПроцедуры


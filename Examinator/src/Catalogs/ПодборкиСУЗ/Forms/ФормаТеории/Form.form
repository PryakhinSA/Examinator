  <attributes>
    <name>ЭлементыПодборки</name>
    <title>
      <key>ru</key>
      <value>Элементы подборки</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЭлементыПодборки.Code</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЭлементыПодборки.IsFolder</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЭлементыПодборки.Owner</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЭлементыПодборки.Parent</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЭлементыПодборки.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЭлементыПодборки.СсылкаНаОбъектСУЗ</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СправочникЭлементыПодборкиСУЗ.Ссылка,
	СправочникЭлементыПодборкиСУЗ.ПометкаУдаления,
	СправочникЭлементыПодборкиСУЗ.Владелец,
	СправочникЭлементыПодборкиСУЗ.Родитель,
	СправочникЭлементыПодборкиСУЗ.ЭтоГруппа,
	СправочникЭлементыПодборкиСУЗ.Код,
	СправочникЭлементыПодборкиСУЗ.Наименование,
	СправочникЭлементыПодборкиСУЗ.ДатаИзменения,
	СправочникЭлементыПодборкиСУЗ.Класс,
	СправочникЭлементыПодборкиСУЗ.СсылкаНаОбъектСУЗ,
	СправочникЭлементыПодборкиСУЗ.Якорь,
	СправочникЭлементыПодборкиСУЗ.Поставщик,
	СправочникЭлементыПодборкиСУЗ.КоличествоВопросов,
	СправочникЭлементыПодборкиСУЗ.ВесВопроса,
	СправочникЭлементыПодборкиСУЗ.РазрешитьРедактироватьНаименование,
	СправочникЭлементыПодборкиСУЗ.Предопределенный,
	СправочникЭлементыПодборкиСУЗ.ИмяПредопределенныхДанных,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(СправочникЭлементыПодборкиСУЗ.СсылкаНаОбъектСУЗ) = ТИП(Справочник.РесурсыСУЗ)
			ТОГДА ВЫБОР
					КОГДА СправочникЭлементыПодборкиСУЗ.СсылкаНаОбъектСУЗ.ЕдинственныйФайл = ЗНАЧЕНИЕ(Справочник.ФайлыСУЗ.ПустаяСсылка)
						ТОГДА ПРЕДСТАВЛЕНИЕ(ТИПЗНАЧЕНИЯ(СправочникЭлементыПодборкиСУЗ.СсылкаНаОбъектСУЗ))
					ИНАЧЕ ВЫБОР
							КОГДА СправочникЭлементыПодборкиСУЗ.СсылкаНаОбъектСУЗ.ЕдинственныйФайл.ТипФайла = ЗНАЧЕНИЕ(Перечисление.ТипыФайловСУЗ.Default)
								ТОГДА &quot;Файл&quot;
							ИНАЧЕ ПРЕДСТАВЛЕНИЕ(СправочникЭлементыПодборкиСУЗ.СсылкаНаОбъектСУЗ.ЕдинственныйФайл.ТипФайла)
						КОНЕЦ
				КОНЕЦ
		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(ТИПЗНАЧЕНИЯ(СправочникЭлементыПодборкиСУЗ.СсылкаНаОбъектСУЗ))
	КОНЕЦ КАК Тип
ИЗ
	Справочник.ЭлементыПодборкиСУЗ КАК СправочникЭлементыПодборкиСУЗ</queryText>
      <mainTable>Catalog.ЭлементыПодборкиСУЗ</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>

		НастройкиРегистрации.Вставить("url", Объект.АдресСтраницыРегистрации); 
		
		ТаблицаПолейРегистрации = Новый ТаблицаЗначений;
		ТаблицаПолейРегистрации.Колонки.Добавить("id");
		ТаблицаПолейРегистрации.Колонки.Добавить("name");
		ТаблицаПолейРегистрации.Колонки.Добавить("typeInput");
		ТаблицаПолейРегистрации.Колонки.Добавить("required");
		ТаблицаПолейРегистрации.Колонки.Добавить("confirm");
		ТаблицаПолейРегистрации.Колонки.Добавить("typeValue");
		ТаблицаПолейРегистрации.Колонки.Добавить("variants");
		ТаблицаПолейРегистрации.Колонки.Добавить("confirmName");
		ТаблицаПолейРегистрации.Колонки.Добавить("description");
		ТаблицаПолейРегистрации.Колонки.Добавить("useAsLogin");
		
		Для каждого Строка Из Объект.ПоляРегистрации Цикл
		
			НоваяСтрока = ТаблицаПолейРегистрации.Добавить();
			НоваяСтрока.id = Строка.Имя;			
			НоваяСтрока.name = Строка.Наименование;
			НоваяСтрока.typeInput = Перечисления.ТипыПолейРегистрацииВебКабинетаСУО.ЗначениеДляВебКабинета(Строка.ТипПоля);
			НоваяСтрока.required = Строка.Обязательное;
			НоваяСтрока.confirm = Строка.ДобавлятьПолеПодтверждения;
			НоваяСтрока.confirmName = Строка.НаименованиеПодтверждения;
			НоваяСтрока.description = Строка.Описание;
			НоваяСтрока.useAsLogin = Строка.ИспользоватьКакЛогин;
			
			Если ЗначениеЗаполнено(Строка.Реквизит) Тогда
				
				ТипРеквизита = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Строка.Реквизит, "ТипЗначения");
				
				//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//

				Если ТипРеквизита.СодержитТип(Тип("СправочникСсылка.ЗначенияСвойствОбъектов")) Тогда
					
					НоваяСтрока.typeValue = "values";
						
					ЗапросДанных = Новый Запрос;
					ЗапросДанных.Текст = 
						"ВЫБРАТЬ
						|	ЗначенияСвойствОбъектов.Ссылка КАК value,
						|	ЗначенияСвойствОбъектов.Наименование КАК name

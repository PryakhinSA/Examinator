	// Настройки электронных курсов
	
	НастройкиЭК = Новый Структура;
	Если ЗначениеЗаполнено(Объект.АдресСервисаЭлектронныхКурсов) Тогда
		НастройкиЭК.Вставить("url", Объект.АдресСервисаЭлектронныхКурсов); 
	Иначе
		НастройкиЭК.Вставить("url", Объект.АдресПубликацииИБ + "/hs/courses"); 
	КонецЕсли;
	НастройкиЭК.Вставить("user", ЛогинСлужебногоПользователя(Объект)); 
	НастройкиЭК.Вставить("password", ПарольСлужебногоПользователя(Объект));	
	
	НастройкиЭКJSON = ОбщегоНазначенияСУ.ДанныеВJSON(НастройкиЭК);

	
	ТекстФайлаНастроек = ТекстФайлаНастроек + "
		|oSettingsCourses = " + НастройкиЭКJSON + ";";			
	
	// Сохраняем файл настроек во временное ранилище
	
	ФайлНастроекТекстовыйДокумент = Новый ТекстовыйДокумент;
	ФайлНастроекТекстовыйДокумент.УстановитьТекст(ТекстФайлаНастроек);
	
	Если ПутьДляЗаписи = Неопределено Тогда
		
		ПутьКФайлуНастроек = ПолучитьИмяВременногоФайла("json");
		ФайлНастроекТекстовыйДокумент.Записать(ПутьКФайлуНастроек);	
		
		ФайлНастроекДвоичныеДанные = Новый ДвоичныеДанные(ПутьКФайлуНастроек);		
		АдресХранения = ПоместитьВоВременноеХранилище(ФайлНастроекДвоичныеДанные, УникальныйИдентификатор);
		
		Попытка
			УдалитьФайлы(ПутьКФайлуНастроек)
		Исключение			
		КонецПопытки;
		
		Возврат АдресХранения;
		
	Иначе
		
		СуществующийФайлНастроек = Новый Файл(ПутьДляЗаписи);
		
		Если СуществующийФайлНастроек.Существует() Тогда
			СуществующийТекстовыйДокумент = Новый ТекстовыйДокумент;
			СуществующийТекстовыйДокумент.Прочитать(ПутьДляЗаписи);
			СуществующийТекстНастроек = СуществующийТекстовыйДокумент.ПолучитьТекст();
			Если Найти(СуществующийТекстНастроек, Объект.Код) = 0 Тогда
				ВызватьИсключение НСтр("ru = 'Возможно, в общем каталоге был установлен веб-кабинет из другой базы.
				|Если в каталоге нет других рабочих публикаций, то удалите файл настроек в нем и повторите операцию.'");
			КонецЕсли;
		КонецЕсли;
		
		ФайлНастроекТекстовыйДокумент.Записать(ПутьДляЗаписи);
		Возврат Неопределено;
		
	КонецЕсли;
		
КонецФункции

Функция АдресВебКабинета(ПубликацияВебКабинета = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ПубликацияВебКабинета = Неопределено Тогда
		ПубликацияВебКабинета = ОсновнаяПубликация();	
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(ПубликацияВебКабинета) Тогда
		Возврат "";
	КонецЕсли;
	
	ДанныеПубликации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПубликацияВебКабинета, "АдресВебСервера, АдресКаталогаКабинета");
	
	Возврат ДанныеПубликации.АдресВебСервера + ДанныеПубликации.АдресКаталогаКабинета;
	
КонецФункции

Функция АдресКаталогаЭлектронныхРесурсов(ПубликацияВебКабинета = Неопределено) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	Если ПубликацияВебКабинета = Неопределено Тогда
		ПубликацияВебКабинета = ОсновнаяПубликация();	
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(ПубликацияВебКабинета) Тогда
		Возврат "";
	КонецЕсли;
	
	ДанныеПубликации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПубликацияВебКабинета, "АдресВебСервера, АдресПубликацийРесурсов");
	
	Возврат ДанныеПубликации.АдресВебСервера + ДанныеПубликации.АдресПубликацийРесурсов;	
	
КонецФункции
	
Функция ОсновнаяПубликация(Знач Редакция = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ОсновнаяПубликацияИзКонстанты = ВебКабинетСУ.ПолучитьОсновнуюПубликациюИзКонстанты(Редакция);
	
	Если ЗначениеЗаполнено(ОсновнаяПубликацияИзКонстанты) Тогда
		Возврат ОсновнаяПубликацияИзКонстанты;
	Иначе
		Возврат ЕдинственнаяПубликацияИзСправочника(Редакция);
	КонецЕсли;
		
КонецФункции

Функция ЕстьПубликации() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПубликацииВебКабинетаСУ.Ссылка
		|ИЗ
		|	Справочник.ПубликацииВебКабинетаСУ КАК ПубликацииВебКабинетаСУ";

	Возврат НЕ Запрос.Выполнить().Пустой();
	
КонецФункции

Функция ЕстьПубликацииРедакции(Знач Редакция = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПубликацииВебКабинетаСУ.Ссылка
		|ИЗ
		|	Справочник.ПубликацииВебКабинетаСУ КАК ПубликацииВебКабинетаСУ
		|ГДЕ
		|	ПубликацииВебКабинетаСУ.ПометкаУдаления = ЛОЖЬ
		|	И ПубликацииВебКабинетаСУ.Редакция = &Редакция";
	
	Запрос.Параметры.Вставить("Редакция", 
		?(ЗначениеЗаполнено(Редакция), Редакция, ВебКабинетСУ.Редакция()));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат НЕ РезультатЗапроса.Пустой();
	
КонецФункции

Функция ЕдинственнаяПубликацияИзСправочника(Знач Редакция = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПубликацииВебКабинетаСУ.Ссылка
		|ИЗ
		|	Справочник.ПубликацииВебКабинетаСУ КАК ПубликацииВебКабинетаСУ
		|ГДЕ
		|	ПубликацииВебКабинетаСУ.ПометкаУдаления = ЛОЖЬ
		|	И ПубликацииВебКабинетаСУ.Редакция = &Редакция";
	
	Запрос.Параметры.Вставить("Редакция", 
		?(ЗначениеЗаполнено(Редакция), Редакция, ВебКабинетСУ.Редакция()));
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Количество() = 1 Тогда		
		ВыборкаДетальныеЗаписи.Следующий();		
		Возврат ВыборкаДетальныеЗаписи.Ссылка;		
	КонецЕсли;

	Возврат Неопределено;
	
КонецФункции

Функция ЕдинственнаяПубликацияВОбщемКаталоге(Знач Редакция = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ОсновнаяПубликация = ОсновнаяПубликация(Редакция);
	
	Если НЕ ЗначениеЗаполнено(ОсновнаяПубликация) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеПубликации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ОсновнаяПубликация, "ЭтоЕдинственнаяПубликацияВОбщемКаталоге, ПометкаУдаления");
	
	Если ДанныеПубликации.ПометкаУдаления Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если НЕ ДанныеПубликации.ЭтоЕдинственнаяПубликацияВОбщемКаталоге Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ОсновнаяПубликация;
	
КонецФункции


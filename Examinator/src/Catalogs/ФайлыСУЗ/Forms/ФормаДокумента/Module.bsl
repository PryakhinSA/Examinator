#Область ПеременныеФормы

// ПЕРЕМЕННЫЕ МОДУЛЯ

&НаКлиенте
Перем ТипОбъектаНаКлиенте; // Тип объекта метаданных в виде строки

&НаСервере
Перем ТипОбъектаНаСервере; // Тип объекта метаданных в виде строки

&НаКлиенте
Перем Приложение; // Объект COM приложения и другие его свойства

&НаКлиенте
Перем РабочийКаталог; // Каталог для хранения документа и его копии

&НаКлиенте
Перем Шаблоны; // Шаблоны и дополнения к документам

&НаКлиенте
Перем ПропуститьЗаписьДокумента; // Обработчик ПриЗаписиДокумента не будет срабатывать

&НаКлиенте
Перем ПропуститьСохранениеДокумента; // Процедура СохранитьДокумент из обработчика ПередЗаписью не будет срабатывать

&НаКлиенте
Перем ПерейтиКФормеРесурсаПередЗакрытием;

&НаКлиенте
Перем ПерейтиКФормеРесурсаПриЗакрытии;

#КонецОбласти

#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Определяем родителя ресурса
	
	ЭлектронныйРесурс = Параметры.ЭлектронныйРесурс;
	Подборка          = Параметры.Подборка;
	РодительРесурса   = Параметры.РодительРесурса;
	ЭлементСодержания = Параметры.ЭлементСодержания;
	ЭлементПодборки   = Параметры.ЭлементПодборки;
	
	Если НЕ ЗначениеЗаполнено(РодительРесурса) Тогда
		
		Если ЗначениеЗаполнено(Параметры.Подборка) Тогда
			РодительРесурса = Справочники.ПодборкиСУЗ.ГруппаПодчиненныхЭлементов(Параметры.Подборка, "СправочникСсылка.РесурсыСУЗ", Параметры.ЭлектронныйРесурс);
		ИначеЕсли ЗначениеЗаполнено(Параметры.ЭлектронныйРесурс) Тогда
			РодительРесурса = Справочники.СводыЗнанийСУЗ.ГруппаДляХраненияПодчиненныхЭлементов(Параметры.ЭлектронныйРесурс, "СправочникСсылка.РесурсыСУЗ");
		КонецЕсли;
		
	КонецЕсли;
	
	
	Если Объект.Ссылка.Пустая() Тогда		
		Объект.ТипФайла = Перечисления.ТипыФайловСУЗ.Document;		
	КонецЕсли;
	
	ОбновитьСсылкуНаЗагруженныйФайл();
	
	// Загружаем версию
	
	ЗагрузитьВерсиюНаСервере(Истина);

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	РазработкаСУЗКлиент.УстановитьКонтекстЭлектронногоРесурса(ЭтотОбъект);
	
	РазработкаСУЗКлиент.УстановитьДоступностьЭлементовВерсииДанных(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если ЗначениеЗаполнено(РодительРесурса) Тогда
		ПараметрыЗаписи.Вставить("РодительРесурса", РодительРесурса);
	КонецЕсли;

	ДокументДоступен = ДокументДоступен();
	
	Если НЕ ДокументДоступен И Объект.Ссылка.Пустая() И НЕ ПропуститьСохранениеДокумента Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Перед записью откройте новый документ'"));
		
		Отказ = Истина;
		
		Возврат;
		
	КонецЕсли;
	
	Если ДокументДоступен И НЕ ПропуститьСохранениеДокумента Тогда
		СохранитьДокумент(Истина);
	КонецЕсли;
	
	ПропуститьСохранениеДокумента = Ложь;
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	Для каждого Параметр Из ПараметрыЗаписи Цикл
		ТекущийОбъект.ДополнительныеСвойства.Вставить(Параметр.Ключ, Параметр.Значение);	
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, Описание, "Описание", "ТекстовыеДанные");
	
	Если ФайлыДляСохранения <> Неопределено Тогда
		
		Для каждого ОписаниеФайла Из ФайлыДляСохранения Цикл
		
			ПереданныйФайл = Новый Файл(ОписаниеФайла.Имя);
			
			ДвоичныеДанные = ПолучитьИзВременногоХранилища(ОписаниеФайла.Хранение);
			
			Если ПереданныйФайл.Расширение = ".zip" Тогда
				
				РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, ДвоичныеДанные, "HTML", "ДвоичныеДанные",,,"zip");
				
			Иначе	
				
				Если ЗначениеЗаполнено(ТекстовыеДанныеДляИндексирования) Тогда					
					
					ДанныеДляСохранения = Новый Структура;
					ДанныеДляСохранения.Вставить("ТекстовыеДанные", ТекстовыеДанныеДляИндексирования);
					ДанныеДляСохранения.Вставить("ДвоичныеДанные", ДвоичныеДанные);
					
					ИмяРеквизитаДляСохранения = "ВсеРеквизиты";
					
					РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ТекущийОбъект, ДанныеДляСохранения, "ДвоичныеДанные", ИмяРеквизитаДляСохранения);
					
				Иначе
					
					РазработкаСУЗ.СохранитьДвоичныеДанныеФайла(ТекущийОбъект, ДвоичныеДанные);
					
				КонецЕсли;
				
			КонецЕсли;
		
		КонецЦикла;		
			
		ТекстовыеДанныеДляИндексирования = "";
		ФайлыДляСохранения = Неопределено;		
		
	КонецЕсли;	
	
	УстановитьДоступностьЭлементовФормыНаСервере();
	
	Если ЗначениеЗаполнено(ЭлементСодержания) Тогда
		Справочники.СодержаниеСУЗ.Перезаписать(ЭлементСодержания);
	КонецЕсли;

	Если ЗначениеЗаполнено(ЭлементПодборки) Тогда
		Справочники.ЭлементыПодборкиСУЗ.Перезаписать(ЭлементПодборки);	
	КонецЕсли;		
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ОбновитьСсылкуНаЗагруженныйФайл();
	
	РазработкаСУЗ.ПоказатьКоличествоВерсийОбъектаНаФорме(ЭтотОбъект, ТекущийОбъект);
	
	// Обновляем ссылки и зависимые ресурсы фоновым заданием
	
	МассивПараметровФЗ = Новый Массив;
	МассивПараметровФЗ.Добавить(Объект.Владелец);
	
	ФоновыеЗадания.Выполнить("РазработкаСУЗ.ОбновитьГиперссылкиРесурса", МассивПараметровФЗ);	
	
	Если ТипЗнч(ЗависимыеРесурсыДляСохранения) = Тип("ФиксированныйМассив") Тогда
		ФоновыеЗадания.Выполнить("РазработкаСУЗ.ОбновитьЗависимыеРесурсы", Новый Массив(ЗависимыеРесурсыДляСохранения));		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	РазработкаСУЗКлиент.УстановитьДоступностьЭлементовВерсииДанных(ЭтотОбъект);
	
	Оповестить("ОбъектСУЗЗаписан", Объект.Ссылка, ЭтотОбъект);
	Оповестить("РесурсЗаписан", Объект.Владелец, ЭтотОбъект); // Всегда
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
		Оповестить("ЭлектронныйРесурсОбновлен", ЭлектронныйРесурс, ЭтотОбъект);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Подборка) Тогда
		Оповестить("ПодборкаОбновлена", Подборка, ЭтотОбъект);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, СтандартнаяОбработка)
	
	Если ДокументМодифицирован() Тогда
		Модифицированность = Истина;
	КонецЕсли;		
	
	Если ПерейтиКФормеРесурсаПередЗакрытием Тогда
		ПерейтиКФормеРесурсаПриЗакрытии = Истина;
	Иначе
		ПерейтиКФормеРесурсаПриЗакрытии = Ложь;
	КонецЕсли;
	
	ПерейтиКФормеРесурсаПередЗакрытием = Ложь;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии()	
	
	Если Приложение <> Неопределено Тогда
		
		Если Приложение.Пользовательское <> Неопределено Тогда
		
			Попытка
				УдалитьОбработчик Приложение.Пользовательское.Quit, ПриЗакрытииВнешнегоПриложения;	
				УдалитьОбработчик Приложение.Пользовательское.DocumentBeforeSave, ПриЗаписиДокумента;	
				УдалитьОбработчик Приложение.Пользовательское.DocumentBeforeClose, ПриЗакрытииДокумента;	
			Исключение		
			КонецПопытки;
			
			Если Приложение.Документ <> Неопределено Тогда
			
				Попытка
					Приложение.Документ.Close(0);
				Исключение		
				КонецПопытки;
				
			КонецЕсли;		
			
			Попытка	
				Приложение.Пользовательское.Quit(0);
			Исключение		
			КонецПопытки;

		КонецЕсли;
			
		Если Приложение.Скрытое <> Неопределено Тогда
		
			Попытка
				Приложение.Скрытое.Quit(0);
			Исключение		
			КонецПопытки;

		КонецЕсли;		
		
		Приложение = Неопределено;
		
	КонецЕсли;
	
		
	Если РабочийКаталог <> Неопределено Тогда
		
		Попытка
			УдалитьФайлы(РабочийКаталог.Путь);
		Исключение		
		КонецПопытки;
		
	КонецЕсли;
	
	Если ПерейтиКФормеРесурсаПриЗакрытии Тогда
		ПараметрыФормы =  Новый Структура("Ключ, РежимВыбора, ОткрытьФормуРесурса, ЭлектронныйРесурс, Подборка, ЭлементПодборки, ЭлементСодержания", Объект.Владелец, РежимВыбора, Истина, ЭлектронныйРесурс, Подборка, ЭлементПодборки, ЭлементСодержания);
		ОткрытьФорму("Справочник.РесурсыСУЗ.ФормаОбъекта", ПараметрыФормы, ВладелецФормы);
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

#КонецОбласти

#Область ОбработчикиКомандФормы

// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ОткрытьДокументWord(Команда)

	#Если НЕ ВебКлиент Тогда

	Если НЕ РазработкаСУЗКлиент.ЕстьПоддержкаДокументов() Тогда	
		Возврат;
	КонецЕсли;
	
	// Инициализируем приложение
	//
	
	Если Приложение = Неопределено Тогда
		Приложение = Новый Структура("Пользовательское, Скрытое, Версия, Документ, РасширениеПодключено", Неопределено, Неопределено, Неопределено, Неопределено, Ложь);
	КонецЕсли;
	
	Если НЕ ПриложениеДоступно(Приложение.Пользовательское) Тогда
		
		Попытка
			Приложение.Пользовательское = Новый COMObject("Word.Application");		
		Исключение
			Приложение.Пользовательское = Неопределено;
		КонецПопытки;			
		
	КонецЕсли;	
	
	Если НЕ ПриложениеДоступно(Приложение.Скрытое) Тогда
		
		Попытка
			Приложение.Скрытое = Новый COMObject("Word.Application");		
		Исключение
			Приложение.Скрытое = Неопределено;
		КонецПопытки;
		
		Приложение.Скрытое.Visible = Ложь;
		
	КонецЕсли;	
	
	Если НЕ ПриложениеДоступно(Приложение.Пользовательское)
		ИЛИ НЕ ПриложениеДоступно(Приложение.Скрытое) Тогда
		
		Приложение = Неопределено;		
		ПоказатьПредупреждение(,НСтр("ru = 'Ошибка инициализации приложения'"));		
		Возврат;
		
	КонецЕсли;
	
	Если Приложение.Версия = Неопределено Тогда
		Приложение.Версия = Число(ОбщегоНазначенияСУКлиентСервер.РасщепитьСтроку(Приложение.Пользовательское.Version, ".")[0]);	
	КонецЕсли;
	
	// Загружаем шаблоны
	//
	
	Если Шаблоны = Неопределено Тогда
		Шаблоны = Новый Структура("ПутьККаталогу, Пользовательские");	
	КонецЕсли;

	// Получаем путь к каталогу с шаблонами
	
	Если Шаблоны.ПутьККаталогу = Неопределено Тогда
	
		ShellApp = Новый COMОбъект("shell.application");				
		Folder = ShellApp.Namespace(21);
		
		Шаблоны.ПутьККаталогу = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(Folder.Self.Path);

	КонецЕсли;
	
	// Подключаем пользовательские шаблоны
	
	Если Шаблоны.Пользовательские = Неопределено Тогда
	
		ПользовательскиеШаблоныФикс = РазработкаСУЗ.ПользовательскиеШаблоныДокументов();	
		
		Шаблоны.Пользовательские = Новый Массив;
		
		Для каждого ШаблонФикс Из ПользовательскиеШаблоныФикс Цикл
			
			Шаблон = Новый Структура(ШаблонФикс);
			
			ПутьКФайлуШаблона = Шаблоны.ПутьККаталогу + Строка(Шаблон.Ссылка.УникальныйИдентификатор());
			ПутьКФайлуШаблона = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКФайлуШаблона);	
			ПутьКФайлуШаблона = ПутьКФайлуШаблона + Шаблон.ИмяФайла;
			
			Шаблон.Вставить("ПутьКФайлу", ПутьКФайлуШаблона);
			
			ФайлШаблона = Новый Файл(ПутьКФайлуШаблона);
			
			Если НЕ ФайлШаблона.Существует() ИЛИ ФайлШаблона.ПолучитьВремяИзменения() < Шаблон.ДатаИзменения Тогда
				
				МассивФайлов = Новый Массив;					
				МассивФайлов.Добавить(Новый ОписаниеПередаваемогоФайла(Шаблон.ИмяФайла, ПолучитьНавигационнуюСсылку(Шаблон.Ссылка, "ДвоичныеДанные")));
								
				ПолучитьФайлы(МассивФайлов,,ФайлШаблона.Путь, Ложь); 
				
				Если ФайлШаблона.Существует() Тогда
					ФайлШаблона.УстановитьВремяИзменения(Шаблон.ДатаИзменения);
				КонецЕсли;
				
			КонецЕсли;
			
			Шаблоны.Пользовательские.Добавить(Шаблон);
			
		КонецЦикла;
		
	КонецЕсли;		
	
	// Открываем документ
	//
	
	// Формируем рабочий каталог для работы с документом
	
	Если РабочийКаталог = Неопределено Тогда
		
		РабочийКаталог = Новый Структура("Путь, Документ, Копия, ФайлДляСохранения");
		
		РабочийКаталог.Путь = ПолучитьИмяВременногоФайла("");
		
		СоздатьКаталог(РабочийКаталог.Путь);
		
		РабочийКаталог.Путь = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(РабочийКаталог.Путь);			
		
		// Путь для сохранения документа
		
		РабочийКаталог.Документ = РабочийКаталог.Путь + "doc";
		
		СоздатьКаталог(РабочийКаталог.Документ);
		
		РабочийКаталог.Документ = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(РабочийКаталог.Документ);			
		
		// Путь для хранения копии документа
		
		РабочийКаталог.Копия = РабочийКаталог.Путь + "copy";
		
		СоздатьКаталог(РабочийКаталог.Копия);
		
		РабочийКаталог.Копия = ОбщегоНазначенияСУКлиентСервер.ДобавитьКонечныйРазделительПути(РабочийКаталог.Копия);		
		
	КонецЕсли;		
	
	// Открываем документ в пользовательском приложении
	
	Если НЕ ДокументДоступен() Тогда
	
		ДобавитьОбработчик Приложение.Пользовательское.Quit, ПриЗакрытииВнешнегоПриложения;
		ДобавитьОбработчик Приложение.Пользовательское.DocumentBeforeSave, ПриЗаписиДокумента;	
		ДобавитьОбработчик Приложение.Пользовательское.DocumentBeforeClose, ПриЗакрытииДокумента;
		
		СвойстваШаблона = Неопределено;
		
		Если ЗначениеЗаполнено(Объект.ШаблонДокумента) Тогда
			
			Для каждого ПользовательскийШаблонСвойства Из Шаблоны.Пользовательские Цикл
				Если ПользовательскийШаблонСвойства.Ссылка = Объект.ШаблонДокумента Тогда
					СвойстваШаблона = ПользовательскийШаблонСвойства;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;	
		
		Если СсылкаНаЗагруженныйФайл = Неопределено Тогда // Нет файла для открытия
		
			Если СвойстваШаблона = Неопределено Тогда		
				Приложение.Документ = Приложение.Пользовательское.Documents.Add();
			Иначе
				Приложение.Документ = Приложение.Пользовательское.Documents.Add(СвойстваШаблона.ПутьКФайлу);
			КонецЕсли;	
			
			Если НЕ ЗначениеЗаполнено(Объект.Наименование) Тогда
				Объект.Наименование = НСтр("ru = 'Документ'");
			КонецЕсли;

			ПропуститьЗаписьДокумента = Истина;
			
			Если Приложение.Версия < 12 Тогда
				
				Если Приложение.Версия < 11 Тогда
					
					Приложение.Документ.SaveAs2000(РабочийКаталог.Документ + Объект.Наименование + ".doc", 0,,,Ложь);
					
				Иначе
					
					Приложение.Документ.SaveAs(РабочийКаталог.Документ + Объект.Наименование + ".doc", 0,,,Ложь);
					
				КонецЕсли;
				
			Иначе
				
				Приложение.Документ.SaveAs(РабочийКаталог.Документ + Объект.Наименование, 16,,, Ложь);
				
			КонецЕсли;		
			
		Иначе
			
			ПолучитьФайл(СсылкаНаЗагруженныйФайл, РабочийКаталог.Документ + Объект.ИмяФайла, Ложь);
			
			Приложение.Документ = Приложение.Пользовательское.Documents.Open(РабочийКаталог.Документ + Объект.ИмяФайла,,,Ложь);
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Определяем видимость приложения
	//
	
	Приложение.Пользовательское.Visible = Истина;
	
	Приложение.Пользовательское.WindowState = 2;
	Приложение.Пользовательское.WindowState = 1;	
	
#КонецЕсли	
	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиВФормуРесурса(Команда)
	
	ПерейтиКФормеРесурсаПередЗакрытием = Истина;
	Закрыть();

КонецПроцедуры

&НаКлиенте
Процедура АрхивВерсий(Команда)
	РазработкаСУЗКлиент.ОткрытьВерсииОбъекта(ЭтотОбъект, Объект);
КонецПроцедуры

&НаКлиенте
Процедура СоздатьВерсию(Команда)
	
	Если ДокументДоступен() ИЛИ Модифицированность ИЛИ Объект.Ссылка.Пустая() Тогда
		
		ПоказатьПредупреждение(,НСтр("ru = 'Перед созданием новой версии сохраните документ и закройте его'"));
		
		Возврат;
		
	КонецЕсли;
	
	ОбновитьСсылкуНаЗагруженныйФайл();
	
	ОткрытьДокументWord(Неопределено);
	
	СтруктураНовойВерсии = РазработкаСУЗ.ПолучитьСтруктуруНовойВерсииОбъекта(Объект, ТипОбъектаНаКлиенте);
	РазработкаСУЗКлиент.СоздатьВерсиюОбъекта(ЭтотОбъект, СтруктураНовойВерсии);		
	
	ОбновитьСсылкуНаЗагруженныйФайл();
	
КонецПроцедуры



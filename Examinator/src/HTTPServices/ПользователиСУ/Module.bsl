Функция ЗагрузитьПользователейPOST(ЗапросHTTP)
	
	УстановитьПривилегированныйРежим(Истина);
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	// Получаем параметры запроса
	
	КлючЗапроса = СокрЛП(Строка(ЗапросHTTP.ПараметрыЗапроса.Получить("key")));
	
	Если НЕ ЗначениеЗаполнено(КлючЗапроса) Тогда
		Ответ = Новый HTTPСервисОтвет(400);
		Возврат Ответ;								
	КонецЕсли;		
	
	ДатаПредыдущегоЗапроса = ЗапросHTTP.ПараметрыЗапроса.Получить("previousRequestDate");
	
	Попытка
		ДатаПредыдущегоЗапроса = XMLЗначение(Тип("Дата"), ДатаПредыдущегоЗапроса);
	Исключение
		ДатаПредыдущегоЗапроса = Дата("00010101");
	КонецПопытки;
	
	// Проверяем ключ
	
	Хеширование = Новый ХешированиеДанных(ХешФункция.SHA1);
	Хеширование.Добавить(КлючЗапроса);		
	ХэшКлюча = Base64Строка(Хеширование.ХешСумма);
	ХэшКлючаВБазе = Константы.ХэшКлючаЗагрузкиПользователейСУО.Получить();
	
	Если ХэшКлючаВБазе <> ХэшКлюча Тогда
		Ответ = Новый HTTPСервисОтвет(403);
		Возврат Ответ;												
	КонецЕсли;
	
	// Возвращаем ответ, если это запрос для тестирования
	
	ВариантЗапроса = СокрЛП(Строка(ЗапросHTTP.ПараметрыЗапроса.Получить("mode")));
	Если ВариантЗапроса = "test" Тогда
		Ответ = Новый HTTPСервисОтвет(200);
		Возврат Ответ;		
	КонецЕсли;
	
	УправлениеОбучениемСУО.ЗагрузитьПользователей(ЗапросHTTP.ПолучитьТелоКакСтроку());
	
	Ответ = Новый HTTPСервисОтвет(200);

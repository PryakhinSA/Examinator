// Служит для получения HTML ссылки на объект.
//
// Параметры:
//  СсылкаНаОбъект    - ссылка на элемент справочника объекта.
//  ЦелевоеОкно       - Значение перечисления ЦелевыеОкнаДляСсылокСУЗ.
//  Якорь             - Строка, дополнительный якорь ссылки.
//  ДопСвойстваСсылки - Структура, содержащая уточняющую информацию о ссылке,
//                      например какую страницу подборки показать.
//
// Возвращаемое значение:
// 	Строка, содержащая текст ссылки.
//
Функция СсылкаНаОбъектСУЗ(Знач СсылкаНаОбъект, Знач ЦелевоеОкно="this", Знач Якорь="", Знач ДопСвойстваСсылки=Неопределено) Экспорт
	
	Перем ТекстСсылки;
	
	Если ТипЗнч(СсылкаНаОбъект) = Тип("СправочникСсылка.СодержаниеСУЗ") Тогда
		
		Если ДопСвойстваСсылки = Неопределено Тогда
			ДопСвойстваСсылки = Новый Структура();
		КонецЕсли;
		
		ДопСвойстваСсылки.Вставить("ЭлементСодержания", СсылкаНаОбъект);
		
		Если СсылкаНаОбъект.ЭтоГруппа Тогда
			
			Если ЗначениеЗаполнено(СсылкаНаОбъект.Карта) Тогда
				Карта = СсылкаНаОбъект.Карта;
			Иначе
				Карта = Справочники.КартыСУЗ.АвтоКарта;
			КонецЕсли;
			
			Если ДопСвойстваСсылки = Неопределено Тогда
				ДопСвойстваСсылки = Новый Структура();
			КонецЕсли;
		
			ДопСвойстваСсылки.Вставить("ПредметКарты", СсылкаНаОбъект);
			ДопСвойстваСсылки.Вставить("ИмяПредметаКарты", "Folder");
			
			СсылкаНаОбъект = Карта;
			
		Иначе
			
			СсылкаНаОбъект = СсылкаНаОбъект.СсылкаНаЭлемент;
			
		КонецЕсли;
		
	КонецЕсли;
	
	
	Если ТипЗнч(СсылкаНаОбъект) = Тип("СправочникСсылка.ЭлементыПодборкиСУЗ") Тогда
		
		Если ДопСвойстваСсылки = Неопределено Тогда
			ДопСвойстваСсылки = Новый Структура();
		КонецЕсли;
		
		ДопСвойстваСсылки.Вставить("ЭлементПодборки", СсылкаНаОбъект);
		
		СсылкаНаОбъект = СсылкаНаОбъект.Владелец;
		
	КонецЕсли;
	
	Если ТипЗнч(СсылкаНаОбъект) = Тип("СправочникСсылка.СодержаниеГлоссарияСУЗ") Тогда
		
		Если ДопСвойстваСсылки = Неопределено Тогда
			ДопСвойстваСсылки = Новый Структура();
		КонецЕсли;
		
		ДопСвойстваСсылки.Вставить("БукваДляПоиска", СсылкаНаОбъект.ТерминГлоссария.БукваДляПоиска);
		
		СсылкаНаОбъект = СсылкаНаОбъект.Владелец;
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
		Возврат "";
	КонецЕсли;
	
	ТипОбъекта = ОбъектыСУЗ.ПолучитьТипОбъектаСУЗ(СсылкаНаОбъект);
	
	ИмяОбъектаСУЗ = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ТипОбъекта);
		
	ТекстСсылки = "?id=" + СсылкаНаОбъект.УникальныйИдентификатор();
	ТекстСсылки = ТекстСсылки + "&object=" + ИмяОбъектаСУЗ;
		
	ИмяЦелевогоОкна = ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ЦелевоеОкно);
	Если НЕ ПустаяСтрока(ИмяЦелевогоОкна) Тогда
		ТекстСсылки = ТекстСсылки + "&window=" + ОбщегоНазначенияСУ.ИмяЗначенияПеречисления(ЦелевоеОкно);
	КонецЕсли;
		
	Если НЕ ПустаяСтрока(Якорь) Тогда
		ТекстСсылки = ТекстСсылки + "&anchor=" + Якорь;
	КонецЕсли;
		
	Если ТипОбъекта = Перечисления.ТипыОбъектовСУЗ.file Тогда
		ТекстСсылки = ТекстСсылки + "&action=openfile";
	КонецЕсли;
	
	Если ДопСвойстваСсылки <> Неопределено И ДопСвойстваСсылки.Свойство("БукваДляПоиска") Тогда
		ТекстСсылки = ТекстСсылки + "&letter=" + ДопСвойстваСсылки.БукваДляПоиска;
	КонецЕсли;
	
	Если (ИмяОбъектаСУЗ = "map" И НЕ ДопСвойстваСсылки=Неопределено) Тогда
		
		ПредметКарты = ДопСвойстваСсылки.ПредметКарты;
        ИдентификаторПредметаКарты = Строка(ПредметКарты.УникальныйИдентификатор());
		
		ТекстСсылки = ТекстСсылки + "&idTargetMap=" + ИдентификаторПредметаКарты;
		ТекстСсылки = ТекстСсылки + "&targetMap=" + ДопСвойстваСсылки.ИмяПредметаКарты;
		
		Если ДопСвойстваСсылки.Свойство("УровеньКарты") Тогда
			ТекстСсылки = ТекстСсылки + "&levelMap=" + ДопСвойстваСсылки.УровеньКарты;
		КонецЕсли;		
		
	КонецЕсли;
	
	Если (ИмяОбъектаСУЗ = "collection" И НЕ ДопСвойстваСсылки=Неопределено) Тогда  // Делаем ссылку на элемент подборки

		ЭлементПодборки = Справочники.ЭлементыПодборкиСУЗ.ПустаяСсылка();
		ДопСвойстваСсылки.Свойство("ЭлементПодборки", ЭлементПодборки);
		
		НомерГруппыПодборки = 0;
		ДопСвойстваСсылки.Свойство("НомерГруппыПодборки", НомерГруппыПодборки);
		
		ДокументСессии = Документы.ПопыткаВыполненияПодборкиВопросовСУЗ.ПустаяСсылка();
		ДопСвойстваСсылки.Свойство("ДокументСессии", ДокументСессии);
		
		НомерДокументаСессии = 0;
		ДопСвойстваСсылки.Свойство("НомерДокументаСессии", НомерДокументаСессии);
		
		Если ЗначениеЗаполнено(ЭлементПодборки) Тогда
			
			Если ДопСвойстваСсылки.Свойство("ПривязатьКИдентификаторуЭлементаПодборки") Тогда
				
				ТекстСсылки = ТекстСсылки + "&idGroup=" + ЭлементПодборки.УникальныйИдентификатор();
				
			Иначе
				
				Если НЕ ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаОбъект, "ЭтоТест")
					ИЛИ ДопСвойстваСсылки.Свойство("РазрешенПереходКВопросамТеста") Тогда
					
					// Находим верхний по иерархии элемент подборки
					Если ЗначениеЗаполнено(ЭлементПодборки.Родитель) Тогда
						ГруппаПодборки = ЭлементПодборки.Родитель;
						Если ЗначениеЗаполнено(ГруппаПодборки.Родитель) Тогда
							ГруппаПодборки = ГруппаПодборки.Родитель
						КонецЕсли;
					Иначе
						ГруппаПодборки = ЭлементПодборки;
					КонецЕсли;
					
					НомерГруппыПодборки = Справочники.ПодборкиСУЗ.НомерГруппыПодборки(СсылкаНаОбъект, ГруппаПодборки);
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НомерГруппыПодборки) Тогда
			ТекстСсылки = ТекстСсылки + "&numGroup=" + Формат(НомерГруппыПодборки, "ЧГ=0");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДокументСессии) Тогда
			НомерДокументаСессии = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСессии, "Номер");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НомерДокументаСессии) Тогда
			
			НомерДокументаСессии = ОбщегоНазначенияСУКлиентСервер.ЧислоВСтроку(НомерДокументаСессии);
			
			ТекстСсылки = ТекстСсылки + "&numDocument=" + НомерДокументаСессии;			
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ДопСвойстваСсылки <> Неопределено И ДопСвойстваСсылки.Свойство("ЭлементСодержания") Тогда
		ТекстСсылки = ТекстСсылки + "&item=" + ДопСвойстваСсылки.ЭлементСодержания.УникальныйИдентификатор();
	КонецЕсли;
	
	Если ДопСвойстваСсылки <> Неопределено И ДопСвойстваСсылки.Свойство("ЭтоСкрытыйРесурс") И ДопСвойстваСсылки.ЭтоСкрытыйРесурс Тогда
		ТекстСсылки = ТекстСсылки + "&isHiddenRes=true";
	КонецЕсли;	
	
	Возврат ТекстСсылки;
	
КонецФункции

// Функция получает текстовую ссылку на элемент содержания свода знаний,
// который следует за переданным в функцию элементом или перед ним.
// Так же допускается поиск элемента по его id или идентификатору SCORM.
//
Функция СсылкаНаОбъектЭлементаСодержанияПоНавигационномуЗапросу(СводЗнаний, ТекущийЭлементСодержания=Неопределено, НавигационныйЗапрос) Экспорт
	
	//0. Получаем дерево содержания.
	
	ТекстЗапроса = "ВЫБРАТЬ
	|	СодержаниеСУЗ.Ссылка КАК Ссылка,
	|	СодержаниеСУЗ.ЭтоГруппа,
	|	СодержаниеСУЗ.СсылкаНаЭлемент
	|ИЗ
	|	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
	|ГДЕ
	|	СодержаниеСУЗ.Владелец = &Владелец
	|	И СодержаниеСУЗ.ПометкаУдаления = ЛОЖЬ

	|УПОРЯДОЧИТЬ ПО
	|	Ссылка ИЕРАРХИЯ,
	|	СодержаниеСУЗ.Код ИЕРАРХИЯ";

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Владелец", СводЗнаний);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат "";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущийЭлементСодержания)
		И ТипЗнч(НавигационныйЗапрос) = Тип("Строка") Тогда
		
		Выборка = Результат.Выбрать();
		
		// 1. Получаем следующую ссылку.
		Если НавигационныйЗапрос = "Следующий" Тогда
			
			Выборка.НайтиСледующий(ТекущийЭлементСодержания, "Ссылка");
			
			Если Выборка.НайтиСледующий(ЛОЖЬ, "ЭтоГруппа") Тогда
				АдресСсылки = ОбъектыСУЗПовтИсп.СсылкаНаОбъектСУЗ(Выборка.СсылкаНаЭлемент, Перечисления.ЦелевыеОкнаДляСсылокСУЗ.main);
				АдресСсылки = АдресСсылки + "&item=" + Строка(Выборка.Ссылка.УникальныйИдентификатор());
				Возврат АдресСсылки;
			Иначе
				Возврат "";
			КонецЕсли;
			
		// 2. Получаем предыдущую ссылку.
		Иначе
			
			ПредыдущийЭлемент         = Неопределено;
			ПредыдущаяСсылкаНаЭлемент = Неопределено;
			
			Пока Выборка.Следующий() Цикл
				
				Если Выборка.Ссылка = ТекущийЭлементСодержания Тогда
					Прервать;
				КонецЕсли;
				
				Если НЕ Выборка.ЭтоГруппа Тогда
					ПредыдущийЭлемент         = Выборка.Ссылка;
					ПредыдущаяСсылкаНаЭлемент = Выборка.СсылкаНаЭлемент;
				КонецЕсли;
			
			КонецЦикла;
			
			Если ПредыдущийЭлемент = Неопределено Тогда
				Возврат "";
			Иначе
				АдресСсылки = ОбъектыСУЗПовтИсп.СсылкаНаОбъектСУЗ(ПредыдущаяСсылкаНаЭлемент, Перечисления.ЦелевыеОкнаДляСсылокСУЗ.main);
				АдресСсылки = АдресСсылки + "&item=" + Строка(ПредыдущийЭлемент.УникальныйИдентификатор());
				Возврат АдресСсылки;
			КонецЕсли;
			
		КонецЕсли;
			
	Иначе
		Возврат "";
	КонецЕсли;
	
		
КонецФункции

// Возвращает адрес гиперссылки на элемент содержания.
//
// Примечание: Следует различать ссылку на элемент содержания 
// и ссылку на объект связанный с этим элементом.
// Если вдруг в процессе разработки, объект элемента содержания будет
// изменен, а элемент содержания останется как таковой, то ссылка
// на этот элемент содержания будет работать, а ссылка 
// на объект, который был когда то связан с этим элементом, уже не будет работать.
//
Функция СсылкаНаЭлементСодержания(ЭлементСодержания) Экспорт
	Возврат "?id=" + ЭлементСодержания.УникальныйИдентификатор() + "&action=openKnowledgeBaseElementLink";
КонецФункции

Функция СсылкаНаПодсказку(Подсказка) Экспорт
	Возврат "?id=" + Подсказка.УникальныйИдентификатор() + "&action=openTip";
КонецФункции

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьОбучениеУчащегося(Команда = Неопределено)
	
	ТекущиеДанные = Элементы.Ведомость.ТекущиеДанные;
	
	Если НЕ ОбщегоНазначенияСУКлиент.ТекущиеДанныеТаблицыДоступны(ТекущиеДанные) Тогда
		Возврат;	
	КонецЕсли;
	
	ТекущееПоле = Элементы.Ведомость.ТекущийЭлемент;
	
	Если Найти(ТекущееПоле.Имя, "ВедомостьЗадание") = 1 Тогда // Стоим в ячейке задания
		
		НомерТекущегоЗадания = СтрЗаменить(ТекущееПоле.Имя, "ВедомостьЗадание", "");
		
		ЭлектронныйРесурс = ТекущиеДанные["Задание"+НомерТекущегоЗадания+"ЭлектронныйРесурс"];
		
		Если ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда // Сразу открываем прохождение электронного ресурса
			
			СсылкаНаЗадание             = ТекущиеДанные["Задание"+НомерТекущегоЗадания+"Ссылка"];
			ФрагментЭлектронногоРесурса = ТекущиеДанные["Задание"+НомерТекущегоЗадания+"ФрагментЭлектронногоРесурса"];
			ПрохождениеОбучения         = ТекущиеДанные["Задание"+НомерТекущегоЗадания+"ПрохождениеОбучения"];
			Вариант                     = ТекущиеДанные["Задание"+НомерТекущегоЗадания+"Вариант"];
			
			ОбъектыСУЗКлиент.ОткрытьОбозреватель(ЭлектронныйРесурс,
												 ФрагментЭлектронногоРесурса,
												 ?(ЗначениеЗаполнено(ФрагментЭлектронногоРесурса), Истина, Ложь),
												 ФрагментЭлектронногоРесурса,
												 ПрохождениеОбучения,
												 СсылкаНаЗадание,
			                                     Вариант);
			
			Возврат;
			
		Иначе
			
			ПрохождениеЗадания = ТекущиеДанные["Задание"+НомерТекущегоЗадания+"Прохождение"];
			
			ДанныеВедомостиЗадания = Новый Структура(
				"Оценка, ВозвращеноНаДоработку, ПричинаВозвратаНаДоработку, КомментарийПреподавателя");
			
			ДанныеВедомостиЗадания.Оценка = ТекущиеДанные["Задание"+НомерТекущегоЗадания+"Оценка"];
			ДанныеВедомостиЗадания.ВозвращеноНаДоработку = ТекущиеДанные["Задание"+НомерТекущегоЗадания+"ВозвращеноНаДоработку"];
			ДанныеВедомостиЗадания.ПричинаВозвратаНаДоработку = ТекущиеДанные["Задание"+НомерТекущегоЗадания+"ПричинаВозвратаНаДоработку"];
			ДанныеВедомостиЗадания.КомментарийПреподавателя = ТекущиеДанные["Задание"+НомерТекущегоЗадания+"КомментарийПреподавателя"];
			
			ДополнительныеПараметрыЗадания = Новый Структура;
			ДополнительныеПараметрыЗадания.Вставить("НомерЗадания", НомерТекущегоЗадания);
			ДополнительныеПараметрыЗадания.Вставить("ТекущаяСтрока", Элементы.Ведомость.ТекущаяСтрока);
			
			ОписаниеОповещенияОЗакрытии = Новый ОписаниеОповещения("ОбработатьПроверкуЗадания", ЭтотОбъект, ДополнительныеПараметрыЗадания);
			
			ОткрытьФорму("ОбщаяФорма.КарточкаЗаданияСУО", Новый Структура("ПрохождениеЗадания, ДанныеВедомости", ПрохождениеЗадания, ДанныеВедомостиЗадания),,,,,ОписаниеОповещенияОЗакрытии);
			
			Возврат;
			
		КонецЕсли;
		
	Иначе
		
		Если ТипЗнч(Сценарий) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда			
			
			ОбъектыСУЗКлиент.ОткрытьОбозреватель(Сценарий,
												 ,
												 ,
												 ,
												 Элементы.Ведомость.ТекущиеДанные.Прохождение,
												 Сценарий
												 );
			
			
		Иначе
			
			ОписаниеМероприятияСОднимЭлектроннымЗаданием = ОбучениеСУОВызовСервера.ОписаниеЕдинственногоЗаданияОбучения(ПроведениеОбучения);
			
			Если ОписаниеМероприятияСОднимЭлектроннымЗаданием <> Неопределено И ОписаниеМероприятияСОднимЭлектроннымЗаданием.НаОсновеЭлектронногоРесурса Тогда

				ОбъектыСУЗКлиент.ОткрытьОбозреватель(ОписаниеМероприятияСОднимЭлектроннымЗаданием.ЭлектронныйРесурс,
													 ,
													 ,
													 ,
													 Элементы.Ведомость.ТекущиеДанные.Прохождение,
													 ОписаниеМероприятияСОднимЭлектроннымЗаданием.Задание
													 );				
													 
			Иначе
				
				ПоказатьПредупреждение(,НСтр("ru = 'Установите курсор на ячейку задания и выберите команду ""Проверить задание""'"));
													 
			КонецЕсли;
			
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьПроверкуЗадания(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСтроки = Ведомость.НайтиПоИдентификатору(ДополнительныеПараметры.ТекущаяСтрока);
	НомерТекущегоЗадания = ДополнительныеПараметры.НомерЗадания;	
	
	ТекущееКомментарийПреподавателя   = ДанныеСтроки["Задание"+НомерТекущегоЗадания+"КомментарийПреподавателя"];
	ТекущееОценкаЗаЗадание            = ДанныеСтроки["Задание"+НомерТекущегоЗадания+"Оценка"];
	ТекущееПричинаВозвратаНаДоработку = ДанныеСтроки["Задание"+НомерТекущегоЗадания+"ПричинаВозвратаНаДоработку"];
	ТекущееПопыткаЗавершена           = ДанныеСтроки["Задание"+НомерТекущегоЗадания+"ПопыткаЗавершена"];
	ТекущееЗадание                    = ДанныеСтроки["Задание"+НомерТекущегоЗадания+"Ссылка"];
	ТекущееПроверенПреподавателем     = ДанныеСтроки["Задание"+НомерТекущегоЗадания+"ПроверенПреподавателем"];
	ТекущееВозвращеноНаДоработку      = ДанныеСтроки["Задание"+НомерТекущегоЗадания+"ВозвращеноНаДоработку"];	
	ТекущееВыставляетсяОценка         = ДанныеСтроки["Задание"+НомерТекущегоЗадания+"ВыставляетсяОценка"];
	
	ЗаполнитьРеквизитыЗаданияВВедомости(ДанныеСтроки, НомерТекущегоЗадания, РезультатЗакрытия, РезультатЗакрытия.Оценка);
	
	ОписаниеПрохождения = ЗаписатьСтрокуВедомости(ДополнительныеПараметры.ТекущаяСтрока, НомерТекущегоЗадания);
	
	Если ОписаниеПрохождения.Свойство("Сообщение")
		И ЗначениеЗаполнено(ОписаниеПрохождения.Сообщение) Тогда
		
			ДанныеВедомостиЗадания = Новый Структура("Оценка, ВозвращеноНаДоработку, ПричинаВозвратаНаДоработку,
			|КомментарийПреподавателя, ПроверенПреподавателем, ПопыткаЗавершена, ВыставляетсяОценка");

			ДанныеВедомостиЗадания.Оценка = ТекущееОценкаЗаЗадание;
			ДанныеВедомостиЗадания.ВозвращеноНаДоработку = ТекущееВозвращеноНаДоработку;
			ДанныеВедомостиЗадания.ПричинаВозвратаНаДоработку = ТекущееПричинаВозвратаНаДоработку;
			ДанныеВедомостиЗадания.КомментарийПреподавателя = ТекущееКомментарийПреподавателя;
			ДанныеВедомостиЗадания.ПроверенПреподавателем = ТекущееПроверенПреподавателем;
			ДанныеВедомостиЗадания.ПопыткаЗавершена = ТекущееПопыткаЗавершена;
			ДанныеВедомостиЗадания.ВыставляетсяОценка = ТекущееВыставляетсяОценка;

			ЗаполнитьРеквизитыЗаданияВВедомости(ДанныеСтроки, НомерТекущегоЗадания, ДанныеВедомостиЗадания, ДанныеВедомостиЗадания.Оценка);
		
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеПрохождения.Сообщение.Текст);
			
		Возврат;
		
	КонецЕсли;

КонецПроцедуры


КонецФункции

Функция ПолучитьОписаниеПользователяPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;
	
	// Получаем переменные
	//
	
	ИдентификаторПользователяСтрока = Запрос.ПараметрыURL.Получить("Пользователь");
	
	Если ИдентификаторПользователяСтрока = "current" Тогда
		Пользователь = ДанныеСессии.Пользователь;
	Иначе
	
		Попытка
			Пользователь = Справочники.Пользователи.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторПользователяСтрока));
		Исключение		
		КонецПопытки;
		
		Если НЕ ЗначениеЗаполнено(Пользователь) Тогда
			Возврат ОтветКлиентуJSON("errorData");
		КонецЕсли;	
		
	КонецЕсли;
		
	// Получаем описание пользователя
	//
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеПользователя.Данные КАК ОписаниеПользователя
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ДанныеПользователя
		|ГДЕ
		|	ДанныеПользователя.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.ПользовательОписание)
		|	И ДанныеПользователя.Объект = &Пользователь";
		
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	
	ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ОтветКлиентуJSON(,ВыборкаДетальныеЗаписи.ОписаниеПользователя);
	Иначе
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;	
	
КонецФункции

Функция ПолучитьСвоиУчебныеГруппыPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВыборкаУчебныхГрупп.Данные
		|ИЗ
		|	РегистрСведений.ДанныеВебКабинетаСУО_ОН КАК ВыборкаУчебныхГрупп
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОтборыДанныхВебКабинетаСУО_О КАК ОтборУчебныхГруппПользователя
		|		ПО ВыборкаУчебныхГрупп.Объект = ОтборУчебныхГруппПользователя.Объект
		|ГДЕ
		|	ОтборУчебныхГруппПользователя.Отбор = &ИдентификаторПользователя
		|	И ВыборкаУчебныхГрупп.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыДанныхВебКабинетаСУО.УчебнаяГруппа)";

	Запрос.УстановитьПараметр("ИдентификаторПользователя", ДанныеСессии.Пользователь.УникальныйИдентификатор());

	РезультатЗапроса = Запрос.Выполнить();

	ВыборкаУчебныхГрупп = РезультатЗапроса.Выбрать();
	
	УчебныеГруппы = Новый Массив;
			
	Пока ВыборкаУчебныхГрупп.Следующий() Цикл		
		УчебныеГруппы.Добавить(ВыборкаУчебныхГрупп.Данные);		
	КонецЦикла;	
	
	Возврат ОтветКлиентуJSON(,УчебныеГруппы);

КонецФункции

// Оценка качества обучения

Функция ЗаписатьОценкуКачестваОбученияPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
		
	// Делаем проверки сессии пользователя
	//
	
	ДанныеСессии = Неопределено;
	КодОшибки    = Неопределено;
	
	ПраваДляПроверки = Новый Массив;
	ПраваДляПроверки.Добавить("Обучение");
	
	РегистрыСведений.СессииВебКабинетаСУ.ДанныеСессииЗапроса(Запрос, ДанныеСессии, КодОшибки, Истина, ПраваДляПроверки);
	
	Если КодОшибки <> Неопределено Тогда
		Возврат ОтветКлиентуJSON(КодОшибки);
	КонецЕсли;

	// Получаем данные
	//	
	
	Попытка
		ИдентификаторПрохожденияОбучения = Новый УникальныйИдентификатор(Запрос.ПараметрыURL.Получить("ПрохождениеОбучения"));
	Исключение
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторПрохожденияОбучения) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	ПрохождениеОбучения = Документы.ПрохождениеОбученияСУО.ПолучитьСсылку(ИдентификаторПрохожденияОбучения);
	
	// Получаем данные для записи
	//
	
	ДанныеДляЗаписиJSON = СокрЛП(Запрос.ПолучитьТелоКакСтроку());
	
	Если НЕ ЗначениеЗаполнено(ДанныеДляЗаписиJSON) Тогда
		Возврат ОтветКлиентуJSON("errorData");
	КонецЕсли;
	
	Попытка
		ДанныеДляЗаписи = ОбщегоНазначенияСУ.JSONВДанные(ДанныеДляЗаписиJSON);
	Исключение
		Возврат ОтветКлиентуJSON("errorData");
	КонецПопытки;
	
	СтруктураДанных = Новый Структура;
	
	Если ДанныеДляЗаписи.Свойство("mark") Тогда		
		СтруктураДанных.Вставить("ОценкаКачестваОбучения", Число(ДанныеДляЗаписи.mark));		
	КонецЕсли;
	
	Если ДанныеДляЗаписи.Свойство("comment") Тогда		
		СтруктураДанных.Вставить("КомментарийКачестваОбучения", ДанныеДляЗаписи.comment);
	КонецЕсли;
	
	ОбучениеСУО.ЗаписатьДанныеОценкиКачестваОбучения(ПрохождениеОбучения, СтруктураДанных, Истина);			
	ВебКабинетСУ.ОбновитьДанныеОбъекта(Документы.ПрохождениеОбученияСУО, ПрохождениеОбучения);
	
	ПроведениеОбучения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПрохождениеОбучения, "ПроведениеОбучения");
	РегистрыСведений.ДокументыТребующиеПерепроведенияСУО.ДобавитьДокумент(ПроведениеОбучения);
	
	// Возвращаем результат
	//
	
	Возврат ОтветКлиентуJSON(, Новый Структура("ОперацияЗавершена", Истина));
	
КонецФункции


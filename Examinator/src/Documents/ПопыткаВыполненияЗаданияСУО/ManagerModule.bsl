#Если Сервер ИЛИ ТолстыйКлиентОбычноеПриложение ИЛИ ВнешнееСоединение Тогда
	
Функция Отменено(ПопыткаВыполненияЗадания) Экспорт
	
	Если ТипЗнч(ПопыткаВыполненияЗадания) = Тип("ДокументСсылка.ПопыткаВыполненияЗаданияСУО") Тогда
		ПопыткаВыполненияЗаданияСвойства = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПопыткаВыполненияЗадания, "ПрохождениеОбучения, Отменено");
	Иначе
		ПопыткаВыполненияЗаданияСвойства = ПопыткаВыполненияЗадания;
	КонецЕсли;
	
	Если ПопыткаВыполненияЗаданияСвойства.Отменено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Документы.ПрохождениеОбученияСУО.Отменено(ПопыткаВыполненияЗаданияСвойства.ПрохождениеОбучения);
	
КонецФункции

Функция Представление(ПопыткаВыполненияЗадания) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ПопыткаВыполненияЗадания) Тогда
		Возврат "";
	КонецЕсли;
	
	ДанныеПопыткаВыполненияЗадания = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПопыткаВыполненияЗадания, "ПрохождениеОбучения, Задание, Дата");
	
	НаименованиеЗадания = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеПопыткаВыполненияЗадания.Задание, "Наименование");
	
	Возврат Строка(Документы.ПрохождениеОбученияСУО.Представление(ДанныеПопыткаВыполненияЗадания.ПрохождениеОбучения)) + " - " + Строка(НаименованиеЗадания) + " - " + Строка(Формат(ДанныеПопыткаВыполненияЗадания.Дата, "ДЛФ=D"));
	
КонецФункции

// Проверяет, выполнено ли задание.
// Выполненным считается задание, которое завершено,
// т.е. сделано пользователем с проходным баллом
// и если оно требует проверки, то и проверено.
//
Функция Выполнено(ПопыткаВыполненияЗадания, ПопыткаЗавершена, ПроверяетсяПреподавателем, ПроверенПреподавателем, Баллы, ПроходнойБалл, ДатаОкончанияДоступаКЗаданию) Экспорт
	
	Если ЗначениеЗаполнено(ДатаОкончанияДоступаКЗаданию)
		И ДатаОкончанияДоступаКЗаданию < ТекущаяДатаСеанса() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПопыткаВыполненияЗадания) Тогда
		Возврат Ложь;
	КонецЕсли;	
	
	ПопыткаЗавершенаСПроходнымБаллом = (ПопыткаЗавершена И Баллы >= ПроходнойБалл);
	
	Если ПроверяетсяПреподавателем Тогда
		Возврат (ПроверенПреподавателем И ПопыткаЗавершенаСПроходнымБаллом);		
	Иначе			
		Возврат ПопыткаЗавершенаСПроходнымБаллом;		
	КонецЕсли;
	
КонецФункции

Функция ПолученаОценка(Знач ПопыткаВыполненияЗадания, Знач ПопыткаЗавершена, Знач ПроверяетсяПреподавателем, Знач ПроверенПреподавателем, Знач ДатаОкончанияДоступаКЗаданию, Знач ВыставляетсяОценка) Экспорт
	
	Если НЕ ВыставляетсяОценка Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПопыткаВыполненияЗадания) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ПопыткаЗавершена И ПроверяетсяПреподавателем И НЕ ПроверенПреподавателем Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаОкончанияДоступаКЗаданию)
		И ДатаОкончанияДоступаКЗаданию < ТекущаяДатаСеанса() Тогда
		Возврат Истина;
	КонецЕсли;
		
	Если ПроверяетсяПреподавателем Тогда
		Возврат (ПроверенПреподавателем И ПопыткаЗавершена);		
	Иначе			
		Возврат ПопыткаЗавершена;		
	КонецЕсли;
	
КонецФункции

Функция ОценкаЗаЗадание(Знач ПопыткаВыполненияЗадания) Экспорт
	
	ДанныеПопытки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПопыткаВыполненияЗадания, "ПроведениеОбучения, ПопыткаЗавершена, Баллы, ПроверяетсяПреподавателем, ПроверенПреподавателем, ДатаОкончанияДоступаКЗаданию, ВыставляетсяОценка");
	
	Если НЕ ПолученаОценка(ПопыткаВыполненияЗадания, ДанныеПопытки.ПопыткаЗавершена, ДанныеПопытки.ПроверяетсяПреподавателем, ДанныеПопытки.ПроверенПреподавателем, ДанныеПопытки.ДатаОкончанияДоступаКЗаданию, ДанныеПопытки.ВыставляетсяОценка) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ШкалаОценки = Документы.ПроведениеОбученияСУО.ШкалаОценки(ДанныеПопытки.ПроведениеОбучения);
	ДанныеОценки = Справочники.ШкалыОценокСУО.ОценкаИзБаллов(ДанныеПопытки.Баллы, ШкалаОценки, Истина);
	
	Возврат ДанныеОценки;
	
КонецФункции

Функция ПопыткиВыполненияЗаданий(ПрохождениеОбучения) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПопыткиПрохожденияЗаданийСУО.Регистратор КАК ПопыткаВыполненияЗадания,
		|	ПопыткиПрохожденияЗаданийСУО.ВыставляетсяОценка КАК ВыставляетсяОценка
		|ИЗ
		|	РегистрСведений.ПопыткиПрохожденияЗаданийСУО КАК ПопыткиПрохожденияЗаданийСУО
		|ГДЕ
		|	ПопыткиПрохожденияЗаданийСУО.ПрохождениеОбучения = &ПрохождениеОбучения";

	Запрос.УстановитьПараметр("ПрохождениеОбучения", ПрохождениеОбучения);

	Результат = Запрос.Выполнить();

	Возврат Результат.Выгрузить();
	
КонецФункции

Функция ФайлыШаблонаЗадания(ПопыткаВыполненияЗадания) Экспорт
	
	Если ТипЗнч(ПопыткаВыполненияЗадания) = Тип("ДокументСсылка.ПопыткаВыполненияЗаданияСУО") Тогда
		ПопыткаВыполненияЗаданияСвойства = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПопыткаВыполненияЗадания, "Задание, Вариант");
	Иначе
		ПопыткаВыполненияЗаданияСвойства = ПопыткаВыполненияЗадания;
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Файлы.ДатаСоздания КАК ДатаСоздания,
		|	Файлы.Наименование КАК Наименование,
		|	Файлы.Описание КАК Описание,
		|	Файлы.Ссылка КАК Файл,
		|	Файлы.Расширение КАК Расширение,
		|	Файлы.Размер КАК Размер
		|ИЗ
		|	Справочник.Файлы КАК Файлы
		|ГДЕ
		|	Файлы.ВладелецФайла = &Владелец
		|	И Файлы.ПометкаУдаления = ЛОЖЬ";
		
		
	Если ЗначениеЗаполнено(ПопыткаВыполненияЗаданияСвойства.Вариант) Тогда
		Запрос.УстановитьПараметр("Владелец", ПопыткаВыполненияЗаданияСвойства.Вариант);
	Иначе
		Запрос.УстановитьПараметр("Владелец", ПопыткаВыполненияЗаданияСвойства.Задание);
	КонецЕсли;	
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ФайлыПрохожденияЗадания(ПопыткаВыполненияЗадания) Экспорт
	
	МассивФайлов = Новый Массив;
	
	Если ЗначениеЗаполнено(ПопыткаВыполненияЗадания) Тогда
		ПрисоединенныеФайлы.ПолучитьПрикрепленныеФайлыКОбъекту(ПопыткаВыполненияЗадания, МассивФайлов);
	КонецЕсли;
	
	Возврат МассивФайлов;
		
КонецФункции

Функция ДанныеОПрохожденииЗаданий(ПрохождениеОбучения, ТаблицаЗаданий, Сценарий, ВидОбучения) Экспорт
	
	ДанныеОПрохождении = Новый Структура(
		"Баллы,
		|ТекущиеБаллы,
		|ЗавершеноВПроцентах,
		|ПроверяетсяПреподавателем,
		|ПроверенПреподавателем,
		|ВозвращеноНаДоработку,
		|МожноЗавершатьАвтоматически,
		|ВыставляетсяОценка",
		0,
		0,
		0,
		Ложь,
		Ложь,
		Ложь,
		Ложь,
		Ложь);
	
	// Получаем все попытки прохождения всех заданий

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПопыткиПрохожденияЗаданийСУО.Баллы КАК Баллы,
		|	ПопыткиПрохожденияЗаданийСУО.Регистратор КАК ПопыткаВыполненияЗадания,
		|	ПопыткиПрохожденияЗаданийСУО.ПроверяетсяПреподавателем КАК ПроверяетсяПреподавателем,
		|	ПопыткиПрохожденияЗаданийСУО.ПроверенПреподавателем КАК ПроверенПреподавателем,
		|	ПопыткиПрохожденияЗаданийСУО.ПопыткаЗавершена КАК ПопыткаЗавершена,
		|	ПопыткиПрохожденияЗаданийСУО.Задание КАК Задание,
		|	ПопыткиПрохожденияЗаданийСУО.Период КАК Дата,
		|	ПопыткиПрохожденияЗаданийСУО.ВозвращеноНаДоработку КАК ВозвращеноНаДоработку,
		|	ПопыткиПрохожденияЗаданийСУО.ЗавершеноВПроцентах КАК ЗавершеноВПроцентах,
		|	ПопыткиПрохожденияЗаданийСУО.ПроходнойБалл КАК ПроходнойБалл,
		|	ПопыткиПрохожденияЗаданийСУО.НеЖдатьПроверки КАК НеЖдатьПроверки,
		|	ПопыткиПрохожденияЗаданийСУО.ДатаОкончанияДоступаКЗаданию КАК ДатаОкончанияДоступаКЗаданию,
		|	ПопыткиПрохожденияЗаданийСУО.ВыставляетсяОценка КАК ВыставляетсяОценка
		|ИЗ
		|	РегистрСведений.ПопыткиПрохожденияЗаданийСУО КАК ПопыткиПрохожденияЗаданийСУО
		|ГДЕ
		|	ПопыткиПрохожденияЗаданийСУО.ПрохождениеОбучения = &ПрохождениеОбучения
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата УБЫВ";

	Запрос.УстановитьПараметр("ПрохождениеОбучения", ПрохождениеОбучения);

	Результат = Запрос.Выполнить();

	ТаблицаПрохожденийЗаданий = Результат.Выгрузить();
	ТаблицаПрохожденийЗаданий.Индексы.Добавить("Задание");	
	
	// Удаляем из таблицы прохождений лишние попытки, если 
	// кто-то сделал вторую попытку, удалив предыдущую,
	// а потом ее вернул. Оставляем на каждое задание по
	// одной попытке.

	МассивСтрокСАктуальнымиПопытками = Новый Массив();	
		
	Для каждого СтрокаТЗ Из ТаблицаЗаданий Цикл
		
		АктуальнаяПопытка = Неопределено;
		
		Для каждого Строка Из ТаблицаПрохожденийЗаданий Цикл
			
			Если Строка.Задание <> СтрокаТЗ.Задание Тогда
				Продолжить;
			КонецЕсли;					
				
			Если АктуальнаяПопытка = Неопределено ИЛИ АктуальнаяПопытка.Дата < Строка.Дата Тогда
				АктуальнаяПопытка = Строка;
			КонецЕсли;
							
		КонецЦикла;
		
		Если АктуальнаяПопытка <> Неопределено Тогда
			МассивСтрокСАктуальнымиПопытками.Добавить(АктуальнаяПопытка);
		КонецЕсли;

	КонецЦикла;	

	Индекс = ТаблицаПрохожденийЗаданий.Количество() - 1;
		
	Пока Индекс >= 0 Цикл

		Строка = ТаблицаПрохожденийЗаданий.Получить(Индекс);
		
		Если МассивСтрокСАктуальнымиПопытками.Найти(Строка) = Неопределено Тогда
			ТаблицаПрохожденийЗаданий.Удалить(Строка);
		КонецЕсли;
		
		Индекс = Индекс - 1;
		
	КонецЦикла;
	
	// Считаем данные о прогрессе и баллы
	
	МаксимальныйПрогресс = 0;
	РеальныйПрогресс = 0;
	МожноЗавершатьАвтоматически = Истина;
	МаксимумБаллов = 0;
	МаксимумТекущихБаллов = 0;
	НабранноеКоличествоБаллов = 0;
	ЕстьВозвращеныеНаДоработку = Ложь;
	ЕстьПроверяемыеПреподавателем = Ложь;
	ВсеПровереноПреподавателем = Истина;
	ВыставляетсяОценкаЗаЗадания = Ложь;
	
	ЗаданияПроверяютсяВыборочно = Справочники.ВидыМероприятийСУО.ЗаданияПроверяютсяВыборочно(ВидОбучения);
	
	Для каждого Строка Из ТаблицаЗаданий Цикл
		
		ЗначимостьЗадания = Строка.Значимость;		
		МаксимальныйПрогресс = МаксимальныйПрогресс + 100;		
		ПопыткаВыполненияЗадания = Неопределено;
		ПопыткаЗавершена = Ложь;
		ПроверяетсяПреподавателем = Ложь;
		ПроверенПреподавателем = Ложь;
		ДатаОкончанияДоступаКЗаданию = Строка.ДатаОкончанияДоступаКЗаданию;
		Баллы = 0;
		ЗавершеноВПроцентах = 0;
		ПроходнойБалл = Строка.ПроходнойБалл;
		ВозвращеноНаДоработку = Ложь;
		ВыставляетсяОценка = Строка.ВыставляетсяОценка;
		
		СтрокаТПЗ = ТаблицаПрохожденийЗаданий.Найти(Строка.Задание, "Задание");
		
		Если СтрокаТПЗ <> Неопределено Тогда
			ПопыткаВыполненияЗадания = СтрокаТПЗ.ПопыткаВыполненияЗадания;
			ПопыткаЗавершена = СтрокаТПЗ.ПопыткаЗавершена;
			ПроверяетсяПреподавателем = СтрокаТПЗ.ПроверяетсяПреподавателем;
			ПроверенПреподавателем = СтрокаТПЗ.ПроверенПреподавателем;
			ДатаОкончанияДоступаКЗаданию = СтрокаТПЗ.ДатаОкончанияДоступаКЗаданию;
			Баллы = СтрокаТПЗ.Баллы;
			ЗавершеноВПроцентах = СтрокаТПЗ.ЗавершеноВПроцентах;
			ВозвращеноНаДоработку = СтрокаТПЗ.ВозвращеноНаДоработку;
			ВыставляетсяОценка = СтрокаТПЗ.ВыставляетсяОценка;
		КонецЕсли;
		
		Если НЕ ВыставляетсяОценка Тогда
			ЗначимостьЗадания = 0;
		КонецЕсли;
		
		Если ВыставляетсяОценка Тогда
			ВыставляетсяОценкаЗаЗадания = Истина;	
		КонецЕсли;
		
		// Если это задание на проверку и оно не завершено,
		// то мы не считаем, что оно проверяется преподавателем
		// до тех пор, пока оно не будет завершено		
		Если ТипЗнч(Строка.Задание) = Тип("СправочникСсылка.ЗаданияСУО") И НЕ ПопыткаЗавершена Тогда
			ПроверяетсяПреподавателем = Ложь;
		КонецЕсли;
				
		Если ПроверяетсяПреподавателем Тогда
			ЕстьПроверяемыеПреподавателем = Истина;
		КонецЕсли;
		
		Если ПроверяетсяПреподавателем И НЕ ПроверенПреподавателем Тогда
			ВсеПровереноПреподавателем = Ложь;
		КонецЕсли;			
		
		Если ВозвращеноНаДоработку Тогда
			ЕстьВозвращеныеНаДоработку = Истина;
		КонецЕсли;
		
		ПолученаОценкаЗаЗадание = ПолученаОценка(ПопыткаВыполненияЗадания, ПопыткаЗавершена, ПроверяетсяПреподавателем, ПроверенПреподавателем, ДатаОкончанияДоступаКЗаданию, Строка.ВыставляетсяОценка);
				
		Если ПолученаОценкаЗаЗадание И ВыставляетсяОценка Тогда
			Если ПопыткаЗавершена Тогда
				ЗавершеноВПроцентах = 100;
			КонецЕсли;
			НабранноеКоличествоБаллов = НабранноеКоличествоБаллов + ЗначимостьЗадания * Баллы;
			МаксимумТекущихБаллов = МаксимумТекущихБаллов + ЗначимостьЗадания * 100;
			МаксимумБаллов = МаксимумБаллов + ЗначимостьЗадания * 100;
		КонецЕсли;
		
		РеальныйПрогресс = РеальныйПрогресс + ЗавершеноВПроцентах;
		
		// Определяем, можно ли завершать автоматически.
		// Завершать автоматически можно, когда все
		// задания выполнены (включая просроченные),
		// а те, что проверяются проверены,
		// кроме тех, что проверяются выборочно
		// и в выполненных набран проходной балл.
		
		ЖдатьПроверкиЗадания = ?(НЕ ЗаданияПроверяютсяВыборочно И НЕ Строка.НеЖдатьПроверки, Истина, Ложь);
		
		Если (НЕ ПолученаОценкаЗаЗадание И ВыставляетсяОценка И ЖдатьПроверкиЗадания) ИЛИ ЗавершеноВПроцентах <> 100 Тогда
			МожноЗавершатьАвтоматически = Ложь;
		КонецЕсли;
		
		Если ЖдатьПроверкиЗадания
			И ПопыткаЗавершена
			И ПроверяетсяПреподавателем 
			И НЕ ПроверенПреподавателем Тогда
			
			МожноЗавершатьАвтоматически = Ложь;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ПроходнойБалл) 
			И Баллы < ПроходнойБалл Тогда
		
			МожноЗавершатьАвтоматически = Ложь;
			
		КонецЕсли;
	
	КонецЦикла;
	
	ДанныеОПрохождении.ВозвращеноНаДоработку = ЕстьВозвращеныеНаДоработку;
	ДанныеОПрохождении.ПроверяетсяПреподавателем = ЕстьПроверяемыеПреподавателем;
	ДанныеОПрохождении.ПроверенПреподавателем = ВсеПровереноПреподавателем;
	ДанныеОПрохождении.ВыставляетсяОценка = ВыставляетсяОценкаЗаЗадания;
	
	Если НЕ ДанныеОПрохождении.ПроверяетсяПреподавателем Тогда
		ДанныеОПрохождении.ПроверенПреподавателем = Ложь;
	КонецЕсли;		
		
	Если МаксимальныйПрогресс > 0 Тогда
		ДанныеОПрохождении.ЗавершеноВПроцентах = Окр(( РеальныйПрогресс / МаксимальныйПрогресс )*100);
	Иначе
		ДанныеОПрохождении.ЗавершеноВПроцентах = 100; // Нет заданий
	КонецЕсли;	
	
	Если МаксимумБаллов > 0 Тогда 		
		ДанныеОПрохождении.Баллы = Окр((НабранноеКоличествоБаллов / МаксимумБаллов)*100);		
	Иначе		
		ДанныеОПрохождении.Баллы = 0; // Нет заданий
	КонецЕсли;	
	
	Если МаксимумТекущихБаллов > 0 Тогда 		
		ДанныеОПрохождении.ТекущиеБаллы = Окр((НабранноеКоличествоБаллов / МаксимумТекущихБаллов)*100);		
	Иначе		
		ДанныеОПрохождении.ТекущиеБаллы = 0; // Нет заданий		
	КонецЕсли;
	
	ДанныеОПрохождении.МожноЗавершатьАвтоматически = МожноЗавершатьАвтоматически;
	
	Возврат ДанныеОПрохождении;
	
КонецФункции


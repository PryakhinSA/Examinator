  <attributes>
    <name>ПользователиДоступ</name>
    <title>
      <key>ru</key>
      <value>Пользователи с отбором доступа</value>
    </title>
    <id>35</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПользователиДоступ.Пользователь</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	Пользователи.Ссылка КАК Пользователь,
	Пользователи.ПометкаУдаления,
	Пользователи.Предопределенный,
	Пользователи.Наименование,
	ВЫБОР
		КОГДА Пользователи.ПометкаУдаления
			ТОГДА 0
		КОГДА Пользователи.ИдентификаторПользователяИБ = &amp;ПустойУникальныйИдентификатор
			ТОГДА 4
		ИНАЧЕ 1
	КОНЕЦ КАК НомерКартинки
ИЗ
	Справочник.Пользователи КАК Пользователи
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПользователиВебКабинетаСУ КАК ПользователиВебКабинетаСУ
		ПО (&amp;ВходВВебКабинетРазрешенЗадано)
			И (ПользователиВебКабинетаСУ.Пользователь = Пользователи.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВремяДоступаПользователейСУО КАК ВремяДоступаПользователейСУО
		ПО (&amp;ЗакончилосьВремяДоступаЗадано)
			И (ВремяДоступаПользователейСУО.Пользователь = Пользователи.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
		ПО (&amp;ЗаполненаЭлектроннаяПочтаЗадано)
			И (ПользователиКонтактнаяИнформация.Ссылка = Пользователи.Ссылка)
			И (ПользователиКонтактнаяИнформация.Вид = &amp;КидКИЭлектроннаяПочтаПользователя)
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
		ПО (&amp;ГруппаДоступаЗадано)
			И (ГруппыДоступаПользователи.Пользователь = Пользователи.Ссылка)
			И (ГруппыДоступаПользователи.Ссылка = &amp;ГруппаДоступа)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СоставыГруппПользователей КАК СоставыГруппПользователей
		ПО (&amp;ГруппаПользователейЗадано)
			И Пользователи.Ссылка = СоставыГруппПользователей.Пользователь
			И (СоставыГруппПользователей.ГруппаПользователей = &amp;ГруппаПользователей)
ГДЕ
	Пользователи.Служебный = ЛОЖЬ
	И (НЕ &amp;ИдентификаторыПользователейИБЗаданы
			ИЛИ &amp;ИдентификаторыПользователейИБЗаданы = ИСТИНА
				И Пользователи.ИдентификаторПользователяИБ В (&amp;ИдентификаторыПользователейИБ))
	И (НЕ &amp;ВходВПрограммуРазрешенИдентификаторыЗаданы
			ИЛИ &amp;ВходВПрограммуРазрешенИдентификаторыЗаданы = ИСТИНА
				И Пользователи.ИдентификаторПользователяИБ В (&amp;ВходВПрограммуРазрешенИдентификаторы)
			ИЛИ &amp;ОтобратьСПустымИдентификаторомИБ = ИСТИНА
				И Пользователи.ИдентификаторПользователяИБ = &amp;ПустойУникальныйИдентификатор)
	И (НЕ &amp;ВходВВебКабинетРазрешенЗадано
			ИЛИ &amp;ВходВВебКабинетРазрешен = ИСТИНА
				И НЕ ПользователиВебКабинетаСУ.Пользователь ЕСТЬ NULL
			ИЛИ &amp;ВходВВебКабинетРазрешен = ЛОЖЬ
				И ПользователиВебКабинетаСУ.Пользователь ЕСТЬ NULL)
	И (НЕ &amp;ЗакончилосьВремяДоступаЗадано
			ИЛИ &amp;ЗакончилосьВремяДоступа = ИСТИНА
				И НЕ ВремяДоступаПользователейСУО.Пользователь ЕСТЬ NULL
				И ВремяДоступаПользователейСУО.ДатаОкончанияДоступа &lt;> &amp;ПустаяДата
				И ВремяДоступаПользователейСУО.ДатаОкончанияДоступа &lt; &amp;ТекущаяДата
			ИЛИ &amp;ЗакончилосьВремяДоступа = ЛОЖЬ
				И (ВремяДоступаПользователейСУО.Пользователь ЕСТЬ NULL
					ИЛИ ВремяДоступаПользователейСУО.ДатаОкончанияДоступа = &amp;ПустаяДата
					ИЛИ ВремяДоступаПользователейСУО.ДатаОкончанияДоступа > &amp;ТекущаяДата))
	И (НЕ &amp;ЗаполненаЭлектроннаяПочтаЗадано
			ИЛИ &amp;ЗаполненаЭлектроннаяПочта = ИСТИНА
				И ПользователиКонтактнаяИнформация.АдресЭП &lt;> &quot;&quot;
			ИЛИ &amp;ЗаполненаЭлектроннаяПочта = ЛОЖЬ
				И ПользователиКонтактнаяИнформация.АдресЭП = &quot;&quot;
			ИЛИ &amp;ЗаполненаЭлектроннаяПочта = ЛОЖЬ
				И ПользователиКонтактнаяИнформация.Ссылка ЕСТЬ NULL)
	И (НЕ &amp;ЭлектроннаяПочтаЗадано
			ИЛИ &amp;ЭлектроннаяПочтаЗадано = ИСТИНА
				И ПользователиКонтактнаяИнформация.АдресЭП = &amp;ЭлектроннаяПочта)
	И (НЕ &amp;ГруппаДоступаЗадано
			ИЛИ &amp;ГруппаДоступаЗадано = ИСТИНА
				И ГруппыДоступаПользователи.Ссылка = &amp;ГруппаДоступа)
	И (НЕ &amp;ГруппаПользователейЗадано
			ИЛИ &amp;ГруппаПользователейЗадано = ИСТИНА
				И СоставыГруппПользователей.ГруппаПользователей = &amp;ГруппаПользователей)
	И (НЕ &amp;НедействителенЗадано
			ИЛИ &amp;НедействителенЗадано = ИСТИНА
				И Пользователи.Недействителен = &amp;Недействителен)
	И (НЕ &amp;ПометкаУдаленияЗадано
			ИЛИ &amp;ПометкаУдаленияЗадано = ИСТИНА
				И Пользователи.ПометкаУдаления = &amp;ПометкаУдаления)
	И (НЕ &amp;УстановленыНастройкиДоступаЗадано
			ИЛИ &amp;УстановленыНастройкиДоступаЗадано = ИСТИНА
				И &amp;УстановленыНастройкиДоступа = ИСТИНА
				И Пользователи.ИдентификаторПользователяИБ &lt;> &amp;ПустойУникальныйИдентификатор
			ИЛИ &amp;УстановленыНастройкиДоступаЗадано = ИСТИНА
				И &amp;УстановленыНастройкиДоступа = ЛОЖЬ
				И Пользователи.ИдентификаторПользователяИБ = &amp;ПустойУникальныйИдентификатор)</queryText>
      <mainTable>Catalog.Пользователи</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>

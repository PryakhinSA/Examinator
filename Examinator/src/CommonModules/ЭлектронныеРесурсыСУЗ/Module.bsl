Функция ОбработатьОтветНаВопрос(ДанныеJSON) Экспорт
	
	// Получаем основные переменные
	
	РезультатОбработки = Новый Структура("Код, Текст, Форма", 0, "", Неопределено);
	
	ПереводСвойств = Новый ТаблицаЗначений;
	
	ПереводСвойств.Колонки.Добавить("EN");
	ПереводСвойств.Колонки.Добавить("RU");
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "code";
	НоваяСтрока.RU = "Код";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "active";
	НоваяСтрока.RU = "Активный";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "complete";
	НоваяСтрока.RU = "Завершен";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "codeComment";
	НоваяСтрока.RU = "КодКомментария";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "startData";
	НоваяСтрока.RU = "НачальныеДанные";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "endData";
	НоваяСтрока.RU = "ИтоговыеДанные";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "answer";
	НоваяСтрока.RU = "ОтветПользователя";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "link";
	НоваяСтрока.RU = "Ссылка";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "score";
	НоваяСтрока.RU = "Результат";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "value";
	НоваяСтрока.RU = "Значение";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "startDate";
	НоваяСтрока.RU = "ДатаНачала";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "endDate";
	НоваяСтрока.RU = "ДатаОкончания";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "safely";
	НоваяСтрока.RU = "Безопасно";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "verAPI";
	НоваяСтрока.RU = "ВерсияAPI";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "data";
	НоваяСтрока.RU = "Данные";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "name";
	НоваяСтрока.RU = "Имя";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "typeValue";
	НоваяСтрока.RU = "ТипЗначения";
	
	НоваяСтрока = ПереводСвойств.Добавить();
	НоваяСтрока.EN = "toProgram";
	НоваяСтрока.RU = "ЗаполняетсяПрограммой";
	
	Данные = ОбщегоНазначенияСУ.JSONВДанные(ДанныеJSON, СтрДлина(ДанныеJSON)); 	
	
	ТаблицаЭтапов = Новый ТаблицаЗначений;
	
	Для каждого Реквизит Из Метаданные.Документы.ОтветНаВопросСУЗ.ТабличныеЧасти.ЭтапыРаботыВПрограмме.Реквизиты Цикл
		ТаблицаЭтапов.Колонки.Добавить(Реквизит.Имя, Реквизит.Тип);	
	КонецЦикла;
	
	ТаблицаПараметров = Новый ТаблицаЗначений;
	
	Для каждого Реквизит Из Метаданные.Справочники.ВопросыСУЗ.ТабличныеЧасти.Параметры.Реквизиты Цикл
		ТаблицаПараметров.Колонки.Добавить(Реквизит.Имя, Реквизит.Тип);	
	КонецЦикла;	
	
	ТаблицаПараметров.Колонки.Добавить("ТипЗначения", Новый ОписаниеТипов("Строка"));
	
	Обработка = Новый Структура;
	
	// Заполняем переменные

	Для каждого Этап Из Данные.stages Цикл

		НоваяСтрока = ТаблицаЭтапов.Добавить();
		
		Для каждого Колонка Из ТаблицаЭтапов.Колонки Цикл
			НоваяСтрока[Колонка.Имя] = Этап[ПереводСвойств.Найти(Колонка.Имя, "RU").EN];	
		КонецЦикла;

	КонецЦикла;
	
	Для каждого Параметр Из Данные.parameters Цикл

		НоваяСтрока = ТаблицаПараметров.Добавить();
		
		Для каждого Колонка Из ТаблицаПараметров.Колонки Цикл
			НоваяСтрока[Колонка.Имя] = Параметр[ПереводСвойств.Найти(Колонка.Имя, "RU").EN];	
		КонецЦикла;

	КонецЦикла;	
	
	Для каждого Строка Из ТаблицаПараметров Цикл
	
		Если Строка.ТипЗначения = "Число" Тогда
			Строка.Значение = Число(Строка.Значение);
		КонецЕсли;
			
		Если Строка.ТипЗначения = "Дата" Тогда
			Строка.Значение = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(Строка.Значение);
		КонецЕсли;

		Если Строка.ТипЗначения = "Булево" Тогда
			Строка.Значение = ОбщегоНазначенияСУКлиентСервер.СтрокаВБулево(Строка.Значение);
		КонецЕсли;
			
	КонецЦикла;
	
	Обработка = Справочники.ПрограммныеПродуктыСУЗ.ОписаниеОбработки();
	
	Для каждого ПараметрОбработки Из Обработка Цикл
		Обработка.Вставить(ПараметрОбработки.Ключ, Данные.program.processor[ПереводСвойств.Найти(ПараметрОбработки.Ключ, "RU").EN]);	
	КонецЦикла;
	
	ДанныеДляОбработкиXML = ОбщегоНазначения.ЗначениеВСтрокуXML(Новый Структура("Этапы, Параметры, Обработка", ТаблицаЭтапов, ТаблицаПараметров, Обработка));
	
	// Соединяемся с внешней базой
	
	ПрограммныйПродукт = Справочники.ПрограммныеПродуктыСУЗ.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.program.id));
	
	РезультатОбработки = Справочники.ПрограммныеПродуктыСУЗ.ОбработатьОтветПользователя(ДанныеДляОбработкиXML, ПрограммныйПродукт, ОбъектыСУЗ.ТекущийПользователь());
	
	Если РезультатОбработки.Код <> 0 Тогда
		Возврат РезультатОбработки;
	КонецЕсли;
	
	// Сохраняем результат в переданные данные
	
	ДанныеДляОбработки = ОбщегоНазначения.ЗначениеИзСтрокиXML(ДанныеДляОбработкиXML);
	
	Для каждого Этап Из Данные.stages Цикл
		
		НовыеСвойстваЭтапа = ДанныеДляОбработки.Этапы.Найти(Этап[ПереводСвойств.Найти("Код", "RU").EN], "Код");	
		
		Если НовыеСвойстваЭтапа = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для каждого СвойстваЭтапа Из Этап Цикл
			
			НовоеЗначение = НовыеСвойстваЭтапа[ПереводСвойств.Найти(СвойстваЭтапа.Ключ, "EN").RU];
							
			Этап.Вставить(СвойстваЭтапа.Ключ, НовоеЗначение);	
			
		КонецЦикла;
		
	КонецЦикла;
	
	Для каждого Параметр Из Данные.parameters Цикл
		
		НовыеСвойстваПараметра = ДанныеДляОбработки.Параметры.Найти(Параметр[ПереводСвойств.Найти("Код", "RU").EN], "Код");	
		
		Если НовыеСвойстваПараметра = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для каждого СвойстваПараметра Из Параметр Цикл
			
			НовоеЗначение = НовыеСвойстваПараметра[ПереводСвойств.Найти(СвойстваПараметра.Ключ, "EN").RU];
							
			Параметр.Вставить(СвойстваПараметра.Ключ, НовоеЗначение);	

		КонецЦикла;
		
	КонецЦикла;
	
	// Завершаем
	
	Данные.Удалить("program"); // Не требуется
	
	ДанныеJSON = ОбщегоНазначенияСУ.ДанныеВJSON(Данные);
	
	Возврат РезультатОбработки;
	
КонецФункции


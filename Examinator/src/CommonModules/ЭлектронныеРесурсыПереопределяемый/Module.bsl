	//----------------------------------//
	
КонецПроцедуры

Функция ОбучениеОтменено(Знач ИзучениеОтменено, Знач ПрохождениеОбучения, Знач Задание) Экспорт
	
	Отменено = ИзучениеОтменено;
	
	//--# КОНСТРУКТОР КУРСОВ УДАЛИТЬ #--//
	
	Если НЕ Отменено Тогда
	
		ПопыткаВыполненияЗадания = ОбучениеСУО.ПоследнееПрохождениеЗадания(ПрохождениеОбучения, Задание);
		Если ЗначениеЗаполнено(ПопыткаВыполненияЗадания) Тогда
			Отменено = Документы.ПопыткаВыполненияЗаданияСУО.Отменено(ПопыткаВыполненияЗадания);
		ИначеЕсли ЗначениеЗаполнено(ПрохождениеОбучения) Тогда
			Отменено = Документы.ПрохождениеОбученияСУО.Отменено(ПрохождениеОбучения);
		КонецЕсли;
		
	КонецЕсли;
		
	//----------------------------------//
	
	Возврат Отменено;
	
КонецФункции
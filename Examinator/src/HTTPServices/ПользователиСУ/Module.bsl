Функция ОбработатьОтветПровайдераOpenIDANY(ЗапросHTTP)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получаем переменные запроса
	
	Куки = ЗапросHTTP.Заголовки.Получить("Cookie");
	ИмяПользователя = ЗапросHTTP.ПараметрыЗапроса.Получить("openid.auth.user");
	ИдентификаторПроверки = ЗапросHTTP.ПараметрыЗапроса.Получить("openid.auth.uid");
	
	КодПубликации = ЗапросHTTP.ПараметрыURL.Получить("КодПубликации");
	ВерсияВебКабинетаНаКлиенте = ЗапросHTTP.ПараметрыURL.Получить("ВерсияAPI");
	ИмяСобытия = ЗапросHTTP.ПараметрыURL.Получить("ИмяСобытия");
		
	
	Если КодПубликации = Неопределено И ЗначениеЗаполнено(Куки) Тогда
		
		// Ищем код публикации
		
		КукиМассив = ОбщегоНазначенияСУКлиентСервер.РасщепитьСтроку(Куки, ";");
		
		Для каждого ЗначениеКуки Из КукиМассив Цикл
		
			ЗначениеКукиМассив = ОбщегоНазначенияСУКлиентСервер.РасщепитьСтроку(ЗначениеКуки, "=");
			
			Если ЗначениеКукиМассив.Количество() <> 2 Тогда
				Продолжить;
			КонецЕсли;
			
			Если СокрЛП(ЗначениеКукиМассив[0]) = "publication" Тогда
				КодПубликации = СокрЛП(ЗначениеКукиМассив[1]);
				Прервать;
			КонецЕсли;
		
		КонецЦикла;			
		
		// Ищем версию веб-кабинета на клиенте
		
		Если ЗначениеЗаполнено(КодПубликации) Тогда
		
			Для каждого ЗначениеКуки Из КукиМассив Цикл
			
				ЗначениеКукиМассив = ОбщегоНазначенияСУКлиентСервер.РасщепитьСтроку(ЗначениеКуки, "=");
				
				Если ЗначениеКукиМассив.Количество() <> 2 Тогда
					Продолжить;
				КонецЕсли;
				
				Если СокрЛП(ЗначениеКукиМассив[0]) = КодПубликации + "_" + "version" Тогда
					ВерсияВебКабинетаНаКлиенте = СокрЛП(ЗначениеКукиМассив[1]);
				КонецЕсли;
				
				Если СокрЛП(ЗначениеКукиМассив[0]) = КодПубликации + "_" + "event" Тогда
					ИмяСобытия = СокрЛП(ЗначениеКукиМассив[1]);
				КонецЕсли;
				
				
			КонецЦикла;	
			
		КонецЕсли;	
		
	КонецЕсли;
	
	// Создаем сессию
	
	СтруктураДанных = Новый Структура(
		"clientID, publication, version, login, event",
		ИдентификаторПроверки, КодПубликации, ВерсияВебКабинетаНаКлиенте, ИмяПользователя, ИмяСобытия);
	
	Если ИмяСобытия = "lookup" ИЛИ ИмяСобытия = "authentication" Тогда
	
		ОтветJSON = СоздатьСессиюПользователя("openid", СтруктураДанных);
		
	Иначе // check
		
		ОтветJSON = ПроверитьЗапросOpenID(СтруктураДанных);
		
		Если ОтветJSON = Неопределено Тогда
			ОтветJSON = ОтветКлиентуJSON(,Новый Структура("result, event", Истина, ИмяСобытия));
		КонецЕсли;		
		
	КонецЕсли;
	
	// Возвращаем результат
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПубликацииВебКабинетаСУ.Редакция
		|ИЗ
		|	Справочник.ПубликацииВебКабинетаСУ КАК ПубликацииВебКабинетаСУ
		|ГДЕ
		|	ПубликацииВебКабинетаСУ.Код = &КодПубликации";
	
	Запрос.УстановитьПараметр("КодПубликации", КодПубликации);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		РедакцияПубликации = ВебКабинетСУ.Редакция();
	Иначе		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий();
		РедакцияПубликации = ВыборкаДетальныеЗаписи.Редакция;
	КонецЕсли;
	
	Если РедакцияПубликации = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
	
		ОтветСервераСтрока = "
		|<!DOCTYPE html>
		|<html>
		|	<head></head>
		|	<body onload=""parent.oAPI.openID.processResponse(document.getElementById('sessionData').textContent, '"+ИмяСобытия+"')"">
		|		<pre id=""sessionData"">%1</pre>
		|	</body>
		|</html>";
		
	Иначе
		
		ОтветСервераСтрока = "
		|<!DOCTYPE html>
		|<html>
		|	<head></head>
		|	<body onload=""parent.postMessage(document.getElementById('sessionData').textContent, '*')"">
		|		<pre id=""sessionData"">%1|%2</pre>
		|	</body>
		|</html>";
		
	КонецЕсли;
		
	ОтветСервераСтрока = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ОтветСервераСтрока, ОтветJSON.ПолучитьТелоКакСтроку(), ИмяСобытия);
	
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "text/html");
	Ответ.УстановитьТелоИзСтроки(ОтветСервераСтрока);
	Возврат Ответ;
	
КонецФункции

// ОБЩИЕ
//

Функция ОтветКлиентуJSON(КодОшибки = "", Данные = NULL)
	
	ТекстСообщенияСтруктура = Новый Структура("error, data", КодОшибки, Данные);
	
	ТекстСообщения = ОбщегоНазначенияСУ.ДанныеВJSON(ТекстСообщенияСтруктура);

	Если ЗначениеЗаполнено(КодОшибки) Тогда
		Ответ = Новый HTTPСервисОтвет(400);
	Иначе
		Ответ = Новый HTTPСервисОтвет(200);
	КонецЕсли;
		
	Ответ.УстановитьТелоИзСтроки(ТекстСообщения);
	
	Ответ.Заголовки.Вставить("Content-Type", "application/json");
	ДобавитьЗаголовкиМежсайтовогоЗапроса(Ответ);
	
	Возврат Ответ;
	
КонецФункции

Функция ОтветКлиентуTEXT(КодОшибки = "", Данные = NULL)
	
	// В настоящее время используется один вариант,
	// С данными в виде текста, без ошибок
	
	ТекстСообщения = Строка(Данные); 
	
	Если ЗначениеЗаполнено(КодОшибки) Тогда
		Ответ = Новый HTTPСервисОтвет(400);
	Иначе
		Ответ = Новый HTTPСервисОтвет(200);
	КонецЕсли;
		
	Ответ.УстановитьТелоИзСтроки(ТекстСообщения);
	
	Ответ.Заголовки.Вставить("Content-Type", "text/plain");
	ДобавитьЗаголовкиМежсайтовогоЗапроса(Ответ);
	
	Возврат Ответ;
	
КонецФункции


// ПОЛНОТЕКСТОВЫЙ ПОИСК

Функция ОбновитьВсеДанныеДляИндексирования() Экспорт
	ОбновитьДанныеДляИндексирования();
КонецФункции
	
Функция ОбновитьДанныеДляИндексирования(ЭлектронныйРесурс = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Очищаем данные регистра ДанныеДляПолнотекстовогоПоискаСУЗ
	
	НаборЗаписей = РегистрыСведений.ДанныеДляПолнотекстовогоПоискаСУЗ.СоздатьНаборЗаписей();
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
		НаборЗаписей.Отбор.ЭлектронныйРесурс.Установить(ЭлектронныйРесурс);
	КонецЕсли;
	
	НаборЗаписей.Записать();
	
	// Записываем данные в регистр
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс) Тогда
		
		ЗаписатьЭлементВДанныеДляИндексирования(ЭлектронныйРесурс);
		
	Иначе
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СводыЗнанийСУЗ.Ссылка КАК ЭлектронныйРесурс
			|ИЗ
			|	Справочник.СводыЗнанийСУЗ КАК СводыЗнанийСУЗ
			|ГДЕ
			|	СводыЗнанийСУЗ.ЭтоГруппа = ЛОЖЬ
			|	И СводыЗнанийСУЗ.ПометкаУдаления = ЛОЖЬ";

		Результат = Запрос.Выполнить();

		ВыборкаДетальныеЗаписи = Результат.Выбрать();

		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ЗаписатьЭлементВДанныеДляИндексирования(ВыборкаДетальныеЗаписи.ЭлектронныйРесурс);
		КонецЦикла;
		
	КонецЕсли;
	
КонецФункции

Функция УдалитьДанныеДляИндексирования() Экспорт
	
	НаборЗаписей = РегистрыСведений.ДанныеДляПолнотекстовогоПоискаСУЗ.СоздатьНаборЗаписей();
	НаборЗаписей.Записать();
	
КонецФункции

Процедура ЗаписатьЭлементВДанныеДляИндексирования(Знач ЭлектронныйРесурс,
	                                              Знач ЭлементСодержания=Неопределено,
	                                              Знач СсылкаНаЭлемент=Неопределено,
											      Знач ЭлементПодборки=Неопределено,
												  Знач ЭлементГлоссария=Неопределено,
												  ТаблицаОбработанных=Неопределено) 
												  
	УстановитьПривилегированныйРежим(Истина);	
	
	// Получаем переменные											  
	//
	
	Если ТаблицаОбработанных = Неопределено Тогда
		
		ТаблицаОбработанных = Новый ТаблицаЗначений;
		ТаблицаОбработанных.Колонки.Добавить("ЭлектронныйРесурс");
		ТаблицаОбработанных.Колонки.Добавить("ЭлементСодержания");
		ТаблицаОбработанных.Колонки.Добавить("СсылкаНаЭлемент");
		ТаблицаОбработанных.Колонки.Добавить("ЭлементПодборки");
		ТаблицаОбработанных.Колонки.Добавить("ЭлементГлоссария");
		
	КонецЕсли;
	
	Если ЭлементСодержания = Неопределено Тогда
		ЭлементСодержания = Справочники.СодержаниеСУЗ.ПустаяСсылка();
	КонецЕсли;
	
	Если СсылкаНаЭлемент = Неопределено Тогда
		СсылкаНаЭлемент = Справочники.СодержаниеСУЗ.ПустаяСсылка();
	КонецЕсли;
	
	Если ЭлементПодборки = Неопределено Тогда
		ЭлементПодборки = Справочники.ЭлементыПодборкиСУЗ.ПустаяСсылка();
	КонецЕсли;
	
	Если ЭлементГлоссария = Неопределено Тогда
		ЭлементГлоссария = Справочники.СодержаниеГлоссарияСУЗ.ПустаяСсылка();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс) И ЗначениеЗаполнено(ЭлементСодержания) И НЕ ЗначениеЗаполнено(СсылкаНаЭлемент) Тогда
		
		// Находим ссылку на элемент
		
		Если ЗначениеЗаполнено(ЭлементПодборки) Тогда
			СсылкаНаЭлемент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлементПодборки, "СсылкаНаОбъектСУЗ");
		ИначеЕсли ЗначениеЗаполнено(ЭлементГлоссария) Тогда
			СсылкаНаЭлемент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлементГлоссария, "ТерминГлоссария");
		Иначе
			СсылкаНаЭлемент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлементСодержания, "СсылкаНаЭлемент");
		КонецЕсли;
			
	КонецЕсли;
	
	// Делаем проверки
	//
	
	Если ТаблицаОбработанных.НайтиСтроки(Новый Структура("ЭлектронныйРесурс, ЭлементСодержания, СсылкаНаЭлемент, ЭлементПодборки, ЭлементГлоссария", ЭлектронныйРесурс, ЭлементСодержания, СсылкаНаЭлемент, ЭлементПодборки, ЭлементГлоссария)).Количество() > 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.ПодборкиСУЗ")
		И ЗначениеЗаполнено(СсылкаНаЭлемент)
		И Справочники.ПодборкиСУЗ.ПустаяПодборка(СсылкаНаЭлемент) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	// Запоминаем обрабатываемый элемент
	//
	
	НоваяСтрока = ТаблицаОбработанных.Добавить();
	НоваяСтрока.ЭлектронныйРесурс = ЭлектронныйРесурс;
	НоваяСтрока.ЭлементСодержания = ЭлементСодержания;
	НоваяСтрока.СсылкаНаЭлемент = СсылкаНаЭлемент;
	НоваяСтрока.ЭлементПодборки = ЭлементПодборки;
	НоваяСтрока.ЭлементГлоссария = ЭлементГлоссария;
	
	// Записываем данные в регистр
	//
	
	Если ЗначениеЗаполнено(СсылкаНаЭлемент) Тогда
	
		Если ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.ФайлыСУЗ") Тогда
			СсылкаНаЭлемент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаЭлемент, "Владелец");
		КонецЕсли;
		
		НаборЗаписей = РегистрыСведений.ДанныеДляПолнотекстовогоПоискаСУЗ.СоздатьНаборЗаписей();
			
		НаборЗаписей.Отбор.ЭлектронныйРесурс.Установить(ЭлектронныйРесурс);
		НаборЗаписей.Отбор.ЭлементСодержания.Установить(ЭлементСодержания);
		НаборЗаписей.Отбор.СсылкаНаОбъектСУЗ.Установить(СсылкаНаЭлемент);
		НаборЗаписей.Отбор.ЭлементПодборки.Установить(ЭлементПодборки);
		НаборЗаписей.Отбор.ЭлементГлоссария.Установить(ЭлементГлоссария);
			
		НоваяЗапись = НаборЗаписей.Добавить();
		
		НоваяЗапись.ЭлектронныйРесурс                = ЭлектронныйРесурс;
		НоваяЗапись.ИдентификаторЭлектронногоРесурса = Строка(ЭлектронныйРесурс.УникальныйИдентификатор());
		НоваяЗапись.ЭлементСодержания                = ЭлементСодержания;
		НоваяЗапись.СсылкаНаОбъектСУЗ                = СсылкаНаЭлемент;
		НоваяЗапись.ЭлементПодборки   = ЭлементПодборки;
		НоваяЗапись.ЭлементГлоссария  = ЭлементГлоссария;	
			
		Если ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.ВопросыСУЗ") Тогда
			НоваяЗапись.Метка = "ДоступноПриНаличииПраваИзмененияЭР";
		КонецЕсли;
		
		НоваяЗапись.Данные = ДанныеДляЗаписиВРегистрПолнотекстовогоПоиска(СсылкаНаЭлемент);
				
		Если ЗначениеЗаполнено(СсылкаНаЭлемент) Тогда
			
			НоваяЗапись.Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаЭлемент, "Наименование");
			
		Иначе
			
			Если ЗначениеЗаполнено(ЭлементПодборки) Тогда
				
				НоваяЗапись.Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлементПодборки, "Наименование");
				
			ИначеЕсли ЗначениеЗаполнено(ЭлементСодержания) Тогда
				
				НоваяЗапись.Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлементСодержания, "Наименование");
				
			Иначе
				
				НоваяЗапись.Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлектронныйРесурс, "Наименование");
				
			КонецЕсли;
			
			
		КонецЕсли;
			
		НаборЗаписей.Записать();
		
	КонецЕсли;
		
	//Рекурсивно обходим подчиненные структуры данных
	//
	
	// Содержание электронного ресурса
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс) И НЕ ЗначениеЗаполнено(ЭлементСодержания) Тогда

		// Обходим содержание электронного ресурса
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СодержаниеСУЗ.Ссылка
			|ИЗ
			|	Справочник.СодержаниеСУЗ КАК СодержаниеСУЗ
			|ГДЕ
			|	СодержаниеСУЗ.ПометкаУдаления = ЛОЖЬ
			|	И СодержаниеСУЗ.Владелец = &ЭлектронныйРесурс";

		Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);

		Результат = Запрос.Выполнить();

		ВыборкаДетальныеЗаписи = Результат.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ЗаписатьЭлементВДанныеДляИндексирования(ЭлектронныйРесурс,
			                                        ВыборкаДетальныеЗаписи.Ссылка,
													,
													,
													,
													ТаблицаОбработанных); // Рекурсия
													
		КонецЦикла;
		
	КонецЕсли;
	
	// Свойства электронного ресурса
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс) И НЕ ЗначениеЗаполнено(СсылкаНаЭлемент) И НЕ ЗначениеЗаполнено(ЭлементСодержания) Тогда	
		
		// Обходим свойства электронного ресурса
		
		СвойстваЭлектронногоРесурса = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭлектронныйРесурс, "Глоссарий, СправочнаяИнформация, СтартоваяСтраница");
		
		Если ЗначениеЗаполнено(СвойстваЭлектронногоРесурса.Глоссарий) Тогда
			ЗаписатьЭлементВДанныеДляИндексирования(ЭлектронныйРесурс,,СвойстваЭлектронногоРесурса.Глоссарий,,,ТаблицаОбработанных); // Рекурсия
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СвойстваЭлектронногоРесурса.СправочнаяИнформация) Тогда
			ЗаписатьЭлементВДанныеДляИндексирования(ЭлектронныйРесурс,,СвойстваЭлектронногоРесурса.СправочнаяИнформация,,,ТаблицаОбработанных); // Рекурсия
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СвойстваЭлектронногоРесурса.СтартоваяСтраница) Тогда
			ЗаписатьЭлементВДанныеДляИндексирования(ЭлектронныйРесурс,,СвойстваЭлектронногоРесурса.СтартоваяСтраница,,,ТаблицаОбработанных); // Рекурсия
		КонецЕсли;		
		
		// Обходим скрытые ресурсы		
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СкрытыеРесурсы.Ресурс КАК Ресурс
			|ИЗ
			|	Справочник.СводыЗнанийСУЗ.СкрытыеРесурсы КАК СкрытыеРесурсы
			|ГДЕ
			|	СкрытыеРесурсы.Ссылка = &ЭлектронныйРесурс";
		
		Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ЗаписатьЭлементВДанныеДляИндексирования(ЭлектронныйРесурс,,ВыборкаДетальныеЗаписи.Ресурс,,,ТаблицаОбработанных); // Рекурсия
		КонецЦикла;
		
	КонецЕсли;
	
	// Содержание подборок
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс)
		И ЗначениеЗаполнено(ЭлементСодержания)
		И ЗначениеЗаполнено(СсылкаНаЭлемент)
		И ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.ПодборкиСУЗ")
		И НЕ ЗначениеЗаполнено(ЭлементПодборки) Тогда

		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЭлементыПодборкиСУЗ.Ссылка
			|ИЗ
			|	Справочник.ЭлементыПодборкиСУЗ КАК ЭлементыПодборкиСУЗ
			|ГДЕ
			|	ЭлементыПодборкиСУЗ.Владелец = &Подборка
			|	И ЭлементыПодборкиСУЗ.ПометкаУдаления = ЛОЖЬ";

		Запрос.УстановитьПараметр("Подборка", СсылкаНаЭлемент);

		Результат = Запрос.Выполнить();

		ВыборкаДетальныеЗаписи = Результат.Выбрать();

		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ЗаписатьЭлементВДанныеДляИндексирования(ЭлектронныйРесурс,
			                                        ЭлементСодержания,
													,
													ВыборкаДетальныеЗаписи.Ссылка,
													,
													ТаблицаОбработанных); // Рекурсия

		КонецЦикла;
		
	КонецЕсли;	
	
	// Термины глоссария
	
	Если ЗначениеЗаполнено(ЭлектронныйРесурс)
		И ЗначениеЗаполнено(ЭлементСодержания)
		И ЗначениеЗаполнено(СсылкаНаЭлемент)		
		И ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.ГлоссарииСУЗ")
		И НЕ ЗначениеЗаполнено(ЭлементГлоссария) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СодержаниеГлоссарияСУЗ.Ссылка
			|ИЗ
			|	Справочник.СодержаниеГлоссарияСУЗ КАК СодержаниеГлоссарияСУЗ
			|ГДЕ
			|	СодержаниеГлоссарияСУЗ.ПометкаУдаления = ЛОЖЬ
			|	И СодержаниеГлоссарияСУЗ.Владелец = &Глоссарий";

		Запрос.УстановитьПараметр("Глоссарий", СсылкаНаЭлемент);

		Результат = Запрос.Выполнить();

		ВыборкаДетальныеЗаписи = Результат.Выбрать();

		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ЗаписатьЭлементВДанныеДляИндексирования(ЭлектронныйРесурс,
			                                        ЭлементСодержания,
													СсылкаНаЭлемент,
													ЭлементПодборки,
													ВыборкаДетальныеЗаписи.Ссылка,
													ТаблицаОбработанных); // Рекурсия
													
		КонецЦикла;

	КонецЕсли;
	
	
КонецПроцедуры

Функция ДанныеДляЗаписиВРегистрПолнотекстовогоПоиска(СсылкаНаЭлемент)
	
	// Делаем проверки
	
	ДанныеДляИндексирования = "";
	
	Если НЕ ЗначениеЗаполнено(СсылкаНаЭлемент) Тогда
		Возврат ДанныеДляИндексирования;
	КонецЕсли;
	
	// Получаем данные термина глоссария	
	
	Если ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.ТерминыСУЗ") Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ОпределенияТерминаСУЗ.Текст КАК Текст
			|ИЗ
			|	Справочник.ОпределенияТерминаСУЗ КАК ОпределенияТерминаСУЗ
			|ГДЕ
			|	ОпределенияТерминаСУЗ.Владелец = &Термин
			|	И ОпределенияТерминаСУЗ.ПометкаУдаления = ЛОЖЬ";

		Запрос.УстановитьПараметр("Термин", СсылкаНаЭлемент);

		Результат = Запрос.Выполнить();

		ВыборкаДетальныеЗаписи = Результат.Выбрать();

		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ДанныеДляИндексирования = ДанныеДляИндексирования + ВыборкаДетальныеЗаписи.Текст + Символы.ПС;
		КонецЦикла;

		ФорматированныйДокумент = Новый ФорматированныйДокумент;
		ФорматированныйДокумент.УстановитьHTML(ДанныеДляИндексирования, Новый Структура());
		
		ДанныеДляИндексирования = ФорматированныйДокумент.ПолучитьТекст();
		
		Возврат ДанныеДляИндексирования;
		
	КонецЕсли;
	
	// Получаем данные ресурса, как совокупность данных файлов
	
	Если ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.РесурсыСУЗ") Тогда		
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ФайлыСУЗ.Ссылка
			|ИЗ
			|	Справочник.ФайлыСУЗ КАК ФайлыСУЗ
			|ГДЕ
			|	ФайлыСУЗ.ПометкаУдаления = ЛОЖЬ
			|	И ФайлыСУЗ.Владелец = &СсылкаНаЭлемент
			|	И ФайлыСУЗ.ЭтоГруппа = ЛОЖЬ
			|	И ФайлыСУЗ.Скрывать = ЛОЖЬ
			|	И ФайлыСУЗ.ВнешнийФайл = ЛОЖЬ";
		
		Запрос.УстановитьПараметр("СсылкаНаЭлемент", СсылкаНаЭлемент);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ДанныеДляИндексирования = ДанныеДляИндексирования + " " + ДанныеДляЗаписиВРегистрПолнотекстовогоПоиска(ВыборкаДетальныеЗаписи.Ссылка); // Рекурсия
		КонецЦикла;
	
	КонецЕсли;
	
	// Получаем данные других объектов из регистра данных	
	
	ИмяРеквизита = Неопределено;
	
	Если ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.ВопросыСУЗ") Тогда
		
		ИмяРеквизита = Новый Массив();
		ИмяРеквизита.Добавить("ТекстовыеДанные");
		ИмяРеквизита.Добавить("ФорматированныйДокумент");
		ИмяРеквизита.Добавить("ВерныйКомментарий");
		ИмяРеквизита.Добавить("ОшибочныйКомментарий");
		
	КонецЕсли;
	
	Если ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.СтраницыСУЗ") Тогда
		
		ИмяРеквизита = Новый Массив();
		ИмяРеквизита.Добавить("ТекстовыеДанные");
		ИмяРеквизита.Добавить("ФорматированныйДокумент");
		
	КонецЕсли;
	
	Если ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.ФайлыСУЗ") Тогда
		
		// Примечание: текстовые данные двоичных данных извлекаются
		// При сохранении файлов.
		
		ИмяРеквизита = Новый Массив();
		ИмяРеквизита.Добавить("ТекстовыеДанные");
		
	КонецЕсли;
	
	Если ИмяРеквизита = Неопределено Тогда
		Возврат ДанныеДляИндексирования;
	КонецЕсли;	

	ВыборкаДанных = ПолучитьДанные(СсылкаНаЭлемент,,Истина,ИмяРеквизита);
		
	Пока ВыборкаДанных.Следующий() Цикл
		
		Если ВыборкаДанных.КодДанных = "Описание" Тогда
			Продолжить;
		КонецЕсли;
		
		Для каждого Реквизит Из ИмяРеквизита Цикл
			
			ТекстДанных = "";
			
			Если Реквизит = "ФорматированныйДокумент" Тогда
				ФорматированныйДокумент = ВыборкаДанных[Реквизит].Получить();
			Иначе
				ФорматированныйДокумент = Новый ФорматированныйДокумент;
				ФорматированныйДокумент.УстановитьHTML(ВыборкаДанных[Реквизит], Новый Структура());
			КонецЕсли;
			
			Если ФорматированныйДокумент <> Неопределено 
				И НЕ ФорматированныйДокумент = NULL Тогда 
				
				ТекстДанных = ФорматированныйДокумент.ПолучитьТекст();
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ТекстДанных) Тогда
				ДанныеДляИндексирования = ДанныеДляИндексирования + ТекстДанных + Символы.ПС;
			КонецЕсли;
		
		КонецЦикла;
	
	КонецЦикла;
	
	Возврат ДанныеДляИндексирования;
	
	
КонецФункции

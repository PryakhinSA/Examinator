Функция ВерсияПодсистемы() Экспорт
	
	Возврат "3.0.9.151";
	
КонецФункции

Функция ПолучитьСвойства(ЭлектронныйРесурс, ПрохождениеОбучения = Неопределено, Задание = Неопределено, Пользователь = Неопределено, КонтрольнаяСумма = 0, КорневаяСессияПрохождения = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(ПрохождениеОбучения)
		И НЕ ЗначениеЗаполнено(Задание) Тогда
		
		ВызватьИсключение НСтр("ru = 'Задание прохождения обучения не задано'");
		
	КонецЕсли;
	
	// Определяем переменные
	//
	
	Если Пользователь = Неопределено Тогда
		Пользователь = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	Если ПрохождениеОбучения = Неопределено Тогда
		ПрохождениеОбучения = Метаданные.ОпределяемыеТипы.ПрохождениеЭлектронногоОбучения.Тип.ПривестиЗначение(ПрохождениеОбучения);
	КонецЕсли;
	
	Если Задание = Неопределено Тогда
		Задание = Метаданные.ОпределяемыеТипы.ЗаданиеЭлектронногоОбучения.Тип.ПривестиЗначение(Задание);
	КонецЕсли;	

	ДанныеПрохождения = Неопределено;
	Если КорневаяСессияПрохождения = Неопределено Тогда
		КорневаяСессияПрохождения = Документы.СессияЭлектронногоРесурсаСУЗ.КорневаяСессияПрохожденияЭлектронногоКурса(Пользователь, ПрохождениеОбучения, ЭлектронныйРесурс, Задание, Перечисления.ТипыСессийЭлектронныхРесурсовСУЗ.course);
	КонецЕсли;
	
	// Находим все сессии прохождения объектов электронного ресурса
	//
	
	Если ЗначениеЗаполнено(КорневаяСессияПрохождения) Тогда
		
		// Ранее проходили электронный ресурс		

		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СессияЭлектронногоРесурсаСУЗ.ДанныеТекстовые
			|ИЗ
			|	Документ.СессияЭлектронногоРесурсаСУЗ КАК СессияЭлектронногоРесурсаСУЗ
			|ГДЕ
			|	СессияЭлектронногоРесурсаСУЗ.Пользователь = &Пользователь
			|	И СессияЭлектронногоРесурсаСУЗ.ЭлектронныйРесурс = &ЭлектронныйРесурс
			|	И СессияЭлектронногоРесурсаСУЗ.ПрохождениеОбучения = &ПрохождениеОбучения
			|	И СессияЭлектронногоРесурсаСУЗ.Задание = &Задание
			|	И СессияЭлектронногоРесурсаСУЗ.Проведен = ИСТИНА
			|	И СессияЭлектронногоРесурсаСУЗ.Отменено = ЛОЖЬ";

		Запрос.УстановитьПараметр("Задание", Задание);
		Запрос.УстановитьПараметр("Пользователь", Пользователь);
		Запрос.УстановитьПараметр("ПрохождениеОбучения", ПрохождениеОбучения);
		Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);

		РезультатЗапроса = Запрос.Выполнить();

		Если НЕ РезультатЗапроса.Пустой() Тогда
		
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

			ДанныеПрохождения = "[";
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ДанныеПрохождения = ДанныеПрохождения + ВыборкаДетальныеЗаписи.ДанныеТекстовые.Получить() + ",";	
			КонецЦикла;
			
			ДанныеПрохождения = Сред(ДанныеПрохождения, 1, СтрДлина(ДанныеПрохождения)-1);
			
			ДанныеПрохождения = ДанныеПрохождения + "]";
			
		КонецЕсли;		
		
	КонецЕсли;
	
	Данные = ПолучитьСвойстваПубликации(ЭлектронныйРесурс, КонтрольнаяСумма);
	
	Если Данные <> Неопределено Тогда
		Данные.Вставить("ДанныеПрохождения", ДанныеПрохождения);
	КонецЕсли;
	
	Возврат Данные;
	
КонецФункции

Функция ПолучитьСвойстваПубликации(ЭлектронныйРесурс, КонтрольнаяСумма = 0) Экспорт
	
	Запрос = Новый Запрос;
	
	ШаблонЗапроса = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПубликацииЭлектронныхРесурсовСУЗ.КонтрольнаяСумма КАК КонтрольнаяСумма,
		|	ПубликацииЭлектронныхРесурсовСУЗ.ДатаЭлектронногоРесурса КАК ДатаЭлектронногоРесурса,
		|	ПубликацииЭлектронныхРесурсовСУЗ.Версия КАК Версия,
		|	ПубликацииЭлектронныхРесурсовСУЗ.Наименование КАК Наименование,
		|	ПубликацииЭлектронныхРесурсовСУЗ.Размер КАК Размер,
		|	ПубликацииЭлектронныхРесурсовСУЗ.Описание КАК Описание,
		|	ПубликацииЭлектронныхРесурсовСУЗ.РазмещеныДанныеДляВебКабинета КАК РазмещеныДанныеДляВебКабинета,
		|	ПубликацииЭлектронныхРесурсовСУЗ.Период КАК Период
		|ИЗ
		|	РегистрСведений.ПубликацииЭлектронныхРесурсовСУЗ КАК ПубликацииЭлектронныхРесурсовСУЗ
		|ГДЕ
		|	&ОтборПоКонтрольнойСумме
		|	И ПубликацииЭлектронныхРесурсовСУЗ.ЭлектронныйРесурс = &ЭлектронныйРесурс
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПубликацииЭлектронныхРесурсовСУЗ.Период УБЫВ";

				
	Если ЗначениеЗаполнено(КонтрольнаяСумма) Тогда		
		Подстановка2 = "КонтрольнаяСумма = &КонтрольнаяСумма";		
		Запрос.УстановитьПараметр("КонтрольнаяСумма", КонтрольнаяСумма);		
	Иначе		
		Подстановка2 = "ИСТИНА";		
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(ШаблонЗапроса, "&ОтборПоКонтрольнойСумме", Подстановка2);
	
	Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйРесурс);
	
	РезультатЗапроса = Запрос.Выполнить();

	Если РезультатЗапроса.Пустой() Тогда
		
		Возврат Неопределено;
		
	Иначе
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

		ВыборкаДетальныеЗаписи.Следующий();

		СвойстваПубликации = Новый Структура("Период, КонтрольнаяСумма, ДатаЭлектронногоРесурса, Версия, Наименование, Размер, Описание, РазмещеныДанныеДляВебКабинета");
		
		СвойстваПубликации.Период                        = ВыборкаДетальныеЗаписи.Период;
		СвойстваПубликации.КонтрольнаяСумма              = ВыборкаДетальныеЗаписи.КонтрольнаяСумма;
		СвойстваПубликации.ДатаЭлектронногоРесурса       = ВыборкаДетальныеЗаписи.ДатаЭлектронногоРесурса;
		СвойстваПубликации.Версия                        = ВыборкаДетальныеЗаписи.Версия;
		СвойстваПубликации.Наименование                  = ВыборкаДетальныеЗаписи.Наименование;
		СвойстваПубликации.Размер                        = ВыборкаДетальныеЗаписи.Размер;
		СвойстваПубликации.Описание                      = ВыборкаДетальныеЗаписи.Описание;
		СвойстваПубликации.РазмещеныДанныеДляВебКабинета = ВыборкаДетальныеЗаписи.РазмещеныДанныеДляВебКабинета;
		
		Возврат СвойстваПубликации;
		
	КонецЕсли;		
	
КонецФункции

Функция СохранитьДанныеПрохождения(Знач Данные, ЭлектронныйРесурс, КонтрольнаяСумма, Пользователь, ПрохождениеОбучения, Задание, ЭтоПроверкаПреподавателем) Экспорт
	
	// Получаем данные сессий из строковых данных
	//
	
	МассивСессий = ОбщегоНазначенияСУ.JSONВДанные(Данные, СтрДлина(Данные));
	
	Если НЕ ТипЗнч(МассивСессий) = Тип("Массив") Тогда
		ВызватьИсключение НСтр("ru = 'Неверный тип данных'");			
	КонецЕсли;
	
	// Формируем объекты сессий
	//
	
	НачатьТранзакцию();
	
	Попытка
		
		СледуетОбновитьДанныеОбучения = Ложь;
		ЭтаВерсияПередаетСессиюКурсаПриВыходе = Ложь;
		
		Для каждого Сессия Из МассивСессий Цикл
			
			Если НЕ ТипЗнч(Сессия) = Тип("Структура") Тогда
				ВызватьИсключение НСтр("ru = 'Неверный тип данных сессии'");			
			КонецЕсли;
			
			Если Сессия.Свойство("version") Тогда
				// Новая версия плеера при выходе из курса
				// передает сессию курса в общем массиве сессий.
				// По этому признаку можно определить, выполняется
				// ли выход из курса и следует ли вызвать обновление
				// данных задания.
				// Старая версия это делала только при изменении
				// сессии курса. В этом случае следует избыточно вызывать
				// обновление данных курса.				
				ЭтаВерсияПередаетСессиюКурсаПриВыходе = Истина;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Сессия.id) Тогда
				
				СессияСсылка = Документы.СессияЭлектронногоРесурсаСУЗ.ПолучитьСсылку(Новый УникальныйИдентификатор(Сессия.id));
								
				БлокировкаДанных = Новый БлокировкаДанных;
				ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Документ.СессияЭлектронногоРесурсаСУЗ");
				ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", СессияСсылка);
				ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
				БлокировкаДанных.Заблокировать();
				
				СессияОбъект = СессияСсылка.ПолучитьОбъект();
				
				НоваяСтрокаИстории = СессияОбъект.ИсторияИзменений.Добавить();
				НоваяСтрокаИстории.Дата = СессияОбъект.ДатаИзменения;
				НоваяСтрокаИстории.Данные = СессияОбъект.Данные;
				НоваяСтрокаИстории.ДанныеТекстовые = СессияОбъект.ДанныеТекстовые;			
				
			Иначе
				
				СессияОбъект = Документы.СессияЭлектронногоРесурсаСУЗ.СоздатьДокумент();
				
				СессияОбъект.Дата = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(Сессия.dateModification);
				СессияОбъект.Пользователь = Пользователь; 
				СессияОбъект.ЭлектронныйРесурс = ЭлектронныйРесурс;
				СессияОбъект.КонтрольнаяСумма = КонтрольнаяСумма;
				СессияОбъект.ПрохождениеОбучения = ПрохождениеОбучения;
				СессияОбъект.Задание = Задание;
				СессияОбъект.ТипСессии = Перечисления.ТипыСессийЭлектронныхРесурсовСУЗ[Сессия.type];
				
				Если ТипЗнч(Сессия.parentSession) = Тип("Строка") Тогда
					
					СессияОбъект.РодительскаяСессия = 	Документы.СессияЭлектронногоРесурсаСУЗ.ПолучитьСсылку(Новый УникальныйИдентификатор(Сессия.parentSession)); // Определена
					
				ИначеЕсли ТипЗнч(Сессия.parentSession) = Тип("Структура") Тогда
					
					СессияОбъект.РодительскаяСессия = Неопределено;
					
					Для каждого СессияРодительская Из МассивСессий Цикл
						
						СессияНайдена = Истина;
						
						Для каждого ЗначениеДляПоиска Из Сессия.parentSession Цикл
							
							НайденноеЗначение = Неопределено;
							
							СессияРодительская.Свойство(ЗначениеДляПоиска.Ключ, НайденноеЗначение);
							
							Если НайденноеЗначение <> ЗначениеДляПоиска.Значение Тогда
								СессияНайдена = Ложь;	
							КонецЕсли;
							
						КонецЦикла;
						
						Если СессияНайдена Тогда
							
							СессияОбъект.РодительскаяСессия = Документы.СессияЭлектронногоРесурсаСУЗ.ПолучитьСсылку(Новый УникальныйИдентификатор(СессияРодительская.id));
							
							Сессия.parentSession = СессияРодительская.id;
							
							Прервать;
							
						КонецЕсли;
						
					КонецЦикла;
					
				Иначе
					
					СессияОбъект.РодительскаяСессия = Документы.СессияЭлектронногоРесурсаСУЗ.ПустаяСсылка(); // Не требуется
					
				КонецЕсли;
				
				СессияОбъект.Записать(); // Записываем без проведения для получения ссылки
				
			КонецЕсли;
			
			СессияСсылка = СессияОбъект.Ссылка;
			
			Сессия.id = Строка(СессияСсылка.УникальныйИдентификатор());
			
			СессияОбъект.Данные = Новый ХранилищеЗначения(Сессия);
			СессияОбъект.ДанныеТекстовые = Новый ХранилищеЗначения(ОбщегоНазначенияСУ.ДанныеВJSON(Сессия));
			СессияОбъект.ДатаИзменения = ОбщегоНазначенияСУКлиентСервер.ЧислоВДату(Сессия.dateModification);
			
			СессияОбъект.Записать(РежимЗаписиДокумента.Проведение);		
			
			Если СессияОбъект.ТипСессии = Перечисления.ТипыСессийЭлектронныхРесурсовСУЗ.course Тогда			
				СледуетОбновитьДанныеОбучения = Истина;			
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЭтоПроверкаПреподавателем Тогда
			СледуетОбновитьДанныеОбучения = Истина;
		КонецЕсли;
		
		// Обновляем данные обучения
		//
		
		Если СледуетОбновитьДанныеОбучения ИЛИ НЕ ЭтаВерсияПередаетСессиюКурсаПриВыходе Тогда
			ЭлектронныеРесурсыПереопределяемый.ПослеСохраненияДанныхПрохожденияПубликации(ЭлектронныйРесурс, ПрохождениеОбучения, Задание, Пользователь, СледуетОбновитьДанныеОбучения);
		КонецЕсли;		
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
	// Возвращаем результат сохранения
	//	
	
	РезультатЗаписи = Новый Массив();
	
	Для каждого Сессия Из МассивСессий Цикл
		
		НовыйРезультат = Новый Структура();
		
		КлючСессии = Новый Структура();
		
		Для каждого ИмяСвойства Из Сессия.keyProperties Цикл
			КлючСессии.Вставить(ИмяСвойства, Сессия[ИмяСвойства]);	
		КонецЦикла;
		
		НовыйРезультат.Вставить("key", КлючСессии);
		
		Для каждого ИмяСвойства Из Сессия.serverProperties Цикл
			НовыйРезультат.Вставить(ИмяСвойства, Сессия[ИмяСвойства]);	
		КонецЦикла;
		
		РезультатЗаписи.Добавить(НовыйРезультат);
		
	КонецЦикла;
	
	Возврат ОбщегоНазначенияСУ.ДанныеВJSON(РезультатЗаписи);
	
КонецФункции


// ОТЧЕТЫ

Процедура ПриКомпоновкеРезультатаОтчета(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка, КомпоновщикНастроек, СхемаКомпоновкиДанных) Экспорт
	
	СтандартнаяОбработка = Ложь;
	
	ДокументРезультат.Очистить();
	
	// Получаем данные отчета
	
	Настройки = КомпоновщикНастроек.ПолучитьНастройки();
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки, ДанныеРасшифровки);	
	
	ВнешниеНаборыДанных = ВнешниеНаборыДанныхОтчета(КомпоновщикНастроек, МакетКомпоновки);	
	
	// Выводим отчет
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных, ДанныеРасшифровки, Истина);	
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.УстановитьДокумент(ДокументРезультат);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);	

КонецПроцедуры

Функция ВнешниеНаборыДанныхОтчета(КомпоновщикНастроек, МакетКомпоновки)	
	
	// Ищем установленный пользователем период
	
	УстановленныйПериод = Неопределено;
	
	Для каждого Элемент Из КомпоновщикНастроек.ПользовательскиеНастройки.Элементы Цикл
		
		ПараметрКомпоновкиДанныхПериод = Новый ПараметрКомпоновкиДанных("Период");
		
		Если ТипЗнч(Элемент) = Тип("ЗначениеПараметраНастроекКомпоновкиДанных")
			И Элемент.Параметр = ПараметрКомпоновкиДанныхПериод
			И Элемент.Использование Тогда
			
			УстановленныйПериод = Элемент.Значение;
			Прервать;
			
		КонецЕсли;
		
	
	КонецЦикла;
	
	// Получаем даты начала и окончания периода
	
	Если УстановленныйПериод = Неопределено Тогда
		НачалоПериода = Дата(2000, 1, 1);
		КонецПериода = Дата(3999, 1, 1);
	Иначе		
		НачалоПериода = НачалоГода(УстановленныйПериод.ДатаНачала);
		КонецПериода  = КонецГода(?(ЗначениеЗаполнено(УстановленныйПериод.ДатаОкончания), УстановленныйПериод.ДатаОкончания, Дата(3999, 1, 1)));
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	МИНИМУМ(ПопыткиПрохожденияЭлектронныхРесурсов.Период) КАК НачалоПериода,
	|	МАКСИМУМ(ПопыткиПрохожденияЭлектронныхРесурсов.Период) КАК КонецПериода
	|ИЗ
	|	РегистрСведений.ПопыткиПрохожденияЭлектронныхРесурсовСУЗ КАК ПопыткиПрохожденияЭлектронныхРесурсов";
	Результат = Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		НачалоПериода = Макс(НачалоПериода, Выборка.НачалоПериода);
		КонецПериода  = Мин(КонецПериода, Выборка.КонецПериода);
	КонецЕсли;
	
	// Получаем таблицу дат
	
	ТаблицаПериоды = Новый ТаблицаЗначений;
	ТаблицаПериоды.Колонки.Добавить("Год");
	ТаблицаПериоды.Колонки.Добавить("Месяц");
	
	ТекущаяДата = НачалоПериода;
	
	Пока ТекущаяДата < КонецПериода Цикл
		НоваяСтрока = ТаблицаПериоды.Добавить();
		НоваяСтрока.Год   = Год(ТекущаяДата);
		НоваяСтрока.Месяц = Месяц(ТекущаяДата);
		
		ТекущаяДата = ДобавитьМесяц(ТекущаяДата, 1);
	КонецЦикла;
	
	// Завершаем
	
	ВнешниеНаборыДанных = Новый Структура("Периоды", ТаблицаПериоды);
	
	Возврат ВнешниеНаборыДанных;
		                                
КонецФункции


Процедура УстановитьОсновнуюПубликацию(ОсновнаяПубликация) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	НомерРедакции = Редакция();
	
	Если НомерРедакции = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОсновнаяПубликация, "Редакция")
			<> Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
			ВызватьИсключение НСтр("ru = 'Редакция публикации не соответствует установленной в основных настройках'");
		КонецЕсли;
		Константы.ОсновнаяПубликацияВебКабинета20СУ.Установить(ОсновнаяПубликация);
	КонецЕсли;
	
	Если НомерРедакции = Перечисления.РедакцииВебКабинетаСУ.Редакция30 Тогда
		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОсновнаяПубликация, "Редакция")
			<> Перечисления.РедакцииВебКабинетаСУ.Редакция30 Тогда
			ВызватьИсключение НСтр("ru = 'Редакция публикации не соответствует установленной в основных настройках'");
		КонецЕсли;
		Константы.ОсновнаяПубликацияВебКабинета30СУ.Установить(ОсновнаяПубликация);
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьОсновнуюПубликациюИзКонстанты(Знач Редакция = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	НомерРедакции = ?(ЗначениеЗаполнено(Редакция), Редакция, Редакция());
	
	Если НомерРедакции = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
		Возврат Константы.ОсновнаяПубликацияВебКабинета20СУ.Получить();
	КонецЕсли;
	
	Если НомерРедакции = Перечисления.РедакцииВебКабинетаСУ.Редакция30 Тогда
		Возврат Константы.ОсновнаяПубликацияВебКабинета30СУ.Получить();
	КонецЕсли;
	
	ВызватьИсключение НСтр("ru = 'Неизвестная редакция веб-кабинета'");
	
КонецФункции

Функция ИмяФайлаДистрибутива() Экспорт
	
	НомерРедакции = Редакция();
	
	Если НомерРедакции = Перечисления.РедакцииВебКабинетаСУ.Редакция20 Тогда
		Возврат "data.zip";
	КонецЕсли;
	
	Если НомерРедакции = Перечисления.РедакцииВебКабинетаСУ.Редакция30 Тогда
		Возврат "cabinet.zip";
	КонецЕсли;

	ВызватьИсключение НСтр("ru = 'Неизвестная редакция веб-кабинета'");
	
КонецФункции


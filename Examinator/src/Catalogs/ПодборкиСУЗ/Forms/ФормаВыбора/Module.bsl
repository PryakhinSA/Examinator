
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Отбор")
		И Параметры.Отбор.Свойство("ЭтоТест") Тогда
		
		АвтоЗаголовок = Ложь;
		
		Если Параметры.Отбор.ЭтоТест Тогда
			Заголовок = Нстр("ru = 'Тесты'");
		Иначе
			Заголовок = Нстр("ru = 'Теория'");
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

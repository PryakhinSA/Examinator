// Обновляет файл, если известно только его имя
//
Функция ОбновитьФайлРесурса(Ресурс, Имя, Наименование, ДвоичныеДанные, Описание, Расширение, Загрузка=Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ФайлыСУЗ.Ссылка
		|ИЗ
		|	Справочник.ФайлыСУЗ КАК ФайлыСУЗ
		|ГДЕ
		|	ФайлыСУЗ.Владелец = &Ресурс
		|	И ФайлыСУЗ.ИмяФайла = &ИмяФайла";

	Запрос.УстановитьПараметр("ИмяФайла", Имя);
	Запрос.УстановитьПараметр("Ресурс", Ресурс);

	Результат = Запрос.Выполнить(); // Ищем файл в ресурсе

	Если Результат.Пустой() Тогда
		
		ФайлРесурсаОбъект = Справочники.ФайлыСУЗ.СоздатьЭлемент();
		
	Иначе
		
		ВыборкаДетальныеЗаписи = Результат.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий();
		
		ФайлРесурсаОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		
	КонецЕсли;
	
	ФайлРесурсаОбъект.Наименование = Наименование;
	ФайлРесурсаОбъект.Владелец     = Ресурс;
	
	РазработкаСУЗ.УстановитьПредпочитаемогоПоставщика(ФайлРесурсаОбъект);
	
	Если ФайлРесурсаОбъект.Ссылка.Пустая() Тогда
		ФайлРесурсаОбъект.Версия = 1;
	Иначе
		ПоследняяВерсия = ОбъектыСУЗ.ПолучитьПоследнююВерсию(ФайлРесурсаОбъект.Ссылка, ФайлРесурсаОбъект.Поставщик);
		Если ПоследняяВерсия.Поставщик = ФайлРесурсаОбъект.Поставщик Тогда 
			ФайлРесурсаОбъект.Версия = ПоследняяВерсия.Версия;
		Иначе
			ФайлРесурсаОбъект.Версия = 1;
		КонецЕсли;
	КонецЕсли;
	
	ФайлРесурсаОбъект.ИмяФайла = Имя;			
	ФайлРесурсаОбъект.ТипФайла = РазработкаСУЗКлиентСервер.ПолучитьТипФайлаПоРасширению(Расширение);
	
	ФайлРесурсаОбъект.ОбменДанными.Загрузка = Загрузка;
	
	ФайлРесурсаОбъект.Записать();
	
	РазработкаСУЗ.ЗаписатьДанныеВерсииОбъектаСУЗ(ФайлРесурсаОбъект, Описание, "Описание", "ТекстовыеДанные");
	
	РазработкаСУЗ.СохранитьДвоичныеДанныеФайла(ФайлРесурсаОбъект, ДвоичныеДанные);			
	
	Возврат ФайлРесурсаОбъект; // Для возможного продолжения записи
	
КонецФункции

#КонецОбласти


#Область ОбработчикиСобытий

// ОБРАБОТЧИКИ СОБЫТИЙ

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда		
		
		Ключ = Неопределено;
		ОткрытьФормуДокумента = Неопределено;		
		
		Параметры.Свойство("Ключ", Ключ);
		Параметры.Свойство("ОткрытьФормуДокумента", ОткрытьФормуДокумента);
		
		Если ЗначениеЗаполнено(Ключ) Тогда
			
			Если ОткрытьФормуДокумента = ИСТИНА Тогда
				
				СтандартнаяОбработка = Ложь;
				ВыбраннаяФорма = "Справочник.ФайлыСУЗ.Форма.ФормаДокумента";
				Возврат;
				
			Иначе
				
				ТипФайла = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ключ, "ТипФайла");
				
				Если ТипФайла = Перечисления.ТипыФайловСУЗ.Document Тогда
					СтандартнаяОбработка = Ложь;
					ВыбраннаяФорма = "Справочник.ФайлыСУЗ.Форма.ФормаДокумента";
					Возврат;					
				КонецЕсли;
				
			КонецЕсли;			
			
		Иначе
			
			Если ОткрытьФормуДокумента = ИСТИНА Тогда
				СтандартнаяОбработка = Ложь;
				ВыбраннаяФорма = "Справочник.ФайлыСУЗ.Форма.ФормаДокумента";
				Возврат;
			КонецЕсли;						
			
		КонецЕсли;
		
	КонецЕсли;
		
	
КонецПроцедуры


#КонецОбласти



#КонецЕсли
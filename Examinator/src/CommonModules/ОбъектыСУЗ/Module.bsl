						ТаблицаСтатистикиПараметровSCORM.Колонки.Удалить("ЭлектронныйРесурс");
						ТаблицаСтатистикиПараметровSCORM.Колонки.Удалить("ЭлементСодержания");
						
						ДокументПопыткиОбъект.СтатистикаПараметров.Загрузить(ТаблицаСтатистикиПараметровSCORM);
						
						// Записываем						
						
						ДокументПопыткиОбъект.Записать(РежимЗаписиДокумента.Проведение);	
						
						СтруктураДанныхXDTO = ОбъектыSCORM.ПолучитьМодельДанныхПопыткиОбъектаSCORM(ДокументПопыткиОбъект, КонтекстВыполнения);
						
					КонецЕсли; // ЗапросНаСохранение <> Неопределено
					
				КонецЕсли;
				
			КонецЕсли; // Commit
			
			
			// Закрытие сессии (Terminate)
			// Примечание: выполняется после сохранения данных.
			//
			
			Если ИмяЗапроса = "Terminate" Тогда
				
				Если ДокументПопыткиСсылка = Неопределено Тогда 
					
					КодОшибки = 112;
					ТекстСообщения = "Невозможно завершить сессию, так как она не найдена (112).";
					
				Иначе 
					
					Если ДокументПопыткиОбъект = Неопределено Тогда
						
						БлокировкаДанных = Новый БлокировкаДанных;
						ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Документ.ПопыткаВыполненияАктивногоРесурсаSCORM");
						ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ДокументПопыткиСсылка);
						ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
						БлокировкаДанных.Заблокировать();						
						
						ДокументПопыткиОбъект = ДокументПопыткиСсылка.ПолучитьОбъект();
						
					КонецЕсли;
					
					ДокументПопыткиОбъект.Дата = ТекущаяДатаСеанса();
					
					Если ЗначениеЗаполнено(ДокументПопыткиОбъект.ПродолжительностьПоследнейСессии) Тогда
						
						Если ЗначениеЗаполнено(ДокументПопыткиОбъект.ОбщаяПродолжительностьСессий) Тогда
							ОбщийВременнойИнтервал = ОбъектыSCORM.СуммироватьДваВременногоИнтервала(ДокументПопыткиОбъект.ПродолжительностьПоследнейСессии, ДокументПопыткиОбъект.ОбщаяПродолжительностьСессий);
						Иначе
							ОбщийВременнойИнтервал = ДокументПопыткиОбъект.ПродолжительностьПоследнейСессии;
						КонецЕсли;
						
						ДокументПопыткиОбъект.ОбщаяПродолжительностьСессий = ОбщийВременнойИнтервал;
						ДокументПопыткиОбъект.ПродолжительностьПоследнейСессии = "";
						
					КонецЕсли;					
					
					СессияСтрока = ДокументПопыткиОбъект.Сессии.Получить(ДокументПопыткиОбъект.Сессии.Количество() - 1); 
					
					СессияСтрока.ДатаЗакрытия = ТекущаяДатаСеанса(); 
					
					ДокументПопыткиОбъект.Записать(РежимЗаписиДокумента.Проведение);
					
					РезультатДействия.Вставить("ЗакрытьСтраницу", Истина);
					
				КонецЕсли;
				
			КонецЕсли; // Terminate
			
			Если КодОшибки > 0 Тогда
				Значение = "false";	
			Иначе
				Значение = "true";	
			КонецЕсли;
			
						
			// Формируем структуру данных для передачи обратно на клиент
			
			РезультатДействия.Вставить("СсылкаДляПерехода", СсылкаДляПерехода);
			РезультатДействия.Вставить("ТекстСообщения", ТекстСообщения);
			РезультатДействия.Вставить("Значение", Значение);
			РезультатДействия.Вставить("КодОшибки", КодОшибки);
			РезультатДействия.Вставить("НомерСессии", НомерСессии);
			
			Если СтруктураДанныхXDTO <> Неопределено Тогда
				
				ЗаписьXML = Новый ЗаписьXML;
				ЗаписьXML.УстановитьСтроку();
				ФабрикаXDTO.ЗаписатьXML(ЗаписьXML, СтруктураДанныхXDTO);
				XMLДанные = ЗаписьXML.Закрыть();
				
				РезультатДействия.Вставить("МодельДанныхПопыткиОбъектаSCORM", XMLДанные);
				
			КонецЕсли;
			
		КонецЕсли; // SCORequest
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
	Возврат РезультатДействия;
	
КонецФункции

// Возвращает структуру действия.
// Используется перед формированием результата действия
// для обеспечения гарантированного наличия всех свойств
// в структуре данных выполненного действия.
//
Функция ПолучитьПустуюСтруктуруДействия()
	
	СтруктураДанных = Новый Структура;
	
	// Общее
	
	СтруктураДанных.Вставить("АдресОбъекта", ""); // Строка
	СтруктураДанных.Вставить("АдресФайла", ""); // Строка
	СтруктураДанных.Вставить("ВнешняяСсылка", ""); // Строка
	СтруктураДанных.Вставить("Якорь", ""); // Строка
	СтруктураДанных.Вставить("ТекстСообщения", ""); // Строка
	СтруктураДанных.Вставить("СессияТестирования", Неопределено); // Булево
	СтруктураДанных.Вставить("ВыполняетсяТестирование", Неопределено); // Булево
	СтруктураДанных.Вставить("ВнешняяОбработка", Неопределено); // Структура
	СтруктураДанных.Вставить("Форма", Неопределено); // Структура
	СтруктураДанных.Вставить("ПовторноеПрохождение", Неопределено); // Массив элементов содержания
	
	// Ресурсы для кэширования на клиенте
	
	Ресурсы = Новый Массив();
	СтруктураДанных.Вставить("Ресурсы", Ресурсы); // Массив
	
	//SCORM
	
	СтруктураДанных.Вставить("Значение", ""); // Строка (для объектов SCORM)
	СтруктураДанных.Вставить("КодОшибки", 0); // Число (для объектов SCORM)
	СтруктураДанных.Вставить("МодельДанныхПопыткиОбъектаSCORM", ""); // Объект XDTO как строка
	СтруктураДанных.Вставить("НомерСессии", ""); // Строка
	
	СтруктураДанных.Вставить("ЗакрытьСтраницу", Ложь); // Булево
	СтруктураДанных.Вставить("ЗакрытьОкно", Ложь); // Булево
	
	// Экспорт данных в автономный пакет
	
	СтруктураДанных.Вставить("ДокументСессииОбъект", Неопределено); // Объект документа "ПопыткаВыполненияСтатичногоОбъектаСУЗ"
	
	Возврат СтруктураДанных;
	
КонецФункции

// СТАТИЧНЫЕ ОБЪЕКТЫ

// Примечание: статичные объекты - это объекты, которые сами не умеют взаимодействовать
// С системой, например страницы. Статистика их просмотра накапливается при переходе
// К другому объекту или закрытии формы.

// Фиксирует попытку выполнения статичного объекта.
//
Процедура ЗавершитьПопыткуВыполненияСтатичногоОбъекта(ПопыткаВыполнения) Экспорт
	
	НачатьТранзакцию();
	
	Попытка
		
		УстановитьПривилегированныйРежим(Истина); 
				
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Документ.ПопыткаВыполненияСтатичногоОбъектаСУЗ");
		ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ПопыткаВыполнения);
		ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
		БлокировкаДанных.Заблокировать();
		
		ПопыткаОбъект = ПопыткаВыполнения.ПолучитьОбъект();
		
		Если НЕ ПопыткаОбъект.ПопыткаЗавершена Тогда
			
			ПопыткаОбъект.ПопыткаЗавершена         = Истина;
			ПопыткаОбъект.ДатаОкончанияВыполнения  = ТекущаяДата();
			ПопыткаОбъект.ВремяВыполненияВСекундах = ПопыткаОбъект.ДатаОкончанияВыполнения - ПопыткаОбъект.ДатаНачалаВыполнения;
			ПопыткаОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
		КонецЕсли;		
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецПроцедуры


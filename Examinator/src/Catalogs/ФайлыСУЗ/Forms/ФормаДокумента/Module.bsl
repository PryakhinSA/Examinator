#Область ПрограммныйИнтерфейс

// ПРОГРАММНЫЙ ИНТЕРФЕЙС

&НаКлиенте
// Загружает данные текущей версии объекта для редактирования.
// Вызывается из общей формы "ВерсииОбъектаСУЗ" и после инициализации редактора.
//
Процедура ЗагрузитьВерсию() Экспорт
	
	ЗагрузитьВерсиюНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьВерсиюНаСервере(ПерваяЗагрузка = Ложь) Экспорт
	
	//////////////////////////////////////////////////////////////////
	РазработкаСУЗ.УстановитьПредпочитаемогоПоставщика(Объект);
	РазработкаСУЗ.УстановитьДоступностьДанныхОтПоставщика(ЭтотОбъект);
	//////////////////////////////////////////////////////////////////
	
	ТипОбъекта = Тип(ТипОбъектаНаСервере);
	
	РазработкаСУЗ.ПоказатьКоличествоВерсийОбъектаНаФорме(ЭтотОбъект, Объект, ТипОбъекта);
	
	Описание  = ОбъектыСУЗ.ПолучитьДанные(Объект.Ссылка, "Описание");
	
	Если НЕ ПерваяЗагрузка Тогда
		Модифицированность = Истина;
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда
		
		Статус = НСтр("ru = 'Данные отсутствуют'", "ru");
		
		СтруктураНовойВерсии = РазработкаСУЗ.ПолучитьСтруктуруНовойВерсииОбъекта(Объект, ТипОбъектаНаСервере);
		
		Объект.Версия    = СтруктураНовойВерсии.Версия;
		Объект.Поставщик = СтруктураНовойВерсии.Поставщик;
		
		Элементы.Поставщик.ТолькоПросмотр  = Ложь;
		Элементы.Версия.ТолькоПросмотр     = Ложь;
		Элементы.СоздатьВерсию.Доступность = Ложь;
		
	Иначе
		
		Статус = НСтр("ru = 'Данные размещены в базе данных'", "ru");
		
		Элементы.Поставщик.ТолькоПросмотр  = Истина;
		Элементы.Версия.ТолькоПросмотр     = Истина;
		Элементы.СоздатьВерсию.Доступность = Истина;
		
	КонецЕсли;	
	
	УстановитьДоступностьЭлементовФормыНаСервере();
	
	ОбновитьСсылкуНаЗагруженныйФайл();
	
КонецПроцедуры




#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	// При создании на основании
	
	Если Объект.Ссылка.Пустая() Тогда
		
		Если Объект.Мероприятие.ЭтоГруппа Тогда
			
			Отказ = Истина;
			Текст = НСтр("ru = 'Выбрана группа мероприятий'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
			Возврат;
			
		КонецЕсли;
		
		Если Объект.ЭлектронныйРесурс.ЭтоГруппа Тогда
			
			Отказ = Истина;
			Текст = НСтр("ru = 'Выбрана группа электронных ресурсов'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
			Возврат;
			
		КонецЕсли;
		
		Если Объект.Аудитория.ЭтоГруппа Тогда
			
			Отказ = Истина;
			Текст = НСтр("ru = 'Выбрана группа аудиторий'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
			Возврат;
			
		КонецЕсли;		
		
	КонецЕсли;
		
	// Заполняем реквизиты
	
	УстановитьДатуИзмененияРесурсовПриСозданииФормы();
	Документы.ПроведениеОбученияСУО.УстановитьВидСценария(Объект, Отказ);	
	ЗапуститьОбновлениеДанныхУчастниковПриОткрытии = ЕстьДанныеУчастниковДляОбновления(Объект.Ссылка);	
	
	Если Объект.Ссылка.Пустая() Тогда
		
		УстановитьОбязательныеРеквизитыФормы();
		
		Если ЗначениеЗаполнено(Объект.ИдентификаторОбъектаКопирования) Тогда
		
			ДокументКопирования = Документы.ПроведениеОбученияСУО.ПолучитьСсылку(Объект.ИдентификаторОбъектаКопирования);
			
			КомментарийОткрытогоМероприятияДляУчастника = ДокументКопирования.КомментарийОткрытогоМероприятияДляУчастника.Получить();
			КомментарийЗапланированногоМероприятияДляУчастника = ДокументКопирования.КомментарийЗапланированногоМероприятияДляУчастника.Получить();
			КомментарийАктивногоМероприятияДляУчастника = ДокументКопирования.КомментарийАктивногоМероприятияДляУчастника.Получить();
			КомментарийЗавершенногоМероприятияДляУчастника = ДокументКопирования.КомментарийЗавершенногоМероприятияДляУчастника.Получить();
			КомментарийОтмененногоМероприятияДляУчастника = ДокументКопирования.КомментарийОтмененногоМероприятияДляУчастника.Получить();
			
			КомментарийЗапланированногоМероприятияДляПреподавателя = ДокументКопирования.КомментарийЗапланированногоМероприятияДляПреподавателя.Получить();
			КомментарийАктивногоМероприятияДляПреподавателя = ДокументКопирования.КомментарийАктивногоМероприятияДляПреподавателя.Получить();
			КомментарийЗавершенногоМероприятияДляПреподавателя = ДокументКопирования.КомментарийЗавершенногоМероприятияДляПреподавателя.Получить();
			КомментарийОтмененногоМероприятияДляПреподавателя = ДокументКопирования.КомментарийОтмененногоМероприятияДляПреподавателя.Получить();	
			
			КоличествоПреподавателейОбъектаКопирования = Документы.ПроведениеОбученияСУО.Преподаватели(
				ДокументКопирования, Объект.Мероприятие).Количество();
				
			Объект.Статус = Перечисления.СтатусыПроведенияОбъектовСУО.Запланировано;
				
		КонецЕсли;		
		
		Если Параметры.Свойство("ЗначенияЗаполнения")
			И Параметры.ЗначенияЗаполнения.Свойство("Мероприятие")
			И ТипЗнч(Параметры.ЗначенияЗаполнения.Мероприятие) = Тип("СправочникСсылка.СводыЗнанийСУЗ") Тогда
			
			Объект.НаОсновеЭлектронногоРесурса = Истина;
			Объект.ЭлектронныйРесурс = Параметры.ЗначенияЗаполнения.Мероприятие;			
			
		КонецЕсли;
		
		Объект.ЗапросНаОбучение = Параметры.ЗапросНаОбучение;
		
		Если ЗначениеЗаполнено(Объект.ЗапросНаОбучение) Тогда
			
			ОбъектЗапроса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ЗапросНаОбучение, "ОбъектЗапроса");
			
			Если ТипЗнч(ОбъектЗапроса) = Тип("СправочникСсылка.КаталогМероприятийСУО") Тогда
				Объект.Мероприятие = ОбъектЗапроса;
			КонецЕсли;
			
		КонецЕсли;
		
		Если НЕ ЭтоПолныйИнтерфейс Тогда
			Объект.НаОсновеЭлектронногоРесурса = Истина;
		КонецЕсли;
				
		Если Объект.НаОсновеЭлектронногоРесурса Тогда
			Объект.ВидОбучения = Справочники.ВидыМероприятийСУО.НаОсновеЭлектронногоРесурса;			
		КонецЕсли;
		
		Если Объект.НаОсновеМероприятия Тогда
			Объект.СкрытьВремяПроведения = ПродолжительностьКратноДню(ПродолжительностьМероприятияВСекундах);
		КонецЕсли;
		
		ДанныеНастроек = ХранилищеСистемныхНастроек.Загрузить(ИмяФормы+"/ТекущиеДанные");
		
		Если ДанныеНастроек <> Неопределено Тогда
			Объект.ЗаголовокБлокаОценкиКачестваОбучения = ДанныеНастроек.Получить("Объект.ЗаголовокБлокаОценкиКачестваОбучения");			
			Объект.ОписаниеБлокаОценкиКачестваОбучения = ДанныеНастроек.Получить("Объект.ОписаниеБлокаОценкиКачестваОбучения");			
		КонецЕсли;		
					
		ЗаполнитьДатыОбученияФормы();
		УстановитьДатыВозможностиУчиться(ЭтотОбъект);
		ЗаполнитьДатуПроведенияФормы(ЭтотОбъект, Объект);
		ЗаполнитьВариантПродолжительностиПоУмолчанию();
		ОбновитьАдресКартинки();
		ОпределитьЗаданыОграниченияНаЗапись(ЭтотОбъект);
		ОпределитьЗаданФильтрПоДатеПриемаСотрудника(ЭтотОбъект);
		ЗаполнитьТабличнуюЧастьЭлектронныеРесурсы();
		
		УстановитьДоступностьЭлементовФормы(Ложь);
		
	КонецЕсли;
		
	// Настраиваем списки
	
	Участники.Параметры.УстановитьЗначениеПараметра("СтатусУдален", НСтр("ru = 'Удален'"));
	Участники.Параметры.УстановитьЗначениеПараметра("СтатусОтменен", НСтр("ru = 'Отменен'"));
	Участники.Параметры.УстановитьЗначениеПараметра("СтатусУдаленИзПрограммы", НСтр("ru = 'Удален из программы'"));
	Участники.Параметры.УстановитьЗначениеПараметра("СтатусНеАктивно", НСтр("ru = 'В ожидании проведения'"));
	Участники.Параметры.УстановитьЗначениеПараметра("ПустаяДата", Дата("00010101"));
	Участники.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДатаСеанса());
	Участники.Параметры.УстановитьЗначениеПараметра("УстановленыДатыДоступаЗаданий", УстановленыДатыДоступаЗаданий(ЭтотОбъект));
	Участники.Параметры.УстановитьЗначениеПараметра("ДатыДоступаЗаданийНеДействуютТекст", НСтр("ru = ', продолжительность заданий не действует'"));
	Участники.Параметры.УстановитьЗначениеПараметра("ТекущаяОценкаПостфикс", НСтр("ru = ' (текущая)'"));
	Участники.Параметры.УстановитьЗначениеПараметра("ПоказыватьТекущуюОценку", Объект.ВидОбучения.ПоказыватьТекущуюОценку);
	Участники.Параметры.УстановитьЗначениеПараметра("БезОценки", НСтр("ru = 'Без оценки'"));
	
	// Блокируем форму
	
	УправлениеОбучениемСУО.ЗаблокироватьДанныеФормы(ЭтотОбъект);
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ЗначениеЗаполнено(Объект.ИдентификаторОбъектаКопирования)
		И КоличествоПреподавателейОбъектаКопирования > 0
		И Объект.Ссылка.Пустая() Тогда
		
		Оповещение = Новый ОписаниеОповещения("ПриОткрытииПродолжениеСКопированием", ЭтотОбъект, Параметры);
		ПоказатьВопрос(Оповещение, НСтр("ru = 'Скопировать преподавателей?'"), РежимДиалогаВопрос.ДаНет, 0);		
		
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда
		Если ЗначениеЗаполнено(Объект.ИдентификаторОбъектаКопирования) Тогда
			ЭтоКопирование = Истина;
		КонецЕсли;
		ЗаполнитьТаблицуЗаданий(ЭтотОбъект, Объект);
		УстановитьВидимостьЭлементовЗакладкиЗаданий(ЭтотОбъект);
	КонецЕсли;
	
	Если ЗапуститьОбновлениеДанныхУчастниковПриОткрытии Тогда
		ЗапуститьОбновлениеДанныхУчастников();
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.ЗаголовокБлокаОценкиКачестваОбучения) Тогда
		Объект.ЗаголовокБлокаОценкиКачестваОбучения = НСтр("ru = 'Вам понравилось?'");
	КонецЕсли;		
	
	Если НЕ ЗначениеЗаполнено(Объект.ОписаниеБлокаОценкиКачестваОбучения) Тогда
		Объект.ОписаниеБлокаОценкиКачестваОбучения = НСтр("ru = 'Ваше мнение о пройденном обучении действительно поможет нам стать лучше. Как все прошло?'");
	КонецЕсли;	
	
	УстановитьОтборыСпискаУчастников();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	Если ПерепровестиДокументВФонеПриЗакрытии И ЗначениеЗаполнено(Объект.Ссылка) Тогда		
		ПерепровестиДокументВФоне(Объект.Ссылка);
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытииПродолжениеСКопированием(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
		УстановитьДоступностьЭлементовФормы(Истина);
		Возврат;
    КонецЕсли;

	ПараметрыЗаписи = Новый Структура;
	ПараметрыЗаписи.Вставить("НазначитьПреподавателейИзОбъектаКопирования", Истина);	
    Записать(ПараметрыЗаписи);

КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)	
	ВыполнитьПроверкуПередЗаписью(Отказ, ПараметрыЗаписи, Ложь);	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	ВыполняетсяЗапись = Ложь;
	ВыполняетсяЗакрытие = Ложь;	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ВыполняетсяЗапись = Ложь;
	ВыполняетсяЗакрытие = Ложь;
	
	// Делаем проверки
	
	Если Объект.НаОсновеЭлектронногоРесурса И НЕ ЗначениеЗаполнено(ТекущийОбъект.Электронныйресурс) Тогда
		Текст = НСтр("ru = 'Укажите электронный курс или тест'");
		Поле = "ЭлектронныйРесурс";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст, ТекущийОбъект, Поле,, Отказ);			
	КонецЕсли;
	
	Если ТекущийОбъект.НаОсновеМероприятия И НЕ ЗначениеЗаполнено(ТекущийОбъект.Мероприятие) Тогда
		
		Текст = НСтр("ru = 'Укажите обучение'");
		Поле = "Мероприятие";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст, ТекущийОбъект, Поле,, Отказ);			
		
	КонецЕсли;	
		
	// Устанавливаем данные
	
	УстановитьДатуИзмененияРесурсовПередЗаписью(ТекущийОбъект);
	
	ТекущийОбъект.КомментарийОткрытогоМероприятияДляУчастника = Новый ХранилищеЗначения(КомментарийОткрытогоМероприятияДляУчастника, Новый СжатиеДанных(9));
	ТекущийОбъект.КомментарийЗапланированногоМероприятияДляУчастника = Новый ХранилищеЗначения(КомментарийЗапланированногоМероприятияДляУчастника, Новый СжатиеДанных(9));
	ТекущийОбъект.КомментарийАктивногоМероприятияДляУчастника = Новый ХранилищеЗначения(КомментарийАктивногоМероприятияДляУчастника, Новый СжатиеДанных(9));
	ТекущийОбъект.КомментарийЗавершенногоМероприятияДляУчастника = Новый ХранилищеЗначения(КомментарийЗавершенногоМероприятияДляУчастника, Новый СжатиеДанных(9));	
	ТекущийОбъект.КомментарийОтмененногоМероприятияДляУчастника = Новый ХранилищеЗначения(КомментарийОтмененногоМероприятияДляУчастника, Новый СжатиеДанных(9));
	
	ТекущийОбъект.КомментарийЗапланированногоМероприятияДляПреподавателя = Новый ХранилищеЗначения(КомментарийЗапланированногоМероприятияДляПреподавателя, Новый СжатиеДанных(9));
	ТекущийОбъект.КомментарийАктивногоМероприятияДляПреподавателя = Новый ХранилищеЗначения(КомментарийАктивногоМероприятияДляПреподавателя, Новый СжатиеДанных(9));
	ТекущийОбъект.КомментарийЗавершенногоМероприятияДляПреподавателя = Новый ХранилищеЗначения(КомментарийЗавершенногоМероприятияДляПреподавателя, Новый СжатиеДанных(9));	
	ТекущийОбъект.КомментарийОтмененногоМероприятияДляПреподавателя = Новый ХранилищеЗначения(КомментарийОтмененногоМероприятияДляПреподавателя, Новый СжатиеДанных(9));	
	
	// Определяем надо ли обновлять подчиненные документы
	
	НеОбновлятьПодчиненныеДокументы = Ложь;
	
	Если НЕ Объект.Проведен 
		И (ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Запись
		ИЛИ ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения) Тогда
		
		// Если выполняется любая запись непроведенного документа,
		// то подчиненные документы не обновляем.
		НеОбновлятьПодчиненныеДокументы = Истина;
		
	КонецЕсли;
	
	Если Объект.Проведен 
		И (ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Запись
		ИЛИ ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение)
		И НЕ Модифицированность Тогда
		
		// Если выполняется запись или проведение проведенного документа,
		// но его не изменяли, то подчиненные документы не обновляем.
		НеОбновлятьПодчиненныеДокументы = Истина;
		
	КонецЕсли;
	
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ОбновлятьПодчиненныеДокументы", НЕ НеОбновлятьПодчиненныеДокументы);
		
	// Электронные задания
	
	ЗаписатьТаблицуЗаданий(ТекущийОбъект, Отказ);
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	Если ЗначениеЗаполнено(Объект.ИдентификаторОбъектаКопирования) И ПараметрыЗаписи <> Неопределено Тогда
		
		ДокументКопирования = Документы.ПроведениеОбученияСУО.ПолучитьСсылку(Объект.ИдентификаторОбъектаКопирования);
		
		Если ПараметрыЗаписи.Свойство("НазначитьУчастниковИзОбъектаКопирования")
			И ПараметрыЗаписи.НазначитьУчастниковИзОбъектаКопирования Тогда
			
			УчастникиМероприятияКопирования = Документы.ПроведениеОбученияСУО.ПрохожденияОбучения(ДокументКопирования).ВыгрузитьКолонку("Пользователь");
			
			ЗачислитьУчастников(Объект.Ссылка, УчастникиМероприятияКопирования);
			
		КонецЕсли;
		
		Если ПараметрыЗаписи.Свойство("НазначитьПреподавателейИзОбъектаКопирования")
			И ПараметрыЗаписи.НазначитьПреподавателейИзОбъектаКопирования Тогда
			
			ПреподавателиМероприятияКопирования = Документы.ПроведениеОбученияСУО.Преподаватели(ДокументКопирования);
			СценарийЭтогоДокумента = Документы.ПроведениеОбученияСУО.СценарийОбучения(Объект.Ссылка);
			
			Для каждого Строка Из ПреподавателиМероприятияКопирования Цикл				
				УправлениеОбучениемСУО.НазначитьПреподавателяНаОбучение(Объект.Ссылка, СценарийЭтогоДокумента, Строка.Преподаватель, Строка.Роль,,,Истина);
			КонецЦикла;
			
		КонецЕсли;
		
		ЗаполнитьТабличнуюЧастьЭлектронныеРесурсы();
		
	КонецЕсли;
	
	ЗаполнитьВариантПродолжительностиПоУмолчанию();		
	УстановитьДоступностьЭлементовФормы(Истина);
	
	УправлениеОбучениемСУО.ЗаблокироватьДанныеФормы(ЭтотОбъект);
	
	ПерепровестиДокументВФонеПриЗакрытии = Ложь;
	
	// Запускаем регламентные задания вручную, не дожидаясь срабатывания расписания
	
	Если Объект.АвтозачислениеНаОбучение Тогда
		ОбщегоНазначенияСУ.ВыполнитьРегламентноеЗаданиеВручную("ЗачислениеПользователейНаОбучениеСУО");
	КонецЕсли;
	
	ОбщегоНазначенияСУ.ВыполнитьРегламентноеЗаданиеВручную("ПерепроведениеДокументовСУО");
	
	Если ВебКабинетСУ.Используется() Тогда
		ОбщегоНазначенияСУ.ВыполнитьРегламентноеЗаданиеВручную("ОбновлениеДанныхВебКабинетаСУ");
	КонецЕсли;
	
	Участники.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДатаСеанса());
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ЗапуститьОбновлениеДанныхУчастников();
	Оповестить("ОбновитьСписокМероприятий",,ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	УстановитьОбязательныеРеквизитыФормы();
	
	ОпределитьЗаданыОграниченияНаЗапись(ЭтотОбъект);
	ОпределитьЗаданФильтрПоДатеПриемаСотрудника(ЭтотОбъект);
	
	КомментарийОткрытогоМероприятияДляУчастника = ТекущийОбъект.КомментарийОткрытогоМероприятияДляУчастника.Получить();
	КомментарийЗапланированногоМероприятияДляУчастника = ТекущийОбъект.КомментарийЗапланированногоМероприятияДляУчастника.Получить();
	КомментарийАктивногоМероприятияДляУчастника = ТекущийОбъект.КомментарийАктивногоМероприятияДляУчастника.Получить();
	КомментарийЗавершенногоМероприятияДляУчастника = ТекущийОбъект.КомментарийЗавершенногоМероприятияДляУчастника.Получить();
	КомментарийОтмененногоМероприятияДляУчастника = ТекущийОбъект.КомментарийОтмененногоМероприятияДляУчастника.Получить();
	
	КомментарийЗапланированногоМероприятияДляПреподавателя = ТекущийОбъект.КомментарийЗапланированногоМероприятияДляПреподавателя.Получить();
	КомментарийАктивногоМероприятияДляПреподавателя = ТекущийОбъект.КомментарийАктивногоМероприятияДляПреподавателя.Получить();
	КомментарийЗавершенногоМероприятияДляПреподавателя = ТекущийОбъект.КомментарийЗавершенногоМероприятияДляПреподавателя.Получить();
	КомментарийОтмененногоМероприятияДляПреподавателя = ТекущийОбъект.КомментарийОтмененногоМероприятияДляПреподавателя.Получить();	
	
	ЗаполнитьДатыОбученияФормы();
	ЗаполнитьТаблицуЗаданий(ЭтотОбъект, ТекущийОбъект);
	ЗаполнитьТабличнуюЧастьЭлектронныеРесурсы();
	ЗаполнитьДатуПроведенияФормы(ЭтотОбъект, Объект);
	УстановитьДатыВозможностиУчиться(ЭтотОбъект);
	ЗаполнитьВариантПродолжительностиПоУмолчанию();
	ОбновитьАдресКартинки();

	// ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);

	УстановитьДоступностьЭлементовФормы(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОбновитьПрохождениеОбучения"
		И Источник <> ЭтотОбъект Тогда		
		Элементы.Участники.Обновить();		
	КонецЕсли;

	Если ИмяСобытия = "ЗачисленПреподаватель" Тогда		
		ОбновитьСписокПреподавателей();		
	КонецЕсли;
	
	Если ИмяСобытия = "ЗаписьМероприятия" И Параметр = Объект.Мероприятие Тогда		
		УстановитьДоступностьЭлементовФормы(Истина);
	КонецЕсли;
	
	Если ИмяСобытия = "ОбновленыВидыОбучения" Тогда		
		УстановитьДоступностьЭлементовФормы(Истина);
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура МероприятиеПриИзменении(Элемент)
	УстановитьДоступностьЭлементовФормы(Истина);
КонецПроцедуры

&НаКлиенте
Процедура СхемаПроведенияПриИзменении(Элемент)
	УстановитьДоступностьЭлементовФормы(Истина);
КонецПроцедуры

&НаКлиенте
Процедура ОткрытоеМероприятиеПриИзменении(Элемент)
	
	УстановитьДоступностьЭлементовФормы(Истина);
	
	Если Объект.ОткрытоеМероприятие Тогда
		Элементы.Страницы.ТекущаяСтраница = Элементы.ГруппаДоступКОбучению;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаИлиВремяПроведенияПриИзменении(Элемент)
	
	Модифицированность = Истина;	
	ПривестиДатуПроведения();
	УстановитьДатыВозможностиУчиться(ЭтотОбъект);
	ОпределитьЗаданыОграниченияНаЗапись(ЭтотОбъект);
	УстановитьДоступностьЭлементовФормы(Ложь);

	Если Элемент = Элементы.ДатаНачалаДоступа
		И ЗначениеЗаполнено(Объект.ДатаНачалаДоступа)
		И НЕ ЗначениеЗаполнено(Объект.ДатаКонтроля) Тогда
		
		 УстановитьРекомендованноеРасписание();
		
	КонецЕсли;
	
	Если Элемент = Элементы.ДатаНачалаПроведения
		И ЗначениеЗаполнено(Объект.ДатаНачалаПроведения)
		И НЕ ЗначениеЗаполнено(Объект.ДатаОкончанияПроведения) Тогда
		
		 УстановитьРекомендованноеРасписание();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АудиторияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	НовыйМассив = Новый Массив();

	НовыйМассив.Добавить(Новый ПараметрВыбора("ДокументСобытия", Объект.Ссылка));
	НовыйМассив.Добавить(Новый ПараметрВыбора("ДатаНачалаИспользования", Объект.ДатаНачалаПроведения));
	НовыйМассив.Добавить(Новый ПараметрВыбора("ДатаОкончанияИспользования", Объект.ДатаОкончанияПроведения));
	НовыйМассив.Добавить(Новый ПараметрВыбора("ТипАудитории", ТребуемыйТипАудитории));
	НовыйМассив.Добавить(Новый ПараметрВыбора("МаксимальноеКоличествоЧеловек", Объект.МаксимальноеКоличествоУчастников));

	Элементы.Аудитория.ПараметрыВыбора = Новый ФиксированныйМассив(НовыйМассив);
	
КонецПроцедуры

